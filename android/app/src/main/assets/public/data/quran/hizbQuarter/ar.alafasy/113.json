{"code":200,"status":"OK","data":{"number":113,"ayahs":[{"number":2030,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2030.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2030.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سُبْحَٰنَ ٱلَّذِىٓ أَسْرَىٰ بِعَبْدِهِۦ لَيْلًۭا مِّنَ ٱلْمَسْجِدِ ٱلْحَرَامِ إِلَى ٱلْمَسْجِدِ ٱلْأَقْصَا ٱلَّذِى بَٰرَكْنَا حَوْلَهُۥ لِنُرِيَهُۥ مِنْ ءَايَٰتِنَآ ۚ إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْبَصِيرُ","numberInSurah":1,"juz":15,"manzil":4,"page":282,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2031,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2031.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2031.mp3"],"text":"وَءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ وَجَعَلْنَٰهُ هُدًۭى لِّبَنِىٓ إِسْرَٰٓءِيلَ أَلَّا تَتَّخِذُوا۟ مِن دُونِى وَكِيلًۭا","numberInSurah":2,"juz":15,"manzil":4,"page":282,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2032,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2032.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2032.mp3"],"text":"ذُرِّيَّةَ مَنْ حَمَلْنَا مَعَ نُوحٍ ۚ إِنَّهُۥ كَانَ عَبْدًۭا شَكُورًۭا","numberInSurah":3,"juz":15,"manzil":4,"page":282,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2033,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2033.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2033.mp3"],"text":"وَقَضَيْنَآ إِلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ فِى ٱلْكِتَٰبِ لَتُفْسِدُنَّ فِى ٱلْأَرْضِ مَرَّتَيْنِ وَلَتَعْلُنَّ عُلُوًّۭا كَبِيرًۭا","numberInSurah":4,"juz":15,"manzil":4,"page":282,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2034,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2034.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2034.mp3"],"text":"فَإِذَا جَآءَ وَعْدُ أُولَىٰهُمَا بَعَثْنَا عَلَيْكُمْ عِبَادًۭا لَّنَآ أُو۟لِى بَأْسٍۢ شَدِيدٍۢ فَجَاسُوا۟ خِلَٰلَ ٱلدِّيَارِ ۚ وَكَانَ وَعْدًۭا مَّفْعُولًۭا","numberInSurah":5,"juz":15,"manzil":4,"page":282,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2035,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2035.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2035.mp3"],"text":"ثُمَّ رَدَدْنَا لَكُمُ ٱلْكَرَّةَ عَلَيْهِمْ وَأَمْدَدْنَٰكُم بِأَمْوَٰلٍۢ وَبَنِينَ وَجَعَلْنَٰكُمْ أَكْثَرَ نَفِيرًا","numberInSurah":6,"juz":15,"manzil":4,"page":282,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2036,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2036.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2036.mp3"],"text":"إِنْ أَحْسَنتُمْ أَحْسَنتُمْ لِأَنفُسِكُمْ ۖ وَإِنْ أَسَأْتُمْ فَلَهَا ۚ فَإِذَا جَآءَ وَعْدُ ٱلْءَاخِرَةِ لِيَسُۥٓـُٔوا۟ وُجُوهَكُمْ وَلِيَدْخُلُوا۟ ٱلْمَسْجِدَ كَمَا دَخَلُوهُ أَوَّلَ مَرَّةٍۢ وَلِيُتَبِّرُوا۟ مَا عَلَوْا۟ تَتْبِيرًا","numberInSurah":7,"juz":15,"manzil":4,"page":282,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2037,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2037.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2037.mp3"],"text":"عَسَىٰ رَبُّكُمْ أَن يَرْحَمَكُمْ ۚ وَإِنْ عُدتُّمْ عُدْنَا ۘ وَجَعَلْنَا جَهَنَّمَ لِلْكَٰفِرِينَ حَصِيرًا","numberInSurah":8,"juz":15,"manzil":4,"page":283,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2038,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2038.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2038.mp3"],"text":"إِنَّ هَٰذَا ٱلْقُرْءَانَ يَهْدِى لِلَّتِى هِىَ أَقْوَمُ وَيُبَشِّرُ ٱلْمُؤْمِنِينَ ٱلَّذِينَ يَعْمَلُونَ ٱلصَّٰلِحَٰتِ أَنَّ لَهُمْ أَجْرًۭا كَبِيرًۭا","numberInSurah":9,"juz":15,"manzil":4,"page":283,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2039,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2039.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2039.mp3"],"text":"وَأَنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ أَعْتَدْنَا لَهُمْ عَذَابًا أَلِيمًۭا","numberInSurah":10,"juz":15,"manzil":4,"page":283,"ruku":240,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2040,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2040.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2040.mp3"],"text":"وَيَدْعُ ٱلْإِنسَٰنُ بِٱلشَّرِّ دُعَآءَهُۥ بِٱلْخَيْرِ ۖ وَكَانَ ٱلْإِنسَٰنُ عَجُولًۭا","numberInSurah":11,"juz":15,"manzil":4,"page":283,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2041,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2041.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2041.mp3"],"text":"وَجَعَلْنَا ٱلَّيْلَ وَٱلنَّهَارَ ءَايَتَيْنِ ۖ فَمَحَوْنَآ ءَايَةَ ٱلَّيْلِ وَجَعَلْنَآ ءَايَةَ ٱلنَّهَارِ مُبْصِرَةًۭ لِّتَبْتَغُوا۟ فَضْلًۭا مِّن رَّبِّكُمْ وَلِتَعْلَمُوا۟ عَدَدَ ٱلسِّنِينَ وَٱلْحِسَابَ ۚ وَكُلَّ شَىْءٍۢ فَصَّلْنَٰهُ تَفْصِيلًۭا","numberInSurah":12,"juz":15,"manzil":4,"page":283,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2042,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2042.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2042.mp3"],"text":"وَكُلَّ إِنسَٰنٍ أَلْزَمْنَٰهُ طَٰٓئِرَهُۥ فِى عُنُقِهِۦ ۖ وَنُخْرِجُ لَهُۥ يَوْمَ ٱلْقِيَٰمَةِ كِتَٰبًۭا يَلْقَىٰهُ مَنشُورًا","numberInSurah":13,"juz":15,"manzil":4,"page":283,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2043,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2043.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2043.mp3"],"text":"ٱقْرَأْ كِتَٰبَكَ كَفَىٰ بِنَفْسِكَ ٱلْيَوْمَ عَلَيْكَ حَسِيبًۭا","numberInSurah":14,"juz":15,"manzil":4,"page":283,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2044,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2044.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2044.mp3"],"text":"مَّنِ ٱهْتَدَىٰ فَإِنَّمَا يَهْتَدِى لِنَفْسِهِۦ ۖ وَمَن ضَلَّ فَإِنَّمَا يَضِلُّ عَلَيْهَا ۚ وَلَا تَزِرُ وَازِرَةٌۭ وِزْرَ أُخْرَىٰ ۗ وَمَا كُنَّا مُعَذِّبِينَ حَتَّىٰ نَبْعَثَ رَسُولًۭا","numberInSurah":15,"juz":15,"manzil":4,"page":283,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2045,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2045.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2045.mp3"],"text":"وَإِذَآ أَرَدْنَآ أَن نُّهْلِكَ قَرْيَةً أَمَرْنَا مُتْرَفِيهَا فَفَسَقُوا۟ فِيهَا فَحَقَّ عَلَيْهَا ٱلْقَوْلُ فَدَمَّرْنَٰهَا تَدْمِيرًۭا","numberInSurah":16,"juz":15,"manzil":4,"page":283,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2046,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2046.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2046.mp3"],"text":"وَكَمْ أَهْلَكْنَا مِنَ ٱلْقُرُونِ مِنۢ بَعْدِ نُوحٍۢ ۗ وَكَفَىٰ بِرَبِّكَ بِذُنُوبِ عِبَادِهِۦ خَبِيرًۢا بَصِيرًۭا","numberInSurah":17,"juz":15,"manzil":4,"page":283,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2047,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2047.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2047.mp3"],"text":"مَّن كَانَ يُرِيدُ ٱلْعَاجِلَةَ عَجَّلْنَا لَهُۥ فِيهَا مَا نَشَآءُ لِمَن نُّرِيدُ ثُمَّ جَعَلْنَا لَهُۥ جَهَنَّمَ يَصْلَىٰهَا مَذْمُومًۭا مَّدْحُورًۭا","numberInSurah":18,"juz":15,"manzil":4,"page":284,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2048,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2048.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2048.mp3"],"text":"وَمَنْ أَرَادَ ٱلْءَاخِرَةَ وَسَعَىٰ لَهَا سَعْيَهَا وَهُوَ مُؤْمِنٌۭ فَأُو۟لَٰٓئِكَ كَانَ سَعْيُهُم مَّشْكُورًۭا","numberInSurah":19,"juz":15,"manzil":4,"page":284,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2049,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2049.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2049.mp3"],"text":"كُلًّۭا نُّمِدُّ هَٰٓؤُلَآءِ وَهَٰٓؤُلَآءِ مِنْ عَطَآءِ رَبِّكَ ۚ وَمَا كَانَ عَطَآءُ رَبِّكَ مَحْظُورًا","numberInSurah":20,"juz":15,"manzil":4,"page":284,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2050,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2050.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2050.mp3"],"text":"ٱنظُرْ كَيْفَ فَضَّلْنَا بَعْضَهُمْ عَلَىٰ بَعْضٍۢ ۚ وَلَلْءَاخِرَةُ أَكْبَرُ دَرَجَٰتٍۢ وَأَكْبَرُ تَفْضِيلًۭا","numberInSurah":21,"juz":15,"manzil":4,"page":284,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2051,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2051.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2051.mp3"],"text":"لَّا تَجْعَلْ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتَقْعُدَ مَذْمُومًۭا مَّخْذُولًۭا","numberInSurah":22,"juz":15,"manzil":4,"page":284,"ruku":241,"hizbQuarter":113,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}}],"surahs":{"17":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},"edition":{}}}