{"code":200,"status":"OK","data":{"number":177,"ayahs":[{"number":3733,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3733.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3733.mp3"],"text":"۞ وَمَآ أَنزَلْنَا عَلَىٰ قَوْمِهِۦ مِنۢ بَعْدِهِۦ مِن جُندٍۢ مِّنَ ٱلسَّمَآءِ وَمَا كُنَّا مُنزِلِينَ","numberInSurah":28,"juz":23,"manzil":5,"page":442,"ruku":382,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3734,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3734.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3734.mp3"],"text":"إِن كَانَتْ إِلَّا صَيْحَةًۭ وَٰحِدَةًۭ فَإِذَا هُمْ خَٰمِدُونَ","numberInSurah":29,"juz":23,"manzil":5,"page":442,"ruku":382,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3735,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3735.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3735.mp3"],"text":"يَٰحَسْرَةً عَلَى ٱلْعِبَادِ ۚ مَا يَأْتِيهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","numberInSurah":30,"juz":23,"manzil":5,"page":442,"ruku":382,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3736,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3736.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3736.mp3"],"text":"أَلَمْ يَرَوْا۟ كَمْ أَهْلَكْنَا قَبْلَهُم مِّنَ ٱلْقُرُونِ أَنَّهُمْ إِلَيْهِمْ لَا يَرْجِعُونَ","numberInSurah":31,"juz":23,"manzil":5,"page":442,"ruku":382,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3737,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3737.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3737.mp3"],"text":"وَإِن كُلٌّۭ لَّمَّا جَمِيعٌۭ لَّدَيْنَا مُحْضَرُونَ","numberInSurah":32,"juz":23,"manzil":5,"page":442,"ruku":382,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3738,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3738.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3738.mp3"],"text":"وَءَايَةٌۭ لَّهُمُ ٱلْأَرْضُ ٱلْمَيْتَةُ أَحْيَيْنَٰهَا وَأَخْرَجْنَا مِنْهَا حَبًّۭا فَمِنْهُ يَأْكُلُونَ","numberInSurah":33,"juz":23,"manzil":5,"page":442,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3739,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3739.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3739.mp3"],"text":"وَجَعَلْنَا فِيهَا جَنَّٰتٍۢ مِّن نَّخِيلٍۢ وَأَعْنَٰبٍۢ وَفَجَّرْنَا فِيهَا مِنَ ٱلْعُيُونِ","numberInSurah":34,"juz":23,"manzil":5,"page":442,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3740,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3740.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3740.mp3"],"text":"لِيَأْكُلُوا۟ مِن ثَمَرِهِۦ وَمَا عَمِلَتْهُ أَيْدِيهِمْ ۖ أَفَلَا يَشْكُرُونَ","numberInSurah":35,"juz":23,"manzil":5,"page":442,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3741,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3741.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3741.mp3"],"text":"سُبْحَٰنَ ٱلَّذِى خَلَقَ ٱلْأَزْوَٰجَ كُلَّهَا مِمَّا تُنۢبِتُ ٱلْأَرْضُ وَمِنْ أَنفُسِهِمْ وَمِمَّا لَا يَعْلَمُونَ","numberInSurah":36,"juz":23,"manzil":5,"page":442,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3742,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3742.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3742.mp3"],"text":"وَءَايَةٌۭ لَّهُمُ ٱلَّيْلُ نَسْلَخُ مِنْهُ ٱلنَّهَارَ فَإِذَا هُم مُّظْلِمُونَ","numberInSurah":37,"juz":23,"manzil":5,"page":442,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3743,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3743.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3743.mp3"],"text":"وَٱلشَّمْسُ تَجْرِى لِمُسْتَقَرٍّۢ لَّهَا ۚ ذَٰلِكَ تَقْدِيرُ ٱلْعَزِيزِ ٱلْعَلِيمِ","numberInSurah":38,"juz":23,"manzil":5,"page":442,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3744,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3744.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3744.mp3"],"text":"وَٱلْقَمَرَ قَدَّرْنَٰهُ مَنَازِلَ حَتَّىٰ عَادَ كَٱلْعُرْجُونِ ٱلْقَدِيمِ","numberInSurah":39,"juz":23,"manzil":5,"page":442,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3745,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3745.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3745.mp3"],"text":"لَا ٱلشَّمْسُ يَنۢبَغِى لَهَآ أَن تُدْرِكَ ٱلْقَمَرَ وَلَا ٱلَّيْلُ سَابِقُ ٱلنَّهَارِ ۚ وَكُلٌّۭ فِى فَلَكٍۢ يَسْبَحُونَ","numberInSurah":40,"juz":23,"manzil":5,"page":442,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3746,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3746.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3746.mp3"],"text":"وَءَايَةٌۭ لَّهُمْ أَنَّا حَمَلْنَا ذُرِّيَّتَهُمْ فِى ٱلْفُلْكِ ٱلْمَشْحُونِ","numberInSurah":41,"juz":23,"manzil":5,"page":443,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3747,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3747.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3747.mp3"],"text":"وَخَلَقْنَا لَهُم مِّن مِّثْلِهِۦ مَا يَرْكَبُونَ","numberInSurah":42,"juz":23,"manzil":5,"page":443,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3748,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3748.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3748.mp3"],"text":"وَإِن نَّشَأْ نُغْرِقْهُمْ فَلَا صَرِيخَ لَهُمْ وَلَا هُمْ يُنقَذُونَ","numberInSurah":43,"juz":23,"manzil":5,"page":443,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3749,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3749.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3749.mp3"],"text":"إِلَّا رَحْمَةًۭ مِّنَّا وَمَتَٰعًا إِلَىٰ حِينٍۢ","numberInSurah":44,"juz":23,"manzil":5,"page":443,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3750,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3750.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3750.mp3"],"text":"وَإِذَا قِيلَ لَهُمُ ٱتَّقُوا۟ مَا بَيْنَ أَيْدِيكُمْ وَمَا خَلْفَكُمْ لَعَلَّكُمْ تُرْحَمُونَ","numberInSurah":45,"juz":23,"manzil":5,"page":443,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3751,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3751.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3751.mp3"],"text":"وَمَا تَأْتِيهِم مِّنْ ءَايَةٍۢ مِّنْ ءَايَٰتِ رَبِّهِمْ إِلَّا كَانُوا۟ عَنْهَا مُعْرِضِينَ","numberInSurah":46,"juz":23,"manzil":5,"page":443,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3752,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3752.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3752.mp3"],"text":"وَإِذَا قِيلَ لَهُمْ أَنفِقُوا۟ مِمَّا رَزَقَكُمُ ٱللَّهُ قَالَ ٱلَّذِينَ كَفَرُوا۟ لِلَّذِينَ ءَامَنُوٓا۟ أَنُطْعِمُ مَن لَّوْ يَشَآءُ ٱللَّهُ أَطْعَمَهُۥٓ إِنْ أَنتُمْ إِلَّا فِى ضَلَٰلٍۢ مُّبِينٍۢ","numberInSurah":47,"juz":23,"manzil":5,"page":443,"ruku":383,"hizbQuarter":177,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3753,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3753.mp3","au