:351,"ruku":302,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2803,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2803.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2803.mp3"],"text":"لَّوْلَآ إِذْ سَمِعْتُمُوهُ ظَنَّ ٱلْمُؤْمِنُونَ وَٱلْمُؤْمِنَٰتُ بِأَنفُسِهِمْ خَيْرًۭا وَقَالُوا۟ هَٰذَآ إِفْكٌۭ مُّبِينٌۭ","numberInSurah":12,"juz":18,"manzil":4,"page":351,"ruku":302,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2804,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2804.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2804.mp3"],"text":"لَّوْلَا جَآءُو عَلَيْهِ بِأَرْبَعَةِ شُهَدَآءَ ۚ فَإِذْ لَمْ يَأْتُوا۟ بِٱلشُّهَدَآءِ فَأُو۟لَٰٓئِكَ عِندَ ٱللَّهِ هُمُ ٱلْكَٰذِبُونَ","numberInSurah":13,"juz":18,"manzil":4,"page":351,"ruku":302,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2805,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2805.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2805.mp3"],"text":"وَلَوْلَا فَضْلُ ٱللَّهِ عَلَيْكُمْ وَرَحْمَتُهُۥ فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ لَمَسَّكُمْ فِى مَآ أَفَضْتُمْ فِيهِ عَذَابٌ عَظِيمٌ","numberInSurah":14,"juz":18,"manzil":4,"page":351,"ruku":302,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2806,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2806.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2806.mp3"],"text":