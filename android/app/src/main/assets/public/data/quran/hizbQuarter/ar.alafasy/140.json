{"code":200,"status":"OK","data":{"number":140,"ayahs":[{"number":2792,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2792.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2792.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سُورَةٌ أَنزَلْنَٰهَا وَفَرَضْنَٰهَا وَأَنزَلْنَا فِيهَآ ءَايَٰتٍۭ بَيِّنَٰتٍۢ لَّعَلَّكُمْ تَذَكَّرُونَ","numberInSurah":1,"juz":18,"manzil":4,"page":350,"ruku":301,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2793,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2793.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2793.mp3"],"text":"ٱلزَّانِيَةُ وَٱلزَّانِى فَٱجْلِدُوا۟ كُلَّ وَٰحِدٍۢ مِّنْهُمَا مِا۟ئَةَ جَلْدَةٍۢ ۖ وَلَا تَأْخُذْكُم بِهِمَا رَأْفَةٌۭ فِى دِينِ ٱللَّهِ إِن كُنتُمْ تُؤْمِنُونَ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ ۖ وَلْيَشْهَدْ عَذَابَهُمَا طَآئِفَةٌۭ مِّنَ ٱلْمُؤْمِنِينَ","numberInSurah":2,"juz":18,"manzil":4,"page":350,"ruku":301,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2794,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2794.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2794.mp3"],"text":"ٱلزَّانِى لَا يَنكِحُ إِلَّا زَانِيَةً أَوْ مُشْرِكَةًۭ وَٱلزَّانِيَةُ لَا يَنكِحُهَآ إِلَّا زَانٍ أَوْ مُشْرِكٌۭ ۚ وَحُرِّمَ ذَٰلِكَ عَلَى ٱلْمُؤْمِنِينَ","numberInSurah":3,"juz":18,"manzil":4,"page":350,"ruku":301,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2795,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2795.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2795.mp3"],"text":"وَٱلَّذِينَ يَرْمُونَ ٱلْمُحْصَنَٰتِ ثُمَّ لَمْ يَأْتُوا۟ بِأَرْبَعَةِ شُهَدَآءَ فَٱجْلِدُوهُمْ ثَمَٰنِينَ جَلْدَةًۭ وَلَا تَقْبَلُوا۟ لَهُمْ شَهَٰدَةً أَبَدًۭا ۚ وَأُو۟لَٰٓئِكَ هُمُ ٱلْفَٰسِقُونَ","numberInSurah":4,"juz":18,"manzil":4,"page":350,"ruku":301,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2796,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2796.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2796.mp3"],"text":"إِلَّا ٱلَّذِينَ تَابُوا۟ مِنۢ بَعْدِ ذَٰلِكَ وَأَصْلَحُوا۟ فَإِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","numberInSurah":5,"juz":18,"manzil":4,"page":350,"ruku":301,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2797,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2797.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2797.mp3"],"text":"وَٱلَّذِينَ يَرْمُونَ أَزْوَٰجَهُمْ وَلَمْ يَكُن لَّهُمْ شُهَدَآءُ إِلَّآ أَنفُسُهُمْ فَشَهَٰدَةُ أَحَدِهِمْ أَرْبَعُ شَهَٰدَٰتٍۭ بِٱللَّهِ ۙ إِنَّهُۥ لَمِنَ ٱلصَّٰدِقِينَ","numberInSurah":6,"juz":18,"manzil":4,"page":350,"ruku":301,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2798,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2798.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2798.mp3"],"text":"وَٱلْخَٰمِسَةُ أَنَّ لَعْنَتَ ٱللَّهِ عَلَيْهِ إِن كَانَ مِنَ ٱلْكَٰذِبِينَ","numberInSurah":7,"juz":18,"manzil":4,"page":350,"ruku":301,"hizbQuarter":140,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Li