{"code":200,"status":"OK","data":{"number":135,"ayahs":[{"number":2633,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2633.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2633.mp3"],"text":"۞ إِنَّ ٱللَّهَ يُدَٰفِعُ عَنِ ٱلَّذِينَ ءَامَنُوٓا۟ ۗ إِنَّ ٱللَّهَ لَا يُحِبُّ كُلَّ خَوَّانٍۢ كَفُورٍ","numberInSurah":38,"juz":17,"manzil":4,"page":336,"ruku":289,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2634,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2634.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2634.mp3"],"text":"أُذِنَ لِلَّذِينَ يُقَٰتَلُونَ بِأَنَّهُمْ ظُلِمُوا۟ ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصْرِهِمْ لَقَدِيرٌ","numberInSurah":39,"juz":17,"manzil":4,"page":337,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2635,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2635.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2635.mp3"],"text":"ٱلَّذِينَ أُخْرِجُوا۟ مِن دِيَٰرِهِم بِغَيْرِ حَقٍّ إِلَّآ أَن يَقُولُوا۟ رَبُّنَا ٱللَّهُ ۗ وَلَوْلَا دَفْعُ ٱللَّهِ ٱلنَّاسَ بَعْضَهُم بِبَعْضٍۢ لَّهُدِّمَتْ صَوَٰمِعُ وَبِيَعٌۭ وَصَلَوَٰتٌۭ وَمَسَٰجِدُ يُذْكَرُ فِيهَا ٱسْمُ ٱللَّهِ كَثِيرًۭا ۗ وَلَيَنصُرَنَّ ٱللَّهُ مَن يَنصُرُهُۥٓ ۗ إِنَّ ٱللَّهَ لَقَوِىٌّ عَزِيزٌ","numberInSurah":40,"juz":17,"manzil":4,"page":337,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2636,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2636.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2636.mp3"],"text":"ٱلَّذِينَ إِن مَّكَّنَّٰهُمْ فِى ٱلْأَرْضِ أَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ وَأَمَرُوا۟ بِٱلْمَعْرُوفِ وَنَهَوْا۟ عَنِ ٱلْمُنكَرِ ۗ وَلِلَّهِ عَٰقِبَةُ ٱلْأُمُورِ","numberInSurah":41,"juz":17,"manzil":4,"page":337,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2637,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2637.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2637.mp3"],"text":"وَإِن يُكَذِّبُوكَ فَقَدْ كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍۢ وَعَادٌۭ وَثَمُودُ","numberInSurah":42,"juz":17,"manzil":4,"page":337,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2638,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2638.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2638.mp3"],"text":"وَقَوْمُ إِبْرَٰهِيمَ وَقَوْمُ لُوطٍۢ","numberInSurah":43,"juz":17,"manzil":4,"page":337,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2639,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2639.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2639.mp3"],"text":"وَأَصْحَٰبُ مَدْيَنَ ۖ وَكُذِّبَ مُوسَىٰ فَأَمْلَيْتُ لِلْكَٰفِرِينَ ثُمَّ أَخَذْتُهُمْ ۖ فَكَيْفَ كَانَ نَكِيرِ","numberInSurah":44,"juz":17,"manzil":4,"page":337,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2640,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2640.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2640.mp3"],"text":"فَكَأَيِّن مِّن قَرْيَةٍ أَهْلَكْنَٰهَا وَهِىَ ظَالِمَةٌۭ فَهِىَ خَاوِيَةٌ عَلَىٰ عُرُوشِهَا وَبِئْرٍۢ مُّعَطَّلَةٍۢ وَقَصْرٍۢ مَّشِيدٍ","numberInSurah":45,"juz":17,"manzil":4,"page":337,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2641,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2641.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2641.mp3"],"text":"أَفَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَتَكُونَ لَهُمْ قُلُوبٌۭ يَعْقِلُونَ بِهَآ أَوْ ءَاذَانٌۭ يَسْمَعُونَ بِهَا ۖ فَإِنَّهَا لَا تَعْمَى ٱلْأَبْصَٰرُ وَلَٰكِن تَعْمَى ٱلْقُلُوبُ ٱلَّتِى فِى ٱلصُّدُورِ","numberInSurah":46,"juz":17,"manzil":4,"page":337,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2642,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2642.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2642.mp3"],"text":"وَيَسْتَعْجِلُونَكَ بِٱلْعَذَابِ وَلَن يُخْلِفَ ٱللَّهُ وَعْدَهُۥ ۚ وَإِنَّ يَوْمًا عِندَ رَبِّكَ كَأَلْفِ سَنَةٍۢ مِّمَّا تَعُدُّونَ","numberInSurah":47,"juz":17,"manzil":4,"page":338,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2643,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2643.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2643.mp3"],"text":"وَكَأَيِّن مِّن قَرْيَةٍ أَمْلَيْتُ لَهَا وَهِىَ ظَالِمَةٌۭ ثُمَّ أَخَذْتُهَا وَإِلَىَّ ٱلْمَصِيرُ","numberInSurah":48,"juz":17,"manzil":4,"page":338,"ruku":290,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2644,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2644.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2644.mp3"],"text":"قُلْ يَٰٓأَيُّهَا ٱلنَّاسُ إِنَّمَآ أَنَا۠ لَكُمْ نَذِيرٌۭ مُّبِينٌۭ","numberInSurah":49,"juz":17,"manzil":4,"page":338,"ruku":291,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2645,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2645.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2645.mp3"],"text":"فَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُم مَّغْفِرَةٌۭ وَرِزْقٌۭ كَرِيمٌۭ","numberInSurah":50,"juz":17,"manzil":4,"page":338,"ruku":291,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2646,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2646.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2646.mp3"],"text":"وَٱلَّذِينَ سَعَوْا۟ فِىٓ ءَايَٰتِنَا مُعَٰجِزِينَ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَحِيمِ","numberInSurah":51,"juz":17,"manzil":4,"page":338,"ruku":291,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2647,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2647.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2647.mp3"],"text":"وَمَآ أَرْسَلْنَا مِن قَبْلِكَ مِن رَّسُولٍۢ وَلَا نَبِىٍّ إِلَّآ إِذَا تَمَنَّىٰٓ أَلْقَى ٱلشَّيْطَٰنُ فِىٓ أُمْنِيَّتِهِۦ فَيَنسَخُ ٱللَّهُ مَا يُلْقِى ٱلشَّيْطَٰنُ ثُمَّ يُحْكِمُ ٱللَّهُ ءَايَٰتِهِۦ ۗ وَٱللَّهُ عَلِيمٌ حَكِيمٌۭ","numberInSurah":52,"juz":17,"manzil":4,"page":338,"ruku":291,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2648,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2648.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2648.mp3"],"text":"لِّيَجْعَلَ مَا يُلْقِى ٱلشَّيْطَٰنُ فِتْنَةًۭ لِّلَّذِينَ فِى قُلُوبِهِم مَّرَضٌۭ وَٱلْقَاسِيَةِ قُلُوبُهُمْ ۗ وَإِنَّ ٱلظَّٰلِمِينَ لَفِى شِقَاقٍۭ بَعِيدٍۢ","numberInSurah":53,"juz":17,"manzil":4,"page":338,"ruku":291,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2649,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2649.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2649.mp3"],"text":"وَلِيَعْلَمَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ أَنَّهُ ٱلْحَقُّ مِن رَّبِّكَ فَيُؤْمِنُوا۟ بِهِۦ فَتُخْبِتَ لَهُۥ قُلُوبُهُمْ ۗ وَإِنَّ ٱللَّهَ لَهَادِ ٱلَّذِينَ ءَامَنُوٓا۟ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","numberInSurah":54,"juz":17,"manzil":4,"page":338,"ruku":291,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2650,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2650.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2650.mp3"],"text":"وَلَا يَزَالُ ٱلَّذِينَ كَفَرُوا۟ فِى مِرْيَةٍۢ مِّنْهُ حَتَّىٰ تَأْتِيَهُمُ ٱلسَّاعَةُ بَغْتَةً أَوْ يَأْتِيَهُمْ عَذَابُ يَوْمٍ عَقِيمٍ","numberInSurah":55,"juz":17,"manzil":4,"page":338,"ruku":291,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2651,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2651.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2651.mp3"],"text":"ٱلْمُلْكُ يَوْمَئِذٍۢ لِّلَّهِ يَحْكُمُ بَيْنَهُمْ ۚ فَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فِى جَنَّٰتِ ٱلنَّعِيمِ","numberInSurah":56,"juz":17,"manzil":4,"page":339,"ruku":291,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2652,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2652.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2652.mp3"],"text":"وَٱلَّذِينَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔايَٰتِنَا فَأُو۟لَٰٓئِكَ لَهُمْ عَذَابٌۭ مُّهِينٌۭ","numberInSurah":57,"juz":17,"manzil":4,"page":339,"ruku":291,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2653,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2653.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2653.mp3"],"text":"وَٱلَّذِينَ هَاجَرُوا۟ فِى سَبِيلِ ٱللَّهِ ثُمَّ قُتِلُوٓا۟ أَوْ مَاتُوا۟ لَيَرْزُقَنَّهُمُ ٱللَّهُ رِزْقًا حَسَنًۭا ۚ وَإِنَّ ٱللَّهَ لَهُوَ خَيْرُ ٱلرَّٰزِقِينَ","numberInSurah":58,"juz":17,"manzil":4,"page":339,"ruku":292,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2654,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2654.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2654.mp3"],"text":"لَيُدْخِلَنَّهُم مُّدْخَلًۭا يَرْضَوْنَهُۥ ۗ وَإِنَّ ٱللَّهَ لَعَلِيمٌ حَلِيمٌۭ","numberInSurah":59,"juz":17,"manzil":4,"page":339,"ruku":292,"hizbQuarter":135,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}}],"surahs":{"22":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},"edition":{}}}