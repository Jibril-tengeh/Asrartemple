{"code":200,"status":"OK","data":{"number":132,"ayahs":[{"number":2566,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2566.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2566.mp3"],"text":"۞ وَأَيُّوبَ إِذْ نَادَىٰ رَبَّهُۥٓ أَنِّى مَسَّنِىَ ٱلضُّرُّ وَأَنتَ أَرْحَمُ ٱلرَّٰحِمِينَ","numberInSurah":83,"juz":17,"manzil":4,"page":329,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2567,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2567.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2567.mp3"],"text":"فَٱسْتَجَبْنَا لَهُۥ فَكَشَفْنَا مَا بِهِۦ مِن ضُرٍّۢ ۖ وَءَاتَيْنَٰهُ أَهْلَهُۥ وَمِثْلَهُم مَّعَهُمْ رَحْمَةًۭ مِّنْ عِندِنَا وَذِكْرَىٰ لِلْعَٰبِدِينَ","numberInSurah":84,"juz":17,"manzil":4,"page":329,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2568,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2568.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2568.mp3"],"text":"وَإِسْمَٰعِيلَ وَإِدْرِيسَ وَذَا ٱلْكِفْلِ ۖ كُلٌّۭ مِّنَ ٱلصَّٰبِرِينَ","numberInSurah":85,"juz":17,"manzil":4,"page":329,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2569,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2569.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2569.mp3"],"text":"وَأَدْخَلْنَٰهُمْ فِى رَحْمَتِنَآ ۖ إِنَّهُم مِّنَ ٱلصَّٰلِحِينَ","numberInSurah":86,"juz":17,"manzil":4,"page":329,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2570,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2570.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2570.mp3"],"text":"وَذَا ٱلنُّونِ إِذ ذَّهَبَ مُغَٰضِبًۭا فَظَنَّ أَن لَّن نَّقْدِرَ عَلَيْهِ فَنَادَىٰ فِى ٱلظُّلُمَٰتِ أَن لَّآ إِلَٰهَ إِلَّآ أَنتَ سُبْحَٰنَكَ إِنِّى كُنتُ مِنَ ٱلظَّٰلِمِينَ","numberInSurah":87,"juz":17,"manzil":4,"page":329,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2571,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2571.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2571.mp3"],"text":"فَٱسْتَجَبْنَا لَهُۥ وَنَجَّيْنَٰهُ مِنَ ٱلْغَمِّ ۚ وَكَذَٰلِكَ نُۨجِى ٱلْمُؤْمِنِينَ","numberInSurah":88,"juz":17,"manzil":4,"page":329,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2572,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2572.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2572.mp3"],"text":"وَزَكَرِيَّآ إِذْ نَادَىٰ رَبَّهُۥ رَبِّ لَا تَذَرْنِى فَرْدًۭا وَأَنتَ خَيْرُ ٱلْوَٰرِثِينَ","numberInSurah":89,"juz":17,"manzil":4,"page":329,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2573,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2573.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2573.mp3"],"text":"فَٱسْتَجَبْنَا لَهُۥ وَوَهَبْنَا لَهُۥ يَحْيَىٰ وَأَصْلَحْنَا لَهُۥ زَوْجَهُۥٓ ۚ إِنَّهُمْ كَانُوا۟ يُسَٰرِعُونَ فِى ٱلْخَيْرَٰتِ وَيَدْعُونَنَا رَغَبًۭا وَرَهَبًۭا ۖ وَكَانُوا۟ لَنَا خَٰشِعِينَ","numberInSurah":90,"juz":17,"manzil":4,"page":329,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2574,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2574.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2574.mp3"],"text":"وَٱلَّتِىٓ أَحْصَنَتْ فَرْجَهَا فَنَفَخْنَا فِيهَا مِن رُّوحِنَا وَجَعَلْنَٰهَا وَٱبْنَهَآ ءَايَةًۭ لِّلْعَٰلَمِينَ","numberInSurah":91,"juz":17,"manzil":4,"page":330,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2575,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2575.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2575.mp3"],"text":"إِنَّ هَٰذِهِۦٓ أُمَّتُكُمْ أُمَّةًۭ وَٰحِدَةًۭ وَأَنَا۠ رَبُّكُمْ فَٱعْبُدُونِ","numberInSurah":92,"juz":17,"manzil":4,"page":330,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2576,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2576.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2576.mp3"],"text":"وَتَقَطَّعُوٓا۟ أَمْرَهُم بَيْنَهُمْ ۖ كُلٌّ إِلَيْنَا رَٰجِعُونَ","numberInSurah":93,"juz":17,"manzil":4,"page":330,"ruku":283,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2577,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2577.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2577.mp3"],"text":"فَمَن يَعْمَلْ مِنَ ٱلصَّٰلِحَٰتِ وَهُوَ مُؤْمِنٌۭ فَلَا كُفْرَانَ لِسَعْيِهِۦ وَإِنَّا لَهُۥ كَٰتِبُونَ","numberInSurah":94,"juz":17,"manzil":4,"page":330,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2578,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2578.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2578.mp3"],"text":"وَحَرَٰمٌ عَلَىٰ قَرْيَةٍ أَهْلَكْنَٰهَآ أَنَّهُمْ لَا يَرْجِعُونَ","numberInSurah":95,"juz":17,"manzil":4,"page":330,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2579,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2579.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2579.mp3"],"text":"حَتَّىٰٓ إِذَا فُتِحَتْ يَأْجُوجُ وَمَأْجُوجُ وَهُم مِّن كُلِّ حَدَبٍۢ يَنسِلُونَ","numberInSurah":96,"juz":17,"manzil":4,"page":330,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2580,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2580.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2580.mp3"],"text":"وَٱقْتَرَبَ ٱلْوَعْدُ ٱلْحَقُّ فَإِذَا هِىَ شَٰخِصَةٌ أَبْصَٰرُ ٱلَّذِينَ كَفَرُوا۟ يَٰوَيْلَنَا قَدْ كُنَّا فِى غَفْلَةٍۢ مِّنْ هَٰذَا بَلْ كُنَّا ظَٰلِمِينَ","numberInSurah":97,"juz":17,"manzil":4,"page":330,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2581,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2581.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2581.mp3"],"text":"إِنَّكُمْ وَمَا تَعْبُدُونَ مِن دُونِ ٱللَّهِ حَصَبُ جَهَنَّمَ أَنتُمْ لَهَا وَٰرِدُونَ","numberInSurah":98,"juz":17,"manzil":4,"page":330,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2582,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2582.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2582.mp3"],"text":"لَوْ كَانَ هَٰٓؤُلَآءِ ءَالِهَةًۭ مَّا وَرَدُوهَا ۖ وَكُلٌّۭ فِيهَا خَٰلِدُونَ","numberInSurah":99,"juz":17,"manzil":4,"page":330,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2583,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2583.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2583.mp3"],"text":"لَهُمْ فِيهَا زَفِيرٌۭ وَهُمْ فِيهَا لَا يَسْمَعُونَ","numberInSurah":100,"juz":17,"manzil":4,"page":330,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2584,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2584.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2584.mp3"],"text":"إِنَّ ٱلَّذِينَ سَبَقَتْ لَهُم مِّنَّا ٱلْحُسْنَىٰٓ أُو۟لَٰٓئِكَ عَنْهَا مُبْعَدُونَ","numberInSurah":101,"juz":17,"manzil":4,"page":330,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2585,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2585.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2585.mp3"],"text":"لَا يَسْمَعُونَ حَسِيسَهَا ۖ وَهُمْ فِى مَا ٱشْتَهَتْ أَنفُسُهُمْ خَٰلِدُونَ","numberInSurah":102,"juz":17,"manzil":4,"page":331,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2586,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2586.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2586.mp3"],"text":"لَا يَحْزُنُهُمُ ٱلْفَزَعُ ٱلْأَكْبَرُ وَتَتَلَقَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ هَٰذَا يَوْمُكُمُ ٱلَّذِى كُنتُمْ تُوعَدُونَ","numberInSurah":103,"juz":17,"manzil":4,"page":331,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2587,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2587.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2587.mp3"],"text":"يَوْمَ نَطْوِى ٱلسَّمَآءَ كَطَىِّ ٱلسِّجِلِّ لِلْكُتُبِ ۚ كَمَا بَدَأْنَآ أَوَّلَ خَلْقٍۢ نُّعِيدُهُۥ ۚ وَعْدًا عَلَيْنَآ ۚ إِنَّا كُنَّا فَٰعِلِينَ","numberInSurah":104,"juz":17,"manzil":4,"page":331,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2588,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2588.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2588.mp3"],"text":"وَلَقَدْ كَتَبْنَا فِى ٱلزَّبُورِ مِنۢ بَعْدِ ٱلذِّكْرِ أَنَّ ٱلْأَرْضَ يَرِثُهَا عِبَادِىَ ٱلصَّٰلِحُونَ","numberInSurah":105,"juz":17,"manzil":4,"page":331,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2589,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2589.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2589.mp3"],"text":"إِنَّ فِى هَٰذَا لَبَلَٰغًۭا لِّقَوْمٍ عَٰبِدِينَ","numberInSurah":106,"juz":17,"manzil":4,"page":331,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2590,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2590.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2590.mp3"],"text":"وَمَآ أَرْسَلْنَٰكَ إِلَّا رَحْمَةًۭ لِّلْعَٰلَمِينَ","numberInSurah":107,"juz":17,"manzil":4,"page":331,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2591,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2591.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2591.mp3"],"text":"قُلْ إِنَّمَا يُوحَىٰٓ إِلَىَّ أَنَّمَآ إِلَٰهُكُمْ إِلَٰهٌۭ وَٰحِدٌۭ ۖ فَهَلْ أَنتُم مُّسْلِمُونَ","numberInSurah":108,"juz":17,"manzil":4,"page":331,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2592,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2592.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2592.mp3"],"text":"فَإِن تَوَلَّوْا۟ فَقُلْ ءَاذَنتُكُمْ عَلَىٰ سَوَآءٍۢ ۖ وَإِنْ أَدْرِىٓ أَقَرِيبٌ أَم بَعِيدٌۭ مَّا تُوعَدُونَ","numberInSurah":109,"juz":17,"manzil":4,"page":331,"ruku":284,"hizbQuarter":132,"sajda":false,"surah":{"number":21,"n