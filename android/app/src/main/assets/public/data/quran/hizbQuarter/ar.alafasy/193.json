{"code":200,"status":"OK","data":{"number":193,"ayahs":[{"number":4265,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4265.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4265.mp3"],"text":"۞ إِلَيْهِ يُرَدُّ عِلْمُ ٱلسَّاعَةِ ۚ وَمَا تَخْرُجُ مِن ثَمَرَٰتٍۢ مِّنْ أَكْمَامِهَا وَمَا تَحْمِلُ مِنْ أُنثَىٰ وَلَا تَضَعُ إِلَّا بِعِلْمِهِۦ ۚ وَيَوْمَ يُنَادِيهِمْ أَيْنَ شُرَكَآءِى قَالُوٓا۟ ءَاذَنَّٰكَ مَا مِنَّا مِن شَهِيدٍۢ","numberInSurah":47,"juz":25,"manzil":6,"page":482,"ruku":418,"hizbQuarter":193,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4266,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4266.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4266.mp3"],"text":"وَضَلَّ عَنْهُم مَّا كَانُوا۟ يَدْعُونَ مِن قَبْلُ ۖ وَظَنُّوا۟ مَا لَهُم مِّن مَّحِيصٍۢ","numberInSurah":48,"juz":25,"manzil":6,"page":482,"ruku":418,"hizbQuarter":193,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4267,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4267.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4267.mp3"],"text":"لَّا يَسْـَٔمُ ٱلْإِنسَٰنُ مِن دُعَآءِ ٱلْخَيْرِ وَإِن مَّسَّهُ ٱلشَّرُّ فَيَـُٔوسٌۭ قَنُوطٌۭ","numberInSurah":49,"juz":25,"manzil":6,"page":482,"ruku":418,"hizbQuarter":193,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4268,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4268.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4268.mp3"],"text":"وَلَئِنْ أَذَقْنَٰهُ رَحْمَةًۭ مِّنَّا مِنۢ بَعْدِ ضَرَّآءَ مَسَّتْهُ لَيَقُولَنَّ هَٰذَا لِى وَمَآ أَظُنُّ ٱلسَّاعَةَ قَآئِمَةًۭ وَلَئِن رُّجِعْتُ إِلَىٰ رَبِّىٓ إِنَّ لِى عِندَهُۥ لَلْحُسْنَىٰ ۚ فَلَنُنَبِّئَنَّ ٱلَّذِينَ كَفَرُوا۟ بِمَا عَمِلُوا۟ وَلَنُذِيقَنَّهُم مِّنْ عَذَابٍ غَلِيظٍۢ","numberInSurah":50,"juz":25,"manzil":6,"page":482,"ruku":418,"hizbQuarter":193,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4269,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4269.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4269.mp3"],"text":"وَإِذَآ أَنْعَمْنَا عَلَى ٱلْإِنسَٰنِ أَعْرَضَ وَنَـَٔا بِجَانِبِهِۦ وَإِذَا مَسَّهُ ٱلشَّرُّ فَذُو دُعَآءٍ عَرِيضٍۢ","numberInSurah":51,"juz":25,"manzil":6,"page":482,"ruku":418,"hizbQuarter":193,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4270,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4270.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4270.mp3"],"text":"قُلْ أَرَءَيْتُمْ إِن كَانَ مِنْ عِندِ ٱللَّهِ ثُمَّ كَفَرْتُم بِهِۦ مَنْ أَضَلُّ مِمَّنْ هُوَ فِى شِقَاقٍۭ بَعِيدٍۢ","numberInSurah":52,"juz":25,"manzil":6,"page":482,"ruku":418,"hizbQuarter":193,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4271,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4271.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4271.mp3"],"text":"سَنُرِيهِمْ ءَايَٰتِنَا فِى ٱلْءَافَاقِ وَفِىٓ أَنفُسِهِمْ حَتَّىٰ يَتَبَيَّنَ لَهُمْ أَنَّهُ ٱلْحَقُّ ۗ أَوَلَمْ يَكْفِ بِرَبِّكَ أَنَّهُۥ عَلَىٰ كُلِّ شَىْءٍۢ شَهِيدٌ","numberInSurah":53,"juz":25,"manzil":6,"page":482,"ruku":418,"hizbQuarter":193,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4272,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4272.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4272.mp3"],"text":"أَلَآ إِنَّهُمْ فِى مِرْيَةٍۢ مِّن لِّقَآءِ رَبِّهِمْ ۗ أَلَآ إِنَّهُۥ بِكُلِّ شَىْءٍۢ مُّحِيطٌۢ","numberInSurah":54,"juz":25,"manzil":6,"page":482,"ruku":418,"hizbQuarter":193,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4273,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4273.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4273.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ حمٓ","numberInSurah":1,"juz":25,"manzil":6,"page":483,"ruku":419,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4274,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4274.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4274.mp3"],"text":"عٓسٓقٓ","numberInSurah":2,"juz":25,"manzil":6,"page":483,"ruku":419,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4275,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4275.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4275.mp3"],"text":"كَذَٰلِكَ يُوحِىٓ إِلَيْكَ وَإِلَى ٱلَّذِينَ مِن قَبْلِكَ ٱللَّهُ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":3,"juz":25,"manzil":6,"page":483,"ruku":419,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4276,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4276.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4276.mp3"],"text":"لَهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۖ وَهُوَ ٱلْعَلِىُّ ٱلْعَظِيمُ","numberInSurah":4,"juz":25,"manzil":6,"page":483,"ruku":419,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4277,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4277.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4277.mp3"],"text":"تَكَادُ ٱلسَّمَٰوَٰتُ يَتَفَطَّرْنَ مِن فَوْقِهِنَّ ۚ وَٱلْمَلَٰٓئِكَةُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ وَيَسْتَغْفِرُونَ لِمَن فِى ٱلْأَرْضِ ۗ أَلَآ إِنَّ ٱللَّهَ هُوَ ٱلْغَفُورُ ٱلرَّحِيمُ","numberInSurah":5,"juz":25,"manzil":6,"page":483,"ruku":419,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4278,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4278.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4278.mp3"],"text":"وَٱلَّذِينَ ٱتَّخَذُوا۟ مِن دُونِهِۦٓ أَوْلِيَآءَ ٱللَّهُ حَفِيظٌ عَلَيْهِمْ وَمَآ أَنتَ عَلَيْهِم بِوَكِيلٍۢ","numberInSurah":6,"juz":25,"manzil":6,"page":483,"ruku":419,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4279,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4279.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4279.mp3"],"text":"وَكَذَٰلِكَ أَوْحَيْنَآ إِلَيْكَ قُرْءَانًا عَرَبِيًّۭا لِّتُنذِرَ أُمَّ ٱلْقُرَىٰ وَمَنْ حَوْلَهَا وَتُنذِرَ يَوْمَ ٱلْجَمْعِ لَا رَيْبَ فِيهِ ۚ فَرِيقٌۭ فِى ٱلْجَنَّةِ وَفَرِيقٌۭ فِى ٱلسَّعِيرِ","numberInSurah":7,"juz":25,"manzil":6,"page":483,"ruku":419,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4280,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4280.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4280.mp3"],"text":"وَلَوْ شَآءَ ٱللَّهُ لَجَعَلَهُمْ أُمَّةًۭ وَٰحِدَةًۭ وَلَٰكِن يُدْخِلُ مَن يَشَآءُ فِى رَحْمَتِهِۦ ۚ وَٱلظَّٰلِمُونَ مَا لَهُم مِّن وَلِىٍّۢ وَلَا نَصِيرٍ","numberInSurah":8,"juz":25,"manzil":6,"page":483,"ruku":419,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4281,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4281.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4281.mp3"],"text":"أَمِ ٱتَّخَذُوا۟ مِن دُونِهِۦٓ أَوْلِيَآءَ ۖ فَٱللَّهُ هُوَ ٱلْوَلِىُّ وَهُوَ يُحْىِ ٱلْمَوْتَىٰ وَهُوَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","numberInSurah":9,"juz":25,"manzil":6,"page":483,"ruku":419,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4282,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4282.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4282.mp3"],"text":"وَمَا ٱخْتَلَفْتُمْ فِيهِ مِن شَىْءٍۢ فَحُكْمُهُۥٓ إِلَى ٱللَّهِ ۚ ذَٰلِكُمُ ٱللَّهُ رَبِّى عَلَيْهِ تَوَكَّلْتُ وَإِلَيْهِ أُنِيبُ","numberInSurah":10,"juz":25,"manzil":6,"page":483,"ruku":420,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4283,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4283.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4283.mp3"],"text":"فَاطِرُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ جَعَلَ لَكُم مِّنْ أَنفُسِكُمْ أَزْوَٰجًۭا وَمِنَ ٱلْأَنْعَٰمِ أَزْوَٰجًۭا ۖ يَذْرَؤُكُمْ فِيهِ ۚ لَيْسَ كَمِثْلِهِۦ شَىْءٌۭ ۖ وَهُوَ ٱلسَّمِيعُ ٱلْبَصِيرُ","numberInSurah":11,"juz":25,"manzil":6,"page":484,"ruku":420,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4284,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4284.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4284.mp3"],"text":"لَهُۥ مَقَالِيدُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۖ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ إِنَّهُۥ بِكُلِّ شَىْءٍ عَلِيمٌۭ","numberInSurah":12,"juz":25,"manzil":6,"page":484,"ruku":420,"hizbQuarter":193,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}}],"surahs":{"41":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"},"42":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},"edition":{}}}