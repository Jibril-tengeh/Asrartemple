{"code":200,"status":"OK","data":{"number":157,"ayahs":[{"number":3303,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3303.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3303.mp3"],"text":"۞ وَلَقَدْ وَصَّلْنَا لَهُمُ ٱلْقَوْلَ لَعَلَّهُمْ يَتَذَكَّرُونَ","numberInSurah":51,"juz":20,"manzil":5,"page":392,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3304,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3304.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3304.mp3"],"text":"ٱلَّذِينَ ءَاتَيْنَٰهُمُ ٱلْكِتَٰبَ مِن قَبْلِهِۦ هُم بِهِۦ يُؤْمِنُونَ","numberInSurah":52,"juz":20,"manzil":5,"page":392,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3305,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3305.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3305.mp3"],"text":"وَإِذَا يُتْلَىٰ عَلَيْهِمْ قَالُوٓا۟ ءَامَنَّا بِهِۦٓ إِنَّهُ ٱلْحَقُّ مِن رَّبِّنَآ إِنَّا كُنَّا مِن قَبْلِهِۦ مُسْلِمِينَ","numberInSurah":53,"juz":20,"manzil":5,"page":392,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3306,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3306.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3306.mp3"],"text":"أُو۟لَٰٓئِكَ يُؤْتَوْنَ أَجْرَهُم مَّرَّتَيْنِ بِمَا صَبَرُوا۟ وَيَدْرَءُونَ بِٱلْحَسَنَةِ ٱلسَّيِّئَةَ وَمِمَّا رَزَقْنَٰهُمْ يُنفِقُونَ","numberInSurah":54,"juz":20,"manzil":5,"page":392,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3307,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3307.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3307.mp3"],"text":"وَإِذَا سَمِعُوا۟ ٱللَّغْوَ أَعْرَضُوا۟ عَنْهُ وَقَالُوا۟ لَنَآ أَعْمَٰلُنَا وَلَكُمْ أَعْمَٰلُكُمْ سَلَٰمٌ عَلَيْكُمْ لَا نَبْتَغِى ٱلْجَٰهِلِينَ","numberInSurah":55,"juz":20,"manzil":5,"page":392,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3308,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3308.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3308.mp3"],"text":"إِنَّكَ لَا تَهْدِى مَنْ أَحْبَبْتَ وَلَٰكِنَّ ٱللَّهَ يَهْدِى مَن يَشَآءُ ۚ وَهُوَ أَعْلَمُ بِٱلْمُهْتَدِينَ","numberInSurah":56,"juz":20,"manzil":5,"page":392,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3309,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3309.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3309.mp3"],"text":"وَقَالُوٓا۟ إِن نَّتَّبِعِ ٱلْهُدَىٰ مَعَكَ نُتَخَطَّفْ مِنْ أَرْضِنَآ ۚ أَوَلَمْ نُمَكِّن لَّهُمْ حَرَمًا ءَامِنًۭا يُجْبَىٰٓ إِلَيْهِ ثَمَرَٰتُ كُلِّ شَىْءٍۢ رِّزْقًۭا مِّن لَّدُنَّا وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","numberInSurah":57,"juz":20,"manzil":5,"page":392,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3310,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3310.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3310.mp3"],"text":"وَكَمْ أَهْلَكْنَا مِن قَرْيَةٍۭ بَطِرَتْ مَعِيشَتَهَا ۖ فَتِلْكَ مَسَٰكِنُهُمْ لَمْ تُسْكَن مِّنۢ بَعْدِهِمْ إِلَّا قَلِيلًۭا ۖ وَكُنَّا نَحْنُ ٱلْوَٰرِثِينَ","numberInSurah":58,"juz":20,"manzil":5,"page":392,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3311,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3311.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3311.mp3"],"text":"وَمَا كَانَ رَبُّكَ مُهْلِكَ ٱلْقُرَىٰ حَتَّىٰ يَبْعَثَ فِىٓ أُمِّهَا رَسُولًۭا يَتْلُوا۟ عَلَيْهِمْ ءَايَٰتِنَا ۚ وَمَا كُنَّا مُهْلِكِى ٱلْقُرَىٰٓ إِلَّا وَأَهْلُهَا ظَٰلِمُونَ","numberInSurah":59,"juz":20,"manzil":5,"page":392,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3312,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3312.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3312.mp3"],"text":"وَمَآ أُوتِيتُم مِّن شَىْءٍۢ فَمَتَٰعُ ٱلْحَيَوٰةِ ٱلدُّنْيَا وَزِينَتُهَا ۚ وَمَا عِندَ ٱللَّهِ خَيْرٌۭ وَأَبْقَىٰٓ ۚ أَفَلَا تَعْقِلُونَ","numberInSurah":60,"juz":20,"manzil":5,"page":393,"ruku":339,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3313,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3313.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3313.mp3"],"text":"أَفَمَن وَعَدْنَٰهُ وَعْدًا حَسَنًۭا فَهُوَ لَٰقِيهِ كَمَن مَّتَّعْنَٰهُ مَتَٰعَ ٱلْحَيَوٰةِ ٱلدُّنْيَا ثُمَّ هُوَ يَوْمَ ٱلْقِيَٰمَةِ مِنَ ٱلْمُحْضَرِينَ","numberInSurah":61,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3314,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3314.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3314.mp3"],"text":"وَيَوْمَ يُنَادِيهِمْ فَيَقُولُ أَيْنَ شُرَكَآءِىَ ٱلَّذِينَ كُنتُمْ تَزْعُمُونَ","numberInSurah":62,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3315,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3315.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3315.mp3"],"text":"قَالَ ٱلَّذِينَ حَقَّ عَلَيْهِمُ ٱلْقَوْلُ رَبَّنَا هَٰٓؤُلَآءِ ٱلَّذِينَ أَغْوَيْنَآ أَغْوَيْنَٰهُمْ كَمَا غَوَيْنَا ۖ تَبَرَّأْنَآ إِلَيْكَ ۖ مَا كَانُوٓا۟ إِيَّانَا يَعْبُدُونَ","numberInSurah":63,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3316,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3316.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3316.mp3"],"text":"وَقِيلَ ٱدْعُوا۟ شُرَكَآءَكُمْ فَدَعَوْهُمْ فَلَمْ يَسْتَجِيبُوا۟ لَهُمْ وَرَأَوُا۟ ٱلْعَذَابَ ۚ لَوْ أَنَّهُمْ كَانُوا۟ يَهْتَدُونَ","numberInSurah":64,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3317,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3317.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3317.mp3"],"text":"وَيَوْمَ يُنَادِيهِمْ فَيَقُولُ مَاذَآ أَجَبْتُمُ ٱلْمُرْسَلِينَ","numberInSurah":65,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3318,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3318.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3318.mp3"],"text":"فَعَمِيَتْ عَلَيْهِمُ ٱلْأَنۢبَآءُ يَوْمَئِذٍۢ فَهُمْ لَا يَتَسَآءَلُونَ","numberInSurah":66,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3319,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3319.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3319.mp3"],"text":"فَأَمَّا مَن تَابَ وَءَامَنَ وَعَمِلَ صَٰلِحًۭا فَعَسَىٰٓ أَن يَكُونَ مِنَ ٱلْمُفْلِحِينَ","numberInSurah":67,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3320,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3320.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3320.mp3"],"text":"وَرَبُّكَ يَخْلُقُ مَا يَشَآءُ وَيَخْتَارُ ۗ مَا كَانَ لَهُمُ ٱلْخِيَرَةُ ۚ سُبْحَٰنَ ٱللَّهِ وَتَعَٰلَىٰ عَمَّا يُشْرِكُونَ","numberInSurah":68,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3321,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3321.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3321.mp3"],"text":"وَرَبُّكَ يَعْلَمُ مَا تُكِنُّ صُدُورُهُمْ وَمَا يُعْلِنُونَ","numberInSurah":69,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3322,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3322.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3322.mp3"],"text":"وَهُوَ ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ ۖ لَهُ ٱلْحَمْدُ فِى ٱلْأُولَىٰ وَٱلْءَاخِرَةِ ۖ وَلَهُ ٱلْحُكْمُ وَإِلَيْهِ تُرْجَعُونَ","numberInSurah":70,"juz":20,"manzil":5,"page":393,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3323,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3323.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3323.mp3"],"text":"قُلْ أَرَءَيْتُمْ إِن جَعَلَ ٱللَّهُ عَلَيْكُمُ ٱلَّيْلَ سَرْمَدًا إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ مَنْ إِلَٰهٌ غَيْرُ ٱللَّهِ يَأْتِيكُم بِضِيَآءٍ ۖ أَفَلَا تَسْمَعُونَ","numberInSurah":71,"juz":20,"manzil":5,"page":394,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3324,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3324.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3324.mp3"],"text":"قُلْ أَرَءَيْتُمْ إِن جَعَلَ ٱللَّهُ عَلَيْكُمُ ٱلنَّهَارَ سَرْمَدًا إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ مَنْ إِلَٰهٌ غَيْرُ ٱللَّهِ يَأْتِيكُم بِلَيْلٍۢ تَسْكُنُونَ فِيهِ ۖ أَفَلَا تُبْصِرُونَ","numberInSurah":72,"juz":20,"manzil":5,"page":394,"ruku":340,"hizbQuarter":157,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3325,"au