{"code":200,"status":"OK","data":{"number":154,"ayahs":[{"number":3241,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3241.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3241.mp3"],"text":"۞ وَإِذَا وَقَعَ ٱلْقَوْلُ عَلَيْهِمْ أَخْرَجْنَا لَهُمْ دَآبَّةًۭ مِّنَ ٱلْأَرْضِ تُكَلِّمُهُمْ أَنَّ ٱلنَّاسَ كَانُوا۟ بِـَٔايَٰتِنَا لَا يُوقِنُونَ","numberInSurah":82,"juz":20,"manzil":5,"page":384,"ruku":332,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3242,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3242.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3242.mp3"],"text":"وَيَوْمَ نَحْشُرُ مِن كُلِّ أُمَّةٍۢ فَوْجًۭا مِّمَّن يُكَذِّبُ بِـَٔايَٰتِنَا فَهُمْ يُوزَعُونَ","numberInSurah":83,"juz":20,"manzil":5,"page":384,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3243,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3243.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3243.mp3"],"text":"حَتَّىٰٓ إِذَا جَآءُو قَالَ أَكَذَّبْتُم بِـَٔايَٰتِى وَلَمْ تُحِيطُوا۟ بِهَا عِلْمًا أَمَّاذَا كُنتُمْ تَعْمَلُونَ","numberInSurah":84,"juz":20,"manzil":5,"page":384,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3244,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3244.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3244.mp3"],"text":"وَوَقَعَ ٱلْقَوْلُ عَلَيْهِم بِمَا ظَلَمُوا۟ فَهُمْ لَا يَنطِقُونَ","numberInSurah":85,"juz":20,"manzil":5,"page":384,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3245,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3245.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3245.mp3"],"text":"أَلَمْ يَرَوْا۟ أَنَّا جَعَلْنَا ٱلَّيْلَ لِيَسْكُنُوا۟ فِيهِ وَٱلنَّهَارَ مُبْصِرًا ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يُؤْمِنُونَ","numberInSurah":86,"juz":20,"manzil":5,"page":384,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3246,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3246.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3246.mp3"],"text":"وَيَوْمَ يُنفَخُ فِى ٱلصُّورِ فَفَزِعَ مَن فِى ٱلسَّمَٰوَٰتِ وَمَن فِى ٱلْأَرْضِ إِلَّا مَن شَآءَ ٱللَّهُ ۚ وَكُلٌّ أَتَوْهُ دَٰخِرِينَ","numberInSurah":87,"juz":20,"manzil":5,"page":384,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3247,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3247.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3247.mp3"],"text":"وَتَرَى ٱلْجِبَالَ تَحْسَبُهَا جَامِدَةًۭ وَهِىَ تَمُرُّ مَرَّ ٱلسَّحَابِ ۚ صُنْعَ ٱللَّهِ ٱلَّذِىٓ أَتْقَنَ كُلَّ شَىْءٍ ۚ إِنَّهُۥ خَبِيرٌۢ بِمَا تَفْعَلُونَ","numberInSurah":88,"juz":20,"manzil":5,"page":384,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3248,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3248.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3248.mp3"],"text":"مَن جَآءَ بِٱلْحَسَنَةِ فَلَهُۥ خَيْرٌۭ مِّنْهَا وَهُم مِّن فَزَعٍۢ يَوْمَئِذٍ ءَامِنُونَ","numberInSurah":89,"juz":20,"manzil":5,"page":385,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3249,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3249.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3249.mp3"],"text":"وَمَن جَآءَ بِٱلسَّيِّئَةِ فَكُبَّتْ وُجُوهُهُمْ فِى ٱلنَّارِ هَلْ تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ","numberInSurah":90,"juz":20,"manzil":5,"page":385,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3250,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3250.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3250.mp3"],"text":"إِنَّمَآ أُمِرْتُ أَنْ أَعْبُدَ رَبَّ هَٰذِهِ ٱلْبَلْدَةِ ٱلَّذِى حَرَّمَهَا وَلَهُۥ كُلُّ شَىْءٍۢ ۖ وَأُمِرْتُ أَنْ أَكُونَ مِنَ ٱلْمُسْلِمِينَ","numberInSurah":91,"juz":20,"manzil":5,"page":385,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3251,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3251.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3251.mp3"],"text":"وَأَنْ أَتْلُوَا۟ ٱلْقُرْءَانَ ۖ فَمَنِ ٱهْتَدَىٰ فَإِنَّمَا يَهْتَدِى لِنَفْسِهِۦ ۖ وَمَن ضَلَّ فَقُلْ إِنَّمَآ أَنَا۠ مِنَ ٱلْمُنذِرِينَ","numberInSurah":92,"juz":20,"manzil":5,"page":385,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3252,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3252.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3252.mp3"],"text":"وَقُلِ ٱلْحَمْدُ لِلَّهِ سَيُرِيكُمْ ءَايَٰتِهِۦ فَتَعْرِفُونَهَا ۚ وَمَا رَبُّكَ بِغَٰفِلٍ عَمَّا تَعْمَلُونَ","numberInSurah":93,"juz":20,"manzil":5,"page":385,"ruku":333,"hizbQuarter":154,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3253,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3253.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3253.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ طسٓمٓ","numberInSurah":1,"juz":20,"manzil":5,"page":385,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3254,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3254.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3254.mp3"],"text":"تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ ٱلْمُبِينِ","numberInSurah":2,"juz":20,"manzil":5,"page":385,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3255,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3255.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3255.mp3"],"text":"نَتْلُوا۟ عَلَيْكَ مِن نَّبَإِ مُوسَىٰ وَفِرْعَوْنَ بِٱلْحَقِّ لِقَوْمٍۢ يُؤْمِنُونَ","numberInSurah":3,"juz":20,"manzil":5,"page":385,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3256,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3256.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3256.mp3"],"text":"إِنَّ فِرْعَوْنَ عَلَا فِى ٱلْأَرْضِ وَجَعَلَ أَهْلَهَا شِيَعًۭا يَسْتَضْعِفُ طَآئِفَةًۭ مِّنْهُمْ يُذَبِّحُ أَبْنَآءَهُمْ وَيَسْتَحْىِۦ نِسَآءَهُمْ ۚ إِنَّهُۥ كَانَ مِنَ ٱلْمُفْسِدِينَ","numberInSurah":4,"juz":20,"manzil":5,"page":385,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3257,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3257.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3257.mp3"],"text":"وَنُرِيدُ أَن نَّمُنَّ عَلَى ٱلَّذِينَ ٱسْتُضْعِفُوا۟ فِى ٱلْأَرْضِ وَنَجْعَلَهُمْ أَئِمَّةًۭ وَنَجْعَلَهُمُ ٱلْوَٰرِثِينَ","numberInSurah":5,"juz":20,"manzil":5,"page":385,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3258,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3258.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3258.mp3"],"text":"وَنُمَكِّنَ لَهُمْ فِى ٱلْأَرْضِ وَنُرِىَ فِرْعَوْنَ وَهَٰمَٰنَ وَجُنُودَهُمَا مِنْهُم مَّا كَانُوا۟ يَحْذَرُونَ","numberInSurah":6,"juz":20,"manzil":5,"page":386,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3259,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3259.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3259.mp3"],"text":"وَأَوْحَيْنَآ إِلَىٰٓ أُمِّ مُوسَىٰٓ أَنْ أَرْضِعِيهِ ۖ فَإِذَا خِفْتِ عَلَيْهِ فَأَلْقِيهِ فِى ٱلْيَمِّ وَلَا تَخَافِى وَلَا تَحْزَنِىٓ ۖ إِنَّا رَآدُّوهُ إِلَيْكِ وَجَاعِلُوهُ مِنَ ٱلْمُرْسَلِينَ","numberInSurah":7,"juz":20,"manzil":5,"page":386,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3260,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3260.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3260.mp3"],"text":"فَٱلْتَقَطَهُۥٓ ءَالُ فِرْعَوْنَ لِيَكُونَ لَهُمْ عَدُوًّۭا وَحَزَنًا ۗ إِنَّ فِرْعَوْنَ وَهَٰمَٰنَ وَجُنُودَهُمَا كَانُوا۟ خَٰطِـِٔينَ","numberInSurah":8,"juz":20,"manzil":5,"page":386,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3261,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3261.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3261.mp3"],"text":"وَقَالَتِ ٱمْرَأَتُ فِرْعَوْنَ قُرَّتُ عَيْنٍۢ لِّى وَلَكَ ۖ لَا تَقْتُلُوهُ عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًۭا وَهُمْ لَا يَشْعُرُونَ","numberInSurah":9,"juz":20,"manzil":5,"page":386,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3262,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3262.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3262.mp3"],"text":"وَأَصْبَحَ فُؤَادُ أُمِّ مُوسَىٰ فَٰرِغًا ۖ إِن كَادَتْ لَتُبْدِى بِهِۦ لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ","numberInSurah":10,"juz":20,"manzil":5,"page":386,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3263,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3263.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3263.mp3"],"text":"وَقَالَتْ لِأُخْتِهِۦ قُصِّيهِ ۖ فَبَصُرَتْ بِهِۦ عَن جُنُبٍۢ وَهُمْ لَا يَشْعُرُونَ","numberInSurah":11,"juz":20,"manzil":5,"page":386,"ruku":334,"hizbQuarter":154,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}}],"surahs":{"27":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"},"28":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},"edition":{}}}