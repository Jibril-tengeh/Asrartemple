{"code":200,"status":"OK","data":{"number":128,"ayahs":[{"number":2459,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2459.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2459.mp3"],"text":"۞ وَعَنَتِ ٱلْوُجُوهُ لِلْحَىِّ ٱلْقَيُّومِ ۖ وَقَدْ خَابَ مَنْ حَمَلَ ظُلْمًۭا","numberInSurah":111,"juz":16,"manzil":4,"page":319,"ruku":275,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2460,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2460.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2460.mp3"],"text":"وَمَن يَعْمَلْ مِنَ ٱلصَّٰلِحَٰتِ وَهُوَ مُؤْمِنٌۭ فَلَا يَخَافُ ظُلْمًۭا وَلَا هَضْمًۭا","numberInSurah":112,"juz":16,"manzil":4,"page":319,"ruku":275,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2461,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2461.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2461.mp3"],"text":"وَكَذَٰلِكَ أَنزَلْنَٰهُ قُرْءَانًا عَرَبِيًّۭا وَصَرَّفْنَا فِيهِ مِنَ ٱلْوَعِيدِ لَعَلَّهُمْ يَتَّقُونَ أَوْ يُحْدِثُ لَهُمْ ذِكْرًۭا","numberInSurah":113,"juz":16,"manzil":4,"page":319,"ruku":275,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2462,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2462.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2462.mp3"],"text":"فَتَعَٰلَى ٱللَّهُ ٱلْمَلِكُ ٱلْحَقُّ ۗ وَلَا تَعْجَلْ بِٱلْقُرْءَانِ مِن قَبْلِ أَن يُقْضَىٰٓ إِلَيْكَ وَحْيُهُۥ ۖ وَقُل رَّبِّ زِدْنِى عِلْمًۭا","numberInSurah":114,"juz":16,"manzil":4,"page":320,"ruku":275,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2463,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2463.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2463.mp3"],"text":"وَلَقَدْ عَهِدْنَآ إِلَىٰٓ ءَادَمَ مِن قَبْلُ فَنَسِىَ وَلَمْ نَجِدْ لَهُۥ عَزْمًۭا","numberInSurah":115,"juz":16,"manzil":4,"page":320,"ruku":275,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2464,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2464.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2464.mp3"],"text":"وَإِذْ قُلْنَا لِلْمَلَٰٓئِكَةِ ٱسْجُدُوا۟ لِءَادَمَ فَسَجَدُوٓا۟ إِلَّآ إِبْلِيسَ أَبَىٰ","numberInSurah":116,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2465,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2465.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2465.mp3"],"text":"فَقُلْنَا يَٰٓـَٔادَمُ إِنَّ هَٰذَا عَدُوٌّۭ لَّكَ وَلِزَوْجِكَ فَلَا يُخْرِجَنَّكُمَا مِنَ ٱلْجَنَّةِ فَتَشْقَىٰٓ","numberInSurah":117,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2466,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2466.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2466.mp3"],"text":"إِنَّ لَكَ أَلَّا تَجُوعَ فِيهَا وَلَا تَعْرَىٰ","numberInSurah":118,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2467,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2467.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2467.mp3"],"text":"وَأَنَّكَ لَا تَظْمَؤُا۟ فِيهَا وَلَا تَضْحَىٰ","numberInSurah":119,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2468,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2468.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2468.mp3"],"text":"فَوَسْوَسَ إِلَيْهِ ٱلشَّيْطَٰنُ قَالَ يَٰٓـَٔادَمُ هَلْ أَدُلُّكَ عَلَىٰ شَجَرَةِ ٱلْخُلْدِ وَمُلْكٍۢ لَّا يَبْلَىٰ","numberInSurah":120,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2469,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2469.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2469.mp3"],"text":"فَأَكَلَا مِنْهَا فَبَدَتْ لَهُمَا سَوْءَٰتُهُمَا وَطَفِقَا يَخْصِفَانِ عَلَيْهِمَا مِن وَرَقِ ٱلْجَنَّةِ ۚ وَعَصَىٰٓ ءَادَمُ رَبَّهُۥ فَغَوَىٰ","numberInSurah":121,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2470,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2470.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2470.mp3"],"text":"ثُمَّ ٱجْتَبَٰهُ رَبُّهُۥ فَتَابَ عَلَيْهِ وَهَدَىٰ","numberInSurah":122,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2471,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2471.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2471.mp3"],"text":"قَالَ ٱهْبِطَا مِنْهَا جَمِيعًۢا ۖ بَعْضُكُمْ لِبَعْضٍ عَدُوٌّۭ ۖ فَإِمَّا يَأْتِيَنَّكُم مِّنِّى هُدًۭى فَمَنِ ٱتَّبَعَ هُدَاىَ فَلَا يَضِلُّ وَلَا يَشْقَىٰ","numberInSurah":123,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2472,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2472.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2472.mp3"],"text":"وَمَنْ أَعْرَضَ عَن ذِكْرِى فَإِنَّ لَهُۥ مَعِيشَةًۭ ضَنكًۭا وَنَحْشُرُهُۥ يَوْمَ ٱلْقِيَٰمَةِ أَعْمَىٰ","numberInSurah":124,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2473,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2473.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2473.mp3"],"text":"قَالَ رَبِّ لِمَ حَشَرْتَنِىٓ أَعْمَىٰ وَقَدْ كُنتُ بَصِيرًۭا","numberInSurah":125,"juz":16,"manzil":4,"page":320,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2474,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2474.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2474.mp3"],"text":"قَالَ كَذَٰلِكَ أَتَتْكَ ءَايَٰتُنَا فَنَسِيتَهَا ۖ وَكَذَٰلِكَ ٱلْيَوْمَ تُنسَىٰ","numberInSurah":126,"juz":16,"manzil":4,"page":321,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2475,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2475.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2475.mp3"],"text":"وَكَذَٰلِكَ نَجْزِى مَنْ أَسْرَفَ وَلَمْ يُؤْمِنۢ بِـَٔايَٰتِ رَبِّهِۦ ۚ وَلَعَذَابُ ٱلْءَاخِرَةِ أَشَدُّ وَأَبْقَىٰٓ","numberInSurah":127,"juz":16,"manzil":4,"page":321,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2476,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2476.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2476.mp3"],"text":"أَفَلَمْ يَهْدِ لَهُمْ كَمْ أَهْلَكْنَا قَبْلَهُم مِّنَ ٱلْقُرُونِ يَمْشُونَ فِى مَسَٰكِنِهِمْ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّأُو۟لِى ٱلنُّهَىٰ","numberInSurah":128,"juz":16,"manzil":4,"page":321,"ruku":276,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2477,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2477.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2477.mp3"],"text":"وَلَوْلَا كَلِمَةٌۭ سَبَقَتْ مِن رَّبِّكَ لَكَانَ لِزَامًۭا وَأَجَلٌۭ مُّسَمًّۭى","numberInSurah":129,"juz":16,"manzil":4,"page":321,"ruku":277,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2478,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2478.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2478.mp3"],"text":"فَٱصْبِرْ عَلَىٰ مَا يَقُولُونَ وَسَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوعِ ٱلشَّمْسِ وَقَبْلَ غُرُوبِهَا ۖ وَمِنْ ءَانَآئِ ٱلَّيْلِ فَسَبِّحْ وَأَطْرَافَ ٱلنَّهَارِ لَعَلَّكَ تَرْضَىٰ","numberInSurah":130,"juz":16,"manzil":4,"page":321,"ruku":277,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2479,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2479.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2479.mp3"],"text":"وَلَا تَمُدَّنَّ عَيْنَيْكَ إِلَىٰ مَا مَتَّعْنَا بِهِۦٓ أَزْوَٰجًۭا مِّنْهُمْ زَهْرَةَ ٱلْحَيَوٰةِ ٱلدُّنْيَا لِنَفْتِنَهُمْ فِيهِ ۚ وَرِزْقُ رَبِّكَ خَيْرٌۭ وَأَبْقَىٰ","numberInSurah":131,"juz":16,"manzil":4,"page":321,"ruku":277,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2480,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2480.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2480.mp3"],"text":"وَأْمُرْ أَهْلَكَ بِٱلصَّلَوٰةِ وَٱصْطَبِرْ عَلَيْهَا ۖ لَا نَسْـَٔلُكَ رِزْقًۭا ۖ نَّحْنُ نَرْزُقُكَ ۗ وَٱلْعَٰقِبَةُ لِلتَّقْوَىٰ","numberInSurah":132,"juz":16,"manzil":4,"page":321,"ruku":277,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2481,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2481.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2481.mp3"],"text":"وَقَالُوا۟ لَوْلَا يَأْتِينَا بِـَٔايَةٍۢ مِّن رَّبِّهِۦٓ ۚ أَوَلَمْ تَأْتِهِم بَيِّنَةُ مَا فِى ٱلصُّحُفِ ٱلْأُولَىٰ","numberInSurah":133,"juz":16,"manzil":4,"page":321,"ruku":277,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2482,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2482.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2482.mp3"],"text":"وَلَوْ أَنَّآ أَهْلَكْنَٰهُم بِعَذَابٍۢ مِّن قَبْلِهِۦ لَقَالُوا۟ رَبَّنَا لَوْلَآ أَرْسَلْتَ إِلَيْنَا رَسُولًۭا فَنَتَّبِعَ ءَايَٰتِكَ مِن قَبْلِ أَن نَّذِلَّ وَنَخْزَىٰ","numberInSurah":134,"juz":16,"manzil":4,"page":321,"ruku":277,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},{"number":2483,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2483.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2483.mp3"],"text":"قُلْ كُلٌّۭ مُّتَرَبِّصٌۭ فَتَرَبَّصُوا۟ ۖ فَسَتَعْلَمُونَ مَنْ أَصْحَٰبُ ٱلصِّرَٰطِ ٱلسَّوِىِّ وَمَنِ ٱهْتَدَىٰ","numberInSurah":135,"juz":16,"manzil":4,"page":321,"ruku":277,"hizbQuarter":128,"sajda":false,"surah":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}}],"surahs":{"20":{"number":20,"name":"سُورَةُ طه","englishName":"Taa-Haa","englishNameTranslation":"Taa-Haa","revelationType":"Meccan"}},"edition":{}}}