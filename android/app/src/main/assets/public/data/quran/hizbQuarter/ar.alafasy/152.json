ation":"The Ant","revelationType":"Meccan"}},{"number":3194,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3194.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3194.mp3"],"text":"وَإِنِّى مُرْسِلَةٌ إِلَيْهِم بِهَدِيَّةٍۢ فَنَاظِرَةٌۢ بِمَ يَرْجِعُ ٱلْمُرْسَلُونَ","numberInSurah":35,"juz":19,"manzil":5,"page":379,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3195,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3195.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3195.mp3"],"text":"فَلَمَّا جَآءَ سُلَيْمَٰنَ قَالَ أَتُمِدُّونَنِ بِمَالٍۢ فَمَآ ءَاتَىٰنِۦَ ٱللَّهُ خَيْرٌۭ مِّمَّآ ءَاتَىٰكُم بَلْ أَنتُم بِهَدِيَّتِكُمْ تَفْرَحُونَ","numberInSurah":36,"juz":19,"manzil":5,"page":380,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3196,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3196.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3196.mp3"],"text":"ٱرْجِعْ إِلَيْهِمْ فَلَنَأْتِيَنَّهُم بِجُنُودٍۢ لَّا قِبَلَ لَهُم بِهَا وَلَنُخْرِجَنَّهُم مِّنْهَآ أَذِلَّةًۭ وَهُمْ صَٰغِرُونَ","numberInSurah":37,"juz":19,"manzil":5,"page":380,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3197,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3197.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3197.mp3"],"text":"قَالَ يَٰٓأَيُّهَا ٱلْمَلَؤُا۟ أَيُّكُمْ يَأْتِينِى بِعَرْشِهَا قَبْلَ أَن يَأْتُونِى مُسْلِمِينَ","numberInSurah":38,"juz":19,"manzil":5,"page":380,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3198,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3198.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3198.mp3"],"text":"قَالَ عِفْرِيتٌۭ مِّنَ ٱلْجِنِّ أَنَا۠ ءَاتِيكَ بِهِۦ قَبْلَ أَن تَقُومَ مِن مَّقَامِكَ ۖ وَإِنِّى عَلَيْهِ لَقَوِىٌّ أَمِينٌۭ","numberInSurah":39,"juz":19,"manzil":5,"page":380,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3199,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3199.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3199.mp3"],"text":"قَالَ ٱلَّذِى عِندَهُۥ عِلْمٌۭ مِّنَ ٱلْكِتَٰبِ أَنَا۠ ءَاتِيكَ بِهِۦ قَبْلَ أَن يَرْتَدَّ إِلَيْكَ طَرْفُكَ ۚ فَلَمَّا رَءَاهُ مُسْتَقِرًّا عِندَهُۥ قَالَ هَٰذَا مِن فَضْلِ رَبِّى لِيَبْلُوَنِىٓ ءَأَشْكُرُ أَمْ أَكْفُرُ ۖ وَمَن شَكَرَ فَإِنَّمَا يَشْكُرُ لِنَفْسِهِۦ ۖ وَمَن كَفَرَ فَإِنَّ رَبِّى غَنِىٌّۭ كَرِيمٌۭ","numberInSurah":40,"juz":19,"manzil":5,"page":380,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3200,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3200.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3200.mp3"],"text":"قَالَ نَكِّرُوا۟ لَهَا عَرْشَهَا نَنظُرْ أَتَهْتَدِىٓ أَمْ تَكُونُ مِنَ ٱلَّذِينَ لَا يَهْتَدُونَ","numberInSurah":41,"juz":19,"manzil":5,"page":380,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3201,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3201.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3201.mp3"],"text":"فَلَمَّا جَآءَتْ قِيلَ أَهَٰكَذَا عَرْشُكِ ۖ قَالَتْ كَأَنَّهُۥ هُوَ ۚ وَأُوتِينَا ٱلْعِلْمَ مِن قَبْلِهَا وَكُنَّا مُسْلِمِينَ","numberInSurah":42,"juz":19,"manzil":5,"page":380,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3202,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3202.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3202.mp3"],"text":"وَصَدَّهَا مَا كَانَت تَّعْبُدُ مِن دُونِ ٱللَّهِ ۖ إِنَّهَا كَانَتْ مِن قَوْمٍۢ كَٰفِرِينَ","numberInSurah":43,"juz":19,"manzil":5,"page":380,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3203,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3203.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3203.mp3"],"text":"قِيلَ لَهَا ٱدْخُلِى ٱلصَّرْحَ ۖ فَلَمَّا رَأَتْهُ حَسِبَتْهُ لُجَّةًۭ وَكَشَفَتْ عَن سَاقَيْهَا ۚ قَالَ إِنَّهُۥ صَرْحٌۭ مُّمَرَّدٌۭ مِّن قَوَارِيرَ ۗ قَالَتْ رَبِّ إِنِّى ظَلَمْتُ نَفْسِى وَأَسْلَمْتُ مَعَ سُلَيْمَٰنَ لِلَّهِ رَبِّ ٱلْعَٰلَمِينَ","numberInSurah":44,"juz":19,"manzil":5,"page":380,"ruku":329,"hizbQuarter":152,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3204,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3204.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3204.mp3"],"text":"وَلَقَدْ أَرْسَلْنَآ إِلَىٰ ثَمُودَ أَخَاهُمْ صَٰلِحًا أَنِ ٱعْبُدُوا۟ ٱللَّهَ فَإِذَا هُمْ فَرِيقَانِ يَخْتَصِمُونَ","numberInSurah":45,"juz":19,"manzil":5,"page":381,"ruku":330,"hizbQuarter":152