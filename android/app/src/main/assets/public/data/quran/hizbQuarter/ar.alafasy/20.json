{"code":200,"status":"OK","data":{"number":20,"ayahs":[{"number":290,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/290.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/290.mp3"],"text":"۞ وَإِن كُنتُمْ عَلَىٰ سَفَرٍۢ وَلَمْ تَجِدُوا۟ كَاتِبًۭا فَرِهَٰنٌۭ مَّقْبُوضَةٌۭ ۖ فَإِنْ أَمِنَ بَعْضُكُم بَعْضًۭا فَلْيُؤَدِّ ٱلَّذِى ٱؤْتُمِنَ أَمَٰنَتَهُۥ وَلْيَتَّقِ ٱللَّهَ رَبَّهُۥ ۗ وَلَا تَكْتُمُوا۟ ٱلشَّهَٰدَةَ ۚ وَمَن يَكْتُمْهَا فَإِنَّهُۥٓ ءَاثِمٌۭ قَلْبُهُۥ ۗ وَٱللَّهُ بِمَا تَعْمَلُونَ عَلِيمٌۭ","numberInSurah":283,"juz":3,"manzil":1,"page":49,"ruku":40,"hizbQuarter":20,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":291,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/291.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/291.mp3"],"text":"لِّلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۗ وَإِن تُبْدُوا۟ مَا فِىٓ أَنفُسِكُمْ أَوْ تُخْفُوهُ يُحَاسِبْكُم بِهِ ٱللَّهُ ۖ فَيَغْفِرُ لِمَن يَشَآءُ وَيُعَذِّبُ مَن يَشَآءُ ۗ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","numberInSurah":284,"juz":3,"manzil":1,"page":49,"ruku":41,"hizbQuarter":20,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":292,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/292.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/292.mp3"],"text":"ءَامَنَ ٱلرَّسُولُ بِمَآ أُنزِلَ إِلَيْهِ مِن رَّبِّهِۦ وَٱلْمُؤْمِنُونَ ۚ كُلٌّ ءَامَنَ بِٱللَّهِ وَمَلَٰٓئِكَتِهِۦ وَكُتُبِهِۦ وَرُسُلِهِۦ لَا نُفَرِّقُ بَيْنَ أَحَدٍۢ مِّن رُّسُلِهِۦ ۚ وَقَالُوا۟ سَمِعْنَا وَأَطَعْنَا ۖ غُفْرَانَكَ رَبَّنَا وَإِلَيْكَ ٱلْمَصِيرُ","numberInSurah":285,"juz":3,"manzil":1,"page":49,"ruku":41,"hizbQuarter":20,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":293,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/293.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/293.mp3"],"text":"لَا يُكَلِّفُ ٱللَّهُ نَفْسًا إِلَّا وُسْعَهَا ۚ لَهَا مَا كَسَبَتْ وَعَلَيْهَا مَا ٱكْتَسَبَتْ ۗ رَبَّنَا لَا تُؤَاخِذْنَآ إِن نَّسِينَآ أَوْ أَخْطَأْنَا ۚ رَبَّنَا وَلَا تَحْمِلْ عَلَيْنَآ إِصْرًۭا كَمَا حَمَلْتَهُۥ عَلَى ٱلَّذِينَ مِن قَبْلِنَا ۚ رَبَّنَا وَلَا تُحَمِّلْنَا مَا لَا طَاقَةَ لَنَا بِهِۦ ۖ وَٱعْفُ عَنَّا وَٱغْفِرْ لَنَا وَٱرْحَمْنَآ ۚ أَنتَ مَوْلَىٰنَا فَٱنصُرْنَا عَلَى ٱلْقَوْمِ ٱلْكَٰفِرِينَ","numberInSurah":286,"juz":3,"manzil":1,"page":49,"ruku":41,"hizbQuarter":20,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":294,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/294.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/294.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓمٓ","numberInSurah":1,"juz":3,"manzil":1,"page":50,"ruku":42,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":295,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/295.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/295.mp3"],"text":"ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْحَىُّ ٱلْقَيُّومُ","numberInSurah":2,"juz":3,"manzil":1,"page":50,"ruku":42,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":296,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/296.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/296.mp3"],"text":"نَزَّلَ عَلَيْكَ ٱلْكِتَٰبَ بِٱلْحَقِّ مُصَدِّقًۭا لِّمَا بَيْنَ يَدَيْهِ وَأَنزَلَ ٱلتَّوْرَىٰةَ وَٱلْإِنجِيلَ","numberInSurah":3,"juz":3,"manzil":1,"page":50,"ruku":42,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":297,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/297.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/297.mp3"],"text":"مِن قَبْلُ هُدًۭى لِّلنَّاسِ وَأَنزَلَ ٱلْفُرْقَانَ ۗ إِنَّ ٱلَّذِينَ كَفَرُوا۟ بِـَٔايَٰتِ ٱللَّهِ لَهُمْ عَذَابٌۭ شَدِيدٌۭ ۗ وَٱللَّهُ عَزِيزٌۭ ذُو ٱنتِقَامٍ","numberInSurah":4,"juz":3,"manzil":1,"page":50,"ruku":42,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":298,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/298.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/298.mp3"],"text":"إِنَّ ٱللَّهَ لَا يَخْفَىٰ عَلَيْهِ شَىْءٌۭ فِى ٱلْأَرْضِ وَلَا فِى ٱلسَّمَآءِ","numberInSurah":5,"juz":3,"manzil":1,"page":50,"ruku":42,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":299,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/299.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/299.mp3"],"text":"هُوَ ٱلَّذِى يُصَوِّرُكُمْ فِى ٱلْأَرْحَامِ كَيْفَ يَشَآءُ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":6,"juz":3,"manzil":1,"page":50,"ruku":42,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":300,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/300.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/300.mp3"],"text":"هُوَ ٱلَّذِىٓ أَنزَلَ عَلَيْكَ ٱلْكِتَٰبَ مِنْهُ ءَايَٰتٌۭ مُّحْكَمَٰتٌ هُنَّ أُمُّ ٱلْكِتَٰبِ وَأُخَرُ مُتَشَٰبِهَٰتٌۭ ۖ فَأَمَّا ٱلَّذِينَ فِى قُلُوبِهِمْ زَيْغٌۭ فَيَتَّبِعُونَ مَا تَشَٰبَهَ مِنْهُ ٱبْتِغَآءَ ٱلْفِتْنَةِ وَٱبْتِغَآءَ تَأْوِيلِهِۦ ۗ وَمَا يَعْلَمُ تَأْوِيلَهُۥٓ إِلَّا ٱللَّهُ ۗ وَٱلرَّٰسِخُونَ فِى ٱلْعِلْمِ يَقُولُونَ ءَامَنَّا بِهِۦ كُلٌّۭ مِّنْ عِندِ رَبِّنَا ۗ وَمَا يَذَّكَّرُ إِلَّآ أُو۟لُوا۟ ٱلْأَلْبَٰبِ","numberInSurah":7,"juz":3,"manzil":1,"page":50,"ruku":42,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":301,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/301.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/301.mp3"],"text":"رَبَّنَا لَا تُزِغْ قُلُوبَنَا بَعْدَ إِذْ هَدَيْتَنَا وَهَبْ لَنَا مِن لَّدُنكَ رَحْمَةً ۚ إِنَّكَ أَنتَ ٱلْوَهَّابُ","numberInSurah":8,"juz":3,"manzil":1,"page":50,"ruku":42,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":302,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/302.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/302.mp3"],"text":"رَبَّنَآ إِنَّكَ جَامِعُ ٱلنَّاسِ لِيَوْمٍۢ لَّا رَيْبَ فِيهِ ۚ إِنَّ ٱللَّهَ لَا يُخْلِفُ ٱلْمِيعَادَ","numberInSurah":9,"juz":3,"manzil":1,"page":50,"ruku":42,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":303,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/303.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/303.mp3"],"text":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ لَن تُغْنِىَ عَنْهُمْ أَمْوَٰلُهُمْ وَلَآ أَوْلَٰدُهُم مِّنَ ٱللَّهِ شَيْـًۭٔا ۖ وَأُو۟لَٰٓئِكَ هُمْ وَقُودُ ٱلنَّارِ","numberInSurah":10,"juz":3,"manzil":1,"page":51,"ruku":43,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":304,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/304.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/304.mp3"],"text":"كَدَأْبِ ءَالِ فِرْعَوْنَ وَٱلَّذِينَ مِن قَبْلِهِمْ ۚ كَذَّبُوا۟ بِـَٔايَٰتِنَا فَأَخَذَهُمُ ٱللَّهُ بِذُنُوبِهِمْ ۗ وَٱللَّهُ شَدِيدُ ٱلْعِقَابِ","numberInSurah":11,"juz":3,"manzil":1,"page":51,"ruku":43,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":305,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/305.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/305.mp3"],"text":"قُل لِّلَّذِينَ كَفَرُوا۟ سَتُغْلَبُونَ وَتُحْشَرُونَ إِلَىٰ جَهَنَّمَ ۚ وَبِئْسَ ٱلْمِهَادُ","numberInSurah":12,"juz":3,"manzil":1,"page":51,"ruku":43,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":306,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/306.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/306.mp3"],"text":"قَدْ كَانَ لَكُمْ ءَايَةٌۭ فِى فِئَتَيْنِ ٱلْتَقَتَا ۖ فِئَةٌۭ تُقَٰتِلُ فِى سَبِيلِ ٱللَّهِ وَأُخْرَىٰ كَافِرَةٌۭ يَرَوْنَهُم مِّثْلَيْهِمْ رَأْىَ ٱلْعَيْنِ ۚ وَٱللَّهُ يُؤَيِّدُ بِنَصْرِهِۦ مَن يَشَآءُ ۗ إِنَّ فِى ذَٰلِكَ لَعِبْرَةًۭ لِّأُو۟لِى ٱلْأَبْصَٰرِ","numberInSurah":13,"juz":3,"manzil":1,"page":51,"ruku":43,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":307,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/307.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/307.mp3"],"text":"زُيِّنَ لِلنَّاسِ حُبُّ ٱلشَّهَوَٰتِ مِنَ ٱلنِّسَآءِ وَٱلْبَنِينَ وَٱلْقَنَٰطِيرِ ٱلْمُقَنطَرَةِ مِنَ ٱلذَّهَبِ وَٱلْفِضَّةِ وَٱلْخَيْلِ ٱلْمُسَوَّمَةِ وَٱلْأَنْعَٰمِ وَٱلْحَرْثِ ۗ ذَٰلِكَ مَتَٰعُ ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَٱللَّهُ عِندَهُۥ حُسْنُ ٱلْمَـَٔابِ","numberInSurah":14,"juz":3,"manzil":1,"page":51,"ruku":43,"hizbQuarter":20,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}}],"surahs":{"2":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"},"3":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},"edition":{}}}