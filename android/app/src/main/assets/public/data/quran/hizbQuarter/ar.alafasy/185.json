anslation":"The Groups","revelationType":"Meccan"}},{"number":4108,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4108.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4108.mp3"],"text":"قَدْ قَالَهَا ٱلَّذِينَ مِن قَبْلِهِمْ فَمَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يَكْسِبُونَ","numberInSurah":50,"juz":24,"manzil":6,"page":464,"ruku":400,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4109,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4109.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4109.mp3"],"text":"فَأَصَابَهُمْ سَيِّـَٔاتُ مَا كَسَبُوا۟ ۚ وَٱلَّذِينَ ظَلَمُوا۟ مِنْ هَٰٓؤُلَآءِ سَيُصِيبُهُمْ سَيِّـَٔاتُ مَا كَسَبُوا۟ وَمَا هُم بِمُعْجِزِينَ","numberInSurah":51,"juz":24,"manzil":6,"page":464,"ruku":400,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4110,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4110.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4110.mp3"],"text":"أَوَلَمْ يَعْلَمُوٓا۟ أَنَّ ٱللَّهَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يُؤْمِنُونَ","numberInSurah":52,"juz":24,"manzil":6,"page":464,"ruku":400,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}}],"surahs":{"39":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},"edition":{}}}