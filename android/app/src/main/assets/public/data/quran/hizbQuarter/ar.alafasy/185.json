{"code":200,"status":"OK","data":{"number":185,"ayahs":[{"number":4090,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4090.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4090.mp3"],"text":"۞ فَمَنْ أَظْلَمُ مِمَّن كَذَبَ عَلَى ٱللَّهِ وَكَذَّبَ بِٱلصِّدْقِ إِذْ جَآءَهُۥٓ ۚ أَلَيْسَ فِى جَهَنَّمَ مَثْوًۭى لِّلْكَٰفِرِينَ","numberInSurah":32,"juz":24,"manzil":6,"page":462,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4091,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4091.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4091.mp3"],"text":"وَٱلَّذِى جَآءَ بِٱلصِّدْقِ وَصَدَّقَ بِهِۦٓ ۙ أُو۟لَٰٓئِكَ هُمُ ٱلْمُتَّقُونَ","numberInSurah":33,"juz":24,"manzil":6,"page":462,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4092,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4092.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4092.mp3"],"text":"لَهُم مَّا يَشَآءُونَ عِندَ رَبِّهِمْ ۚ ذَٰلِكَ جَزَآءُ ٱلْمُحْسِنِينَ","numberInSurah":34,"juz":24,"manzil":6,"page":462,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4093,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4093.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4093.mp3"],"text":"لِيُكَفِّرَ ٱللَّهُ عَنْهُمْ أَسْوَأَ ٱلَّذِى عَمِلُوا۟ وَيَجْزِيَهُمْ أَجْرَهُم بِأَحْسَنِ ٱلَّذِى كَانُوا۟ يَعْمَلُونَ","numberInSurah":35,"juz":24,"manzil":6,"page":462,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4094,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4094.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4094.mp3"],"text":"أَلَيْسَ ٱللَّهُ بِكَافٍ عَبْدَهُۥ ۖ وَيُخَوِّفُونَكَ بِٱلَّذِينَ مِن دُونِهِۦ ۚ وَمَن يُضْلِلِ ٱللَّهُ فَمَا لَهُۥ مِنْ هَادٍۢ","numberInSurah":36,"juz":24,"manzil":6,"page":462,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4095,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4095.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4095.mp3"],"text":"وَمَن يَهْدِ ٱللَّهُ فَمَا لَهُۥ مِن مُّضِلٍّ ۗ أَلَيْسَ ٱللَّهُ بِعَزِيزٍۢ ذِى ٱنتِقَامٍۢ","numberInSurah":37,"juz":24,"manzil":6,"page":462,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4096,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4096.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4096.mp3"],"text":"وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ لَيَقُولُنَّ ٱللَّهُ ۚ قُلْ أَفَرَءَيْتُم مَّا تَدْعُونَ مِن دُونِ ٱللَّهِ إِنْ أَرَادَنِىَ ٱللَّهُ بِضُرٍّ هَلْ هُنَّ كَٰشِفَٰتُ ضُرِّهِۦٓ أَوْ أَرَادَنِى بِرَحْمَةٍ هَلْ هُنَّ مُمْسِكَٰتُ رَحْمَتِهِۦ ۚ قُلْ حَسْبِىَ ٱللَّهُ ۖ عَلَيْهِ يَتَوَكَّلُ ٱلْمُتَوَكِّلُونَ","numberInSurah":38,"juz":24,"manzil":6,"page":462,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4097,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4097.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4097.mp3"],"text":"قُلْ يَٰقَوْمِ ٱعْمَلُوا۟ عَلَىٰ مَكَانَتِكُمْ إِنِّى عَٰمِلٌۭ ۖ فَسَوْفَ تَعْلَمُونَ","numberInSurah":39,"juz":24,"manzil":6,"page":462,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4098,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4098.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4098.mp3"],"text":"مَن يَأْتِيهِ عَذَابٌۭ يُخْزِيهِ وَيَحِلُّ عَلَيْهِ عَذَابٌۭ مُّقِيمٌ","numberInSurah":40,"juz":24,"manzil":6,"page":462,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4099,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4099.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4099.mp3"],"text":"إِنَّآ أَنزَلْنَا عَلَيْكَ ٱلْكِتَٰبَ لِلنَّاسِ بِٱلْحَقِّ ۖ فَمَنِ ٱهْتَدَىٰ فَلِنَفْسِهِۦ ۖ وَمَن ضَلَّ فَإِنَّمَا يَضِلُّ عَلَيْهَا ۖ وَمَآ أَنتَ عَلَيْهِم بِوَكِيلٍ","numberInSurah":41,"juz":24,"manzil":6,"page":463,"ruku":399,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4100,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4100.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4100.mp3"],"text":"ٱللَّهُ يَتَوَفَّى ٱلْأَنفُسَ حِينَ مَوْتِهَا وَٱلَّتِى لَمْ تَمُتْ فِى مَنَامِهَا ۖ فَيُمْسِكُ ٱلَّتِى قَضَىٰ عَلَيْهَا ٱلْمَوْتَ وَيُرْسِلُ ٱلْأُخْرَىٰٓ إِلَىٰٓ أَجَلٍۢ مُّسَمًّى ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يَتَفَكَّرُونَ","numberInSurah":42,"juz":24,"manzil":6,"page":463,"ruku":400,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4101,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4101.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4101.mp3"],"text":"أَمِ ٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ شُفَعَآءَ ۚ قُلْ أَوَلَوْ كَانُوا۟ لَا يَمْلِكُونَ شَيْـًۭٔا وَلَا يَعْقِلُونَ","numberInSurah":43,"juz":24,"manzil":6,"page":463,"ruku":400,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4102,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4102.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4102.mp3"],"text":"قُل لِّلَّهِ ٱلشَّفَٰعَةُ جَمِيعًۭا ۖ لَّهُۥ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۖ ثُمَّ إِلَيْهِ تُرْجَعُونَ","numberInSurah":44,"juz":24,"manzil":6,"page":463,"ruku":400,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4103,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4103.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4103.mp3"],"text":"وَإِذَا ذُكِرَ ٱللَّهُ وَحْدَهُ ٱشْمَأَزَّتْ قُلُوبُ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ ۖ وَإِذَا ذُكِرَ ٱلَّذِينَ مِن دُونِهِۦٓ إِذَا هُمْ يَسْتَبْشِرُونَ","numberInSurah":45,"juz":24,"manzil":6,"page":463,"ruku":400,"hizbQuarter":185,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4104,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4104.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4104.mp3"],"text":"قُلِ ٱللَّهُمَّ فَاطِرَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ عَٰلِمَ ٱلْغَي