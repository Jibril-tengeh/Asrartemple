{"code":200,"status":"OK","data":{"number":158,"ayahs":[{"number":3328,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3328.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3328.mp3"],"text":"۞ إِنَّ قَٰرُونَ كَانَ مِن قَوْمِ مُوسَىٰ فَبَغَىٰ عَلَيْهِمْ ۖ وَءَاتَيْنَٰهُ مِنَ ٱلْكُنُوزِ مَآ إِنَّ مَفَاتِحَهُۥ لَتَنُوٓأُ بِٱلْعُصْبَةِ أُو۟لِى ٱلْقُوَّةِ إِذْ قَالَ لَهُۥ قَوْمُهُۥ لَا تَفْرَحْ ۖ إِنَّ ٱللَّهَ لَا يُحِبُّ ٱلْفَرِحِينَ","numberInSurah":76,"juz":20,"manzil":5,"page":394,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3329,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3329.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3329.mp3"],"text":"وَٱبْتَغِ فِيمَآ ءَاتَىٰكَ ٱللَّهُ ٱلدَّارَ ٱلْءَاخِرَةَ ۖ وَلَا تَنسَ نَصِيبَكَ مِنَ ٱلدُّنْيَا ۖ وَأَحْسِن كَمَآ أَحْسَنَ ٱللَّهُ إِلَيْكَ ۖ وَلَا تَبْغِ ٱلْفَسَادَ فِى ٱلْأَرْضِ ۖ إِنَّ ٱللَّهَ لَا يُحِبُّ ٱلْمُفْسِدِينَ","numberInSurah":77,"juz":20,"manzil":5,"page":394,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3330,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3330.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3330.mp3"],"text":"قَالَ إِنَّمَآ أُوتِيتُهُۥ عَلَىٰ عِلْمٍ عِندِىٓ ۚ أَوَلَمْ يَعْلَمْ أَنَّ ٱللَّهَ قَدْ أَهْلَكَ مِن قَبْلِهِۦ مِنَ ٱلْقُرُونِ مَنْ هُوَ أَشَدُّ مِنْهُ قُوَّةًۭ وَأَكْثَرُ جَمْعًۭا ۚ وَلَا يُسْـَٔلُ عَن ذُنُوبِهِمُ ٱلْمُجْرِمُونَ","numberInSurah":78,"juz":20,"manzil":5,"page":395,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3331,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3331.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3331.mp3"],"text":"فَخَرَجَ عَلَىٰ قَوْمِهِۦ فِى زِينَتِهِۦ ۖ قَالَ ٱلَّذِينَ يُرِيدُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا يَٰلَيْتَ لَنَا مِثْلَ مَآ أُوتِىَ قَٰرُونُ إِنَّهُۥ لَذُو حَظٍّ عَظِيمٍۢ","numberInSurah":79,"juz":20,"manzil":5,"page":395,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3332,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3332.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3332.mp3"],"text":"وَقَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ وَيْلَكُمْ ثَوَابُ ٱللَّهِ خَيْرٌۭ لِّمَنْ ءَامَنَ وَعَمِلَ صَٰلِحًۭا وَلَا يُلَقَّىٰهَآ إِلَّا ٱلصَّٰبِرُونَ","numberInSurah":80,"juz":20,"manzil":5,"page":395,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3333,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3333.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3333.mp3"],"text":"فَخَسَفْنَا بِهِۦ وَبِدَارِهِ ٱلْأَرْضَ فَمَا كَانَ لَهُۥ مِن فِئَةٍۢ يَنصُرُونَهُۥ مِن دُونِ ٱللَّهِ وَمَا كَانَ مِنَ ٱلْمُنتَصِرِينَ","numberInSurah":81,"juz":20,"manzil":5,"page":395,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3334,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3334.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3334.mp3"],"text":"وَأَصْبَحَ ٱلَّذِينَ تَمَنَّوْا۟ مَكَانَهُۥ بِٱلْأَمْسِ يَقُولُونَ وَيْكَأَنَّ ٱللَّهَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ مِنْ عِبَادِهِۦ وَيَقْدِرُ ۖ لَوْلَآ أَن مَّنَّ ٱللَّهُ عَلَيْنَا لَخَسَفَ بِنَا ۖ وَيْكَأَنَّهُۥ لَا يُفْلِحُ ٱلْكَٰفِرُونَ","numberInSurah":82,"juz":20,"manzil":5,"page":395,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3335,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3335.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3335.mp3"],"text":"تِلْكَ ٱلدَّارُ ٱلْءَاخِرَةُ نَجْعَلُهَا لِلَّذِينَ لَا يُرِيدُونَ عُلُوًّۭا فِى ٱلْأَرْضِ وَلَا فَسَادًۭا ۚ وَٱلْعَٰقِبَةُ لِلْمُتَّقِينَ","numberInSurah":83,"juz":20,"manzil":5,"page":395,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3336,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3336.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3336.mp3"],"text":"مَن جَآءَ بِٱلْحَسَنَةِ فَلَهُۥ خَيْرٌۭ مِّنْهَا ۖ وَمَن جَآءَ بِٱلسَّيِّئَةِ فَلَا يُجْزَى ٱلَّذِينَ عَمِلُوا۟ ٱلسَّيِّـَٔاتِ إِلَّا مَا كَانُوا۟ يَعْمَلُونَ","numberInSurah":84,"juz":20,"manzil":5,"page":395,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3337,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3337.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3337.mp3"],"text":"إِنَّ ٱلَّذِى فَرَضَ عَلَيْكَ ٱلْقُرْءَانَ لَرَآدُّكَ إِلَىٰ مَعَادٍۢ ۚ قُل رَّبِّىٓ أَعْلَمُ مَن جَآءَ بِٱلْهُدَىٰ وَمَنْ هُوَ فِى ضَلَٰلٍۢ مُّبِينٍۢ","numberInSurah":85,"juz":20,"manzil":5,"page":396,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3338,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3338.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3338.mp3"],"text":"وَمَا كُنتَ تَرْجُوٓا۟ أَن يُلْقَىٰٓ إِلَيْكَ ٱلْكِتَٰبُ إِلَّا رَحْمَةًۭ مِّن رَّبِّكَ ۖ فَلَا تَكُونَنَّ ظَهِيرًۭا لِّلْكَٰفِرِينَ","numberInSurah":86,"juz":20,"manzil":5,"page":396,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3339,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3339.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3339.mp3"],"text":"وَلَا يَصُدُّنَّكَ عَنْ ءَايَٰتِ ٱللَّهِ بَعْدَ إِذْ أُنزِلَتْ إِلَيْكَ ۖ وَٱدْعُ إِلَىٰ رَبِّكَ ۖ وَلَا تَكُونَنَّ مِنَ ٱلْمُشْرِكِينَ","numberInSurah":87,"juz":20,"manzil":5,"page":396,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3340,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3340.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3340.mp3"],"text":"وَلَا تَدْعُ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ ۘ لَآ إِلَٰهَ إِلَّا هُوَ ۚ كُلُّ شَىْءٍ هَالِكٌ إِلَّا وَجْهَهُۥ ۚ لَهُ ٱلْحُكْمُ وَإِلَيْهِ تُرْجَعُونَ","numberInSurah":88,"juz":20,"manzil":5,"page":396,"ruku":341,"hizbQuarter":158,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}}],"surahs":{"28":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},"edition":{}}}