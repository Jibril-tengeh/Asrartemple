{"code":200,"status":"OK","data":{"number":201,"ayahs":[{"number":4511,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4511.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4511.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ حمٓ","numberInSurah":1,"juz":26,"manzil":6,"page":502,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4512,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4512.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4512.mp3"],"text":"تَنزِيلُ ٱلْكِتَٰبِ مِنَ ٱللَّهِ ٱلْعَزِيزِ ٱلْحَكِيمِ","numberInSurah":2,"juz":26,"manzil":6,"page":502,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4513,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4513.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4513.mp3"],"text":"مَا خَلَقْنَا ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَآ إِلَّا بِٱلْحَقِّ وَأَجَلٍۢ مُّسَمًّۭى ۚ وَٱلَّذِينَ كَفَرُوا۟ عَمَّآ أُنذِرُوا۟ مُعْرِضُونَ","numberInSurah":3,"juz":26,"manzil":6,"page":502,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4514,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4514.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4514.mp3"],"text":"قُلْ أَرَءَيْتُم مَّا تَدْعُونَ مِن دُونِ ٱللَّهِ أَرُونِى مَاذَا خَلَقُوا۟ مِنَ ٱلْأَرْضِ أَمْ لَهُمْ شِرْكٌۭ فِى ٱلسَّمَٰوَٰتِ ۖ ٱئْتُونِى بِكِتَٰبٍۢ مِّن قَبْلِ هَٰذَآ أَوْ أَثَٰرَةٍۢ مِّنْ عِلْمٍ إِن كُنتُمْ صَٰدِقِينَ","numberInSurah":4,"juz":26,"manzil":6,"page":502,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4515,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4515.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4515.mp3"],"text":"وَمَنْ أَضَلُّ مِمَّن يَدْعُوا۟ مِن دُونِ ٱللَّهِ مَن لَّا يَسْتَجِيبُ لَهُۥٓ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ وَهُمْ عَن دُعَآئِهِمْ غَٰفِلُونَ","numberInSurah":5,"juz":26,"manzil":6,"page":502,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4516,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4516.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4516.mp3"],"text":"وَإِذَا حُشِرَ ٱلنَّاسُ كَانُوا۟ لَهُمْ أَعْدَآءًۭ وَكَانُوا۟ بِعِبَادَتِهِمْ كَٰفِرِينَ","numberInSurah":6,"juz":26,"manzil":6,"page":503,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4517,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4517.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4517.mp3"],"text":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍۢ قَالَ ٱلَّذِينَ كَفَرُوا۟ لِلْحَقِّ لَمَّا جَآءَهُمْ هَٰذَا سِحْرٌۭ مُّبِينٌ","numberInSurah":7,"juz":26,"manzil":6,"page":503,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4518,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4518.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4518.mp3"],"text":"أَمْ يَقُولُونَ ٱفْتَرَىٰهُ ۖ قُلْ إِنِ ٱفْتَرَيْتُهُۥ فَلَا تَمْلِكُونَ لِى مِنَ ٱللَّهِ شَيْـًٔا ۖ هُوَ أَعْلَمُ بِمَا تُفِيضُونَ فِيهِ ۖ كَفَىٰ بِهِۦ شَهِيدًۢا بَيْنِى وَبَيْنَكُمْ ۖ وَهُوَ ٱلْغَفُورُ ٱلرَّحِيمُ","numberInSurah":8,"juz":26,"manzil":6,"page":503,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4519,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4519.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4519.mp3"],"text":"قُلْ مَا كُنتُ بِدْعًۭا مِّنَ ٱلرُّسُلِ وَمَآ أَدْرِى مَا يُفْعَلُ بِى وَلَا بِكُمْ ۖ إِنْ أَتَّبِعُ إِلَّا مَا يُوحَىٰٓ إِلَىَّ وَمَآ أَنَا۠ إِلَّا نَذِيرٌۭ مُّبِينٌۭ","numberInSurah":9,"juz":26,"manzil":6,"page":503,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4520,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4520.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4520.mp3"],"text":"قُلْ أَرَءَيْتُمْ إِن كَانَ مِنْ عِندِ ٱللَّهِ وَكَفَرْتُم بِهِۦ وَشَهِدَ شَاهِدٌۭ مِّنۢ بَنِىٓ إِسْرَٰٓءِيلَ عَلَىٰ مِثْلِهِۦ فَـَٔامَنَ وَٱسْتَكْبَرْتُمْ ۖ إِنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّٰلِمِينَ","numberInSurah":10,"juz":26,"manzil":6,"page":503,"ruku":438,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4521,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4521.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4521.mp3"],"text":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لِلَّذِينَ ءَامَنُوا۟ لَوْ كَانَ خَيْرًۭا مَّا سَبَقُونَآ إِلَيْهِ ۚ وَإِذْ لَمْ يَهْتَدُوا۟ بِهِۦ فَسَيَقُولُونَ هَٰذَآ إِفْكٌۭ قَدِيمٌۭ","numberInSurah":11,"juz":26,"manzil":6,"page":503,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4522,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4522.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4522.mp3"],"text":"وَمِن قَبْلِهِۦ كِتَٰبُ مُوسَىٰٓ إِمَامًۭا وَرَحْمَةًۭ ۚ وَهَٰذَا كِتَٰبٌۭ مُّصَدِّقٌۭ لِّسَانًا عَرَبِيًّۭا لِّيُنذِرَ ٱلَّذِينَ ظَلَمُوا۟ وَبُشْرَىٰ لِلْمُحْسِنِينَ","numberInSurah":12,"juz":26,"manzil":6,"page":503,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4523,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4523.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4523.mp3"],"text":"إِنَّ ٱلَّذِينَ قَالُوا۟ رَبُّنَا ٱللَّهُ ثُمَّ ٱسْتَقَٰمُوا۟ فَلَا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ","numberInSurah":13,"juz":26,"manzil":6,"page":503,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4524,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4524.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4524.mp3"],"text":"أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَنَّةِ خَٰلِدِينَ فِيهَا جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ","numberInSurah":14,"juz":26,"manzil":6,"page":503,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4525,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4525.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4525.mp3"],"text":"وَوَصَّيْنَا ٱلْإِنسَٰنَ بِوَٰلِدَيْهِ إِحْسَٰنًا ۖ حَمَلَتْهُ أُمُّهُۥ كُرْهًۭا وَوَضَعَتْهُ كُرْهًۭا ۖ وَحَمْلُهُۥ وَفِصَٰلُهُۥ ثَلَٰثُونَ شَهْرًا ۚ حَتَّىٰٓ إِذَا بَلَغَ أَشُدَّهُۥ وَبَلَغَ أَرْبَعِينَ سَنَةًۭ قَالَ رَبِّ أَوْزِعْنِىٓ أَنْ أَشْكُرَ نِعْمَتَكَ ٱلَّتِىٓ أَنْعَمْتَ عَلَىَّ وَعَلَىٰ وَٰلِدَىَّ وَأَنْ أَعْمَلَ صَٰلِحًۭا تَرْضَىٰهُ وَأَصْلِحْ لِى فِى ذُرِّيَّتِىٓ ۖ إِنِّى تُبْتُ إِلَيْكَ وَإِنِّى مِنَ ٱلْمُسْلِمِينَ","numberInSurah":15,"juz":26,"manzil":6,"page":504,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4526,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4526.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4526.mp3"],"text":"أُو۟لَٰٓئِكَ ٱلَّذِينَ نَتَقَبَّلُ عَنْهُمْ أَحْسَنَ مَا عَمِلُوا۟ وَنَتَجَاوَزُ عَن سَيِّـَٔاتِهِمْ فِىٓ أَصْحَٰبِ ٱلْجَنَّةِ ۖ وَعْدَ ٱلصِّدْقِ ٱلَّذِى كَانُوا۟ يُوعَدُونَ","numberInSurah":16,"juz":26,"manzil":6,"page":504,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4527,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4527.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4527.mp3"],"text":"وَٱلَّذِى قَالَ لِوَٰلِدَيْهِ أُفٍّۢ لَّكُمَآ أَتَعِدَانِنِىٓ أَنْ أُخْرَجَ وَقَدْ خَلَتِ ٱلْقُرُونُ مِن قَبْلِى وَهُمَا يَسْتَغِيثَانِ ٱللَّهَ وَيْلَكَ ءَامِنْ إِنَّ وَعْدَ ٱللَّهِ حَقٌّۭ فَيَقُولُ مَا هَٰذَآ إِلَّآ أَسَٰطِيرُ ٱلْأَوَّلِينَ","numberInSurah":17,"juz":26,"manzil":6,"page":504,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4528,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4528.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4528.mp3"],"text":"أُو۟لَٰٓئِكَ ٱلَّذِينَ حَقَّ عَلَيْهِمُ ٱلْقَوْلُ فِىٓ أُمَمٍۢ قَدْ خَلَتْ مِن قَبْلِهِم مِّنَ ٱلْجِنِّ وَٱلْإِنسِ ۖ إِنَّهُمْ كَانُوا۟ خَٰسِرِينَ","numberInSurah":18,"juz":26,"manzil":6,"page":504,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4529,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4529.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4529.mp3"],"text":"وَلِكُلٍّۢ دَرَجَٰتٌۭ مِّمَّا عَمِلُوا۟ ۖ وَلِيُوَفِّيَهُمْ أَعْمَٰلَهُمْ وَهُمْ لَا يُظْلَمُونَ","numberInSurah":19,"juz":26,"manzil":6,"page":504,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},{"number":4530,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4530.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4530.mp3"],"text":"وَيَوْمَ يُعْرَضُ ٱلَّذِينَ كَفَرُوا۟ عَلَى ٱلنَّارِ أَذْهَبْتُمْ طَيِّبَٰتِكُمْ فِى حَيَاتِكُمُ ٱلدُّنْيَا وَٱسْتَمْتَعْتُم بِهَا فَٱلْيَوْمَ تُجْزَوْنَ عَذَابَ ٱلْهُونِ بِمَا كُنتُمْ تَسْتَكْبِرُونَ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ وَبِمَا كُنتُمْ تَفْسُقُونَ","numberInSurah":20,"juz":26,"manzil":6,"page":504,"ruku":439,"hizbQuarter":201,"sajda":false,"surah":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}}],"surahs":{"46":{"number":46,"name":"سُورَةُ الأَحۡقَافِ","englishName":"Al-Ahqaf","englishNameTranslation":"The Dunes","revelationType":"Meccan"}},"edition":{}}}