{"code":200,"status":"OK","data":{"number":172,"ayahs":[{"number":3616,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3616.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3616.mp3"],"text":"۞ وَلَقَدْ ءَاتَيْنَا دَاوُۥدَ مِنَّا فَضْلًۭا ۖ يَٰجِبَالُ أَوِّبِى مَعَهُۥ وَٱلطَّيْرَ ۖ وَأَلَنَّا لَهُ ٱلْحَدِيدَ","numberInSurah":10,"juz":22,"manzil":5,"page":429,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3617,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3617.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3617.mp3"],"text":"أَنِ ٱعْمَلْ سَٰبِغَٰتٍۢ وَقَدِّرْ فِى ٱلسَّرْدِ ۖ وَٱعْمَلُوا۟ صَٰلِحًا ۖ إِنِّى بِمَا تَعْمَلُونَ بَصِيرٌۭ","numberInSurah":11,"juz":22,"manzil":5,"page":429,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3618,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3618.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3618.mp3"],"text":"وَلِسُلَيْمَٰنَ ٱلرِّيحَ غُدُوُّهَا شَهْرٌۭ وَرَوَاحُهَا شَهْرٌۭ ۖ وَأَسَلْنَا لَهُۥ عَيْنَ ٱلْقِطْرِ ۖ وَمِنَ ٱلْجِنِّ مَن يَعْمَلُ بَيْنَ يَدَيْهِ بِإِذْنِ رَبِّهِۦ ۖ وَمَن يَزِغْ مِنْهُمْ عَنْ أَمْرِنَا نُذِقْهُ مِنْ عَذَابِ ٱلسَّعِيرِ","numberInSurah":12,"juz":22,"manzil":5,"page":429,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3619,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3619.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3619.mp3"],"text":"يَعْمَلُونَ لَهُۥ مَا يَشَآءُ مِن مَّحَٰرِيبَ وَتَمَٰثِيلَ وَجِفَانٍۢ كَٱلْجَوَابِ وَقُدُورٍۢ رَّاسِيَٰتٍ ۚ ٱعْمَلُوٓا۟ ءَالَ دَاوُۥدَ شُكْرًۭا ۚ وَقَلِيلٌۭ مِّنْ عِبَادِىَ ٱلشَّكُورُ","numberInSurah":13,"juz":22,"manzil":5,"page":429,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3620,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3620.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3620.mp3"],"text":"فَلَمَّا قَضَيْنَا عَلَيْهِ ٱلْمَوْتَ مَا دَلَّهُمْ عَلَىٰ مَوْتِهِۦٓ إِلَّا دَآبَّةُ ٱلْأَرْضِ تَأْكُلُ مِنسَأَتَهُۥ ۖ فَلَمَّا خَرَّ تَبَيَّنَتِ ٱلْجِنُّ أَن لَّوْ كَانُوا۟ يَعْلَمُونَ ٱلْغَيْبَ مَا لَبِثُوا۟ فِى ٱلْعَذَابِ ٱلْمُهِينِ","numberInSurah":14,"juz":22,"manzil":5,"page":429,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3621,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3621.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3621.mp3"],"text":"لَقَدْ كَانَ لِسَبَإٍۢ فِى مَسْكَنِهِمْ ءَايَةٌۭ ۖ جَنَّتَانِ عَن يَمِينٍۢ وَشِمَالٍۢ ۖ كُلُوا۟ مِن رِّزْقِ رَبِّكُمْ وَٱشْكُرُوا۟ لَهُۥ ۚ بَلْدَةٌۭ طَيِّبَةٌۭ وَرَبٌّ غَفُورٌۭ","numberInSurah":15,"juz":22,"manzil":5,"page":430,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3622,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3622.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3622.mp3"],"text":"فَأَعْرَضُوا۟ فَأَرْسَلْنَا عَلَيْهِمْ سَيْلَ ٱلْعَرِمِ وَبَدَّلْنَٰهُم بِجَنَّتَيْهِمْ جَنَّتَيْنِ ذَوَاتَىْ أُكُلٍ خَمْطٍۢ وَأَثْلٍۢ وَشَىْءٍۢ مِّن سِدْرٍۢ قَلِيلٍۢ","numberInSurah":16,"juz":22,"manzil":5,"page":430,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3623,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3623.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3623.mp3"],"text":"ذَٰلِكَ جَزَيْنَٰهُم بِمَا كَفَرُوا۟ ۖ وَهَلْ نُجَٰزِىٓ إِلَّا ٱلْكَفُورَ","numberInSurah":17,"juz":22,"manzil":5,"page":430,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3624,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3624.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3624.mp3"],"text":"وَجَعَلْنَا بَيْنَهُمْ وَبَيْنَ ٱلْقُرَى ٱلَّتِى بَٰرَكْنَا فِيهَا قُرًۭى ظَٰهِرَةًۭ وَقَدَّرْنَا فِيهَا ٱلسَّيْرَ ۖ سِيرُوا۟ فِيهَا لَيَالِىَ وَأَيَّامًا ءَامِنِينَ","numberInSurah":18,"juz":22,"manzil":5,"page":430,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3625,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3625.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3625.mp3"],"text":"فَقَالُوا۟ رَبَّنَا بَٰعِدْ بَيْنَ أَسْفَارِنَا وَظَلَمُوٓا۟ أَنفُسَهُمْ فَجَعَلْنَٰهُمْ أَحَادِيثَ وَمَزَّقْنَٰهُمْ كُلَّ مُمَزَّقٍ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّكُلِّ صَبَّارٍۢ شَكُورٍۢ","numberInSurah":19,"juz":22,"manzil":5,"page":430,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3626,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3626.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3626.mp3"],"text":"وَلَقَدْ صَدَّقَ عَلَيْهِمْ إِبْلِيسُ ظَنَّهُۥ فَٱتَّبَعُوهُ إِلَّا فَرِيقًۭا مِّنَ ٱلْمُؤْمِنِينَ","numberInSurah":20,"juz":22,"manzil":5,"page":430,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3627,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3627.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3627.mp3"],"text":"وَمَا كَانَ لَهُۥ عَلَيْهِم مِّن سُلْطَٰنٍ إِلَّا لِنَعْلَمَ مَن يُؤْمِنُ بِٱلْءَاخِرَةِ مِمَّنْ هُوَ مِنْهَا فِى شَكٍّۢ ۗ وَرَبُّكَ عَلَىٰ كُلِّ شَىْءٍ حَفِيظٌۭ","numberInSurah":21,"juz":22,"manzil":5,"page":430,"ruku":371,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3628,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3628.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3628.mp3"],"text":"قُلِ ٱدْعُوا۟ ٱلَّذِينَ زَعَمْتُم مِّن دُونِ ٱللَّهِ ۖ لَا يَمْلِكُونَ مِثْقَالَ ذَرَّةٍۢ فِى ٱلسَّمَٰوَٰتِ وَلَا فِى ٱلْأَرْضِ وَمَا لَهُمْ فِيهِمَا مِن شِرْكٍۢ وَمَا لَهُۥ مِنْهُم مِّن ظَهِيرٍۢ","numberInSurah":22,"juz":22,"manzil":5,"page":430,"ruku":372,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3629,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3629.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3629.mp3"],"text":"وَلَا تَنفَعُ ٱلشَّفَٰعَةُ عِندَهُۥٓ إِلَّا لِمَنْ أَذِنَ لَهُۥ ۚ حَتَّىٰٓ إِذَا فُزِّعَ عَن قُلُوبِهِمْ قَالُوا۟ مَاذَا قَالَ رَبُّكُمْ ۖ قَالُوا۟ ٱلْحَقَّ ۖ وَهُوَ ٱلْعَلِىُّ ٱلْكَبِيرُ","numberInSurah":23,"juz":22,"manzil":5,"page":431,"ruku":372,"hizbQuarter":172,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}}],"surahs":{"34":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},"edition":{}}}