{"code":200,"status":"OK","data":{"number":142,"ayahs":[{"number":2826,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2826.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2826.mp3"],"text":"۞ ٱللَّهُ نُورُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ مَثَلُ نُورِهِۦ كَمِشْكَوٰةٍۢ فِيهَا مِصْبَاحٌ ۖ ٱلْمِصْبَاحُ فِى زُجَاجَةٍ ۖ ٱلزُّجَاجَةُ كَأَنَّهَا كَوْكَبٌۭ دُرِّىٌّۭ يُوقَدُ مِن شَجَرَةٍۢ مُّبَٰرَكَةٍۢ زَيْتُونَةٍۢ لَّا شَرْقِيَّةٍۢ وَلَا غَرْبِيَّةٍۢ يَكَادُ زَيْتُهَا يُضِىٓءُ وَلَوْ لَمْ تَمْسَسْهُ نَارٌۭ ۚ نُّورٌ عَلَىٰ نُورٍۢ ۗ يَهْدِى ٱللَّهُ لِنُورِهِۦ مَن يَشَآءُ ۚ وَيَضْرِبُ ٱللَّهُ ٱلْأَمْثَٰلَ لِلنَّاسِ ۗ وَٱللَّهُ بِكُلِّ شَىْءٍ عَلِيمٌۭ","numberInSurah":35,"juz":18,"manzil":4,"page":354,"ruku":305,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2827,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2827.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2827.mp3"],"text":"فِى بُيُوتٍ أَذِنَ ٱللَّهُ أَن تُرْفَعَ وَيُذْكَرَ فِيهَا ٱسْمُهُۥ يُسَبِّحُ لَهُۥ فِيهَا بِٱلْغُدُوِّ وَٱلْءَاصَالِ","numberInSurah":36,"juz":18,"manzil":4,"page":354,"ruku":305,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2828,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2828.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2828.mp3"],"text":"رِجَالٌۭ لَّا تُلْهِيهِمْ تِجَٰرَةٌۭ وَلَا بَيْعٌ عَن ذِكْرِ ٱللَّهِ وَإِقَامِ ٱلصَّلَوٰةِ وَإِيتَآءِ ٱلزَّكَوٰةِ ۙ يَخَافُونَ يَوْمًۭا تَتَقَلَّبُ فِيهِ ٱلْقُلُوبُ وَٱلْأَبْصَٰرُ","numberInSurah":37,"juz":18,"manzil":4,"page":355,"ruku":305,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2829,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2829.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2829.mp3"],"text":"لِيَجْزِيَهُمُ ٱللَّهُ أَحْسَنَ مَا عَمِلُوا۟ وَيَزِيدَهُم مِّن فَضْلِهِۦ ۗ وَٱللَّهُ يَرْزُقُ مَن يَشَآءُ بِغَيْرِ حِسَابٍۢ","numberInSurah":38,"juz":18,"manzil":4,"page":355,"ruku":305,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2830,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2830.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2830.mp3"],"text":"وَٱلَّذِينَ كَفَرُوٓا۟ أَعْمَٰلُهُمْ كَسَرَابٍۭ بِقِيعَةٍۢ يَحْسَبُهُ ٱلظَّمْـَٔانُ مَآءً حَتَّىٰٓ إِذَا جَآءَهُۥ لَمْ يَجِدْهُ شَيْـًۭٔا وَوَجَدَ ٱللَّهَ عِندَهُۥ فَوَفَّىٰهُ حِسَابَهُۥ ۗ وَٱللَّهُ سَرِيعُ ٱلْحِسَابِ","numberInSurah":39,"juz":18,"manzil":4,"page":355,"ruku":305,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2831,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2831.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2831.mp3"],"text":"أَوْ كَظُلُمَٰتٍۢ فِى بَحْرٍۢ لُّجِّىٍّۢ يَغْشَىٰهُ مَوْجٌۭ مِّن فَوْقِهِۦ مَوْجٌۭ مِّن فَوْقِهِۦ سَحَابٌۭ ۚ ظُلُمَٰتٌۢ بَعْضُهَا فَوْقَ بَعْضٍ إِذَآ أَخْرَجَ يَدَهُۥ لَمْ يَكَدْ يَرَىٰهَا ۗ وَمَن لَّمْ يَجْعَلِ ٱللَّهُ لَهُۥ نُورًۭا فَمَا لَهُۥ مِن نُّورٍ","numberInSurah":40,"juz":18,"manzil":4,"page":355,"ruku":305,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2832,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2832.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2832.mp3"],"text":"أَلَمْ تَرَ أَنَّ ٱللَّهَ يُسَبِّحُ لَهُۥ مَن فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَٱلطَّيْرُ صَٰٓفَّٰتٍۢ ۖ كُلٌّۭ قَدْ عَلِمَ صَلَاتَهُۥ وَتَسْبِيحَهُۥ ۗ وَٱللَّهُ عَلِيمٌۢ بِمَا يَفْعَلُونَ","numberInSurah":41,"juz":18,"manzil":4,"page":355,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2833,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2833.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2833.mp3"],"text":"وَلِلَّهِ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۖ وَإِلَى ٱللَّهِ ٱلْمَصِيرُ","numberInSurah":42,"juz":18,"manzil":4,"page":355,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2834,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2834.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2834.mp3"],"text":"أَلَمْ تَرَ أَنَّ ٱللَّهَ يُزْجِى سَحَابًۭا ثُمَّ يُؤَلِّفُ بَيْنَهُۥ ثُمَّ يَجْعَلُهُۥ رُكَامًۭا فَتَرَى ٱلْوَدْقَ يَخْرُجُ مِنْ خِلَٰلِهِۦ وَيُنَزِّلُ مِنَ ٱلسَّمَآءِ مِن جِبَالٍۢ فِيهَا مِنۢ بَرَدٍۢ فَيُصِيبُ بِهِۦ مَن يَشَآءُ وَيَصْرِفُهُۥ عَن مَّن يَشَآءُ ۖ يَكَادُ سَنَا بَرْقِهِۦ يَذْهَبُ بِٱلْأَبْصَٰرِ","numberInSurah":43,"juz":18,"manzil":4,"page":355,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2835,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2835.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2835.mp3"],"text":"يُقَلِّبُ ٱللَّهُ ٱلَّيْلَ وَٱلنَّهَارَ ۚ إِنَّ فِى ذَٰلِكَ لَعِبْرَةًۭ لِّأُو۟لِى ٱلْأَبْصَٰرِ","numberInSurah":44,"juz":18,"manzil":4,"page":356,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2836,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2836.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2836.mp3"],"text":"وَٱللَّهُ خَلَقَ كُلَّ دَآبَّةٍۢ مِّن مَّآءٍۢ ۖ فَمِنْهُم مَّن يَمْشِى عَلَىٰ بَطْنِهِۦ وَمِنْهُم مَّن يَمْشِى عَلَىٰ رِجْلَيْنِ وَمِنْهُم مَّن يَمْشِى عَلَىٰٓ أَرْبَعٍۢ ۚ يَخْلُقُ ٱللَّهُ مَا يَشَآءُ ۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","numberInSurah":45,"juz":18,"manzil":4,"page":356,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2837,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2837.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2837.mp3"],"text":"لَّقَدْ أَنزَلْنَآ ءَايَٰتٍۢ مُّبَيِّنَٰتٍۢ ۚ وَٱللَّهُ يَهْدِى مَن يَشَآءُ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","numberInSurah":46,"juz":18,"manzil":4,"page":356,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2838,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2838.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2838.mp3"],"text":"وَيَقُولُونَ ءَامَنَّا بِٱللَّهِ وَبِٱلرَّسُولِ وَأَطَعْنَا ثُمَّ يَتَوَلَّىٰ فَرِيقٌۭ مِّنْهُم مِّنۢ بَعْدِ ذَٰلِكَ ۚ وَمَآ أُو۟لَٰٓئِكَ بِٱلْمُؤْمِنِينَ","numberInSurah":47,"juz":18,"manzil":4,"page":356,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2839,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2839.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2839.mp3"],"text":"وَإِذَا دُعُوٓا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِيَحْكُمَ بَيْنَهُمْ إِذَا فَرِيقٌۭ مِّنْهُم مُّعْرِضُونَ","numberInSurah":48,"juz":18,"manzil":4,"page":356,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2840,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2840.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2840.mp3"],"text":"وَإِن يَكُن لَّهُمُ ٱلْحَقُّ يَأْتُوٓا۟ إِلَيْهِ مُذْعِنِينَ","numberInSurah":49,"juz":18,"manzil":4,"page":356,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2841,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2841.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2841.mp3"],"text":"أَفِى قُلُوبِهِم مَّرَضٌ أَمِ ٱرْتَابُوٓا۟ أَمْ يَخَافُونَ أَن يَحِيفَ ٱللَّهُ عَلَيْهِمْ وَرَسُولُهُۥ ۚ بَلْ أُو۟لَٰٓئِكَ هُمُ ٱلظَّٰلِمُونَ","numberInSurah":50,"juz":18,"manzil":4,"page":356,"ruku":306,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2842,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2842.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2842.mp3"],"text":"إِنَّمَا كَانَ قَوْلَ ٱلْمُؤْمِنِينَ إِذَا دُعُوٓا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِيَحْكُمَ بَيْنَهُمْ أَن يَقُولُوا۟ سَمِعْنَا وَأَطَعْنَا ۚ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","numberInSurah":51,"juz":18,"manzil":4,"page":356,"ruku":307,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},{"number":2843,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2843.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2843.mp3"],"text":"وَمَن يُطِعِ ٱللَّهَ وَرَسُولَهُۥ وَيَخْشَ ٱللَّهَ وَيَتَّقْهِ فَأُو۟لَٰٓئِكَ هُمُ ٱلْفَآئِزُونَ","numberInSurah":52,"juz":18,"manzil":4,"page":356,"ruku":307,"hizbQuarter":142,"sajda":false,"surah":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}}],"surahs":{"24":{"number":24,"name":"سُورَةُ النُّورِ","englishName":"An-Noor","englishNameTranslation":"The Light","revelationType":"Medinan"}},"edition":{}}}