glishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":10,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/10.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/10.mp3"],"text":"ٱلَّذِينَ يُؤْمِنُونَ بِٱلْغَيْبِ وَيُقِيمُونَ ٱلصَّلَوٰةَ وَمِمَّا رَزَقْنَٰهُمْ يُنفِقُونَ","numberInSurah":3,"juz":1,"manzil":1,"page":2,"ruku":2,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":11,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/11.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/11.mp3"],"text":"وَٱلَّذِينَ يُؤْمِنُونَ بِمَآ أُنزِلَ إِلَيْكَ وَمَآ أُنزِلَ مِن قَبْلِكَ وَبِٱلْءَاخِرَةِ هُمْ يُوقِنُونَ","numberInSurah":4,"juz":1,"manzil":1,"page":2,"ruku":2,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":12,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/12.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/12.mp3"],"text":"أُو۟لَٰٓئِكَ عَلَىٰ هُدًۭى مِّن رَّبِّهِمْ ۖ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","numberInSurah":5,"juz":1,"manzil":1,"page":2,"ruku":2,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":13,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/13.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/13.mp3"],"text":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ سَوَآءٌ عَلَيْهِمْ ءَأَنذَرْتَهُمْ أَمْ لَمْ تُنذِرْهُمْ لَا يُؤْمِنُونَ","numberInSurah":6,"juz":1,"manzil":1,"page":3,"ruku":2,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":14,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/14.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/14.mp3"],"text":"خَتَمَ ٱللَّهُ عَلَىٰ قُلُوبِهِمْ وَعَلَىٰ سَمْعِهِمْ ۖ وَعَلَىٰٓ أَبْصَٰرِهِمْ غِشَٰوَةٌۭ ۖ وَلَهُمْ عَذَابٌ عَظِيمٌۭ","numberInSurah":7,"juz":1,"manzil":1,"page":3,"ruku":2,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":15,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/15.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/15.mp3"],"text":"وَمِنَ ٱلنَّاسِ مَن يَقُولُ ءَامَنَّا بِٱللَّهِ وَبِٱلْيَوْمِ ٱلْءَاخِرِ وَمَا هُم بِمُؤْمِنِينَ","numberInSurah":8,"juz":1,"manzil":1,"page":3,"ruku":3,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":16,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/16.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/16.mp3"],"text":"يُخَٰدِعُونَ ٱللَّهَ وَٱلَّذِينَ ءَامَنُوا۟ وَمَا يَخْدَعُونَ إِلَّآ أَنفُسَهُمْ وَمَا يَشْعُرُونَ","numberInSurah":9,"juz":1,"manzil":1,"page":3,"ruku":3,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":17,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/17.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/17.mp3"],"text":"فِى قُلُوبِهِم مَّرَضٌۭ فَزَادَهُمُ ٱللَّهُ مَرَضًۭا ۖ وَلَهُمْ عَذَابٌ أَلِيمٌۢ بِمَا كَانُوا۟ يَكْذِبُونَ","numberInSurah":10,"juz":1,"manzil":1,"page":3,"ruku":3,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":18,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/18.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/18.mp3"],"text":"وَإِذَا قِيلَ لَهُمْ لَا تُفْسِدُوا۟ فِى ٱلْأَرْضِ قَالُوٓا۟ إِنَّمَا نَحْنُ مُصْلِحُونَ","numberInSurah":11,"juz":1,"manzil":1,"page":3,"ruku":3,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":19,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/19.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/19.mp3"],"text":"أَلَآ إِنَّهُمْ هُمُ ٱلْمُفْسِدُونَ وَلَٰكِن لَّا يَشْعُرُونَ","numberInSurah":12,"juz":1,"manzil":1,"page":3,"ruku":3,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":20,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/20.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/20.mp3"],"text":"وَإِذَا قِيلَ لَهُمْ ءَامِنُوا۟ كَمَآ ءَامَنَ ٱلنَّاسُ قَالُوٓا۟ أَنُؤْمِنُ كَمَآ ءَامَنَ ٱلسُّفَهَآءُ ۗ أَلَآ إِنَّهُمْ هُمُ ٱلسُّفَهَآءُ وَلَٰكِن لَّا يَعْلَمُونَ","numberInSurah":13,"juz":1,"manzil":1,"page":3,"ruku":3,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":21,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/21.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/21.mp3"],"text":"وَإِذَا لَقُوا۟ ٱلَّذِينَ ءَامَنُوا۟ قَالُوٓا۟ ءَامَنَّا وَإِذَا خَلَوْا۟ إِلَىٰ شَيَٰطِينِهِمْ قَالُوٓا۟ إِنَّا مَعَكُمْ إِنَّمَا نَحْنُ مُسْتَهْزِءُونَ","numberInSurah":14,"juz":1,"manzil":1,"page":3,"ruku":3,"hizbQuarter":1,"sajda":false,"s