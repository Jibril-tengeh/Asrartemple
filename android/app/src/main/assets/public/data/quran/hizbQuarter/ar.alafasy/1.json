er":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":26,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/26.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/26.mp3"],"text":"أَوْ كَصَيِّبٍۢ مِّنَ ٱلسَّمَآءِ فِيهِ ظُلُمَٰتٌۭ وَرَعْدٌۭ وَبَرْقٌۭ يَجْعَلُونَ أَصَٰبِعَهُمْ فِىٓ ءَاذَانِهِم مِّنَ ٱلصَّوَٰعِقِ حَذَرَ ٱلْمَوْتِ ۚ وَٱللَّهُ مُحِيطٌۢ بِٱلْكَٰفِرِينَ","numberInSurah":19,"juz":1,"manzil":1,"page":4,"ruku":3,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":27,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/27.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/27.mp3"],"text":"يَكَادُ ٱلْبَرْقُ يَخْطَفُ أَبْصَٰرَهُمْ ۖ كُلَّمَآ أَضَآءَ لَهُم مَّشَوْا۟ فِيهِ وَإِذَآ أَظْلَمَ عَلَيْهِمْ قَامُوا۟ ۚ وَلَوْ شَآءَ ٱللَّهُ لَذَهَبَ بِسَمْعِهِمْ وَأَبْصَٰرِهِمْ ۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","numberInSurah":20,"juz":1,"manzil":1,"page":4,"ruku":3,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":28,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/28.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/28.mp3"],"text":"يَٰٓأَيُّهَا ٱلنَّاسُ ٱعْبُدُوا۟ رَبَّكُمُ ٱلَّذِى خَلَقَكُمْ وَٱلَّذِينَ مِن قَبْلِكُمْ لَعَلَّكُمْ تَتَّقُونَ","numberInSurah":21,"juz":1,"manzil":1,"page":4,"ruku":4,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":29,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/29.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/29.mp3"],"text":"ٱلَّذِى جَعَلَ لَكُمُ ٱلْأَرْضَ فِرَٰشًۭا وَٱلسَّمَآءَ بِنَآءًۭ وَأَنزَلَ مِنَ ٱلسَّمَآءِ مَآءًۭ فَأَخْرَجَ بِهِۦ مِنَ ٱلثَّمَرَٰتِ رِزْقًۭا لَّكُمْ ۖ فَلَا تَجْعَلُوا۟ لِلَّهِ أَندَادًۭا وَأَنتُمْ تَعْلَمُونَ","numberInSurah":22,"juz":1,"manzil":1,"page":4,"ruku":4,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":30,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/30.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/30.mp3"],"text":"وَإِن كُنتُمْ فِى رَيْبٍۢ مِّمَّا نَزَّلْنَا عَلَىٰ عَبْدِنَا فَأْتُوا۟ بِسُورَةٍۢ مِّن مِّثْلِهِۦ وَٱدْعُوا۟ شُهَدَآءَكُم مِّن دُونِ ٱللَّهِ إِن كُنتُمْ صَٰدِقِينَ","numberInSurah":23,"juz":1,"manzil":1,"page":4,"ruku":4,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":31,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/31.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/31.mp3"],"text":"فَإِن لَّمْ تَفْعَلُوا۟ وَلَن تَفْعَلُوا۟ فَٱتَّقُوا۟ ٱلنَّارَ ٱلَّتِى وَقُودُهَا ٱلنَّاسُ وَٱلْحِجَارَةُ ۖ أُعِدَّتْ لِلْكَٰفِرِينَ","numberInSurah":24,"juz":1,"manzil":1,"page":4,"ruku":4,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":32,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/32.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/32.mp3"],"text":"وَبَشِّرِ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ أَنَّ لَهُمْ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۖ كُلَّمَا رُزِقُوا۟ مِنْهَا مِن ثَمَرَةٍۢ رِّزْقًۭا ۙ قَالُوا۟ هَٰذَا ٱلَّذِى رُزِقْنَا مِن قَبْلُ ۖ وَأُتُوا۟ بِهِۦ مُتَشَٰبِهًۭا ۖ وَلَهُمْ فِيهَآ أَزْوَٰجٌۭ مُّطَهَّرَةٌۭ ۖ وَهُمْ فِيهَا خَٰلِدُونَ","numberInSurah":25,"juz":1,"manzil":1,"page":5,"ruku":4,"hizbQuarter":1,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}}],"surahs":{"1":{"number":1,"name":"سُورَةُ ٱلْفَاتِحَةِ","englishName":"Al-Faatiha","englishNameTranslation":"The Opening","revelationType":"Meccan"},"2":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},"edition":{}}}