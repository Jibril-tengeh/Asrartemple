{"code":200,"status":"OK","data":{"number":207,"ayahs":[{"number":4626,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4626.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4626.mp3"],"text":"۞ قَالَتِ ٱلْأَعْرَابُ ءَامَنَّا ۖ قُل لَّمْ تُؤْمِنُوا۟ وَلَٰكِن قُولُوٓا۟ أَسْلَمْنَا وَلَمَّا يَدْخُلِ ٱلْإِيمَٰنُ فِى قُلُوبِكُمْ ۖ وَإِن تُطِيعُوا۟ ٱللَّهَ وَرَسُولَهُۥ لَا يَلِتْكُم مِّنْ أَعْمَٰلِكُمْ شَيْـًٔا ۚ إِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌ","numberInSurah":14,"juz":26,"manzil":6,"page":517,"ruku":451,"hizbQuarter":207,"sajda":false,"surah":{"number":49,"name":"سُورَةُ الحُجُرَاتِ","englishName":"Al-Hujuraat","englishNameTranslation":"The Inner Apartments","revelationType":"Medinan"}},{"number":4627,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4627.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4627.mp3"],"text":"إِنَّمَا ٱلْمُؤْمِنُونَ ٱلَّذِينَ ءَامَنُوا۟ بِٱللَّهِ وَرَسُولِهِۦ ثُمَّ لَمْ يَرْتَابُوا۟ وَجَٰهَدُوا۟ بِأَمْوَٰلِهِمْ وَأَنفُسِهِمْ فِى سَبِيلِ ٱللَّهِ ۚ أُو۟لَٰٓئِكَ هُمُ ٱلصَّٰدِقُونَ","numberInSurah":15,"juz":26,"manzil":6,"page":517,"ruku":451,"hizbQuarter":207,"sajda":false,"surah":{"number":49,"name":"سُورَةُ الحُجُرَاتِ","englishName":"Al-Hujuraat","englishNameTranslation":"The Inner Apartments","revelationType":"Medinan"}},{"number":4628,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4628.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4628.mp3"],"text":"قُلْ أَتُعَلِّمُونَ ٱللَّهَ بِدِينِكُمْ وَٱللَّهُ يَعْلَمُ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۚ وَٱللَّهُ بِكُلِّ شَىْءٍ عَلِيمٌۭ","numberInSurah":16,"juz":26,"manzil":6,"page":517,"ruku":451,"hizbQuarter":207,"sajda":false,"surah":{"number":49,"name":"سُورَةُ الحُجُرَاتِ","englishName":"Al-Hujuraat","englishNameTranslation":"The Inner Apartments","revelationType":"Medinan"}},{"number":4629,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4629.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4629.mp3"],"text":"يَمُنُّونَ عَلَيْكَ أَنْ أَسْلَمُوا۟ ۖ قُل لَّا تَمُنُّوا۟ عَلَىَّ إِسْلَٰمَكُم ۖ بَلِ ٱللَّهُ يَمُنُّ عَلَيْكُمْ أَنْ هَدَىٰكُمْ لِلْإِيمَٰنِ إِن كُنتُمْ صَٰدِقِينَ","numberInSurah":17,"juz":26,"manzil":6,"page":517,"ruku":451,"hizbQuarter":207,"sajda":false,"surah":{"number":49,"name":"سُورَةُ الحُجُرَاتِ","englishName":"Al-Hujuraat","englishNameTranslation":"The Inner Apartments","revelationType":"Medinan"}},{"number":4630,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4630.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4630.mp3"],"text":"إِنَّ ٱللَّهَ يَعْلَمُ غَيْبَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ بَصِيرٌۢ بِمَا تَعْمَلُونَ","numberInSurah":18,"juz":26,"manzil":6,"page":517,"ruku":451,"hizbQuarter":207,"sajda":false,"surah":{"number":49,"name":"سُورَةُ الحُجُرَاتِ","englishName":"Al-Hujuraat","englishNameTranslation":"The Inner Apartments","revelationType":"Medinan"}},{"number":4631,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4631.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4631.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قٓ ۚ وَٱلْقُرْءَانِ ٱلْمَجِيدِ","numberInSurah":1,"juz":26,"manzil":7,"page":518,"ruku":452,"hizbQuarter":207,"sajda":false,"surah":{"number":50,"name":"سُورَةُ قٓ","englishName":"Qaaf","englishNameTranslation":"The letter Qaaf","revelationType":"Meccan"}},{"number":4632,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4632.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4632.mp3"],"text":"بَلْ عَجِبُوٓا۟ أَن جَآءَهُم مُّنذِرٌۭ مِّنْهُمْ فَقَالَ ٱلْكَٰفِرُونَ هَٰذَا شَىْءٌ عَجِيبٌ","numberInSurah":2,"juz":26,"manzil":7,"page":518,"ruku":452,"hizbQuarter":207,"sajda":false,"surah":{"number":50,"name":"سُورَةُ قٓ","englishName":"Qaaf","englishNameTranslation":"The letter Qaaf","revelationType":"Meccan"}},{"number":4633,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4633.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4633.mp3"],"text":"أَءِذَا مِتْنَا وَكُنَّا تُرَابًۭا ۖ ذَٰلِكَ رَجْعٌۢ بَعِيدٌۭ","numberInSurah":3,"juz":26,"manzil":7,"page":518,"ruku":452,"hizbQuarter":207,"sajda":false,"surah":{"number":50,"name":"سُورَةُ قٓ","englishName":"Qaaf","englishNameTranslation":"The letter Qaaf","revelationType":"Meccan"}},{"number":4634,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4634.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4634.mp3"],"text":"قَدْ عَلِمْنَا مَا تَنقُصُ ٱلْأَرْضُ مِنْهُمْ ۖ وَعِندَنَا كِتَٰبٌ حَفِيظٌۢ","numberInSurah":4,"juz":26,"manzil":7,"page":518,"ruku":452,"hizbQuarter":207,"sajda":false,"surah":{"number":50,"name":"سُورَةُ قٓ","englishName":"Qaaf","englishNameTranslation":"The letter Qaaf","revelationType":"Meccan"}},{"number":4635,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4635.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4635.mp3"],"text":"بَلْ كَذَّبُوا۟ بِٱلْحَقِّ لَمَّا جَآءَهُمْ فَهُمْ فِىٓ أَمْرٍۢ مَّرِيجٍ","numberInSurah":5,"juz":26,"manzil":7,"page":518,"ruku":452,"hizbQuarter":207,"sajda":false,"surah":{"number":50,"name":"سُورَةُ قٓ","englishName":"Qaaf","englishNameTranslation":"The letter Qaaf","revelationType":"Meccan"}},{"number":4636,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4636.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4636.mp3"],"text":"أَفَلَمْ يَنظُرُوٓا۟ إِلَى ٱلسَّمَآءِ فَوْقَهُمْ كَيْفَ بَنَيْنَٰهَا وَزَيَّنَّٰهَا وَمَا لَهَا مِن فُرُوجٍۢ","numberInSurah":6,"juz":26,"manzil":7,"page":518,"ruku":452,"hizbQuarter":207,"sajda":false,"surah":{"number":50,"name":"سُورَةُ قٓ","englishName":"Qaaf","englishNameTranslation":"The letter Qaaf","revelationType":"Meccan"}},{"number":4637,"audio":"http