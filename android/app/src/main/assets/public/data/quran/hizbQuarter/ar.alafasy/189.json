/ar.alafasy/4181.mp3"],"text":"قَالَ ٱلَّذِينَ ٱسْتَكْبَرُوٓا۟ إِنَّا كُلٌّۭ فِيهَآ إِنَّ ٱللَّهَ قَدْ حَكَمَ بَيْنَ ٱلْعِبَادِ","numberInSurah":48,"juz":24,"manzil":6,"page":472,"ruku":408,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4182,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4182.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4182.mp3"],"text":"وَقَالَ ٱلَّذِينَ فِى ٱلنَّارِ لِخَزَنَةِ جَهَنَّمَ ٱدْعُوا۟ رَبَّكُمْ يُخَفِّفْ عَنَّا يَوْمًۭا مِّنَ ٱلْعَذَابِ","numberInSurah":49,"juz":24,"manzil":6,"page":472,"ruku":408,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4183,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4183.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4183.mp3"],"text":"قَالُوٓا۟ أَوَلَمْ تَكُ تَأْتِيكُمْ رُسُلُكُم بِٱلْبَيِّنَٰتِ ۖ قَالُوا۟ بَلَىٰ ۚ قَالُوا۟ فَٱدْعُوا۟ ۗ وَمَا دُعَٰٓؤُا۟ ٱلْكَٰفِرِينَ إِلَّا فِى ضَلَٰلٍ","numberInSurah":50,"juz":24,"manzil":6,"page":473,"ruku":408,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4184,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4184.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4184.mp3"],"text":"إِنَّا لَنَنصُرُ رُسُلَنَا وَٱلَّذِينَ ءَامَنُوا۟ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا وَيَوْمَ يَقُومُ ٱلْأَشْهَٰدُ","numberInSurah":51,"juz":24,"manzil":6,"page":473,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4185,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4185.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4185.mp3"],"text":"يَوْمَ لَا يَنفَعُ ٱلظَّٰلِمِينَ مَعْذِرَتُهُمْ ۖ وَلَهُمُ ٱللَّعْنَةُ وَلَهُمْ سُوٓءُ ٱلدَّارِ","numberInSurah":52,"juz":24,"manzil":6,"page":473,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4186,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4186.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4186.mp3"],"text":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْهُدَىٰ وَأَوْرَثْنَا بَنِىٓ إِسْرَٰٓءِيلَ ٱلْكِتَٰبَ","numberInSurah":53,"juz":24,"manzil":6,"page":473,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4187,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4187.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4187.mp3"],"text":"هُدًۭى وَذِكْرَىٰ لِأُو۟لِى ٱلْأَلْبَٰبِ","numberInSurah":54,"juz":24,"manzil":6,"page":473,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4188,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4188.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4188.mp3"],"text":"فَٱصْبِرْ إِنَّ وَعْدَ ٱللَّهِ حَقٌّۭ وَٱسْتَغْفِرْ لِذَنۢبِكَ وَسَبِّحْ بِحَمْدِ رَبِّكَ بِٱلْعَشِىِّ وَٱلْإِبْكَٰرِ","numberInSurah":55,"juz":24,"manzil":6,"page":473,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4189,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4189.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4189.mp3"],"text":"إِنَّ ٱلَّذِينَ يُجَٰدِلُونَ فِىٓ ءَايَٰتِ ٱللَّهِ بِغَيْرِ سُلْطَٰنٍ أَتَىٰهُمْ ۙ إِن فِى صُدُورِهِمْ إِلَّا كِبْرٌۭ مَّا هُم بِبَٰلِغِيهِ ۚ فَٱسْتَعِذْ بِٱللَّهِ ۖ إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْبَصِيرُ","numberInSurah":56,"juz":24,"manzil":6,"page":473,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4190,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4190.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4190.mp3"],"text":"لَخَلْقُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ أَكْبَرُ مِنْ خَلْقِ ٱلنَّاسِ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","numberInSurah":57,"juz":24,"manzil":6,"page":473,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4191,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4191.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4191.mp3"],"text":"وَمَا يَسْتَوِى ٱلْأَعْمَىٰ وَٱلْبَصِيرُ وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَلَا ٱلْمُسِىٓءُ ۚ قَلِيلًۭا مَّا تَتَذَكَّرُونَ","numberInSurah":58,"juz":24,"manzil":6,"page":473,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4192,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4192.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4192.mp3"],"text":"إِنَّ ٱلسَّاعَةَ لَءَاتِيَةٌۭ لَّا رَيْبَ فِيهَا وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يُؤْمِنُونَ","numberInSurah":59,"juz":24,"manzil":6,"page":474,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4193,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4193.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4193.mp3"],"text":"وَقَالَ رَبُّكُمُ ٱدْعُونِىٓ أَسْتَجِبْ لَكُمْ ۚ إِنَّ ٱلَّذِينَ يَسْتَكْبِرُونَ عَنْ عِبَادَتِى سَيَدْخُلُونَ جَهَنَّمَ دَاخِرِينَ","numberInSurah":60,"juz":24,"manzil":6,"page":474,"ruku":409,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4194,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4194.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4194.mp3"],"text":"ٱللَّهُ ٱلَّذِى جَعَلَ لَكُمُ ٱلَّيْلَ لِتَسْكُنُوا۟ فِيهِ وَٱلنَّهَارَ مُبْصِرًا ۚ إِنَّ ٱللَّهَ لَذُو فَضْلٍ عَلَى ٱلنَّاسِ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَشْكُرُونَ","numberInSurah":61,"juz":24,"manzil":6,"page":474,"ruku":410,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4195,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4195.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4195.mp3"],"text":"ذَٰلِكُمُ ٱللَّهُ رَبُّكُمْ خَٰلِقُ كُلِّ شَىْءٍۢ لَّآ إِلَٰهَ إِلَّا هُوَ ۖ فَأَنَّىٰ تُؤْفَكُونَ","numberInSurah":62,"juz":24,"manzil":6,"page":474,"ruku":410,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4196,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4196.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4196.mp3"],"text":"كَذَٰلِكَ يُؤْفَكُ ٱلَّذِينَ 