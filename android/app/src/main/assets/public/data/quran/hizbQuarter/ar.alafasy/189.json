{"code":200,"status":"OK","data":{"number":189,"ayahs":[{"number":4174,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4174.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4174.mp3"],"text":"۞ وَيَٰقَوْمِ مَا لِىٓ أَدْعُوكُمْ إِلَى ٱلنَّجَوٰةِ وَتَدْعُونَنِىٓ إِلَى ٱلنَّارِ","numberInSurah":41,"juz":24,"manzil":6,"page":472,"ruku":408,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4175,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4175.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4175.mp3"],"text":"تَدْعُونَنِى لِأَكْفُرَ بِٱللَّهِ وَأُشْرِكَ بِهِۦ مَا لَيْسَ لِى بِهِۦ عِلْمٌۭ وَأَنَا۠ أَدْعُوكُمْ إِلَى ٱلْعَزِيزِ ٱلْغَفَّٰرِ","numberInSurah":42,"juz":24,"manzil":6,"page":472,"ruku":408,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4176,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4176.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4176.mp3"],"text":"لَا جَرَمَ أَنَّمَا تَدْعُونَنِىٓ إِلَيْهِ لَيْسَ لَهُۥ دَعْوَةٌۭ فِى ٱلدُّنْيَا وَلَا فِى ٱلْءَاخِرَةِ وَأَنَّ مَرَدَّنَآ إِلَى ٱللَّهِ وَأَنَّ ٱلْمُسْرِفِينَ هُمْ أَصْحَٰبُ ٱلنَّارِ","numberInSurah":43,"juz":24,"manzil":6,"page":472,"ruku":408,"hizbQuarter":189,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4177,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4177.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4177.mp3"],"text":"فَسَتَذْكُرُونَ مَآ أَقُولُ لَكُمْ ۚ وَأُفَوِّضُ أَمْرِىٓ إِلَى ٱللَّهِ ۚ إِنَّ ٱللَّهَ بَصِيرٌۢ بِٱلْعِبَادِ","numberInSurah":