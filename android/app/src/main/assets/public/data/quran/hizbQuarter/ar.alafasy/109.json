{"code":200,"status":"OK","data":{"number":109,"ayahs":[{"number":1952,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1952.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1952.mp3"],"text":"۞ وَقَالَ ٱللَّهُ لَا تَتَّخِذُوٓا۟ إِلَٰهَيْنِ ٱثْنَيْنِ ۖ إِنَّمَا هُوَ إِلَٰهٌۭ وَٰحِدٌۭ ۖ فَإِيَّٰىَ فَٱرْهَبُونِ","numberInSurah":51,"juz":14,"manzil":3,"page":272,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1953,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1953.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1953.mp3"],"text":"وَلَهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَلَهُ ٱلدِّينُ وَاصِبًا ۚ أَفَغَيْرَ ٱللَّهِ تَتَّقُونَ","numberInSurah":52,"juz":14,"manzil":3,"page":272,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1954,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1954.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1954.mp3"],"text":"وَمَا بِكُم مِّن نِّعْمَةٍۢ فَمِنَ ٱللَّهِ ۖ ثُمَّ إِذَا مَسَّكُمُ ٱلضُّرُّ فَإِلَيْهِ تَجْـَٔرُونَ","numberInSurah":53,"juz":14,"manzil":3,"page":272,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1955,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1955.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1955.mp3"],"text":"ثُمَّ إِذَا كَشَفَ ٱلضُّرَّ عَنكُمْ إِذَا فَرِيقٌۭ مِّنكُم بِرَبِّهِمْ يُشْرِكُونَ","numberInSurah":54,"juz":14,"manzil":3,"page":272,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1956,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1956.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1956.mp3"],"text":"لِيَكْفُرُوا۟ بِمَآ ءَاتَيْنَٰهُمْ ۚ فَتَمَتَّعُوا۟ ۖ فَسَوْفَ تَعْلَمُونَ","numberInSurah":55,"juz":14,"manzil":3,"page":273,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1957,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1957.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1957.mp3"],"text":"وَيَجْعَلُونَ لِمَا لَا يَعْلَمُونَ نَصِيبًۭا مِّمَّا رَزَقْنَٰهُمْ ۗ تَٱللَّهِ لَتُسْـَٔلُنَّ عَمَّا كُنتُمْ تَفْتَرُونَ","numberInSurah":56,"juz":14,"manzil":3,"page":273,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1958,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1958.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1958.mp3"],"text":"وَيَجْعَلُونَ لِلَّهِ ٱلْبَنَٰتِ سُبْحَٰنَهُۥ ۙ وَلَهُم مَّا يَشْتَهُونَ","numberInSurah":57,"juz":14,"manzil":3,"page":273,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1959,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1959.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1959.mp3"],"text":"وَإِذَا بُشِّرَ أَحَدُهُم بِٱلْأُنثَىٰ ظَلَّ وَجْهُهُۥ مُسْوَدًّۭا وَهُوَ كَظِيمٌۭ","numberInSurah":58,"juz":14,"manzil":3,"page":273,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1960,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1960.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1960.mp3"],"text":"يَتَوَٰرَىٰ مِنَ ٱلْقَوْمِ مِن سُوٓءِ مَا بُشِّرَ بِهِۦٓ ۚ أَيُمْسِكُهُۥ عَلَىٰ هُونٍ أَمْ يَدُسُّهُۥ فِى ٱلتُّرَابِ ۗ أَلَا سَآءَ مَا يَحْكُمُونَ","numberInSurah":59,"juz":14,"manzil":3,"page":273,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1961,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1961.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1961.mp3"],"text":"لِلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ مَثَلُ ٱلسَّوْءِ ۖ وَلِلَّهِ ٱلْمَثَلُ ٱلْأَعْلَىٰ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":60,"juz":14,"manzil":3,"page":273,"ruku":230,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1962,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1962.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1962.mp3"],"text":"وَلَوْ يُؤَاخِذُ ٱللَّهُ ٱلنَّاسَ بِظُلْمِهِم مَّا تَرَكَ عَلَيْهَا مِن دَآبَّةٍۢ وَلَٰكِن يُؤَخِّرُهُمْ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى ۖ فَإِذَا جَآءَ أَجَلُهُمْ لَا يَسْتَـْٔخِرُونَ سَاعَةًۭ ۖ وَلَا يَسْتَقْدِمُونَ","numberInSurah":61,"juz":14,"manzil":3,"page":273,"ruku":231,"hizbQuarter":109,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1963,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1963.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1963.mp3"],"text":"وَيَجْعَلُون