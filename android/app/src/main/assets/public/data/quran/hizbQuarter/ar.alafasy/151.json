{"code":200,"status":"OK","data":{"number":151,"ayahs":[{"number":3160,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3160.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3160.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ طسٓ ۚ تِلْكَ ءَايَٰتُ ٱلْقُرْءَانِ وَكِتَابٍۢ مُّبِينٍ","numberInSurah":1,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3161,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3161.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3161.mp3"],"text":"هُدًۭى وَبُشْرَىٰ لِلْمُؤْمِنِينَ","numberInSurah":2,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3162,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3162.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3162.mp3"],"text":"ٱلَّذِينَ يُقِيمُونَ ٱلصَّلَوٰةَ وَيُؤْتُونَ ٱلزَّكَوٰةَ وَهُم بِٱلْءَاخِرَةِ هُمْ يُوقِنُونَ","numberInSurah":3,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3163,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3163.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3163.mp3"],"text":"إِنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ زَيَّنَّا لَهُمْ أَعْمَٰلَهُمْ فَهُمْ يَعْمَهُونَ","numberInSurah":4,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3164,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3164.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3164.mp3"],"text":"أُو۟لَٰٓئِكَ ٱلَّذِينَ لَهُمْ سُوٓءُ ٱلْعَذَابِ وَهُمْ فِى ٱلْءَاخِرَةِ هُمُ ٱلْأَخْسَرُونَ","numberInSurah":5,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3165,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3165.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3165.mp3"],"text":"وَإِنَّكَ لَتُلَقَّى ٱلْقُرْءَانَ مِن لَّدُنْ حَكِيمٍ عَلِيمٍ","numberInSurah":6,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3166,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3166.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3166.mp3"],"text":"إِذْ قَالَ مُوسَىٰ لِأَهْلِهِۦٓ إِنِّىٓ ءَانَسْتُ نَارًۭا سَـَٔاتِيكُم مِّنْهَا بِخَبَرٍ أَوْ ءَاتِيكُم بِشِهَابٍۢ قَبَسٍۢ لَّعَلَّكُمْ تَصْطَلُونَ","numberInSurah":7,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3167,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3167.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3167.mp3"],"text":"فَلَمَّا جَآءَهَا نُودِىَ أَنۢ بُورِكَ مَن فِى ٱلنَّارِ وَمَنْ حَوْلَهَا وَسُبْحَٰنَ ٱللَّهِ رَبِّ ٱلْعَٰلَمِينَ","numberInSurah":8,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3168,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3168.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3168.mp3"],"text":"يَٰمُوسَىٰٓ إِنَّهُۥٓ أَنَا ٱللَّهُ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":9,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3169,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3169.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3169.mp3"],"text":"وَأَلْقِ عَصَاكَ ۚ فَلَمَّا رَءَاهَا تَهْتَزُّ كَأَنَّهَا جَآنٌّۭ وَلَّىٰ مُدْبِرًۭا وَلَمْ يُعَقِّبْ ۚ يَٰمُوسَىٰ لَا تَخَفْ إِنِّى لَا يَخَافُ لَدَىَّ ٱلْمُرْسَلُونَ","numberInSurah":10,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3170,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3170.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3170.mp3"],"text":"إِلَّا مَن ظَلَمَ ثُمَّ بَدَّلَ حُسْنًۢا بَعْدَ سُوٓءٍۢ فَإِنِّى غَفُورٌۭ رَّحِيمٌۭ","numberInSurah":11,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3171,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3171.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3171.mp3"],"text":"وَأَدْخِلْ يَدَكَ فِى جَيْبِكَ تَخْرُجْ بَيْضَآءَ مِنْ غَيْرِ سُوٓءٍۢ ۖ فِى تِسْعِ ءَايَٰتٍ إِلَىٰ فِرْعَوْنَ وَقَوْمِهِۦٓ ۚ إِنَّهُمْ كَانُوا۟ قَوْمًۭا فَٰسِقِينَ","numberInSurah":12,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3172,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3172.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3172.mp3"],"text":"فَلَمَّا جَآءَتْهُمْ ءَايَٰتُنَا مُبْصِرَةًۭ قَالُوا۟ هَٰذَا سِحْرٌۭ مُّبِينٌۭ","numberInSurah":13,"juz":19,"manzil":5,"page":377,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3173,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3173.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3173.mp3"],"text":"وَجَحَدُوا۟ بِهَا وَٱسْتَيْقَنَتْهَآ أَنفُسُهُمْ ظُلْمًۭا وَعُلُوًّۭا ۚ فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُفْسِدِينَ","numberInSurah":14,"juz":19,"manzil":5,"page":378,"ruku":327,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3174,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3174.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3174.mp3"],"text":"وَلَقَدْ ءَاتَيْنَا دَاوُۥدَ وَسُلَيْمَٰنَ عِلْمًۭا ۖ وَقَالَا ٱلْحَمْدُ لِلَّهِ ٱلَّذِى فَضَّلَنَا عَلَىٰ كَثِيرٍۢ مِّنْ عِبَادِهِ ٱلْمُؤْمِنِينَ","numberInSurah":15,"juz":19,"manzil":5,"page":378,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3175,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3175.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3175.mp3"],"text":"وَوَرِثَ سُلَيْمَٰنُ دَاوُۥدَ ۖ وَقَالَ يَٰٓأَيُّهَا ٱلنَّاسُ عُلِّمْنَا مَنطِقَ ٱلطَّيْرِ وَأُوتِينَا مِن كُلِّ شَىْءٍ ۖ إِنَّ هَٰذَا لَهُوَ ٱلْفَضْلُ ٱلْمُبِينُ","numberInSurah":16,"juz":19,"manzil":5,"page":378,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3176,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3176.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3176.mp3"],"text":"وَحُشِرَ لِسُلَيْمَٰنَ جُنُودُهُۥ مِنَ ٱلْجِنِّ وَٱلْإِنسِ وَٱلطَّيْرِ فَهُمْ يُوزَعُونَ","numberInSurah":17,"juz":19,"manzil":5,"page":378,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3177,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3177.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3177.mp3"],"text":"حَتَّىٰٓ إِذَآ أَتَوْا۟ عَلَىٰ وَادِ ٱلنَّمْلِ قَالَتْ نَمْلَةٌۭ يَٰٓأَيُّهَا ٱلنَّمْلُ ٱدْخُلُوا۟ مَسَٰكِنَكُمْ لَا يَحْطِمَنَّكُمْ سُلَيْمَٰنُ وَجُنُودُهُۥ وَهُمْ لَا يَشْعُرُونَ","numberInSurah":18,"juz":19,"manzil":5,"page":378,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3178,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3178.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3178.mp3"],"text":"فَتَبَسَّمَ ضَاحِكًۭا مِّن قَوْلِهَا وَقَالَ رَبِّ أَوْزِعْنِىٓ أَنْ أَشْكُرَ نِعْمَتَكَ ٱلَّتِىٓ أَنْعَمْتَ عَلَىَّ وَعَلَىٰ وَٰلِدَىَّ وَأَنْ أَعْمَلَ صَٰلِحًۭا تَرْضَىٰهُ وَأَدْخِلْنِى بِرَحْمَتِكَ فِى عِبَادِكَ ٱلصَّٰلِحِينَ","numberInSurah":19,"juz":19,"manzil":5,"page":378,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3179,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3179.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3179.mp3"],"text":"وَتَفَقَّدَ ٱلطَّيْرَ فَقَالَ مَا لِىَ لَآ أَرَى ٱلْهُدْهُدَ أَمْ كَانَ مِنَ ٱلْغَآئِبِينَ","numberInSurah":20,"juz":19,"manzil":5,"page":378,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3180,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3180.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3180.mp3"],"text":"لَأُعَذِّبَنَّهُۥ عَذَابًۭا شَدِيدًا أَوْ لَأَا۟ذْبَحَنَّهُۥٓ أَوْ لَيَأْتِيَنِّى بِسُلْطَٰنٍۢ مُّبِينٍۢ","numberInSurah":21,"juz":19,"manzil":5,"page":378,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3181,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3181.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3181.mp3"],"text":"فَمَكَثَ غَيْرَ بَعِيدٍۢ فَقَالَ أَحَطتُ بِمَا لَمْ تُحِطْ بِهِۦ وَجِئْتُكَ مِن سَبَإٍۭ بِنَبَإٍۢ يَقِينٍ","numberInSurah":22,"juz":19,"manzil":5,"page":378,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3182,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3182.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3182.mp3"],"text":"إِنِّى وَجَدتُّ ٱمْرَأَةًۭ تَمْلِكُهُمْ وَأُوتِيَتْ مِن كُلِّ شَىْءٍۢ وَلَهَا عَرْشٌ عَظِيمٌۭ","numberInSurah":23,"juz":19,"manzil":5,"page":379,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3183,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3183.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3183.mp3"],"text":"وَجَدتُّهَا وَقَوْمَهَا يَسْجُدُونَ لِلشَّمْسِ مِن دُونِ ٱللَّهِ وَزَيَّنَ لَهُمُ ٱلشَّيْطَٰنُ أَعْمَٰلَهُمْ فَصَدَّهُمْ عَنِ ٱلسَّبِيلِ فَهُمْ لَا يَهْتَدُونَ","numberInSurah":24,"juz":19,"manzil":5,"page":379,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3184,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3184.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3184.mp3"],"text":"أَلَّا يَسْجُدُوا۟ لِلَّهِ ٱلَّذِى يُخْرِجُ ٱلْخَبْءَ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَيَعْلَمُ مَا تُخْفُونَ وَمَا تُعْلِنُونَ","numberInSurah":25,"juz":19,"manzil":5,"page":379,"ruku":328,"hizbQuarter":151,"sajda":false,"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},{"number":3185,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3185.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3185.mp3"],"text":"ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ رَبُّ ٱلْعَرْشِ ٱلْعَظِيمِ ۩","numberInSurah":26,"juz":19,"manzil":5,"page":379,"ruku":328,"hizbQuarter":151,"sajda":{"id":9,"recommended":true,"obligatory":false},"surah":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}}],"surahs":{"27":{"number":27,"name":"سُورَةُ النَّمۡلِ","englishName":"An-Naml","englishNameTranslation":"The Ant","revelationType":"Meccan"}},"edition":{}}}