{"code":200,"status":"OK","data":{"number":159,"ayahs":[{"number":3341,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3341.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3341.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓمٓ","numberInSurah":1,"juz":20,"manzil":5,"page":396,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3342,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3342.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3342.mp3"],"text":"أَحَسِبَ ٱلنَّاسُ أَن يُتْرَكُوٓا۟ أَن يَقُولُوٓا۟ ءَامَنَّا وَهُمْ لَا يُفْتَنُونَ","numberInSurah":2,"juz":20,"manzil":5,"page":396,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3343,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3343.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3343.mp3"],"text":"وَلَقَدْ فَتَنَّا ٱلَّذِينَ مِن قَبْلِهِمْ ۖ فَلَيَعْلَمَنَّ ٱللَّهُ ٱلَّذِينَ صَدَقُوا۟ وَلَيَعْلَمَنَّ ٱلْكَٰذِبِينَ","numberInSurah":3,"juz":20,"manzil":5,"page":396,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3344,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3344.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3344.mp3"],"text":"أَمْ حَسِبَ ٱلَّذِينَ يَعْمَلُونَ ٱلسَّيِّـَٔاتِ أَن يَسْبِقُونَا ۚ سَآءَ مَا يَحْكُمُونَ","numberInSurah":4,"juz":20,"manzil":5,"page":396,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3345,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3345.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3345.mp3"],"text":"مَن كَانَ يَرْجُوا۟ لِقَآءَ ٱللَّهِ فَإِنَّ أَجَلَ ٱللَّهِ لَءَاتٍۢ ۚ وَهُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","numberInSurah":5,"juz":20,"manzil":5,"page":396,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3346,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3346.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3346.mp3"],"text":"وَمَن جَٰهَدَ فَإِنَّمَا يُجَٰهِدُ لِنَفْسِهِۦٓ ۚ إِنَّ ٱللَّهَ لَغَنِىٌّ عَنِ ٱلْعَٰلَمِينَ","numberInSurah":6,"juz":20,"manzil":5,"page":396,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3347,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3347.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3347.mp3"],"text":"وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَنُكَفِّرَنَّ عَنْهُمْ سَيِّـَٔاتِهِمْ وَلَنَجْزِيَنَّهُمْ أَحْسَنَ ٱلَّذِى كَانُوا۟ يَعْمَلُونَ","numberInSurah":7,"juz":20,"manzil":5,"page":397,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3348,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3348.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3348.mp3"],"text":"وَوَصَّيْنَا ٱلْإِنسَٰنَ بِوَٰلِدَيْهِ حُسْنًۭا ۖ وَإِن جَٰهَدَاكَ لِتُشْرِكَ بِى مَا لَيْسَ لَكَ بِهِۦ عِلْمٌۭ فَلَا تُطِعْهُمَآ ۚ إِلَىَّ مَرْجِعُكُمْ فَأُنَبِّئُكُم بِمَا كُنتُمْ تَعْمَلُونَ","numberInSurah":8,"juz":20,"manzil":5,"page":397,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3349,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3349.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3349.mp3"],"text":"وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَنُدْخِلَنَّهُمْ فِى ٱلصَّٰلِحِينَ","numberInSurah":9,"juz":20,"manzil":5,"page":397,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3350,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3350.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3350.mp3"],"text":"وَمِنَ ٱلنَّاسِ مَن يَقُولُ ءَامَنَّا بِٱللَّهِ فَإِذَآ أُوذِىَ فِى ٱللَّهِ جَعَلَ فِتْنَةَ ٱلنَّاسِ كَعَذَابِ ٱللَّهِ وَلَئِن جَآءَ نَصْرٌۭ مِّن رَّبِّكَ لَيَقُولُنَّ إِنَّا كُنَّا مَعَكُمْ ۚ أَوَلَيْسَ ٱللَّهُ بِأَعْلَمَ بِمَا فِى صُدُورِ ٱلْعَٰلَمِينَ","numberInSurah":10,"juz":20,"manzil":5,"page":397,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3351,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3351.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3351.mp3"],"text":"وَلَيَعْلَمَنَّ ٱللَّهُ ٱلَّذِينَ ءَامَنُوا۟ وَلَيَعْلَمَنَّ ٱلْمُنَٰفِقِينَ","numberInSurah":11,"juz":20,"manzil":5,"page":397,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3352,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3352.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3352.mp3"],"text":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لِلَّذِينَ ءَامَنُوا۟ ٱتَّبِعُوا۟ سَبِيلَنَا وَلْنَحْمِلْ خَطَٰيَٰكُمْ وَمَا هُم بِحَٰمِلِينَ مِنْ خَطَٰيَٰهُم مِّن شَىْءٍ ۖ إِنَّهُمْ لَكَٰذِبُونَ","numberInSurah":12,"juz":20,"manzil":5,"page":397,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3353,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3353.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3353.mp3"],"text":"وَلَيَحْمِلُنَّ أَثْقَالَهُمْ وَأَثْقَالًۭا مَّعَ أَثْقَالِهِمْ ۖ وَلَيُسْـَٔلُنَّ يَوْمَ ٱلْقِيَٰمَةِ عَمَّا كَانُوا۟ يَفْتَرُونَ","numberInSurah":13,"juz":20,"manzil":5,"page":397,"ruku":342,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3354,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3354.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3354.mp3"],"text":"وَلَقَدْ أَرْسَلْنَا نُوحًا إِلَىٰ قَوْمِهِۦ فَلَبِثَ فِيهِمْ أَلْفَ سَنَةٍ إِلَّا خَمْسِينَ عَامًۭا فَأَخَذَهُمُ ٱلطُّوفَانُ وَهُمْ ظَٰلِمُونَ","numberInSurah":14,"juz":20,"manzil":5,"page":397,"ruku":343,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3355,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3355.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3355.mp3"],"text":"فَأَنجَيْنَٰهُ وَأَصْحَٰبَ ٱلسَّفِينَةِ وَجَعَلْنَٰهَآ ءَايَةًۭ لِّلْعَٰلَمِينَ","numberInSurah":15,"juz":20,"manzil":5,"page":398,"ruku":343,"hizb