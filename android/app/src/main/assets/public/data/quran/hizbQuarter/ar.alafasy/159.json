audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3359.mp3"],"text":"أَوَلَمْ يَرَوْا۟ كَيْفَ يُبْدِئُ ٱللَّهُ ٱلْخَلْقَ ثُمَّ يُعِيدُهُۥٓ ۚ إِنَّ ذَٰلِكَ عَلَى ٱللَّهِ يَسِيرٌۭ","numberInSurah":19,"juz":20,"manzil":5,"page":398,"ruku":343,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3360,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3360.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3360.mp3"],"text":"قُلْ سِيرُوا۟ فِى ٱلْأَرْضِ فَٱنظُرُوا۟ كَيْفَ بَدَأَ ٱلْخَلْقَ ۚ ثُمَّ ٱللَّهُ يُنشِئُ ٱلنَّشْأَةَ ٱلْءَاخِرَةَ ۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","numberInSurah":20,"juz":20,"manzil":5,"page":398,"ruku":343,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3361,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3361.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3361.mp3"],"text":"يُعَذِّبُ مَن يَشَآءُ وَيَرْحَمُ مَن يَشَآءُ ۖ وَإِلَيْهِ تُقْلَبُونَ","numberInSurah":21,"juz":20,"manzil":5,"page":398,"ruku":343,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3362,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3362.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3362.mp3"],"text":"وَمَآ أَنتُم بِمُعْجِزِينَ فِى ٱلْأَرْضِ وَلَا فِى ٱلسَّمَآءِ ۖ وَمَا لَكُم مِّن دُونِ ٱللَّهِ مِن وَلِىٍّۢ وَلَا نَصِيرٍۢ","numberInSurah":22,"juz":20,"manzil":5,"page":398,"ruku":343,"hizbQuarter":159,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNam