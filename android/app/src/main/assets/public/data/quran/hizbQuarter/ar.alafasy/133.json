{"code":200,"status":"OK","data":{"number":133,"ayahs":[{"number":2596,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2596.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2596.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ ۚ إِنَّ زَلْزَلَةَ ٱلسَّاعَةِ شَىْءٌ عَظِيمٌۭ","numberInSurah":1,"juz":17,"manzil":4,"page":332,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2597,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2597.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2597.mp3"],"text":"يَوْمَ تَرَوْنَهَا تَذْهَلُ كُلُّ مُرْضِعَةٍ عَمَّآ أَرْضَعَتْ وَتَضَعُ كُلُّ ذَاتِ حَمْلٍ حَمْلَهَا وَتَرَى ٱلنَّاسَ سُكَٰرَىٰ وَمَا هُم بِسُكَٰرَىٰ وَلَٰكِنَّ عَذَابَ ٱللَّهِ شَدِيدٌۭ","numberInSurah":2,"juz":17,"manzil":4,"page":332,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2598,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2598.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2598.mp3"],"text":"وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍۢ وَيَتَّبِعُ كُلَّ شَيْطَٰنٍۢ مَّرِيدٍۢ","numberInSurah":3,"juz":17,"manzil":4,"page":332,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2599,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2599.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2599.mp3"],"text":"كُتِبَ عَلَيْهِ أَنَّهُۥ مَن تَوَلَّاهُ فَأَنَّهُۥ يُضِلُّهُۥ وَيَهْدِيهِ إِلَىٰ عَذَابِ ٱلسَّعِيرِ","numberInSurah":4,"juz":17,"manzil":4,"page":332,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2600,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2600.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2600.mp3"],"text":"يَٰٓأَيُّهَا ٱلنَّاسُ إِن كُنتُمْ فِى رَيْبٍۢ مِّنَ ٱلْبَعْثِ فَإِنَّا خَلَقْنَٰكُم مِّن تُرَابٍۢ ثُمَّ مِن نُّطْفَةٍۢ ثُمَّ مِنْ عَلَقَةٍۢ ثُمَّ مِن مُّضْغَةٍۢ مُّخَلَّقَةٍۢ وَغَيْرِ مُخَلَّقَةٍۢ لِّنُبَيِّنَ لَكُمْ ۚ وَنُقِرُّ فِى ٱلْأَرْحَامِ مَا نَشَآءُ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى ثُمَّ نُخْرِجُكُمْ طِفْلًۭا ثُمَّ لِتَبْلُغُوٓا۟ أَشُدَّكُمْ ۖ وَمِنكُم مَّن يُتَوَفَّىٰ وَمِنكُم مَّن يُرَدُّ إِلَىٰٓ أَرْذَلِ ٱلْعُمُرِ لِكَيْلَا يَعْلَمَ مِنۢ بَعْدِ عِلْمٍۢ شَيْـًۭٔا ۚ وَتَرَى ٱلْأَرْضَ هَامِدَةًۭ فَإِذَآ أَنزَلْنَا عَلَيْهَا ٱلْمَآءَ ٱهْتَزَّتْ وَرَبَتْ وَأَنۢبَتَتْ مِن كُلِّ زَوْجٍۭ بَهِيجٍۢ","numberInSurah":5,"juz":17,"manzil":4,"page":332,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2601,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2601.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2601.mp3"],"text":"ذَٰلِكَ بِأَنَّ ٱللَّهَ هُوَ ٱلْحَقُّ وَأَنَّهُۥ يُحْىِ ٱلْمَوْتَىٰ وَأَنَّهُۥ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","numberInSurah":6,"juz":17,"manzil":4,"page":333,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2602,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2602.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2602.mp3"],"text":"وَأَنَّ ٱلسَّاعَةَ ءَاتِيَةٌۭ لَّا رَيْبَ فِيهَا وَأَنَّ ٱللَّهَ يَبْعَثُ مَن فِى ٱلْقُبُورِ","numberInSurah":7,"juz":17,"manzil":4,"page":333,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2603,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2603.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2603.mp3"],"text":"وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍۢ وَلَا هُدًۭى وَلَا كِتَٰبٍۢ مُّنِيرٍۢ","numberInSurah":8,"juz":17,"manzil":4,"page":333,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2604,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2604.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2604.mp3"],"text":"ثَانِىَ عِطْفِهِۦ لِيُضِلَّ عَن سَبِيلِ ٱللَّهِ ۖ لَهُۥ فِى ٱلدُّنْيَا خِزْىٌۭ ۖ وَنُذِيقُهُۥ يَوْمَ ٱلْقِيَٰمَةِ عَذَابَ ٱلْحَرِيقِ","numberInSurah":9,"juz":17,"manzil":4,"page":333,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2605,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2605.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2605.mp3"],"text":"ذَٰلِكَ بِمَا قَدَّمَتْ يَدَاكَ وَأَنَّ ٱللَّهَ لَيْسَ بِظَلَّٰمٍۢ لِّلْعَبِيدِ","numberInSurah":10,"juz":17,"manzil":4,"page":333,"ruku":285,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2606,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2606.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2606.mp3"],"text":"وَمِنَ ٱلنَّاسِ مَن يَعْبُدُ ٱللَّهَ عَلَىٰ حَرْفٍۢ ۖ فَإِنْ أَصَابَهُۥ خَيْرٌ ٱطْمَأَنَّ بِهِۦ ۖ وَإِنْ أَصَابَتْهُ فِتْنَةٌ ٱنقَلَبَ عَلَىٰ وَجْهِهِۦ خَسِرَ ٱلدُّنْيَا وَٱلْءَاخِرَةَ ۚ ذَٰلِكَ هُوَ ٱلْخُسْرَانُ ٱلْمُبِينُ","numberInSurah":11,"juz":17,"manzil":4,"page":333,"ruku":286,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2607,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2607.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2607.mp3"],"text":"يَدْعُوا۟ مِن دُونِ ٱللَّهِ مَا لَا يَضُرُّهُۥ وَمَا لَا يَنفَعُهُۥ ۚ ذَٰلِكَ هُوَ ٱلضَّلَٰلُ ٱلْبَعِيدُ","numberInSurah":12,"juz":17,"manzil":4,"page":333,"ruku":286,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2608,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2608.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2608.mp3"],"text":"يَدْعُوا۟ لَمَن ضَرُّهُۥٓ أَقْرَبُ مِن نَّفْعِهِۦ ۚ لَبِئْسَ ٱلْمَوْلَىٰ وَلَبِئْسَ ٱلْعَشِيرُ","numberInSurah":13,"juz":17,"manzil":4,"page":333,"ruku":286,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2609,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2609.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2609.mp3"],"text":"إِنَّ ٱللَّهَ يُدْخِلُ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۚ إِنَّ ٱللَّهَ يَفْعَلُ مَا يُرِيدُ","numberInSurah":14,"juz":17,"manzil":4,"page":333,"ruku":286,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2610,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2610.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2610.mp3"],"text":"مَن كَانَ يَظُنُّ أَن لَّن يَنصُرَهُ ٱللَّهُ فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ فَلْيَمْدُدْ بِسَبَبٍ إِلَى ٱلسَّمَآءِ ثُمَّ لْيَقْطَعْ فَلْيَنظُرْ هَلْ يُذْهِبَنَّ كَيْدُهُۥ مَا يَغِيظُ","numberInSurah":15,"juz":17,"manzil":4,"page":333,"ruku":286,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2611,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2611.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2611.mp3"],"text":"وَكَذَٰلِكَ أَنزَلْنَٰهُ ءَايَٰتٍۭ بَيِّنَٰتٍۢ وَأَنَّ ٱللَّهَ يَهْدِى مَن يُرِيدُ","numberInSurah":16,"juz":17,"manzil":4,"page":334,"ruku":286,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2612,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2612.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2612.mp3"],"text":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَٱلَّذِينَ هَادُوا۟ وَٱلصَّٰبِـِٔينَ وَٱلنَّصَٰرَىٰ وَٱلْمَجُوسَ وَٱلَّذِينَ أَشْرَكُوٓا۟ إِنَّ ٱللَّهَ يَفْصِلُ بَيْنَهُمْ يَوْمَ ٱلْقِيَٰمَةِ ۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ شَهِيدٌ","numberInSurah":17,"juz":17,"manzil":4,"page":334,"ruku":286,"hizbQuarter":133,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2613,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2613.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2613.mp3"],"text":"أَلَمْ تَرَ أَنَّ ٱللَّهَ يَسْجُدُ لَهُۥ مَن فِى ٱلسَّمَٰوَٰتِ وَمَن فِى ٱلْأَرْضِ وَٱلشَّمْسُ وَٱلْقَمَرُ وَٱلنُّجُومُ وَٱلْجِبَالُ وَٱلشَّجَرُ وَٱلدَّوَآبُّ وَكَثِيرٌۭ مِّنَ ٱلنَّاسِ ۖ وَكَثِيرٌ حَقَّ عَلَيْهِ ٱلْعَذَابُ ۗ وَمَن يُهِنِ ٱللَّهُ فَمَا لَهُۥ مِن مُّكْرِمٍ ۚ إِنَّ ٱللَّهَ يَفْعَلُ مَا يَشَآءُ ۩","numberInSurah":18,"juz":17,"manzil":4,"page":334,"ruku":286,"hizbQuarter":133,"sajda":{"id":6,"recommended":true,"obligatory":false},"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}}],"surahs":{"22":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},"edition":{}}}