{"code":200,"status":"OK","data":{"number":188,"ayahs":[{"number":4154,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4154.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4154.mp3"],"text":"۞ أَوَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَيَنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ كَانُوا۟ مِن قَبْلِهِمْ ۚ كَانُوا۟ هُمْ أَشَدَّ مِنْهُمْ قُوَّةًۭ وَءَاثَارًۭا فِى ٱلْأَرْضِ فَأَخَذَهُمُ ٱللَّهُ بِذُنُوبِهِمْ وَمَا كَانَ لَهُم مِّنَ ٱللَّهِ مِن وَاقٍۢ","numberInSurah":21,"juz":24,"manzil":6,"page":469,"ruku":406,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4155,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4155.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4155.mp3"],"text":"ذَٰلِكَ بِأَنَّهُمْ كَانَت تَّأْتِيهِمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ فَكَفَرُوا۟ فَأَخَذَهُمُ ٱللَّهُ ۚ إِنَّهُۥ قَوِىٌّۭ شَدِيدُ ٱلْعِقَابِ","numberInSurah":22,"juz":24,"manzil":6,"page":469,"ruku":406,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4156,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4156.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4156.mp3"],"text":"وَلَقَدْ أَرْسَلْنَا مُوسَىٰ بِـَٔايَٰتِنَا وَسُلْطَٰنٍۢ مُّبِينٍ","numberInSurah":23,"juz":24,"manzil":6,"page":469,"ruku":406,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4157,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4157.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4157.mp3"],"text":"إِلَىٰ فِرْعَوْنَ وَهَٰمَٰنَ وَقَٰرُونَ فَقَالُوا۟ سَٰحِرٌۭ كَذَّابٌۭ","numberInSurah":24,"juz":24,"manzil":6,"page":469,"ruku":406,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4158,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4158.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4158.mp3"],"text":"فَلَمَّا جَآءَهُم بِٱلْحَقِّ مِنْ عِندِنَا قَالُوا۟ ٱقْتُلُوٓا۟ أَبْنَآءَ ٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ وَٱسْتَحْيُوا۟ نِسَآءَهُمْ ۚ وَمَا كَيْدُ ٱلْكَٰفِرِينَ إِلَّا فِى ضَلَٰلٍۢ","numberInSurah":25,"juz":24,"manzil":6,"page":469,"ruku":406,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4159,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4159.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4159.mp3"],"text":"وَقَالَ فِرْعَوْنُ ذَرُونِىٓ أَقْتُلْ مُوسَىٰ وَلْيَدْعُ رَبَّهُۥٓ ۖ إِنِّىٓ أَخَافُ أَن يُبَدِّلَ دِينَكُمْ أَوْ أَن يُظْهِرَ فِى ٱلْأَرْضِ ٱلْفَسَادَ","numberInSurah":26,"juz":24,"manzil":6,"page":470,"ruku":406,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4160,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4160.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4160.mp3"],"text":"وَقَالَ مُوسَىٰٓ إِنِّى عُذْتُ بِرَبِّى وَرَبِّكُم مِّن كُلِّ مُتَكَبِّرٍۢ لَّا يُؤْمِنُ بِيَوْمِ ٱلْحِسَابِ","numberInSurah":27,"juz":24,"manzil":6,"page":470,"ruku":406,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4161,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4161.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4161.mp3"],"text":"وَقَالَ رَجُلٌۭ مُّؤْمِنٌۭ مِّنْ ءَالِ فِرْعَوْنَ يَكْتُمُ إِيمَٰنَهُۥٓ أَتَقْتُلُونَ رَجُلًا أَن يَقُولَ رَبِّىَ ٱللَّهُ وَقَدْ جَآءَكُم بِٱلْبَيِّنَٰتِ مِن رَّبِّكُمْ ۖ وَإِن يَكُ كَٰذِبًۭا فَعَلَيْهِ كَذِبُهُۥ ۖ وَإِن يَكُ صَادِقًۭا يُصِبْكُم بَعْضُ ٱلَّذِى يَعِدُكُمْ ۖ إِنَّ ٱللَّهَ لَا يَهْدِى مَنْ هُوَ مُسْرِفٌۭ كَذَّابٌۭ","numberInSurah":28,"juz":24,"manzil":6,"page":470,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4162,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4162.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4162.mp3"],"text":"يَٰقَوْمِ لَكُمُ ٱلْمُلْكُ ٱلْيَوْمَ ظَٰهِرِينَ فِى ٱلْأَرْضِ فَمَن يَنصُرُنَا مِنۢ بَأْسِ ٱللَّهِ إِن جَآءَنَا ۚ قَالَ فِرْعَوْنُ مَآ أُرِيكُمْ إِلَّا مَآ أَرَىٰ وَمَآ أَهْدِيكُمْ إِلَّا سَبِيلَ ٱلرَّشَادِ","numberInSurah":29,"juz":24,"manzil":6,"page":470,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4163,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4163.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4163.mp3"],"text":"وَقَالَ ٱلَّذِىٓ ءَامَنَ يَٰقَوْمِ إِنِّىٓ أَخَافُ عَلَيْكُم مِّثْلَ يَوْمِ ٱلْأَحْزَابِ","numberInSurah":30,"juz":24,"manzil":6,"page":470,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4164,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4164.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4164.mp3"],"text":"مِثْلَ دَأْبِ قَوْمِ نُوحٍۢ وَعَادٍۢ وَثَمُودَ وَٱلَّذِينَ مِنۢ بَعْدِهِمْ ۚ وَمَا ٱللَّهُ يُرِيدُ ظُلْمًۭا لِّلْعِبَادِ","numberInSurah":31,"juz":24,"manzil":6,"page":470,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4165,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4165.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4165.mp3"],"text":"وَيَٰقَوْمِ إِنِّىٓ أَخَافُ عَلَيْكُمْ يَوْمَ ٱلتَّنَادِ","numberInSurah":32,"juz":24,"manzil":6,"page":470,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4166,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4166.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4166.mp3"],"text":"يَوْمَ تُوَلُّونَ مُدْبِرِينَ مَا لَكُم مِّنَ ٱللَّهِ مِنْ عَاصِمٍۢ ۗ وَمَن يُضْلِلِ ٱللَّهُ فَمَا لَهُۥ مِنْ هَادٍۢ","numberInSurah":33,"juz":24,"manzil":6,"page":470,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4167,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4167.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4167.mp3"],"text":"وَلَقَدْ جَآءَكُمْ يُوسُفُ مِن قَبْلُ بِٱلْبَيِّنَٰتِ فَمَا زِلْتُمْ فِى شَكٍّۢ مِّمَّا جَآءَكُم بِهِۦ ۖ حَتَّىٰٓ إِذَا هَلَكَ قُلْتُمْ لَن يَبْعَثَ ٱللَّهُ مِنۢ بَعْدِهِۦ رَسُولًۭا ۚ كَذَٰلِكَ يُضِلُّ ٱللَّهُ مَنْ هُوَ مُسْرِفٌۭ مُّرْتَابٌ","numberInSurah":34,"juz":24,"manzil":6,"page":471,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4168,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4168.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4168.mp3"],"text":"ٱلَّذِينَ يُجَٰدِلُونَ فِىٓ ءَايَٰتِ ٱللَّهِ بِغَيْرِ سُلْطَٰنٍ أَتَىٰهُمْ ۖ كَبُرَ مَقْتًا عِندَ ٱللَّهِ وَعِندَ ٱلَّذِينَ ءَامَنُوا۟ ۚ كَذَٰلِكَ يَطْبَعُ ٱللَّهُ عَلَىٰ كُلِّ قَلْبِ مُتَكَبِّرٍۢ جَبَّارٍۢ","numberInSurah":35,"juz":24,"manzil":6,"page":471,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4169,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4169.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4169.mp3"],"text":"وَقَالَ فِرْعَوْنُ يَٰهَٰمَٰنُ ٱبْنِ لِى صَرْحًۭا لَّعَلِّىٓ أَبْلُغُ ٱلْأَسْبَٰبَ","numberInSurah":36,"juz":24,"manzil":6,"page":471,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4170,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4170.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4170.mp3"],"text":"أَسْبَٰبَ ٱلسَّمَٰوَٰتِ فَأَطَّلِعَ إِلَىٰٓ إِلَٰهِ مُوسَىٰ وَإِنِّى لَأَظُنُّهُۥ كَٰذِبًۭا ۚ وَكَذَٰلِكَ زُيِّنَ لِفِرْعَوْنَ سُوٓءُ عَمَلِهِۦ وَصُدَّ عَنِ ٱلسَّبِيلِ ۚ وَمَا كَيْدُ فِرْعَوْنَ إِلَّا فِى تَبَابٍۢ","numberInSurah":37,"juz":24,"manzil":6,"page":471,"ruku":407,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4171,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4171.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4171.mp3"],"text":"وَقَالَ ٱلَّذِىٓ ءَامَنَ يَٰقَوْمِ ٱتَّبِعُونِ أَهْدِكُمْ سَبِيلَ ٱلرَّشَادِ","numberInSurah":38,"juz":24,"manzil":6,"page":471,"ruku":408,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4172,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4172.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4172.mp3"],"text":"يَٰقَوْمِ إِنَّمَا هَٰذِهِ ٱلْحَيَوٰةُ ٱلدُّنْيَا مَتَٰعٌۭ وَإِنَّ ٱلْءَاخِرَةَ هِىَ دَارُ ٱلْقَرَارِ","numberInSurah":39,"juz":24,"manzil":6,"page":471,"ruku":408,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4173,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4173.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4173.mp3"],"text":"مَنْ عَمِلَ سَيِّئَةًۭ فَلَا يُجْزَىٰٓ إِلَّا مِثْلَهَا ۖ وَمَنْ عَمِلَ صَٰلِحًۭا مِّن ذَكَرٍ أَوْ أُنثَىٰ وَهُوَ مُؤْمِنٌۭ فَأُو۟لَٰٓئِكَ يَدْخُلُونَ ٱلْجَنَّةَ يُرْزَقُونَ فِيهَا بِغَيْرِ حِسَابٍۢ","numberInSurah":40,"juz":24,"manzil":6,"page":471,"ruku":408,"hizbQuarter":188,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}}],"surahs":{"40":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},"edition":{}}}