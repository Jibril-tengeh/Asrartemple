{"code":200,"status":"OK","data":{"number":117,"ayahs":[{"number":2128,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2128.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2128.mp3"],"text":"۞ أَوَلَمْ يَرَوْا۟ أَنَّ ٱللَّهَ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ قَادِرٌ عَلَىٰٓ أَن يَخْلُقَ مِثْلَهُمْ وَجَعَلَ لَهُمْ أَجَلًۭا لَّا رَيْبَ فِيهِ فَأَبَى ٱلظَّٰلِمُونَ إِلَّا كُفُورًۭا","numberInSurah":99,"juz":15,"manzil":4,"page":292,"ruku":250,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2129,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2129.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2129.mp3"],"text":"قُل لَّوْ أَنتُمْ تَمْلِكُونَ خَزَآئِنَ رَحْمَةِ رَبِّىٓ إِذًۭا لَّأَمْسَكْتُمْ خَشْيَةَ ٱلْإِنفَاقِ ۚ وَكَانَ ٱلْإِنسَٰنُ قَتُورًۭا","numberInSurah":100,"juz":15,"manzil":4,"page":292,"ruku":250,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2130,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2130.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2130.mp3"],"text":"وَلَقَدْ ءَاتَيْنَا مُوسَىٰ تِسْعَ ءَايَٰتٍۭ بَيِّنَٰتٍۢ ۖ فَسْـَٔلْ بَنِىٓ إِسْرَٰٓءِيلَ إِذْ جَآءَهُمْ فَقَالَ لَهُۥ فِرْعَوْنُ إِنِّى لَأَظُنُّكَ يَٰمُوسَىٰ مَسْحُورًۭا","numberInSurah":101,"juz":15,"manzil":4,"page":292,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2131,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2131.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2131.mp3"],"text":"قَالَ لَقَدْ عَلِمْتَ مَآ أَنزَلَ هَٰٓؤُلَآءِ إِلَّا رَبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ بَصَآئِرَ وَإِنِّى لَأَظُنُّكَ يَٰفِرْعَوْنُ مَثْبُورًۭا","numberInSurah":102,"juz":15,"manzil":4,"page":292,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2132,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2132.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2132.mp3"],"text":"فَأَرَادَ أَن يَسْتَفِزَّهُم مِّنَ ٱلْأَرْضِ فَأَغْرَقْنَٰهُ وَمَن مَّعَهُۥ جَمِيعًۭا","numberInSurah":103,"juz":15,"manzil":4,"page":292,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2133,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2133.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2133.mp3"],"text":"وَقُلْنَا مِنۢ بَعْدِهِۦ لِبَنِىٓ إِسْرَٰٓءِيلَ ٱسْكُنُوا۟ ٱلْأَرْضَ فَإِذَا جَآءَ وَعْدُ ٱلْءَاخِرَةِ جِئْنَا بِكُمْ لَفِيفًۭا","numberInSurah":104,"juz":15,"manzil":4,"page":292,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2134,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2134.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2134.mp3"],"text":"وَبِٱلْحَقِّ أَنزَلْنَٰهُ وَبِٱلْحَقِّ نَزَلَ ۗ وَمَآ أَرْسَلْنَٰكَ إِلَّا مُبَشِّرًۭا وَنَذِيرًۭا","numberInSurah":105,"juz":15,"manzil":4,"page":293,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2135,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2135.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2135.mp3"],"text":"وَقُرْءَانًۭا فَرَقْنَٰهُ لِتَقْرَأَهُۥ عَلَى ٱلنَّاسِ عَلَىٰ مُكْثٍۢ وَنَزَّلْنَٰهُ تَنزِيلًۭا","numberInSurah":106,"juz":15,"manzil":4,"page":293,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2136,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2136.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2136.mp3"],"text":"قُلْ ءَامِنُوا۟ بِهِۦٓ أَوْ لَا تُؤْمِنُوٓا۟ ۚ إِنَّ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ مِن قَبْلِهِۦٓ إِذَا يُتْلَىٰ عَلَيْهِمْ يَخِرُّونَ لِلْأَذْقَانِ سُجَّدًۭا","numberInSurah":107,"juz":15,"manzil":4,"page":293,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2137,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2137.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2137.mp3"],"text":"وَيَقُولُونَ سُبْحَٰنَ رَبِّنَآ إِن كَانَ وَعْدُ رَبِّنَا لَمَفْعُولًۭا","numberInSurah":108,"juz":15,"manzil":4,"page":293,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2138,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2138.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2138.mp3"],"text":"وَيَخِرُّونَ لِلْأَذْقَانِ يَبْكُونَ وَيَزِيدُهُمْ خُشُوعًۭا ۩","numberInSurah":109,"juz":15,"manzil":4,"page":293,"ruku":251,"hizbQuarter":117,"sajda":{"id":4,"recommended":true,"obligatory":false},"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2139,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2139.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2139.mp3"],"text":"قُلِ ٱدْعُوا۟ ٱللَّهَ أَوِ ٱدْعُوا۟ ٱلرَّحْمَٰنَ ۖ أَيًّۭا مَّا تَدْعُوا۟ فَلَهُ ٱلْأَسْمَآءُ ٱلْحُسْنَىٰ ۚ وَلَا تَجْهَرْ بِصَلَاتِكَ وَلَا تُخَافِتْ بِهَا وَٱبْتَغِ بَيْنَ ذَٰلِكَ سَبِيلًۭا","numberInSurah":110,"juz":15,"manzil":4,"page":293,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2140,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2140.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2140.mp3"],"text":"وَقُلِ ٱلْحَمْدُ لِلَّهِ ٱلَّذِى لَمْ يَتَّخِذْ وَلَدًۭا وَلَمْ يَكُن لَّهُۥ شَرِيكٌۭ فِى ٱلْمُلْكِ وَلَمْ يَكُن لَّهُۥ وَلِىٌّۭ مِّنَ ٱلذُّلِّ ۖ وَكَبِّرْهُ تَكْبِيرًۢا","numberInSurah":111,"juz":15,"manzil":4,"page":293,"ruku":251,"hizbQuarter":117,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2141,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2141.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2141.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْحَمْدُ لِلَّهِ ٱلَّذِىٓ أَنزَلَ عَلَىٰ عَبْدِهِ ٱلْكِتَٰبَ وَلَمْ يَجْعَل لَّهُۥ عِوَجَا ۜ","numberInSurah":1,"juz":15,"manzil":4,"page":293,"ruku":252,"hizbQuarter":117,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2142,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2142.mp3","audioSecondary":["https://cdn.islamic.netwo