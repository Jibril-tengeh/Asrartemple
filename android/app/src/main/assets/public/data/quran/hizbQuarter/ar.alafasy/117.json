asy/2150.mp3"],"text":"إِذْ أَوَى ٱلْفِتْيَةُ إِلَى ٱلْكَهْفِ فَقَالُوا۟ رَبَّنَآ ءَاتِنَا مِن لَّدُنكَ رَحْمَةًۭ وَهَيِّئْ لَنَا مِنْ أَمْرِنَا رَشَدًۭا","numberInSurah":10,"juz":15,"manzil":4,"page":294,"ruku":252,"hizbQuarter":117,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2151,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2151.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2151.mp3"],"text":"فَضَرَبْنَا عَلَىٰٓ ءَاذَانِهِمْ فِى ٱلْكَهْفِ سِنِينَ عَدَدًۭا","numberInSurah":11,"juz":15,"manzil":4,"page":294,"ruku":252,"hizbQuarter":117,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2152,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2152.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2152.mp3"],"text":"ثُمَّ بَعَثْنَٰهُمْ لِنَعْلَمَ أَىُّ ٱلْحِزْبَيْنِ أَحْصَىٰ لِمَا لَبِثُوٓا۟ أَمَدًۭا","numberInSurah":12,"juz":15,"manzil":4,"page":294,"ruku":252,"hizbQuarter":117,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2153,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2153.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2153.mp3"],"text":"نَّحْنُ نَقُصُّ عَلَيْكَ نَبَأَهُم بِٱلْحَقِّ ۚ إِنَّهُمْ فِتْيَةٌ ءَامَنُوا۟ بِرَبِّهِمْ وَزِدْنَٰهُمْ هُدًۭى","numberInSurah":13,"juz":15,"manzil":4,"page":294,"ruku":253,"hizbQuarter":117,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2154,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2154.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2154.mp3"],"text":"وَرَبَطْنَا عَلَىٰ قُلُوبِهِمْ إِذْ قَامُوا۟ فَقَالُوا۟ رَبُّنَا رَبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ لَن نَّدْعُوَا۟ مِن دُونِهِۦٓ إِلَٰهًۭا ۖ لَّقَدْ قُلْنَآ إِذًۭا شَطَطًا","numberInSurah":14,"juz":15,"manzil":4,"page":294,"ruku":253,"hizbQuarter":117,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2155,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2155.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2155.mp3"],"text":"هَٰٓؤُلَآءِ قَوْمُنَا ٱتَّخَذُوا۟ مِن دُونِهِۦٓ ءَالِهَةًۭ ۖ لَّوْلَا يَأْتُونَ عَلَيْهِم بِسُلْطَٰنٍۭ بَيِّنٍۢ ۖ فَمَنْ أَظْلَمُ مِمَّنِ ٱفْتَرَىٰ عَلَى ٱللَّهِ كَذِبًۭا","numberInSurah":15,"juz":15,"manzil":4,"page":294,"ruku":253,"hizbQuarter":117,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2156,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2156.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2156.mp3"],"text":"وَإِذِ ٱعْتَزَلْتُمُوهُمْ وَمَا يَعْبُدُونَ إِلَّا ٱللَّهَ فَأْوُۥٓا۟ إِلَى ٱلْكَهْفِ يَنشُرْ لَكُمْ رَبُّكُم مِّن رَّحْمَتِهِۦ وَيُهَيِّئْ لَكُم مِّنْ أَمْرِكُم مِّرْفَقًۭا","numberInSurah":16,"juz":15,"manzil":4,"page":295,"ruku":253,"hizbQuarter":117,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}}],"surahs":{"17":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"},"18":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},"edition":{}}}