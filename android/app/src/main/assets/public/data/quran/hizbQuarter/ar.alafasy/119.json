{"code":200,"status":"OK","data":{"number":119,"ayahs":[{"number":2172,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2172.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2172.mp3"],"text":"۞ وَٱضْرِبْ لَهُم مَّثَلًۭا رَّجُلَيْنِ جَعَلْنَا لِأَحَدِهِمَا جَنَّتَيْنِ مِنْ أَعْنَٰبٍۢ وَحَفَفْنَٰهُمَا بِنَخْلٍۢ وَجَعَلْنَا بَيْنَهُمَا زَرْعًۭا","numberInSurah":32,"juz":15,"manzil":4,"page":297,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2173,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2173.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2173.mp3"],"text":"كِلْتَا ٱلْجَنَّتَيْنِ ءَاتَتْ أُكُلَهَا وَلَمْ تَظْلِم مِّنْهُ شَيْـًۭٔا ۚ وَفَجَّرْنَا خِلَٰلَهُمَا نَهَرًۭا","numberInSurah":33,"juz":15,"manzil":4,"page":297,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2174,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2174.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2174.mp3"],"text":"وَكَانَ لَهُۥ ثَمَرٌۭ فَقَالَ لِصَٰحِبِهِۦ وَهُوَ يُحَاوِرُهُۥٓ أَنَا۠ أَكْثَرُ مِنكَ مَالًۭا وَأَعَزُّ نَفَرًۭا","numberInSurah":34,"juz":15,"manzil":4,"page":297,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2175,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2175.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2175.mp3"],"text":"وَدَخَلَ جَنَّتَهُۥ وَهُوَ ظَالِمٌۭ لِّنَفْسِهِۦ قَالَ مَآ أَظُنُّ أَن تَبِيدَ هَٰذِهِۦٓ أَبَدًۭا","numberInSurah":35,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2176,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2176.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2176.mp3"],"text":"وَمَآ أَظُنُّ ٱلسَّاعَةَ قَآئِمَةًۭ وَلَئِن رُّدِدتُّ إِلَىٰ رَبِّى لَأَجِدَنَّ خَيْرًۭا مِّنْهَا مُنقَلَبًۭا","numberInSurah":36,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2177,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2177.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2177.mp3"],"text":"قَالَ لَهُۥ صَاحِبُهُۥ وَهُوَ يُحَاوِرُهُۥٓ أَكَفَرْتَ بِٱلَّذِى خَلَقَكَ مِن تُرَابٍۢ ثُمَّ مِن نُّطْفَةٍۢ ثُمَّ سَوَّىٰكَ رَجُلًۭا","numberInSurah":37,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2178,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2178.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2178.mp3"],"text":"لَّٰكِنَّا۠ هُوَ ٱللَّهُ رَبِّى وَلَآ أُشْرِكُ بِرَبِّىٓ أَحَدًۭا","numberInSurah":38,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2179,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2179.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2179.mp3"],"text":"وَلَوْلَآ إِذْ دَخَلْتَ جَنَّتَكَ قُلْتَ مَا شَآءَ ٱللَّهُ لَا قُوَّةَ إِلَّا بِٱللَّهِ ۚ إِن تَرَنِ أَنَا۠ أَقَلَّ مِنكَ مَالًۭا وَوَلَدًۭا","numberInSurah":39,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2180,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2180.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2180.mp3"],"text":"فَعَسَىٰ رَبِّىٓ أَن يُؤْتِيَنِ خَيْرًۭا مِّن جَنَّتِكَ وَيُرْسِلَ عَلَيْهَا حُسْبَانًۭا مِّنَ ٱلسَّمَآءِ فَتُصْبِحَ صَعِيدًۭا زَلَقًا","numberInSurah":40,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2181,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2181.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2181.mp3"],"text":"أَوْ يُصْبِحَ مَآؤُهَا غَوْرًۭا فَلَن تَسْتَطِيعَ لَهُۥ طَلَبًۭا","numberInSurah":41,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2182,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2182.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2182.mp3"],"text":"وَأُحِيطَ بِثَمَرِهِۦ فَأَصْبَحَ يُقَلِّبُ كَفَّيْهِ عَلَىٰ مَآ أَنفَقَ فِيهَا وَهِىَ خَاوِيَةٌ عَلَىٰ عُرُوشِهَا وَيَقُولُ يَٰلَيْتَنِى لَمْ أُشْرِكْ بِرَبِّىٓ أَحَدًۭا","numberInSurah":42,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2183,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2183.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2183.mp3"],"text":"وَلَمْ تَكُن لَّهُۥ فِئَةٌۭ يَنصُرُونَهُۥ مِن دُونِ ٱللَّهِ وَمَا كَانَ مُنتَصِرًا","numberInSurah":43,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2184,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2184.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2184.mp3"],"text":"هُنَالِكَ ٱلْوَلَٰيَةُ لِلَّهِ ٱلْحَقِّ ۚ هُوَ خَيْرٌۭ ثَوَابًۭا وَخَيْرٌ عُقْبًۭا","numberInSurah":44,"juz":15,"manzil":4,"page":298,"ruku":256,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2185,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2185.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2185.mp3"],"text":"وَٱضْرِبْ لَهُم مَّثَلَ ٱلْحَيَوٰةِ ٱلدُّنْيَا كَمَآءٍ أَنزَلْنَٰهُ مِنَ ٱلسَّمَآءِ فَٱخْتَلَطَ بِهِۦ نَبَاتُ ٱلْأَرْضِ فَأَصْبَحَ هَشِيمًۭا تَذْرُوهُ ٱلرِّيَٰحُ ۗ وَكَانَ ٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ مُّقْتَدِرًا","numberInSurah":45,"juz":15,"manzil":4,"page":298,"ruku":257,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2186,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2186.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2186.mp3"],"text":"ٱلْمَالُ وَٱلْبَنُونَ زِينَةُ ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَٱلْبَٰقِيَٰتُ ٱلصَّٰلِحَٰتُ خَيْرٌ عِندَ رَبِّكَ ثَوَابًۭا وَخَيْرٌ أَمَلًۭا","numberInSurah":46,"juz":15,"manzil":4,"page":299,"ruku":257,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2187,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2187.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2187.mp3"],"text":"وَيَوْمَ نُسَيِّرُ ٱلْجِبَالَ وَتَرَى ٱلْأَرْضَ بَارِزَةًۭ وَحَشَرْنَٰهُمْ فَلَمْ نُغَادِرْ مِنْهُمْ أَحَدًۭا","numberInSurah":47,"juz":15,"manzil":4,"page":299,"ruku":257,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2188,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2188.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2188.mp3"],"text":"وَعُرِضُوا۟ عَلَىٰ رَبِّكَ صَفًّۭا لَّقَدْ جِئْتُمُونَا كَمَا خَلَقْنَٰكُمْ أَوَّلَ مَرَّةٍۭ ۚ بَلْ زَعَمْتُمْ أَلَّن نَّجْعَلَ لَكُم مَّوْعِدًۭا","numberInSurah":48,"juz":15,"manzil":4,"page":299,"ruku":257,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2189,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2189.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2189.mp3"],"text":"وَوُضِعَ ٱلْكِتَٰبُ فَتَرَى ٱلْمُجْرِمِينَ مُشْفِقِينَ مِمَّا فِيهِ وَيَقُولُونَ يَٰوَيْلَتَنَا مَالِ هَٰذَا ٱلْكِتَٰبِ لَا يُغَادِرُ صَغِيرَةًۭ وَلَا كَبِيرَةً إِلَّآ أَحْصَىٰهَا ۚ وَوَجَدُوا۟ مَا عَمِلُوا۟ حَاضِرًۭا ۗ وَلَا يَظْلِمُ رَبُّكَ أَحَدًۭا","numberInSurah":49,"juz":15,"manzil":4,"page":299,"ruku":257,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2190,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2190.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2190.mp3"],"text":"وَإِذْ قُلْنَا لِلْمَلَٰٓئِكَةِ ٱسْجُدُوا۟ لِءَادَمَ فَسَجَدُوٓا۟ إِلَّآ إِبْلِيسَ كَانَ مِنَ ٱلْجِنِّ فَفَسَقَ عَنْ أَمْرِ رَبِّهِۦٓ ۗ أَفَتَتَّخِذُونَهُۥ وَذُرِّيَّتَهُۥٓ أَوْلِيَآءَ مِن دُونِى وَهُمْ لَكُمْ عَدُوٌّۢ ۚ بِئْسَ لِلظَّٰلِمِينَ بَدَلًۭا","numberInSurah":50,"juz":15,"manzil":4,"page":299,"ruku":258,"hizbQuarter":119,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}}],"surahs":{"18":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},"edition":{}}}