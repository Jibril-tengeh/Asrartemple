"لَقَدْ حَقَّ ٱلْقَوْلُ عَلَىٰٓ أَكْثَرِهِمْ فَهُمْ لَا يُؤْمِنُونَ","numberInSurah":7,"juz":22,"manzil":5,"page":440,"ruku":381,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3713,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3713.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3713.mp3"],"text":"إِنَّا جَعَلْنَا فِىٓ أَعْنَٰقِهِمْ أَغْلَٰلًۭا فَهِىَ إِلَى ٱلْأَذْقَانِ فَهُم مُّقْمَحُونَ","numberInSurah":8,"juz":22,"manzil":5,"page":440,"ruku":381,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3714,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3714.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3714.mp3"],"text":"وَجَعَلْنَا مِنۢ بَيْنِ أَيْدِيهِمْ سَدًّۭا وَمِنْ خَلْفِهِمْ سَدًّۭا فَأَغْشَيْنَٰهُمْ فَهُمْ لَا يُبْصِرُونَ","numberInSurah":9,"juz":22,"manzil":5,"page":440,"ruku":381,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3715,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3715.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3715.mp3"],"text":"وَسَوَآءٌ عَلَيْهِمْ ءَأَنذَرْتَهُمْ أَمْ لَمْ تُنذِرْهُمْ لَا يُؤْمِنُونَ","numberInSurah":10,"juz":22,"manzil":5,"page":440,"ruku":381,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3716,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3716.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3716.mp3"],"text":"إِنَّمَا تُنذِرُ مَنِ ٱتَّبَعَ ٱلذِّكْرَ وَخَشِىَ ٱلرَّحْمَٰنَ بِٱلْغَيْبِ ۖ فَبَشِّرْهُ بِمَغْفِرَةٍۢ وَأَجْرٍۢ كَرِيمٍ","numberInSurah":11,"juz":22,"manzil":5,"page":440,"ruku":381,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3717,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3717.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3717.mp3"],"text":"إِنَّا نَحْنُ نُحْىِ ٱلْمَوْتَىٰ وَنَكْتُبُ مَا قَدَّمُوا۟ وَءَاثَٰرَهُمْ ۚ وَكُلَّ شَىْءٍ أَحْصَيْنَٰهُ فِىٓ إِمَامٍۢ مُّبِينٍۢ","numberInSurah":12,"juz":22,"manzil":5,"page":440,"ruku":381,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3718,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3718.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3718.mp3"],"text":"وَٱضْرِبْ لَهُم مَّثَلًا أَصْحَٰبَ ٱلْقَرْيَةِ إِذْ جَآءَهَا ٱلْمُرْسَلُونَ","numberInSurah":13,"juz":22,"manzil":5,"page":441,"ruku":382,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3719,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3719.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3719.mp3"],"text":"إِذْ أَرْسَلْنَآ إِلَيْهِمُ ٱثْنَيْنِ فَكَذَّبُوهُمَا فَعَزَّزْنَا بِثَالِثٍۢ فَقَالُوٓا۟ إِنَّآ إِلَيْكُم مُّرْسَلُونَ","numberInSurah":14,"juz":22,"manzil":5,"page":441,"ruku":382,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3720,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3720.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3720.mp3"],"text":"قَالُوا۟ مَآ أَنتُمْ إِلَّا بَشَرٌۭ مِّثْلُنَا وَمَآ أَنزَلَ ٱلرَّحْمَٰنُ مِن شَىْءٍ إِنْ أَنتُمْ إِلَّا تَكْذِبُونَ","numberInSurah":15,"juz":22,"manzil":5,"page":441,"ruku":382,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3721,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3721.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3721.mp3"],"text":"قَالُوا۟ رَبُّنَا يَعْلَمُ إِنَّآ إِلَيْكُمْ لَمُرْسَلُونَ","numberInSurah":16,"juz":22,"manzil":5,"page":441,"ruku":382,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3722,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3722.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3722.mp3"],"text":"وَمَا عَلَيْنَآ إِلَّا ٱلْبَلَٰغُ ٱلْمُبِينُ","numberInSurah":17,"juz":22,"manzil":5,"page":441,"ruku":382,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3723,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3723.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3723.mp3"],"text":"قَالُوٓا۟ إِنَّا تَطَيَّرْنَا بِكُمْ ۖ لَئِن لَّمْ تَنتَهُوا۟ لَنَرْجُمَنَّكُمْ وَلَيَمَسَّنَّكُم مِّنَّا عَذَابٌ أَلِيمٌۭ","numberInSurah":18,"juz":22,"manzil":5,"page":441,"ruku":382,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3724,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3724.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3724.mp3"],"text":"قَالُوا۟ طَٰٓئِرُكُم مَّعَكُمْ ۚ أ