{"code":200,"status":"OK","data":{"number":176,"ayahs":[{"number":3701,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3701.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3701.mp3"],"text":"۞ إِنَّ ٱللَّهَ يُمْسِكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ أَن تَزُولَا ۚ وَلَئِن زَالَتَآ إِنْ أَمْسَكَهُمَا مِنْ أَحَدٍۢ مِّنۢ بَعْدِهِۦٓ ۚ إِنَّهُۥ كَانَ حَلِيمًا غَفُورًۭا","numberInSurah":41,"juz":22,"manzil":5,"page":439,"ruku":380,"hizbQuarter":176,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3702,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3702.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3702.mp3"],"text":"وَأَقْسَمُوا۟ بِٱللَّهِ جَهْدَ أَيْمَٰنِهِمْ لَئِن جَآءَهُمْ نَذِيرٌۭ لَّيَكُونُنَّ أَهْدَىٰ مِنْ إِحْدَى ٱلْأُمَمِ ۖ فَلَمَّا جَآءَهُمْ نَذِيرٌۭ مَّا زَادَهُمْ إِلَّا نُفُورًا","numberInSurah":42,"juz":22,"manzil":5,"page":439,"ruku":380,"hizbQuarter":176,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3703,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3703.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3703.mp3"],"text":"ٱسْتِكْبَارًۭا فِى ٱلْأَرْضِ وَمَكْرَ ٱلسَّيِّئِ ۚ وَلَا يَحِيقُ ٱلْمَكْرُ ٱلسَّيِّئُ إِلَّا بِأَهْلِهِۦ ۚ فَهَلْ يَنظُرُونَ إِلَّا سُنَّتَ ٱلْأَوَّلِينَ ۚ فَلَن تَجِدَ لِسُنَّتِ ٱللَّهِ تَبْدِيلًۭا ۖ وَلَن تَجِدَ لِسُنَّتِ ٱللَّهِ تَحْوِيلًا","numberInSurah":43,"juz":22,"manzil":5,"page":439,"ruku":380,"hizbQuarter":176,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3704,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3704.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3704.mp3"],"text":"أَوَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَيَنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ مِن قَبْلِهِمْ وَكَانُوٓا۟ أَشَدَّ مِنْهُمْ قُوَّةًۭ ۚ وَمَا كَانَ ٱللَّهُ لِيُعْجِزَهُۥ مِن شَىْءٍۢ فِى ٱلسَّمَٰوَٰتِ وَلَا فِى ٱلْأَرْضِ ۚ إِنَّهُۥ كَانَ عَلِيمًۭا قَدِيرًۭا","numberInSurah":44,"juz":22,"manzil":5,"page":439,"ruku":380,"hizbQuarter":176,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3705,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3705.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3705.mp3"],"text":"وَلَوْ يُؤَاخِذُ ٱللَّهُ ٱلنَّاسَ بِمَا كَسَبُوا۟ مَا تَرَكَ عَلَىٰ ظَهْرِهَا مِن دَآبَّةٍۢ وَلَٰكِن يُؤَخِّرُهُمْ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى ۖ فَإِذَا جَآءَ أَجَلُهُمْ فَإِنَّ ٱللَّهَ كَانَ بِعِبَادِهِۦ بَصِيرًۢا","numberInSurah":45,"juz":22,"manzil":5,"page":440,"ruku":380,"hizbQuarter":176,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3706,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3706.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3706.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يسٓ","numberInSurah":1,"juz":22,"manzil":5,"page":440,"ruku":381,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3707,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3707.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3707.mp3"],"text":"وَٱلْقُرْءَانِ ٱلْحَكِيمِ","numberInSurah":2,"juz":22,"manzil":5,"page":440,"ruku":381,"hizbQuarter":176,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","e