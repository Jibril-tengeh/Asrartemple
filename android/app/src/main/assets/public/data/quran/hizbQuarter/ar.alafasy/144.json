{"code":200,"status":"OK","data":{"number":144,"ayahs":[{"number":2856,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2856.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2856.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ تَبَارَكَ ٱلَّذِى نَزَّلَ ٱلْفُرْقَانَ عَلَىٰ عَبْدِهِۦ لِيَكُونَ لِلْعَٰلَمِينَ نَذِيرًا","numberInSurah":1,"juz":18,"manzil":4,"page":359,"ruku":310,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2857,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2857.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2857.mp3"],"text":"ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَلَمْ يَتَّخِذْ وَلَدًۭا وَلَمْ يَكُن لَّهُۥ شَرِيكٌۭ فِى ٱلْمُلْكِ وَخَلَقَ كُلَّ شَىْءٍۢ فَقَدَّرَهُۥ تَقْدِيرًۭا","numberInSurah":2,"juz":18,"manzil":4,"page":359,"ruku":310,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2858,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2858.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2858.mp3"],"text":"وَٱتَّخَذُوا۟ مِن دُونِهِۦٓ ءَالِهَةًۭ لَّا يَخْلُقُونَ شَيْـًۭٔا وَهُمْ يُخْلَقُونَ وَلَا يَمْلِكُونَ لِأَنفُسِهِمْ ضَرًّۭا وَلَا نَفْعًۭا وَلَا يَمْلِكُونَ مَوْتًۭا وَلَا حَيَوٰةًۭ وَلَا نُشُورًۭا","numberInSurah":3,"juz":18,"manzil":4,"page":360,"ruku":310,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2859,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2859.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2859.mp3"],"text":"وَقَالَ ٱلَّذِينَ كَفَرُوٓا۟ إِنْ هَٰذَآ إِلَّآ إِفْكٌ ٱفْتَرَىٰهُ وَأَعَانَهُۥ عَلَيْهِ قَوْمٌ ءَاخَرُونَ ۖ فَقَدْ جَآءُو ظُلْمًۭا وَزُورًۭا","numberInSurah":4,"juz":18,"manzil":4,"page":360,"ruku":310,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2860,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2860.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2860.mp3"],"text":"وَقَالُوٓا۟ أَسَٰطِيرُ ٱلْأَوَّلِينَ ٱكْتَتَبَهَا فَهِىَ تُمْلَىٰ عَلَيْهِ بُكْرَةًۭ وَأَصِيلًۭا","numberInSurah":5,"juz":18,"manzil":4,"page":360,"ruku":310,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2861,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2861.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2861.mp3"],"text":"قُلْ أَنزَلَهُ ٱلَّذِى يَعْلَمُ ٱلسِّرَّ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ إِنَّهُۥ كَانَ غَفُورًۭا رَّحِيمًۭا","numberInSurah":6,"juz":18,"manzil":4,"page":360,"ruku":310,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2862,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2862.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2862.mp3"],"text":"وَقَالُوا۟ مَالِ هَٰذَا ٱلرَّسُولِ يَأْكُلُ ٱلطَّعَامَ وَيَمْشِى فِى ٱلْأَسْوَاقِ ۙ لَوْلَآ أُنزِلَ إِلَيْهِ مَلَكٌۭ فَيَكُونَ مَعَهُۥ نَذِيرًا","numberInSurah":7,"juz":18,"manzil":4,"page":360,"ruku":310,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2863,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2863.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2863.mp3"],"text":"أَوْ يُلْقَىٰٓ إِلَيْهِ كَنزٌ أَوْ تَكُونُ لَهُۥ جَنَّةٌۭ يَأْكُلُ مِنْهَا ۚ وَقَالَ ٱلظَّٰلِمُونَ إِن تَتَّبِعُونَ إِلَّا رَجُلًۭا مَّسْحُورًا","numberInSurah":8,"juz":18,"manzil":4,"page":360,"ruku":310,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2864,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2864.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2864.mp3"],"text":"ٱنظُرْ كَيْفَ ضَرَبُوا۟ لَكَ ٱلْأَمْثَٰلَ فَضَلُّوا۟ فَلَا يَسْتَطِيعُونَ سَبِيلًۭا","numberInSurah":9,"juz":18,"manzil":4,"page":360,"ruku":310,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2865,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2865.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2865.mp3"],"text":"تَبَارَكَ ٱلَّذِىٓ إِن شَآءَ جَعَلَ لَكَ خَيْرًۭا مِّن ذَٰلِكَ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ وَيَجْعَل لَّكَ قُصُورًۢا","numberInSurah":10,"juz":18,"manzil":4,"page":360,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2866,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2866.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2866.mp3"],"text":"بَلْ كَذَّبُوا۟ بِٱلسَّاعَةِ ۖ وَأَعْتَدْنَا لِمَن كَذَّبَ بِٱلسَّاعَةِ سَعِيرًا","numberInSurah":11,"juz":18,"manzil":4,"page":360,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2867,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2867.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2867.mp3"],"text":"إِذَا رَأَتْهُم مِّن مَّكَانٍۭ بَعِيدٍۢ سَمِعُوا۟ لَهَا تَغَيُّظًۭا وَزَفِيرًۭا","numberInSurah":12,"juz":18,"manzil":4,"page":361,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2868,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2868.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2868.mp3"],"text":"وَإِذَآ أُلْقُوا۟ مِنْهَا مَكَانًۭا ضَيِّقًۭا مُّقَرَّنِينَ دَعَوْا۟ هُنَالِكَ ثُبُورًۭا","numberInSurah":13,"juz":18,"manzil":4,"page":361,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2869,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2869.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2869.mp3"],"text":"لَّا تَدْعُوا۟ ٱلْيَوْمَ ثُبُورًۭا وَٰحِدًۭا وَٱدْعُوا۟ ثُبُورًۭا كَثِيرًۭا","numberInSurah":14,"juz":18,"manzil":4,"page":361,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2870,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2870.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2870.mp3"],"text":"قُلْ أَذَٰلِكَ خَيْرٌ أَمْ جَنَّةُ ٱلْخُلْدِ ٱلَّتِى وُعِدَ ٱلْمُتَّقُونَ ۚ كَانَتْ لَهُمْ جَزَآءًۭ وَمَصِيرًۭا","numberInSurah":15,"juz":18,"manzil":4,"page":361,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2871,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2871.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2871.mp3"],"text":"لَّهُمْ فِيهَا مَا يَشَآءُونَ خَٰلِدِينَ ۚ كَانَ عَلَىٰ رَبِّكَ وَعْدًۭا مَّسْـُٔولًۭا","numberInSurah":16,"juz":18,"manzil":4,"page":361,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2872,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2872.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2872.mp3"],"text":"وَيَوْمَ يَحْشُرُهُمْ وَمَا يَعْبُدُونَ مِن دُونِ ٱللَّهِ فَيَقُولُ ءَأَنتُمْ أَضْلَلْتُمْ عِبَادِى هَٰٓؤُلَآءِ أَمْ هُمْ ضَلُّوا۟ ٱلسَّبِيلَ","numberInSurah":17,"juz":18,"manzil":4,"page":361,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2873,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2873.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2873.mp3"],"text":"قَالُوا۟ سُبْحَٰنَكَ مَا كَانَ يَنۢبَغِى لَنَآ أَن نَّتَّخِذَ مِن دُونِكَ مِنْ أَوْلِيَآءَ وَلَٰكِن مَّتَّعْتَهُمْ وَءَابَآءَهُمْ حَتَّىٰ نَسُوا۟ ٱلذِّكْرَ وَكَانُوا۟ قَوْمًۢا بُورًۭا","numberInSurah":18,"juz":18,"manzil":4,"page":361,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2874,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2874.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2874.mp3"],"text":"فَقَدْ كَذَّبُوكُم بِمَا تَقُولُونَ فَمَا تَسْتَطِيعُونَ صَرْفًۭا وَلَا نَصْرًۭا ۚ وَمَن يَظْلِم مِّنكُمْ نُذِقْهُ عَذَابًۭا كَبِيرًۭا","numberInSurah":19,"juz":18,"manzil":4,"page":361,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2875,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2875.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2875.mp3"],"text":"وَمَآ أَرْسَلْنَا قَبْلَكَ مِنَ ٱلْمُرْسَلِينَ إِلَّآ إِنَّهُمْ لَيَأْكُلُونَ ٱلطَّعَامَ وَيَمْشُونَ فِى ٱلْأَسْوَاقِ ۗ وَجَعَلْنَا بَعْضَكُمْ لِبَعْضٍۢ فِتْنَةً أَتَصْبِرُونَ ۗ وَكَانَ رَبُّكَ بَصِيرًۭا","numberInSurah":20,"juz":18,"manzil":4,"page":361,"ruku":311,"hizbQuarter":144,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}}],"surahs":{"25":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},"edition":{}}}