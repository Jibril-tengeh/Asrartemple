{"code":200,"status":"OK","data":{"number":191,"ayahs":[{"number":4227,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4227.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4227.mp3"],"text":"۞ قُلْ أَئِنَّكُمْ لَتَكْفُرُونَ بِٱلَّذِى خَلَقَ ٱلْأَرْضَ فِى يَوْمَيْنِ وَتَجْعَلُونَ لَهُۥٓ أَندَادًۭا ۚ ذَٰلِكَ رَبُّ ٱلْعَٰلَمِينَ","numberInSurah":9,"juz":24,"manzil":6,"page":477,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4228,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4228.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4228.mp3"],"text":"وَجَعَلَ فِيهَا رَوَٰسِىَ مِن فَوْقِهَا وَبَٰرَكَ فِيهَا وَقَدَّرَ فِيهَآ أَقْوَٰتَهَا فِىٓ أَرْبَعَةِ أَيَّامٍۢ سَوَآءًۭ لِّلسَّآئِلِينَ","numberInSurah":10,"juz":24,"manzil":6,"page":477,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4229,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4229.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4229.mp3"],"text":"ثُمَّ ٱسْتَوَىٰٓ إِلَى ٱلسَّمَآءِ وَهِىَ دُخَانٌۭ فَقَالَ لَهَا وَلِلْأَرْضِ ٱئْتِيَا طَوْعًا أَوْ كَرْهًۭا قَالَتَآ أَتَيْنَا طَآئِعِينَ","numberInSurah":11,"juz":24,"manzil":6,"page":477,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4230,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4230.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4230.mp3"],"text":"فَقَضَىٰهُنَّ سَبْعَ سَمَٰوَاتٍۢ فِى يَوْمَيْنِ وَأَوْحَىٰ فِى كُلِّ سَمَآءٍ أَمْرَهَا ۚ وَزَيَّنَّا ٱلسَّمَآءَ ٱلدُّنْيَا بِمَصَٰبِيحَ وَحِفْظًۭا ۚ ذَٰلِكَ تَقْدِيرُ ٱلْعَزِيزِ ٱلْعَلِيمِ","numberInSurah":12,"juz":24,"manzil":6,"page":478,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4231,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4231.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4231.mp3"],"text":"فَإِنْ أَعْرَضُوا۟ فَقُلْ أَنذَرْتُكُمْ صَٰعِقَةًۭ مِّثْلَ صَٰعِقَةِ عَادٍۢ وَثَمُودَ","numberInSurah":13,"juz":24,"manzil":6,"page":478,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4232,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4232.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4232.mp3"],"text":"إِذْ جَآءَتْهُمُ ٱلرُّسُلُ مِنۢ بَيْنِ أَيْدِيهِمْ وَمِنْ خَلْفِهِمْ أَلَّا تَعْبُدُوٓا۟ إِلَّا ٱللَّهَ ۖ قَالُوا۟ لَوْ شَآءَ رَبُّنَا لَأَنزَلَ مَلَٰٓئِكَةًۭ فَإِنَّا بِمَآ أُرْسِلْتُم بِهِۦ كَٰفِرُونَ","numberInSurah":14,"juz":24,"manzil":6,"page":478,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4233,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4233.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4233.mp3"],"text":"فَأَمَّا عَادٌۭ فَٱسْتَكْبَرُوا۟ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ وَقَالُوا۟ مَنْ أَشَدُّ مِنَّا قُوَّةً ۖ أَوَلَمْ يَرَوْا۟ أَنَّ ٱللَّهَ ٱلَّذِى خَلَقَهُمْ هُوَ أَشَدُّ مِنْهُمْ قُوَّةًۭ ۖ وَكَانُوا۟ بِـَٔايَٰتِنَا يَجْحَدُونَ","numberInSurah":15,"juz":24,"manzil":6,"page":478,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4234,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4234.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4234.mp3"],"text":"فَأَرْسَلْنَا عَلَيْهِمْ رِيحًۭا صَرْصَرًۭا فِىٓ أَيَّامٍۢ نَّحِسَاتٍۢ لِّنُذِيقَهُمْ عَذَابَ ٱلْخِزْىِ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَلَعَذَابُ ٱلْءَاخِرَةِ أَخْزَىٰ ۖ وَهُمْ لَا يُنصَرُونَ","numberInSurah":16,"juz":24,"manzil":6,"page":478,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4235,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4235.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4235.mp3"],"text":"وَأَمَّا ثَمُودُ فَهَدَيْنَٰهُمْ فَٱسْتَحَبُّوا۟ ٱلْعَمَىٰ عَلَى ٱلْهُدَىٰ فَأَخَذَتْهُمْ صَٰعِقَةُ ٱلْعَذَابِ ٱلْهُونِ بِمَا كَانُوا۟ يَكْسِبُونَ","numberInSurah":17,"juz":24,"manzil":6,"page":478,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4236,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4236.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4236.mp3"],"text":"وَنَجَّيْنَا ٱلَّذِينَ ءَامَنُوا۟ وَكَانُوا۟ يَتَّقُونَ","numberInSurah":18,"juz":24,"manzil":6,"page":478,"ruku":414,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4237,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4237.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4237.mp3"],"text":"وَيَوْمَ يُحْشَرُ أَعْدَآءُ ٱللَّهِ إِلَى ٱلنَّارِ فَهُمْ يُوزَعُونَ","numberInSurah":19,"juz":24,"manzil":6,"page":478,"ruku":415,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4238,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4238.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4238.mp3"],"text":"حَتَّىٰٓ إِذَا مَا جَآءُوهَا شَهِدَ عَلَيْهِمْ سَمْعُهُمْ وَأَبْصَٰرُهُمْ وَجُلُودُهُم بِمَا كَانُوا۟ يَعْمَلُونَ","numberInSurah":20,"juz":24,"manzil":6,"page":478,"ruku":415,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4239,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4239.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4239.mp3"],"text":"وَقَالُوا۟ لِجُلُودِهِمْ لِمَ شَهِدتُّمْ عَلَيْنَا ۖ قَالُوٓا۟ أَنطَقَنَا ٱللَّهُ ٱلَّذِىٓ أَنطَقَ كُلَّ شَىْءٍۢ وَهُوَ خَلَقَكُمْ أَوَّلَ مَرَّةٍۢ وَإِلَيْهِ تُرْجَعُونَ","numberInSurah":21,"juz":24,"manzil":6,"page":479,"ruku":415,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4240,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4240.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4240.mp3"],"text":"وَمَا كُنتُمْ تَسْتَتِرُونَ أَن يَشْهَدَ عَلَيْكُمْ سَمْعُكُمْ وَلَآ أَبْصَٰرُكُمْ وَلَا جُلُودُكُمْ وَلَٰكِن ظَنَنتُمْ أَنَّ ٱللَّهَ لَا يَعْلَمُ كَثِيرًۭا مِّمَّا تَعْمَلُونَ","numberInSurah":22,"juz":24,"manzil":6,"page":479,"ruku":415,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4241,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4241.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4241.mp3"],"text":"وَذَٰلِكُمْ ظَنُّكُمُ ٱلَّذِى ظَنَنتُم بِرَبِّكُمْ أَرْدَىٰكُمْ فَأَصْبَحْتُم مِّنَ ٱلْخَٰسِرِينَ","numberInSurah":23,"juz":24,"manzil":6,"page":479,"ruku":415,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4242,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4242.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4242.mp3"],"text":"فَإِن يَصْبِرُوا۟ فَٱلنَّارُ مَثْوًۭى لَّهُمْ ۖ وَإِن يَسْتَعْتِبُوا۟ فَمَا هُم مِّنَ ٱلْمُعْتَبِينَ","numberInSurah":24,"juz":24,"manzil":6,"page":479,"ruku":415,"hizbQuarter":191,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}}],"surahs":{"41":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},"edition":{}}}