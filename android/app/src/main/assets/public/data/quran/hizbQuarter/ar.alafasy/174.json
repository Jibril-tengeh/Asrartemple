{"code":200,"status":"OK","data":{"number":174,"ayahs":[{"number":3652,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3652.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3652.mp3"],"text":"۞ قُلْ إِنَّمَآ أَعِظُكُم بِوَٰحِدَةٍ ۖ أَن تَقُومُوا۟ لِلَّهِ مَثْنَىٰ وَفُرَٰدَىٰ ثُمَّ تَتَفَكَّرُوا۟ ۚ مَا بِصَاحِبِكُم مِّن جِنَّةٍ ۚ إِنْ هُوَ إِلَّا نَذِيرٌۭ لَّكُم بَيْنَ يَدَىْ عَذَابٍۢ شَدِيدٍۢ","numberInSurah":46,"juz":22,"manzil":5,"page":433,"ruku":375,"hizbQuarter":174,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3653,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3653.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3653.mp3"],"text":"قُلْ مَا سَأَلْتُكُم مِّنْ أَجْرٍۢ فَهُوَ لَكُمْ ۖ إِنْ أَجْرِىَ إِلَّا عَلَى ٱللَّهِ ۖ وَهُوَ عَلَىٰ كُلِّ شَىْءٍۢ شَهِيدٌۭ","numberInSurah":47,"juz":22,"manzil":5,"page":433,"ruku":375,"hizbQuarter":174,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3654,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3654.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3654.mp3"],"text":"قُلْ إِنَّ رَبِّى يَقْذِفُ بِٱلْحَقِّ عَلَّٰمُ ٱلْغُيُوبِ","numberInSurah":48,"juz":22,"manzil":5,"page":433,"ruku":375,"hizbQuarter":174,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3655,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3655.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3655.mp3"],"text":"قُلْ جَآءَ ٱلْحَقُّ وَمَا يُبْدِئُ ٱلْبَٰطِلُ وَمَا يُعِيدُ","numberInSurah":49,"juz":22,"manzil":5,"page":434,"ruku":375,"hizbQuarter":174,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3656,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3656.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3656.mp3"],"text":"قُلْ إِن ضَلَلْتُ فَإِنَّمَآ أَضِلُّ عَلَىٰ نَفْسِى ۖ وَإِنِ ٱهْتَدَيْتُ فَبِمَا يُوحِىٓ إِلَىَّ رَبِّىٓ ۚ إِنَّهُۥ سَمِيعٌۭ قَرِيبٌۭ","numberInSurah":50,"juz":22,"manzil":5,"page":434,"ruku":375,"hizbQuarter":174,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3657,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3657.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3657.mp3"],"text":"وَلَوْ تَرَىٰٓ إِذْ فَزِعُوا۟ فَلَا فَوْتَ وَأُخِذُوا۟ مِن مَّكَانٍۢ قَرِيبٍۢ","numberInSurah":51,"juz":22,"manzil":5,"page":434,"ruku":375,"hizbQuarter":174,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3658,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3658.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3658.mp3"],"text":"وَقَالُوٓا۟ ءَامَنَّا بِهِۦ وَأَنَّىٰ لَهُمُ ٱلتَّنَاوُشُ مِن مَّكَانٍۭ بَعِيدٍۢ","numberInSurah":52,"juz":22,"manzil":5,"page":434,"ruku":375,"hizbQuarter":174,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3659,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3659.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3659.mp3"],"text":"وَقَدْ كَفَرُوا۟ بِهِۦ مِن قَبْلُ ۖ وَيَقْذِفُونَ بِٱلْغَيْبِ مِن مَّكَانٍۭ بَعِيدٍۢ","numberInSurah":53,"juz":22,"manzil":5,"page":434,"ruku":375,"hizbQuarter":174,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3660,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3660.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3660.mp3"],"text":"وَحِيلَ بَيْنَهُمْ وَبَيْنَ مَا يَشْتَهُونَ كَمَا فُعِلَ بِأَشْيَاعِهِم مِّن قَبْلُ ۚ إِنَّهُمْ كَانُوا۟ فِى شَكٍّۢ مُّرِيبٍۭ","numberInSurah":54,"juz":22,"manzil":5,"page":434,"ruku":375,"hizbQuarter":174,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3661,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3661.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3661.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْحَمْدُ لِلَّهِ فَاطِرِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ جَاعِلِ ٱلْمَلَٰٓئِكَةِ رُسُلًا أُو۟لِىٓ أَجْنِحَةٍۢ مَّثْنَىٰ وَثُلَٰثَ وَرُبَٰعَ ۚ يَزِيدُ فِى ٱلْخَلْقِ مَا يَشَآءُ ۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","numberInSurah":1,"juz":22,"manzil":5,"page":434,"ruku":376,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3662,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3662.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3662.mp3"],"text":"مَّا يَفْتَحِ ٱللَّهُ لِلنَّاسِ مِن رَّحْمَةٍۢ فَلَا مُمْسِكَ لَهَا ۖ وَمَا يُمْسِكْ فَلَا مُرْسِلَ لَهُۥ مِنۢ بَعْدِهِۦ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":2,"juz":22,"manzil":5,"page":434,"ruku":376,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3663,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3663.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3663.mp3"],"text":"يَٰٓأَيُّهَا ٱلنَّاسُ ٱذْكُرُوا۟ نِعْمَتَ ٱللَّهِ عَلَيْكُمْ ۚ هَلْ مِنْ خَٰلِقٍ غَيْرُ ٱللَّهِ يَرْزُقُكُم مِّنَ ٱلسَّمَآءِ وَٱلْأَرْضِ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ۖ فَأَنَّىٰ تُؤْفَكُونَ","numberInSurah":3,"juz":22,"manzil":5,"page":434,"ruku":376,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3664,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3664.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3664.mp3"],"text":"وَإِن يُكَذِّبُوكَ فَقَدْ كُذِّبَتْ رُسُلٌۭ مِّن قَبْلِكَ ۚ وَإِلَى ٱللَّهِ تُرْجَعُ ٱلْأُمُورُ","numberInSurah":4,"juz":22,"manzil":5,"page":435,"ruku":376,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3665,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3665.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3665.mp3"],"text":"يَٰٓأَيُّهَا ٱلنَّاسُ إِنَّ وَعْدَ ٱللَّهِ حَقٌّۭ ۖ فَلَا تَغُرَّنَّكُمُ ٱلْحَيَوٰةُ ٱلدُّنْيَا ۖ وَلَا يَغُرَّنَّكُم بِٱللَّهِ ٱلْغَرُورُ","numberInSurah":5,"juz":22,"manzil":5,"page":435,"ruku":376,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3666,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3666.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3666.mp3"],"text":"إِنَّ ٱلشَّيْطَٰنَ لَكُمْ عَدُوٌّۭ فَٱتَّخِذُوهُ عَدُوًّا ۚ إِنَّمَا يَدْعُوا۟ حِزْبَهُۥ لِيَكُونُوا۟ مِنْ أَصْحَٰبِ ٱلسَّعِيرِ","numberInSurah":6,"juz":22,"manzil":5,"page":435,"ruku":376,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3667,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3667.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3667.mp3"],"text":"ٱلَّذِينَ كَفَرُوا۟ لَهُمْ عَذَابٌۭ شَدِيدٌۭ ۖ وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُم مَّغْفِرَةٌۭ وَأَجْرٌۭ كَبِيرٌ","numberInSurah":7,"juz":22,"manzil":5,"page":435,"ruku":376,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3668,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3668.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3668.mp3"],"text":"أَفَمَن زُيِّنَ لَهُۥ سُوٓءُ عَمَلِهِۦ فَرَءَاهُ حَسَنًۭا ۖ فَإِنَّ ٱللَّهَ يُضِلُّ مَن يَشَآءُ وَيَهْدِى مَن يَشَآءُ ۖ فَلَا تَذْهَبْ نَفْسُكَ عَلَيْهِمْ حَسَرَٰتٍ ۚ إِنَّ ٱللَّهَ عَلِيمٌۢ بِمَا يَصْنَعُونَ","numberInSurah":8,"juz":22,"manzil":5,"page":435,"ruku":377,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3669,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3669.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3669.mp3"],"text":"وَٱللَّهُ ٱلَّذِىٓ أَرْسَلَ ٱلرِّيَٰحَ فَتُثِيرُ سَحَابًۭا فَسُقْنَٰهُ إِلَىٰ بَلَدٍۢ مَّيِّتٍۢ فَأَحْيَيْنَا بِهِ ٱلْأَرْضَ بَعْدَ مَوْتِهَا ۚ كَذَٰلِكَ ٱلنُّشُورُ","numberInSurah":9,"juz":22,"manzil":5,"page":435,"ruku":377,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3670,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3670.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3670.mp3"],"text":"مَن كَانَ يُرِيدُ ٱلْعِزَّةَ فَلِلَّهِ ٱلْعِزَّةُ جَمِيعًا ۚ إِلَيْهِ يَصْعَدُ ٱلْكَلِمُ ٱلطَّيِّبُ وَٱلْعَمَلُ ٱلصَّٰلِحُ يَرْفَعُهُۥ ۚ وَٱلَّذِينَ يَمْكُرُونَ ٱلسَّيِّـَٔاتِ لَهُمْ عَذَابٌۭ شَدِيدٌۭ ۖ وَمَكْرُ أُو۟لَٰٓئِكَ هُوَ يَبُورُ","numberInSurah":10,"juz":22,"manzil":5,"page":435,"ruku":377,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3671,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3671.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3671.mp3"],"text":"وَٱللَّهُ خَلَقَكُم مِّن تُرَابٍۢ ثُمَّ مِن نُّطْفَةٍۢ ثُمَّ جَعَلَكُمْ أَزْوَٰجًۭا ۚ وَمَا تَحْمِلُ مِنْ أُنثَىٰ وَلَا تَضَعُ إِلَّا بِعِلْمِهِۦ ۚ وَمَا يُعَمَّرُ مِن مُّعَمَّرٍۢ وَلَا يُنقَصُ مِنْ عُمُرِهِۦٓ إِلَّا فِى كِتَٰبٍ ۚ إِنَّ ذَٰلِكَ عَلَى ٱللَّهِ يَسِيرٌۭ","numberInSurah":11,"juz":22,"manzil":5,"page":435,"ruku":377,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3672,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3672.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3672.mp3"],"text":"وَمَا يَسْتَوِى ٱلْبَحْرَانِ هَٰذَا عَذْبٌۭ فُرَاتٌۭ سَآئِغٌۭ شَرَابُهُۥ وَهَٰذَا مِلْحٌ أُجَاجٌۭ ۖ وَمِن كُلٍّۢ تَأْكُلُونَ لَحْمًۭا طَرِيًّۭا وَتَسْتَخْرِجُونَ حِلْيَةًۭ تَلْبَسُونَهَا ۖ وَتَرَى ٱلْفُلْكَ فِيهِ مَوَاخِرَ لِتَبْتَغُوا۟ مِن فَضْلِهِۦ وَلَعَلَّكُمْ تَشْكُرُونَ","numberInSurah":12,"juz":22,"manzil":5,"page":436,"ruku":377,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3673,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3673.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3673.mp3"],"text":"يُولِجُ ٱلَّيْلَ فِى ٱلنَّهَارِ وَيُولِجُ ٱلنَّهَارَ فِى ٱلَّيْلِ وَسَخَّرَ ٱلشَّمْسَ وَٱلْقَمَرَ كُلٌّۭ يَجْرِى لِأَجَلٍۢ مُّسَمًّۭى ۚ ذَٰلِكُمُ ٱللَّهُ رَبُّكُمْ لَهُ ٱلْمُلْكُ ۚ وَٱلَّذِينَ تَدْعُونَ مِن دُونِهِۦ مَا يَمْلِكُونَ مِن قِطْمِيرٍ","numberInSurah":13,"juz":22,"manzil":5,"page":436,"ruku":377,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3674,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3674.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3674.mp3"],"text":"إِن تَدْعُوهُمْ لَا يَسْمَعُوا۟ دُعَآءَكُمْ وَلَوْ سَمِعُوا۟ مَا ٱسْتَجَابُوا۟ لَكُمْ ۖ وَيَوْمَ ٱلْقِيَٰمَةِ يَكْفُرُونَ بِشِرْكِكُمْ ۚ وَلَا يُنَبِّئُكَ مِثْلُ خَبِيرٍۢ","numberInSurah":14,"juz":22,"manzil":5,"page":436,"ruku":377,"hizbQuarter":174,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}}],"surahs":{"34":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"},"35":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},"edition":{}}}