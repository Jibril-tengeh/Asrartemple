{"code":200,"status":"OK","data":{"number":166,"ayahs":[{"number":3514,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3514.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3514.mp3"],"text":"۞ قُلْ يَتَوَفَّىٰكُم مَّلَكُ ٱلْمَوْتِ ٱلَّذِى وُكِّلَ بِكُمْ ثُمَّ إِلَىٰ رَبِّكُمْ تُرْجَعُونَ","numberInSurah":11,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3515,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3515.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3515.mp3"],"text":"وَلَوْ تَرَىٰٓ إِذِ ٱلْمُجْرِمُونَ نَاكِسُوا۟ رُءُوسِهِمْ عِندَ رَبِّهِمْ رَبَّنَآ أَبْصَرْنَا وَسَمِعْنَا فَٱرْجِعْنَا نَعْمَلْ صَٰلِحًا إِنَّا مُوقِنُونَ","numberInSurah":12,"juz":21,"manzil":5,"page":416,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3516,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3516.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3516.mp3"],"text":"وَلَوْ شِئْنَا لَءَاتَيْنَا كُلَّ نَفْسٍ هُدَىٰهَا وَلَٰكِنْ حَقَّ ٱلْقَوْلُ مِنِّى لَأَمْلَأَنَّ جَهَنَّمَ مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ أَجْمَعِينَ","numberInSurah":13,"juz":21,"manzil":5,"page":416,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3517,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3517.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3517.mp3"],"text":"فَذُوقُوا۟ بِمَا نَسِيتُمْ لِقَآءَ يَوْمِكُمْ هَٰذَآ إِنَّا نَسِينَٰكُمْ ۖ وَذُوقُوا۟ عَذَابَ ٱلْخُلْدِ بِمَا كُنتُمْ تَعْمَلُونَ","numberInSurah":14,"juz":21,"manzil":5,"page":416,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3518,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3518.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3518.mp3"],"text":"إِنَّمَا يُؤْمِنُ بِـَٔايَٰتِنَا ٱلَّذِينَ إِذَا ذُكِّرُوا۟ بِهَا خَرُّوا۟ سُجَّدًۭا وَسَبَّحُوا۟ بِحَمْدِ رَبِّهِمْ وَهُمْ لَا يَسْتَكْبِرُونَ ۩","numberInSurah":15,"juz":21,"manzil":5,"page":416,"ruku":359,"hizbQuarter":166,"sajda":{"id":10,"recommended":false,"obligatory":true},"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3519,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3519.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3519.mp3"],"text":"تَتَجَافَىٰ جُنُوبُهُمْ عَنِ ٱلْمَضَاجِعِ يَدْعُونَ رَبَّهُمْ خَوْفًۭا وَطَمَعًۭا وَمِمَّا رَزَقْنَٰهُمْ يُنفِقُونَ","numberInSurah":16,"juz":21,"manzil":5,"page":416,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3520,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3520.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3520.mp3"],"text":"فَلَا تَعْلَمُ نَفْسٌۭ مَّآ أُخْفِىَ لَهُم مِّن قُرَّةِ أَعْيُنٍۢ جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ","numberInSurah":17,"juz":21,"manzil":5,"page":416,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3521,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3521.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3521.mp3"],"text":"أَفَمَن كَانَ مُؤْمِنًۭا كَمَن كَانَ فَاسِقًۭا ۚ لَّا يَسْتَوُۥنَ","numberInSurah":18,"juz":21,"manzil":5,"page":416,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3522,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3522.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3522.mp3"],"text":"أَمَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فَلَهُمْ جَنَّٰتُ ٱلْمَأْوَىٰ نُزُلًۢا بِمَا كَانُوا۟ يَعْمَلُونَ","numberInSurah":19,"juz":21,"manzil":5,"page":416,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3523,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3523.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3523.mp3"],"text":"وَأَمَّا ٱلَّذِينَ فَسَقُوا۟ فَمَأْوَىٰهُمُ ٱلنَّارُ ۖ كُلَّمَآ أَرَادُوٓا۟ أَن يَخْرُجُوا۟ مِنْهَآ أُعِيدُوا۟ فِيهَا وَقِيلَ لَهُمْ ذُوقُوا۟ عَذَابَ ٱلنَّارِ ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ","numberInSurah":20,"juz":21,"manzil":5,"page":416,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3524,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3524.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3524.mp3"],"text":"وَلَنُذِيقَنَّهُم مِّنَ ٱلْعَذَابِ ٱلْأَدْنَىٰ دُونَ ٱلْعَذَابِ ٱلْأَكْبَرِ لَعَلَّهُمْ يَرْجِعُونَ","numberInSurah":21,"juz":21,"manzil":5,"page":417,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3525,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3525.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3525.mp3"],"text":"وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ ثُمَّ أَعْرَضَ عَنْهَآ ۚ إِنَّا مِنَ ٱلْمُجْرِمِينَ مُنتَقِمُونَ","numberInSurah":22,"juz":21,"manzil":5,"page":417,"ruku":359,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3526,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3526.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3526.mp3"],"text":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ فَلَا تَكُن فِى مِرْيَةٍۢ مِّن لِّقَآئِهِۦ ۖ وَجَعَلْنَٰهُ هُدًۭى لِّبَنِىٓ إِسْرَٰٓءِيلَ","numberInSurah":23,"juz":21,"manzil":5,"page":417,"ruku":360,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3527,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3527.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3527.mp3"],"text":"وَجَعَلْنَا مِنْهُمْ أَئِمَّةًۭ يَهْدُونَ بِأَمْرِنَا لَمَّا صَبَرُوا۟ ۖ وَكَانُوا۟ بِـَٔايَٰتِنَا يُوقِنُونَ","numberInSurah":24,"juz":21,"manzil":5,"page":417,"ruku":360,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3528,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3528.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3528.mp3"],"text":"إِنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ يَوْمَ ٱلْقِيَٰمَةِ فِيمَا كَانُوا۟ فِيهِ يَخْتَلِفُونَ","numberInSurah":25,"juz":21,"manzil":5,"page":417,"ruku":360,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3529,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3529.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3529.mp3"],"text":"أَوَلَمْ يَهْدِ لَهُمْ كَمْ أَهْلَكْنَا مِن قَبْلِهِم مِّنَ ٱلْقُرُونِ يَمْشُونَ فِى مَسَٰكِنِهِمْ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍ ۖ أَفَلَا يَسْمَعُونَ","numberInSurah":26,"juz":21,"manzil":5,"page":417,"ruku":360,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3530,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3530.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3530.mp3"],"text":"أَوَلَمْ يَرَوْا۟ أَنَّا نَسُوقُ ٱلْمَآءَ إِلَى ٱلْأَرْضِ ٱلْجُرُزِ فَنُخْرِجُ بِهِۦ زَرْعًۭا تَأْكُلُ مِنْهُ أَنْعَٰمُهُمْ وَأَنفُسُهُمْ ۖ أَفَلَا يُبْصِرُونَ","numberInSurah":27,"juz":21,"manzil":5,"page":417,"ruku":360,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3531,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3531.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3531.mp3"],"text":"وَيَقُولُونَ مَتَىٰ هَٰذَا ٱلْفَتْحُ إِن كُنتُمْ صَٰدِقِينَ","numberInSurah":28,"juz":21,"manzil":5,"page":417,"ruku":360,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3532,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3532.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3532.mp3"],"text":"قُلْ يَوْمَ ٱلْفَتْحِ لَا يَنفَعُ ٱلَّذِينَ كَفَرُوٓا۟ إِيمَٰنُهُمْ وَلَا هُمْ يُنظَرُونَ","numberInSurah":29,"juz":21,"manzil":5,"page":417,"ruku":360,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3533,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3533.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3533.mp3"],"text":"فَأَعْرِضْ عَنْهُمْ وَٱنتَظِرْ إِنَّهُم مُّنتَظِرُونَ","numberInSurah":30,"juz":21,"manzil":5,"page":417,"ruku":360,"hizbQuarter":166,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}}],"surahs":{"32":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},"edition":{}}}