{"code":200,"status":"OK","data":{"number":108,"ayahs":[{"number":1931,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1931.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1931.mp3"],"text":"۞ وَقِيلَ لِلَّذِينَ ٱتَّقَوْا۟ مَاذَآ أَنزَلَ رَبُّكُمْ ۚ قَالُوا۟ خَيْرًۭا ۗ لِّلَّذِينَ أَحْسَنُوا۟ فِى هَٰذِهِ ٱلدُّنْيَا حَسَنَةٌۭ ۚ وَلَدَارُ ٱلْءَاخِرَةِ خَيْرٌۭ ۚ وَلَنِعْمَ دَارُ ٱلْمُتَّقِينَ","numberInSurah":30,"juz":14,"manzil":3,"page":270,"ruku":227,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1932,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1932.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1932.mp3"],"text":"جَنَّٰتُ عَدْنٍۢ يَدْخُلُونَهَا تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۖ لَهُمْ فِيهَا مَا يَشَآءُونَ ۚ كَذَٰلِكَ يَجْزِى ٱللَّهُ ٱلْمُتَّقِينَ","numberInSurah":31,"juz":14,"manzil":3,"page":270,"ruku":227,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1933,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1933.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1933.mp3"],"text":"ٱلَّذِينَ تَتَوَفَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ طَيِّبِينَ ۙ يَقُولُونَ سَلَٰمٌ عَلَيْكُمُ ٱدْخُلُوا۟ ٱلْجَنَّةَ بِمَا كُنتُمْ تَعْمَلُونَ","numberInSurah":32,"juz":14,"manzil":3,"page":270,"ruku":227,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1934,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1934.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1934.mp3"],"text":"هَلْ يَنظُرُونَ إِلَّآ أَن تَأْتِيَهُمُ ٱلْمَلَٰٓئِكَةُ أَوْ يَأْتِىَ أَمْرُ رَبِّكَ ۚ كَذَٰلِكَ فَعَلَ ٱلَّذِينَ مِن قَبْلِهِمْ ۚ وَمَا ظَلَمَهُمُ ٱللَّهُ وَلَٰكِن كَانُوٓا۟ أَنفُسَهُمْ يَظْلِمُونَ","numberInSurah":33,"juz":14,"manzil":3,"page":270,"ruku":227,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1935,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1935.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1935.mp3"],"text":"فَأَصَابَهُمْ سَيِّـَٔاتُ مَا عَمِلُوا۟ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","numberInSurah":34,"juz":14,"manzil":3,"page":270,"ruku":227,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1936,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1936.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1936.mp3"],"text":"وَقَالَ ٱلَّذِينَ أَشْرَكُوا۟ لَوْ شَآءَ ٱللَّهُ مَا عَبَدْنَا مِن دُونِهِۦ مِن شَىْءٍۢ نَّحْنُ وَلَآ ءَابَآؤُنَا وَلَا حَرَّمْنَا مِن دُونِهِۦ مِن شَىْءٍۢ ۚ كَذَٰلِكَ فَعَلَ ٱلَّذِينَ مِن قَبْلِهِمْ ۚ فَهَلْ عَلَى ٱلرُّسُلِ إِلَّا ٱلْبَلَٰغُ ٱلْمُبِينُ","numberInSurah":35,"juz":14,"manzil":3,"page":271,"ruku":228,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1937,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1937.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1937.mp3"],"text":"وَلَقَدْ بَعَثْنَا فِى كُلِّ أُمَّةٍۢ رَّسُولًا أَنِ ٱعْبُدُوا۟ ٱللَّهَ وَٱجْتَنِبُوا۟ ٱلطَّٰغُوتَ ۖ فَمِنْهُم مَّنْ هَدَى ٱللَّهُ وَمِنْهُم مَّنْ حَقَّتْ عَلَيْهِ ٱلضَّلَٰلَةُ ۚ فَسِيرُوا۟ فِى ٱلْأَرْضِ فَٱنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُكَذِّبِينَ","numberInSurah":36,"juz":14,"manzil":3,"page":271,"ruku":228,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1938,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1938.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1938.mp3"],"text":"إِن تَحْرِصْ عَلَىٰ هُدَىٰهُمْ فَإِنَّ ٱللَّهَ لَا يَهْدِى مَن يُضِلُّ ۖ وَمَا لَهُم مِّن نَّٰصِرِينَ","numberInSurah":37,"juz":14,"manzil":3,"page":271,"ruku":228,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1939,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1939.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1939.mp3"],"text":"وَأَقْسَمُوا۟ بِٱللَّهِ جَهْدَ أَيْمَٰنِهِمْ ۙ لَا يَبْعَثُ ٱللَّهُ مَن يَمُوتُ ۚ بَلَىٰ وَعْدًا عَلَيْهِ حَقًّۭا وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","numberInSurah":38,"juz":14,"manzil":3,"page":271,"ruku":228,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1940,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1940.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1940.mp3"],"text":"لِيُبَيِّنَ لَهُمُ ٱلَّذِى يَخْتَلِفُونَ فِيهِ وَلِيَعْلَمَ ٱلَّذِينَ كَفَرُوٓا۟ أَنَّهُمْ كَانُوا۟ كَٰذِبِينَ","numberInSurah":39,"juz":14,"manzil":3,"page":271,"ruku":228,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1941,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1941.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1941.mp3"],"text":"إِنَّمَا قَو