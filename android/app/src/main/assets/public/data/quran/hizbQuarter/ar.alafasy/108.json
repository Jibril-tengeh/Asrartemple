slamic.network/quran/audio/64/ar.alafasy/1945.mp3"],"text":"بِٱلْبَيِّنَٰتِ وَٱلزُّبُرِ ۗ وَأَنزَلْنَآ إِلَيْكَ ٱلذِّكْرَ لِتُبَيِّنَ لِلنَّاسِ مَا نُزِّلَ إِلَيْهِمْ وَلَعَلَّهُمْ يَتَفَكَّرُونَ","numberInSurah":44,"juz":14,"manzil":3,"page":272,"ruku":229,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1946,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1946.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1946.mp3"],"text":"أَفَأَمِنَ ٱلَّذِينَ مَكَرُوا۟ ٱلسَّيِّـَٔاتِ أَن يَخْسِفَ ٱللَّهُ بِهِمُ ٱلْأَرْضَ أَوْ يَأْتِيَهُمُ ٱلْعَذَابُ مِنْ حَيْثُ لَا يَشْعُرُونَ","numberInSurah":45,"juz":14,"manzil":3,"page":272,"ruku":229,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1947,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1947.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1947.mp3"],"text":"أَوْ يَأْخُذَهُمْ فِى تَقَلُّبِهِمْ فَمَا هُم بِمُعْجِزِينَ","numberInSurah":46,"juz":14,"manzil":3,"page":272,"ruku":229,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1948,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1948.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1948.mp3"],"text":"أَوْ يَأْخُذَهُمْ عَلَىٰ تَخَوُّفٍۢ فَإِنَّ رَبَّكُمْ لَرَءُوفٌۭ رَّحِيمٌ","numberInSurah":47,"juz":14,"manzil":3,"page":272,"ruku":229,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1949,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1949.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1949.mp3"],"text":"أَوَلَمْ يَرَوْا۟ إِلَىٰ مَا خَلَقَ ٱللَّهُ مِن شَىْءٍۢ يَتَفَيَّؤُا۟ ظِلَٰلُهُۥ عَنِ ٱلْيَمِينِ وَٱلشَّمَآئِلِ سُجَّدًۭا لِّلَّهِ وَهُمْ دَٰخِرُونَ","numberInSurah":48,"juz":14,"manzil":3,"page":272,"ruku":229,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1950,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1950.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1950.mp3"],"text":"وَلِلَّهِ يَسْجُدُ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ مِن دَآبَّةٍۢ وَٱلْمَلَٰٓئِكَةُ وَهُمْ لَا يَسْتَكْبِرُونَ","numberInSurah":49,"juz":14,"manzil":3,"page":272,"ruku":229,"hizbQuarter":108,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1951,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1951.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1951.mp3"],"text":"يَخَافُونَ رَبَّهُم مِّن فَوْقِهِمْ وَيَفْعَلُونَ مَا يُؤْمَرُونَ ۩","numberInSurah":50,"juz":14,"manzil":3,"page":272,"ruku":229,"hizbQuarter":108,"sajda":{"id":3,"recommended":true,"obligatory":false},"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}}],"surahs":{"16":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},"edition":{}}}