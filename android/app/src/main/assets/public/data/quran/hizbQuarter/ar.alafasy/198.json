ah":64,"juz":25,"manzil":6,"page":494,"ruku":429,"hizbQuarter":198,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4390,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4390.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4390.mp3"],"text":"فَٱخْتَلَفَ ٱلْأَحْزَابُ مِنۢ بَيْنِهِمْ ۖ فَوَيْلٌۭ لِّلَّذِينَ ظَلَمُوا۟ مِنْ عَذَابِ يَوْمٍ أَلِيمٍ","numberInSurah":65,"juz":25,"manzil":6,"page":494,"ruku":429,"hizbQuarter":198,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4391,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4391.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4391.mp3"],"text":"هَلْ يَنظُرُونَ إِلَّا ٱلسَّاعَةَ أَن تَأْتِيَهُم بَغْتَةًۭ وَهُمْ لَا يَشْعُرُونَ","numberInSurah":66,"juz":25,"manzil":6,"page":494,"ruku":429,"hizbQuarter":198,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4392,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4392.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4392.mp3"],"text":"ٱلْأَخِلَّآءُ يَوْمَئِذٍۭ بَعْضُهُمْ لِبَعْضٍ عَدُوٌّ إِلَّا ٱلْمُتَّقِينَ","numberInSurah":67,"juz":25,"manzil":6,"page":494,"ruku":429,"hizbQuarter":198,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4393,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4393.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4393.mp3"],"text":"يَٰعِبَادِ لَا خَوْفٌ عَلَيْكُمُ ٱلْيَوْمَ وَلَآ أ