{"code":200,"status":"OK","data":{"number":198,"ayahs":[{"number":4382,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4382.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4382.mp3"],"text":"۞ وَلَمَّا ضُرِبَ ٱبْنُ مَرْيَمَ مَثَلًا إِذَا قَوْمُكَ مِنْهُ يَصِدُّونَ","numberInSurah":57,"juz":25,"manzil":6,"page":493,"ruku":429,"hizbQuarter":198,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4383,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4383.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4383.mp3"],"text":"وَقَالُوٓا۟ ءَأَٰلِهَتُنَا خَيْرٌ أَمْ هُوَ ۚ مَا ضَرَبُوهُ لَكَ إِلَّا جَدَلًۢا ۚ بَلْ هُمْ قَوْمٌ خَصِمُونَ","numberInSurah":58,"juz":25,"manzil":6,"page":493,"ruku":429,"hizbQuarter":198,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4384,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4384.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4384.mp3"],"text":"إِنْ هُوَ إِلَّا عَبْدٌ أَنْعَمْنَا عَلَيْهِ وَجَعَلْنَٰهُ مَثَلًۭا لِّبَنِىٓ إِسْرَٰٓءِيلَ","numberInSurah":59,"juz":25,"manzil":6,"page":493,"ruku":429,"hizbQuarter":198,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4385,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4385.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4385.mp3"],"text":"وَلَوْ نَشَآءُ لَجَعَلْنَا مِنكُم مَّلَٰٓئِكَةًۭ فِى ٱلْأَرْضِ يَخْلُفُونَ","numberInSurah":60,"juz":25,"manzil":6,"page":493,"ruku":429,"hizbQuarter":198,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّ