{"code":200,"status":"OK","data":{"number":101,"ayahs":[{"number":1726,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1726.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1726.mp3"],"text":"۞ أَفَمَن يَعْلَمُ أَنَّمَآ أُنزِلَ إِلَيْكَ مِن رَّبِّكَ ٱلْحَقُّ كَمَنْ هُوَ أَعْمَىٰٓ ۚ إِنَّمَا يَتَذَكَّرُ أُو۟لُوا۟ ٱلْأَلْبَٰبِ","numberInSurah":19,"juz":13,"manzil":3,"page":252,"ruku":207,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1727,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1727.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1727.mp3"],"text":"ٱلَّذِينَ يُوفُونَ بِعَهْدِ ٱللَّهِ وَلَا يَنقُضُونَ ٱلْمِيثَٰقَ","numberInSurah":20,"juz":13,"manzil":3,"page":252,"ruku":207,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1728,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1728.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1728.mp3"],"text":"وَٱلَّذِينَ يَصِلُونَ مَآ أَمَرَ ٱللَّهُ بِهِۦٓ أَن يُوصَلَ وَيَخْشَوْنَ رَبَّهُمْ وَيَخَافُونَ سُوٓءَ ٱلْحِسَابِ","numberInSurah":21,"juz":13,"manzil":3,"page":252,"ruku":207,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1729,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1729.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1729.mp3"],"text":"وَٱلَّذِينَ صَبَرُوا۟ ٱبْتِغَآءَ وَجْهِ رَبِّهِمْ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَأَنفَقُوا۟ مِمَّا رَزَقْنَٰهُمْ سِرًّۭا وَعَلَانِيَةًۭ وَيَدْرَءُونَ بِٱلْحَسَنَةِ ٱلسَّيِّئَةَ أُو۟لَٰٓئِكَ لَهُمْ عُقْبَى ٱلدَّارِ","numberInSurah":22,"juz":13,"manzil":3,"page":252,"ruku":207,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1730,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1730.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1730.mp3"],"text":"جَنَّٰتُ عَدْنٍۢ يَدْخُلُونَهَا وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۖ وَٱلْمَلَٰٓئِكَةُ يَدْخُلُونَ عَلَيْهِم مِّن كُلِّ بَابٍۢ","numberInSurah":23,"juz":13,"manzil":3,"page":252,"ruku":207,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1731,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1731.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1731.mp3"],"text":"سَلَٰمٌ عَلَيْكُم بِمَا صَبَرْتُمْ ۚ فَنِعْمَ عُقْبَى ٱلدَّارِ","numberInSurah":24,"juz":13,"manzil":3,"page":252,"ruku":207,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1732,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1732.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1732.mp3"],"text":"وَٱلَّذِينَ يَنقُضُونَ عَهْدَ ٱللَّهِ مِنۢ بَعْدِ مِيثَٰقِهِۦ وَيَقْطَعُونَ مَآ أَمَرَ ٱللَّهُ بِهِۦٓ أَن يُوصَلَ وَيُفْسِدُونَ فِى ٱلْأَرْضِ ۙ أُو۟لَٰٓئِكَ لَهُمُ ٱللَّعْنَةُ وَلَهُمْ سُوٓءُ ٱلدَّارِ","numberInSurah":25,"juz":13,"manzil":3,"page":252,"ruku":207,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1733,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1733.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1733.mp3"],"text":"ٱللَّهُ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ وَفَرِحُوا۟ بِٱلْحَيَوٰةِ ٱلدُّنْيَا وَمَا ٱلْحَيَوٰةُ ٱلدُّنْيَا فِى ٱلْءَاخِرَةِ إِلَّا مَتَٰعٌۭ","numberInSurah":26,"juz":13,"manzil":3,"page":252,"ruku":207,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1734,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1734.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1734.mp3"],"text":"وَيَقُولُ ٱلَّذِينَ كَفَرُوا۟ لَوْلَآ أُنزِلَ عَلَيْهِ ءَايَةٌۭ مِّن رَّبِّهِۦ ۗ قُلْ إِنَّ ٱللَّهَ يُضِلُّ مَن يَشَآءُ وَيَهْدِىٓ إِلَيْهِ مَنْ أَنَابَ","numberInSurah":27,"juz":13,"manzil":3,"page":252,"ruku":208,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1735,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1735.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1735.mp3"],"text":"ٱلَّذِينَ ءَامَنُوا۟ وَتَطْمَئِنُّ قُلُوبُهُم بِذِكْرِ ٱللَّهِ ۗ أَلَا بِذِكْرِ ٱللَّهِ تَطْمَئِنُّ ٱلْقُلُوبُ","numberInSurah":28,"juz":13,"manzil":3,"page":252,"ruku":208,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1736,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1736.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1736.mp3"],"text":"ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ طُوبَىٰ لَهُمْ وَحُسْنُ مَـَٔابٍۢ","numberInSurah":29,"juz":13,"manzil":3,"page":253,"ruku":208,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1737,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1737.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1737.mp3"],"text":"كَذَٰلِكَ أَرْسَلْنَٰكَ فِىٓ أُمَّةٍۢ قَدْ خَلَتْ مِن قَبْلِهَآ أُمَمٌۭ لِّتَتْلُوَا۟ عَلَيْهِمُ ٱلَّذِىٓ أَوْحَيْنَآ إِلَيْكَ وَهُمْ يَكْفُرُونَ بِٱلرَّحْمَٰنِ ۚ قُلْ هُوَ رَبِّى لَآ إِلَٰهَ إِلَّا هُوَ عَلَيْهِ تَوَكَّلْتُ وَإِلَيْهِ مَتَابِ","numberInSurah":30,"juz":13,"manzil":3,"page":253,"ruku":208,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1738,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1738.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1738.mp3"],"text":"وَلَوْ أَنَّ قُرْءَانًۭا سُيِّرَتْ بِهِ ٱلْجِبَالُ أَوْ قُطِّعَتْ بِهِ ٱلْأَرْضُ أَوْ كُلِّمَ بِهِ ٱلْمَوْتَىٰ ۗ بَل لِّلَّهِ ٱلْأَمْرُ جَمِيعًا ۗ أَفَلَمْ يَا۟يْـَٔسِ ٱلَّذِينَ ءَامَنُوٓا۟ أَن لَّوْ يَشَآءُ ٱللَّهُ لَهَدَى ٱلنَّاسَ جَمِيعًۭا ۗ وَلَا يَزَالُ ٱلَّذِينَ كَفَرُوا۟ تُصِيبُهُم بِمَا صَنَعُوا۟ قَارِعَةٌ أَوْ تَحُلُّ قَرِيبًۭا مِّن دَارِهِمْ حَتَّىٰ يَأْتِىَ وَعْدُ ٱللَّهِ ۚ إِنَّ ٱللَّهَ لَا يُخْلِفُ ٱلْمِيعَادَ","numberInSurah":31,"juz":13,"manzil":3,"page":253,"ruku":208,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1739,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1739.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1739.mp3"],"text":"وَلَقَدِ ٱسْتُهْزِئَ بِرُسُلٍۢ مِّن قَبْلِكَ فَأَمْلَيْتُ لِلَّذِينَ كَفَرُوا۟ ثُمَّ أَخَذْتُهُمْ ۖ فَكَيْفَ كَانَ عِقَابِ","numberInSurah":32,"juz":13,"manzil":3,"page":253,"ruku":209,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1740,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1740.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1740.mp3"],"text":"أَفَمَنْ هُوَ قَآئِمٌ عَلَىٰ كُلِّ نَفْسٍۭ بِمَا كَسَبَتْ ۗ وَجَعَلُوا۟ لِلَّهِ شُرَكَآءَ قُلْ سَمُّوهُمْ ۚ أَمْ تُنَبِّـُٔونَهُۥ بِمَا لَا يَعْلَمُ فِى ٱلْأَرْضِ أَم بِظَٰهِرٍۢ مِّنَ ٱلْقَوْلِ ۗ بَلْ زُيِّنَ لِلَّذِينَ كَفَرُوا۟ مَكْرُهُمْ وَصُدُّوا۟ عَنِ ٱلسَّبِيلِ ۗ وَمَن يُضْلِلِ ٱللَّهُ فَمَا لَهُۥ مِنْ هَادٍۢ","numberInSurah":33,"juz":13,"manzil":3,"page":253,"ruku":209,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1741,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1741.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1741.mp3"],"text":"لَّهُمْ عَذَابٌۭ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَلَعَذَابُ ٱلْءَاخِرَةِ أَشَقُّ ۖ وَمَا لَهُم مِّنَ ٱللَّهِ مِن وَاقٍۢ","numberInSurah":34,"juz":13,"manzil":3,"page":253,"ruku":209,"hizbQuarter":101,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}}],"surahs":{"13":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},"edition":{}}}