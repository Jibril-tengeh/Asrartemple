{"code":200,"status":"OK","data":{"number":112,"ayahs":[{"number":2012,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2012.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2012.mp3"],"text":"۞ يَوْمَ تَأْتِى كُلُّ نَفْسٍۢ تُجَٰدِلُ عَن نَّفْسِهَا وَتُوَفَّىٰ كُلُّ نَفْسٍۢ مَّا عَمِلَتْ وَهُمْ لَا يُظْلَمُونَ","numberInSurah":111,"juz":14,"manzil":3,"page":280,"ruku":238,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2013,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2013.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2013.mp3"],"text":"وَضَرَبَ ٱللَّهُ مَثَلًۭا قَرْيَةًۭ كَانَتْ ءَامِنَةًۭ مُّطْمَئِنَّةًۭ يَأْتِيهَا رِزْقُهَا رَغَدًۭا مِّن كُلِّ مَكَانٍۢ فَكَفَرَتْ بِأَنْعُمِ ٱللَّهِ فَأَذَٰقَهَا ٱللَّهُ لِبَاسَ ٱلْجُوعِ وَٱلْخَوْفِ بِمَا كَانُوا۟ يَصْنَعُونَ","numberInSurah":112,"juz":14,"manzil":3,"page":280,"ruku":238,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2014,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2014.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2014.mp3"],"text":"وَلَقَدْ جَآءَهُمْ رَسُولٌۭ مِّنْهُمْ فَكَذَّبُوهُ فَأَخَذَهُمُ ٱلْعَذَابُ وَهُمْ ظَٰلِمُونَ","numberInSurah":113,"juz":14,"manzil":3,"page":280,"ruku":238,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2015,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2015.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2015.mp3"],"text":"فَكُلُوا۟ مِمَّا رَزَقَكُمُ ٱللَّهُ حَلَٰلًۭا طَيِّبًۭا وَٱشْكُرُوا۟ نِعْمَتَ ٱللَّهِ إِن كُنتُمْ إِيَّاهُ تَعْبُدُونَ","numberInSurah":114,"juz":14,"manzil":3,"page":280,"ruku":238,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2016,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2016.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2016.mp3"],"text":"إِنَّمَا حَرَّمَ عَلَيْكُمُ ٱلْمَيْتَةَ وَٱلدَّمَ وَلَحْمَ ٱلْخِنزِيرِ وَمَآ أُهِلَّ لِغَيْرِ ٱللَّهِ بِهِۦ ۖ فَمَنِ ٱضْطُرَّ غَيْرَ بَاغٍۢ وَلَا عَادٍۢ فَإِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","numberInSurah":115,"juz":14,"manzil":3,"page":280,"ruku":238,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2017,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2017.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2017.mp3"],"text":"وَلَا تَقُولُوا۟ لِمَا تَصِفُ أَلْسِنَتُكُمُ ٱلْكَذِبَ هَٰذَا حَلَٰلٌۭ وَهَٰذَا حَرَامٌۭ لِّتَفْتَرُوا۟ عَلَى ٱللَّهِ ٱلْكَذِبَ ۚ إِنَّ ٱلَّذِينَ يَفْتَرُونَ عَلَى ٱللَّهِ ٱلْكَذِبَ لَا يُفْلِحُونَ","numberInSurah":116,"juz":14,"manzil":3,"page":280,"ruku":238,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2018,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2018.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2018.mp3"],"text":"مَتَٰعٌۭ قَلِيلٌۭ وَلَهُمْ عَذَابٌ أَلِيمٌۭ","numberInSurah":117,"juz":14,"manzil":3,"page":280,"ruku":238,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2019,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2019.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2019.mp3"],"text":"وَعَلَى ٱلَّذِينَ هَادُوا۟ حَرَّمْنَا مَا قَصَصْنَا عَلَيْكَ مِن قَبْلُ ۖ وَمَا ظَلَمْنَٰهُمْ وَلَٰكِن كَانُوٓا۟ أَنفُسَهُمْ يَظْلِمُونَ","numberInSurah":118,"juz":14,"manzil":3,"page":280,"ruku":238,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2020,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2020.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2020.mp3"],"text":"ثُمَّ إِنَّ رَبَّكَ لِلَّذِينَ عَمِلُوا۟ ٱلسُّوٓءَ بِجَهَٰلَةٍۢ ثُمَّ تَابُوا۟ مِنۢ بَعْدِ ذَٰلِكَ وَأَصْلَحُوٓا۟ إِنَّ رَبَّكَ مِنۢ بَعْدِهَا لَغَفُورٌۭ رَّحِيمٌ","numberInSurah":119,"juz":14,"manzil":3,"page":281,"ruku":238,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2021,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2021.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2021.mp3"],"text":"إِنَّ إِبْرَٰهِيمَ كَانَ أُمَّةًۭ قَانِتًۭا لِّلَّهِ حَنِيفًۭا وَلَمْ يَكُ مِنَ ٱلْمُشْرِكِينَ","numberInSurah":120,"juz":14,"manzil":3,"page":281,"ruku":239,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2022,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2022.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2022.mp3"],"text":"شَاكِرًۭا لِّأَنْعُمِهِ ۚ ٱجْتَبَىٰهُ وَهَدَىٰهُ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","numberInSurah":121,"juz":14,"manzil":3,"page":281,"ruku":239,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2023,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2023.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2023.mp3"],"text":"وَءَاتَيْنَٰهُ فِى ٱلدُّنْيَا حَسَنَةًۭ ۖ وَإِنَّهُۥ فِى ٱلْءَاخِرَةِ لَمِنَ ٱلصَّٰلِحِينَ","numberInSurah":122,"juz":14,"manzil":3,"page":281,"ruku":239,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2024,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2024.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2024.mp3"],"text":"ثُمَّ أَوْحَيْنَآ إِلَيْكَ أَنِ ٱتَّبِعْ مِلَّةَ إِبْرَٰهِيمَ حَنِيفًۭا ۖ وَمَا كَانَ مِنَ ٱلْمُشْرِكِينَ","numberInSurah":123,"juz":14,"manzil":3,"page":281,"ruku":239,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2025,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2025.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2025.mp3"],"text":"إِنَّمَا جُعِلَ ٱلسَّبْتُ عَلَى ٱلَّذِينَ ٱخْتَلَفُوا۟ فِيهِ ۚ وَإِنَّ رَبَّكَ لَيَحْكُمُ بَيْنَهُمْ يَوْمَ ٱلْقِيَٰمَةِ فِيمَا كَانُوا۟ فِيهِ يَخْتَلِفُونَ","numberInSurah":124,"juz":14,"manzil":3,"page":281,"ruku":239,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2026,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2026.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2026.mp3"],"text":"ٱدْعُ إِلَىٰ سَبِيلِ رَبِّكَ بِٱلْحِكْمَةِ وَٱلْمَوْعِظَةِ ٱلْحَسَنَةِ ۖ وَجَٰدِلْهُم بِٱلَّتِى هِىَ أَحْسَنُ ۚ إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ ۖ وَهُوَ أَعْلَمُ بِٱلْمُهْتَدِينَ","numberInSurah":125,"juz":14,"manzil":3,"page":281,"ruku":239,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2027,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2027.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2027.mp3"],"text":"وَإِنْ عَاقَبْتُمْ فَعَاقِبُوا۟ بِمِثْلِ مَا عُوقِبْتُم بِهِۦ ۖ وَلَئِن صَبَرْتُمْ لَهُوَ خَيْرٌۭ لِّلصَّٰبِرِينَ","numberInSurah":126,"juz":14,"manzil":3,"page":281,"ruku":239,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2028,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2028.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2028.mp3"],"text":"وَٱصْبِرْ وَمَا صَبْرُكَ إِلَّا بِٱللَّهِ ۚ وَلَا تَحْزَنْ عَلَيْهِمْ وَلَا تَكُ فِى ضَيْقٍۢ مِّمَّا يَمْكُرُونَ","numberInSurah":127,"juz":14,"manzil":3,"page":281,"ruku":239,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":2029,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2029.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2029.mp3"],"text":"إِنَّ ٱللَّهَ مَعَ ٱلَّذِينَ ٱتَّقَوا۟ وَّٱلَّذِينَ هُم مُّحْسِنُونَ","numberInSurah":128,"juz":14,"manzil":3,"page":281,"ruku":239,"hizbQuarter":112,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}}],"surahs":{"16":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},"edition":{}}}