{"code":200,"status":"OK","data":{"number":204,"ayahs":[{"number":4578,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4578.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4578.mp3"],"text":"۞ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ أَطِيعُوا۟ ٱللَّهَ وَأَطِيعُوا۟ ٱلرَّسُولَ وَلَا تُبْطِلُوٓا۟ أَعْمَٰلَكُمْ","numberInSurah":33,"juz":26,"manzil":6,"page":510,"ruku":445,"hizbQuarter":204,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4579,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4579.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4579.mp3"],"text":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ وَصَدُّوا۟ عَن سَبِيلِ ٱللَّهِ ثُمَّ مَاتُوا۟ وَهُمْ كُفَّارٌۭ فَلَن يَغْفِرَ ٱللَّهُ لَهُمْ","numberInSurah":34,"juz":26,"manzil":6,"page":510,"ruku":445,"hizbQuarter":204,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4580,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4580.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4580.mp3"],"text":"فَلَا تَهِنُوا۟ وَتَدْعُوٓا۟ إِلَى ٱلسَّلْمِ وَأَنتُمُ ٱلْأَعْلَوْنَ وَٱللَّهُ مَعَكُمْ وَلَن يَتِرَكُمْ أَعْمَٰلَكُمْ","numberInSurah":35,"juz":26,"manzil":6,"page":510,"ruku":445,"hizbQuarter":204,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4581,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4581.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4581.mp3"],"text":"إِنَّمَا ٱلْحَيَوٰةُ ٱلدُّنْيَا لَعِبٌۭ وَلَهْوٌۭ ۚ وَإِن تُؤْمِنُوا۟ وَتَتَّقُوا۟ يُؤْتِكُمْ أُجُورَكُمْ وَلَا يَسْـَٔلْكُمْ أَمْوَٰلَكُمْ","numberInSurah":36,"juz":26,"manzil":6,"page":510,"ruku":445,"hizbQuarter":204,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4582,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4582.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4582.mp3"],"text":"إِن يَسْـَٔلْكُمُوهَا فَيُحْفِكُمْ تَبْخَلُوا۟ وَيُخْرِجْ أَضْغَٰنَكُمْ","numberInSurah":37,"juz":26,"manzil":6,"page":510,"ruku":445,"hizbQuarter":204,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4583,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4583.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4583.mp3"],"text":"هَٰٓأَنتُمْ هَٰٓؤُلَآءِ تُدْعَوْنَ لِتُنفِقُوا۟ فِى سَبِيلِ ٱللَّهِ فَمِنكُم مَّن يَبْخَلُ ۖ وَمَن يَبْخَلْ فَإِنَّمَا يَبْخَلُ عَن نَّفْسِهِۦ ۚ وَٱللَّهُ ٱلْغَنِىُّ وَأَنتُمُ ٱلْفُقَرَآءُ ۚ وَإِن تَتَوَلَّوْا۟ يَسْتَبْدِلْ قَوْمًا غَيْرَكُمْ ثُمَّ لَا يَكُونُوٓا۟ أَمْثَٰلَكُم","numberInSurah":38,"juz":26,"manzil":6,"page":510,"ruku":445,"hizbQuarter":204,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4584,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4584.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4584.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّا فَتَحْنَا لَكَ فَتْحًۭا مُّبِينًۭا","numberInSurah":1,"juz":26,"manzil":6,"page":511,"ruku":446,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4585,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4585.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4585.mp3"],"text":"لِّيَغْفِرَ لَكَ ٱللَّهُ مَا تَقَدَّمَ مِن ذَنۢبِكَ وَمَا تَأَخَّرَ وَيُتِمَّ نِعْمَتَهُۥ عَلَيْكَ وَيَهْدِيَكَ صِرَٰطًۭا مُّسْتَقِيمًۭا","numberInSurah":2,"juz":26,"manzil":6,"page":511,"ruku":446,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4586,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4586.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4586.mp3"],"text":"وَيَنصُرَكَ ٱللَّهُ نَصْرًا عَزِيزًا","numberInSurah":3,"juz":26,"manzil":6,"page":511,"ruku":446,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4587,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4587.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4587.mp3"],"text":"هُوَ ٱلَّذِىٓ أَنزَلَ ٱلسَّكِينَةَ فِى قُلُوبِ ٱلْمُؤْمِنِينَ لِيَزْدَادُوٓا۟ إِيمَٰنًۭا مَّعَ إِيمَٰنِهِمْ ۗ وَلِلَّهِ جُنُودُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَكَانَ ٱللَّهُ عَلِيمًا حَكِيمًۭا","numberInSurah":4,"juz":26,"manzil":6,"page":511,"ruku":446,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4588,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4588.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4588.mp3"],"text":"لِّيُدْخِلَ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَا وَيُكَفِّرَ عَنْهُمْ سَيِّـَٔاتِهِمْ ۚ وَكَانَ ذَٰلِكَ عِندَ ٱللَّهِ فَوْزًا عَظِيمًۭا","numberInSurah":5,"juz":26,"manzil":6,"page":511,"ruku":446,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4589,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4589.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4589.mp3"],"text":"وَيُعَذِّبَ ٱلْمُنَٰفِقِينَ وَٱلْمُنَٰفِقَٰتِ وَٱلْمُشْرِكِينَ وَٱلْمُشْرِكَٰتِ ٱلظَّآنِّينَ بِٱللَّهِ ظَنَّ ٱلسَّوْءِ ۚ عَلَيْهِمْ دَآئِرَةُ ٱلسَّوْءِ ۖ وَغَضِبَ ٱللَّهُ عَلَيْهِمْ وَلَعَنَهُمْ وَأَعَدَّ لَهُمْ جَهَنَّمَ ۖ وَسَآءَتْ مَصِيرًۭا","numberInSurah":6,"juz":26,"manzil":6,"page":511,"ruku":446,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4590,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4590.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4590.mp3"],"text":"وَلِلَّهِ جُنُودُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَكَانَ ٱللَّهُ عَزِيزًا حَكِيمًا","numberInSurah":7,"juz":26,"manzil":6,"page":511,"ruku":446,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4591,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4591.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4591.mp3"],"text":"إِنَّآ أَرْسَلْنَٰكَ شَٰهِدًۭا وَمُبَشِّرًۭا وَنَذِيرًۭا","numberInSurah":8,"juz":26,"manzil":6,"page":511,"ruku":446,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4592,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4592.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4592.mp3"],"text":"لِّتُؤْمِنُوا۟ بِٱللَّهِ وَرَسُولِهِۦ وَتُعَزِّرُوهُ وَتُوَقِّرُوهُ وَتُسَبِّحُوهُ بُكْرَةًۭ وَأَصِيلًا","numberI