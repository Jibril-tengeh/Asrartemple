page":512,"ruku":447,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4596,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4596.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4596.mp3"],"text":"وَمَن لَّمْ يُؤْمِنۢ بِٱللَّهِ وَرَسُولِهِۦ فَإِنَّآ أَعْتَدْنَا لِلْكَٰفِرِينَ سَعِيرًۭا","numberInSurah":13,"juz":26,"manzil":6,"page":512,"ruku":447,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4597,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4597.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4597.mp3"],"text":"وَلِلَّهِ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ يَغْفِرُ لِمَن يَشَآءُ وَيُعَذِّبُ مَن يَشَآءُ ۚ وَكَانَ ٱللَّهُ غَفُورًۭا رَّحِيمًۭا","numberInSurah":14,"juz":26,"manzil":6,"page":512,"ruku":447,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4598,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4598.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4598.mp3"],"text":"سَيَقُولُ ٱلْمُخَلَّفُونَ إِذَا ٱنطَلَقْتُمْ إِلَىٰ مَغَانِمَ لِتَأْخُذُوهَا ذَرُونَا نَتَّبِعْكُمْ ۖ يُرِيدُونَ أَن يُبَدِّلُوا۟ كَلَٰمَ ٱللَّهِ ۚ قُل لَّن تَتَّبِعُونَا كَذَٰلِكُمْ قَالَ ٱللَّهُ مِن قَبْلُ ۖ فَسَيَقُولُونَ بَلْ تَحْسُدُونَنَا ۚ بَلْ كَانُوا۟ لَا يَفْقَهُونَ إِلَّا قَلِيلًۭا","numberInSurah":15,"juz":26,"manzil":6,"page":512,"ruku":447,"hizbQuarter":204,"sajda":false,"surah":{"number":48,"name":"سُورَةُ الفَتۡحِ","englishName":"Al-Fath","englishNameTranslation":"The Victory","revelationType":"Medinan"}},{"number":4599,"audio":"https://cdn.islamic.netw