amic.network/quran/audio/64/ar.alafasy/4342.mp3"],"text":"وَإِذَا بُشِّرَ أَحَدُهُم بِمَا ضَرَبَ لِلرَّحْمَٰنِ مَثَلًۭا ظَلَّ وَجْهُهُۥ مُسْوَدًّۭا وَهُوَ كَظِيمٌ","numberInSurah":17,"juz":25,"manzil":6,"page":490,"ruku":425,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4343,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4343.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4343.mp3"],"text":"أَوَمَن يُنَشَّؤُا۟ فِى ٱلْحِلْيَةِ وَهُوَ فِى ٱلْخِصَامِ غَيْرُ مُبِينٍۢ","numberInSurah":18,"juz":25,"manzil":6,"page":490,"ruku":425,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4344,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4344.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4344.mp3"],"text":"وَجَعَلُوا۟ ٱلْمَلَٰٓئِكَةَ ٱلَّذِينَ هُمْ عِبَٰدُ ٱلرَّحْمَٰنِ إِنَٰثًا ۚ أَشَهِدُوا۟ خَلْقَهُمْ ۚ سَتُكْتَبُ شَهَٰدَتُهُمْ وَيُسْـَٔلُونَ","numberInSurah":19,"juz":25,"manzil":6,"page":490,"ruku":425,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4345,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4345.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4345.mp3"],"text":"وَقَالُوا۟ لَوْ شَآءَ ٱلرَّحْمَٰنُ مَا عَبَدْنَٰهُم ۗ مَّا لَهُم بِذَٰلِكَ مِنْ عِلْمٍ ۖ إِنْ هُمْ إِلَّا يَخْرُصُونَ","numberInSurah":20,"juz":25,"manzil":6,"page":490,"ruku":425,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4346,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4346.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4346.mp3"],"text":"أَمْ ءَاتَيْنَٰهُمْ كِتَٰبًۭا مِّن قَبْلِهِۦ فَهُم بِهِۦ مُسْتَمْسِكُونَ","numberInSurah":21,"juz":25,"manzil":6,"page":490,"ruku":425,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4347,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4347.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4347.mp3"],"text":"بَلْ قَالُوٓا۟ إِنَّا وَجَدْنَآ ءَابَآءَنَا عَلَىٰٓ أُمَّةٍۢ وَإِنَّا عَلَىٰٓ ءَاثَٰرِهِم مُّهْتَدُونَ","numberInSurah":22,"juz":25,"manzil":6,"page":490,"ruku":425,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4348,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4348.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4348.mp3"],"text":"وَكَذَٰلِكَ مَآ أَرْسَلْنَا مِن قَبْلِكَ فِى قَرْيَةٍۢ مِّن نَّذِيرٍ إِلَّا قَالَ مُتْرَفُوهَآ إِنَّا وَجَدْنَآ ءَابَآءَنَا عَلَىٰٓ أُمَّةٍۢ وَإِنَّا عَلَىٰٓ ءَاثَٰرِهِم مُّقْتَدُونَ","numberInSurah":23,"juz":25,"manzil":6,"page":491,"ruku":425,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}}],"surahs":{"42":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"},"43":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},"edition":{}}}