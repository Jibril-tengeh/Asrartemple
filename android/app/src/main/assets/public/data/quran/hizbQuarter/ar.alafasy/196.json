{"code":200,"status":"OK","data":{"number":196,"ayahs":[{"number":4323,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4323.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4323.mp3"],"text":"۞ وَمَا كَانَ لِبَشَرٍ أَن يُكَلِّمَهُ ٱللَّهُ إِلَّا وَحْيًا أَوْ مِن وَرَآئِ حِجَابٍ أَوْ يُرْسِلَ رَسُولًۭا فَيُوحِىَ بِإِذْنِهِۦ مَا يَشَآءُ ۚ إِنَّهُۥ عَلِىٌّ حَكِيمٌۭ","numberInSurah":51,"juz":25,"manzil":6,"page":488,"ruku":423,"hizbQuarter":196,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4324,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4324.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4324.mp3"],"text":"وَكَذَٰلِكَ أَوْحَيْنَآ إِلَيْكَ رُوحًۭا مِّنْ أَمْرِنَا ۚ مَا كُنتَ تَدْرِى مَا ٱلْكِتَٰبُ وَلَا ٱلْإِيمَٰنُ وَلَٰكِن جَعَلْنَٰهُ نُورًۭا نَّهْدِى بِهِۦ مَن نَّشَآءُ مِنْ عِبَادِنَا ۚ وَإِنَّكَ لَتَهْدِىٓ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","numberInSurah":52,"juz":25,"manzil":6,"page":489,"ruku":423,"hizbQuarter":196,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4325,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4325.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4325.mp3"],"text":"صِرَٰطِ ٱللَّهِ ٱلَّذِى لَهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۗ أَلَآ إِلَى ٱللَّهِ تَصِيرُ ٱلْأُمُورُ","numberInSurah":53,"juz":25,"manzil":6,"page":489,"ruku":423,"hizbQuarter":196,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4326,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4326.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4326.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ حمٓ","numberInSurah":1,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4327,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4327.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4327.mp3"],"text":"وَٱلْكِتَٰبِ ٱلْمُبِينِ","numberInSurah":2,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4328,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4328.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4328.mp3"],"text":"إِنَّا جَعَلْنَٰهُ قُرْءَٰنًا عَرَبِيًّۭا لَّعَلَّكُمْ تَعْقِلُونَ","numberInSurah":3,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4329,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4329.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4329.mp3"],"text":"وَإِنَّهُۥ فِىٓ أُمِّ ٱلْكِتَٰبِ لَدَيْنَا لَعَلِىٌّ حَكِيمٌ","numberInSurah":4,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4330,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4330.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4330.mp3"],"text":"أَفَنَضْرِبُ عَنكُمُ ٱلذِّكْرَ صَفْحًا أَن كُنتُمْ قَوْمًۭا مُّسْرِفِينَ","numberInSurah":5,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4331,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4331.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4331.mp3"],"text":"وَكَمْ أَرْسَلْنَا مِن نَّبِىٍّۢ فِى ٱلْأَوَّلِينَ","numberInSurah":6,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4332,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4332.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4332.mp3"],"text":"وَمَا يَأْتِيهِم مِّن نَّبِىٍّ إِلَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","numberInSurah":7,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4333,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4333.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4333.mp3"],"text":"فَأَهْلَكْنَآ أَشَدَّ مِنْهُم بَطْشًۭا وَمَضَىٰ مَثَلُ ٱلْأَوَّلِينَ","numberInSurah":8,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4334,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4334.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4334.mp3"],"text":"وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ لَيَقُولُنَّ خَلَقَهُنَّ ٱلْعَزِيزُ ٱلْعَلِيمُ","numberInSurah":9,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4335,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4335.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4335.mp3"],"text":"ٱلَّذِى جَعَلَ لَكُمُ ٱلْأَرْضَ مَهْدًۭا وَجَعَلَ لَكُمْ فِيهَا سُبُلًۭا لَّعَلَّكُمْ تَهْتَدُونَ","numberInSurah":10,"juz":25,"manzil":6,"page":489,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4336,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4336.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4336.mp3"],"text":"وَٱلَّذِى نَزَّلَ مِنَ ٱلسَّمَآءِ مَآءًۢ بِقَدَرٍۢ فَأَنشَرْنَا بِهِۦ بَلْدَةًۭ مَّيْتًۭا ۚ كَذَٰلِكَ تُخْرَجُونَ","numberInSurah":11,"juz":25,"manzil":6,"page":490,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4337,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4337.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4337.mp3"],"text":"وَٱلَّذِى خَلَقَ ٱلْأَزْوَٰجَ كُلَّهَا وَجَعَلَ لَكُم مِّنَ ٱلْفُلْكِ وَٱلْأَنْعَٰمِ مَا تَرْكَبُونَ","numberInSurah":12,"juz":25,"manzil":6,"page":490,"ruku":424,"hizbQuarter":196,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4338,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4338.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4338.mp3"],"text":"لِتَسْتَوُۥا