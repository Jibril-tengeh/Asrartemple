{"code":200,"status":"OK","data":{"number":136,"ayahs":[{"number":2655,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2655.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2655.mp3"],"text":"۞ ذَٰلِكَ وَمَنْ عَاقَبَ بِمِثْلِ مَا عُوقِبَ بِهِۦ ثُمَّ بُغِىَ عَلَيْهِ لَيَنصُرَنَّهُ ٱللَّهُ ۗ إِنَّ ٱللَّهَ لَعَفُوٌّ غَفُورٌۭ","numberInSurah":60,"juz":17,"manzil":4,"page":339,"ruku":292,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2656,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2656.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2656.mp3"],"text":"ذَٰلِكَ بِأَنَّ ٱللَّهَ يُولِجُ ٱلَّيْلَ فِى ٱلنَّهَارِ وَيُولِجُ ٱلنَّهَارَ فِى ٱلَّيْلِ وَأَنَّ ٱللَّهَ سَمِيعٌۢ بَصِيرٌۭ","numberInSurah":61,"juz":17,"manzil":4,"page":339,"ruku":292,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2657,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2657.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2657.mp3"],"text":"ذَٰلِكَ بِأَنَّ ٱللَّهَ هُوَ ٱلْحَقُّ وَأَنَّ مَا يَدْعُونَ مِن دُونِهِۦ هُوَ ٱلْبَٰطِلُ وَأَنَّ ٱللَّهَ هُوَ ٱلْعَلِىُّ ٱلْكَبِيرُ","numberInSurah":62,"juz":17,"manzil":4,"page":339,"ruku":292,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2658,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2658.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2658.mp3"],"text":"أَلَمْ تَرَ أَنَّ ٱللَّهَ أَنزَلَ مِنَ ٱلسَّمَآءِ مَآءًۭ فَتُصْبِحُ ٱلْأَرْضُ مُخْضَرَّةً ۗ إِنَّ ٱللَّهَ لَطِيفٌ خَبِيرٌۭ","numberInSurah":63,"juz":17,"manzil":4,"page":339,"ruku":292,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2659,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2659.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2659.mp3"],"text":"لَّهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۗ وَإِنَّ ٱللَّهَ لَهُوَ ٱلْغَنِىُّ ٱلْحَمِيدُ","numberInSurah":64,"juz":17,"manzil":4,"page":339,"ruku":292,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2660,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2660.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2660.mp3"],"text":"أَلَمْ تَرَ أَنَّ ٱللَّهَ سَخَّرَ لَكُم مَّا فِى ٱلْأَرْضِ وَٱلْفُلْكَ تَجْرِى فِى ٱلْبَحْرِ بِأَمْرِهِۦ وَيُمْسِكُ ٱلسَّمَآءَ أَن تَقَعَ عَلَى ٱلْأَرْضِ إِلَّا بِإِذْنِهِۦٓ ۗ إِنَّ ٱللَّهَ بِٱلنَّاسِ لَرَءُوفٌۭ رَّحِيمٌۭ","numberInSurah":65,"juz":17,"manzil":4,"page":340,"ruku":293,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2661,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2661.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2661.mp3"],"text":"وَهُوَ ٱلَّذِىٓ أَحْيَاكُمْ ثُمَّ يُمِيتُكُمْ ثُمَّ يُحْيِيكُمْ ۗ إِنَّ ٱلْإِنسَٰنَ لَكَفُورٌۭ","numberInSurah":66,"juz":17,"manzil":4,"page":340,"ruku":293,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2662,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2662.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2662.mp3"],"text":"لِّكُلِّ أُمَّةٍۢ جَعَلْنَا مَنسَكًا هُمْ نَاسِكُوهُ ۖ فَلَا يُنَٰزِعُنَّكَ فِى ٱلْأَمْرِ ۚ وَٱدْعُ إِلَىٰ رَبِّكَ ۖ إِنَّكَ لَعَلَىٰ هُدًۭى مُّسْتَقِيمٍۢ","numberInSurah":67,"juz":17,"manzil":4,"page":340,"ruku":293,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2663,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2663.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2663.mp3"],"text":"وَإِن جَٰدَلُوكَ فَقُلِ ٱللَّهُ أَعْلَمُ بِمَا تَعْمَلُونَ","numberInSurah":68,"juz":17,"manzil":4,"page":340,"ruku":293,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2664,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2664.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2664.mp3"],"text":"ٱللَّهُ يَحْكُمُ بَيْنَكُمْ يَوْمَ ٱلْقِيَٰمَةِ فِيمَا كُنتُمْ فِيهِ تَخْتَلِفُونَ","numberInSurah":69,"juz":17,"manzil":4,"page":340,"ruku":293,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2665,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2665.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2665.mp3"],"text":"أَلَمْ تَعْلَمْ أَنَّ ٱللَّهَ يَعْلَمُ مَا فِى ٱلسَّمَآءِ وَٱلْأَرْضِ ۗ إِنَّ ذَٰلِكَ فِى كِتَٰبٍ ۚ إِنَّ ذَٰلِكَ عَلَى ٱللَّهِ يَسِيرٌۭ","numberInSurah":70,"juz":17,"manzil":4,"page":340,"ruku":293,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2666,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2666.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2666.mp3"],"text":"وَيَعْبُدُونَ مِن دُونِ ٱللَّهِ مَا لَمْ يُنَزِّلْ بِهِۦ سُلْطَٰنًۭا وَمَا لَيْسَ لَهُم بِهِۦ عِلْمٌۭ ۗ وَمَا لِلظَّٰلِمِينَ مِن نَّصِيرٍۢ","numberInSurah":71,"juz":17,"manzil":4,"page":340,"ruku":293,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2667,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2667.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2667.mp3"],"text":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍۢ تَعْرِفُ فِى وُجُوهِ ٱلَّذِينَ كَفَرُوا۟ ٱلْمُنكَرَ ۖ يَكَادُونَ يَسْطُونَ بِٱلَّذِينَ يَتْلُونَ عَلَيْهِمْ ءَايَٰتِنَا ۗ قُلْ أَفَأُنَبِّئُكُم بِشَرٍّۢ مِّن ذَٰلِكُمُ ۗ ٱلنَّارُ وَعَدَهَا ٱللَّهُ ٱلَّذِينَ كَفَرُوا۟ ۖ وَبِئْسَ ٱلْمَصِيرُ","numberInSurah":72,"juz":17,"manzil":4,"page":340,"ruku":293,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2668,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2668.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2668.mp3"],"text":"يَٰٓأَيُّهَا ٱلنَّاسُ ضُرِبَ مَثَلٌۭ فَٱسْتَمِعُوا۟ لَهُۥٓ ۚ إِنَّ ٱلَّذِينَ تَدْعُونَ مِن دُونِ ٱللَّهِ لَن يَخْلُقُوا۟ ذُبَابًۭا وَلَوِ ٱجْتَمَعُوا۟ لَهُۥ ۖ وَإِن يَسْلُبْهُمُ ٱلذُّبَابُ شَيْـًۭٔا لَّا يَسْتَنقِذُوهُ مِنْهُ ۚ ضَعُفَ ٱلطَّالِبُ وَٱلْمَطْلُوبُ","numberInSurah":73,"juz":17,"manzil":4,"page":341,"ruku":294,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2669,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2669.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2669.mp3"],"text":"مَا قَدَرُوا۟ ٱللَّهَ حَقَّ قَدْرِهِۦٓ ۗ إِنَّ ٱللَّهَ لَقَوِىٌّ عَزِيزٌ","numberInSurah":74,"juz":17,"manzil":4,"page":341,"ruku":294,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2670,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2670.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2670.mp3"],"text":"ٱللَّهُ يَصْطَفِى مِنَ ٱلْمَلَٰٓئِكَةِ رُسُلًۭا وَمِنَ ٱلنَّاسِ ۚ إِنَّ ٱللَّهَ سَمِيعٌۢ بَصِيرٌۭ","numberInSurah":75,"juz":17,"manzil":4,"page":341,"ruku":294,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2671,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2671.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2671.mp3"],"text":"يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ ۗ وَإِلَى ٱللَّهِ تُرْجَعُ ٱلْأُمُورُ","numberInSurah":76,"juz":17,"manzil":4,"page":341,"ruku":294,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2672,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2672.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2672.mp3"],"text":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱرْكَعُوا۟ وَٱسْجُدُوا۟ وَٱعْبُدُوا۟ رَبَّكُمْ وَٱفْعَلُوا۟ ٱلْخَيْرَ لَعَلَّكُمْ تُفْلِحُونَ ۩","numberInSurah":77,"juz":17,"manzil":4,"page":341,"ruku":294,"hizbQuarter":136,"sajda":{"id":7,"recommended":true,"obligatory":false},"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2673,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2673.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2673.mp3"],"text":"وَجَٰهِدُوا۟ فِى ٱللَّهِ حَقَّ جِهَادِهِۦ ۚ هُوَ ٱجْتَبَىٰكُمْ وَمَا جَعَلَ عَلَيْكُمْ فِى ٱلدِّينِ مِنْ حَرَجٍۢ ۚ مِّلَّةَ أَبِيكُمْ إِبْرَٰهِيمَ ۚ هُوَ سَمَّىٰكُمُ ٱلْمُسْلِمِينَ مِن قَبْلُ وَفِى هَٰذَا لِيَكُونَ ٱلرَّسُولُ شَهِيدًا عَلَيْكُمْ وَتَكُونُوا۟ شُهَدَآءَ عَلَى ٱلنَّاسِ ۚ فَأَقِيمُوا۟ ٱلصَّلَوٰةَ وَءَاتُوا۟ ٱلزَّكَوٰةَ وَٱعْتَصِمُوا۟ بِٱللَّهِ هُوَ مَوْلَىٰكُمْ ۖ فَنِعْمَ ٱلْمَوْلَىٰ وَنِعْمَ ٱلنَّصِيرُ","numberInSurah":78,"juz":17,"manzil":4,"page":341,"ruku":294,"hizbQuarter":136,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}}],"surahs":{"22":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},"edition":{}}}