{"code":200,"status":"OK","data":{"number":186,"ayahs":[{"number":4111,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4111.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4111.mp3"],"text":"۞ قُلْ يَٰعِبَادِىَ ٱلَّذِينَ أَسْرَفُوا۟ عَلَىٰٓ أَنفُسِهِمْ لَا تَقْنَطُوا۟ مِن رَّحْمَةِ ٱللَّهِ ۚ إِنَّ ٱللَّهَ يَغْفِرُ ٱلذُّنُوبَ جَمِيعًا ۚ إِنَّهُۥ هُوَ ٱلْغَفُورُ ٱلرَّحِيمُ","numberInSurah":53,"juz":24,"manzil":6,"page":464,"ruku":401,"hizbQuarter":186,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4112,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4112.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4112.mp3"],"text":"وَأَنِيبُوٓا۟ إِلَىٰ رَبِّكُمْ وَأَسْلِمُوا۟ لَهُۥ مِن قَبْلِ أَن يَأْتِيَكُمُ ٱلْعَذَابُ ثُمَّ لَا تُنصَرُونَ","numberInSurah":54,"juz":24,"manzil":6,"page":464,"ruku":401,"hizbQuarter":186,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4113,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4113.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4113.mp3"],"text":"وَٱتَّبِعُوٓا۟ أَحْسَنَ مَآ أُنزِلَ إِلَيْكُم مِّن رَّبِّكُم مِّن قَبْلِ أَن يَأْتِيَكُمُ ٱلْعَذَابُ بَغْتَةًۭ وَأَنتُمْ لَا تَشْعُرُونَ","numberInSurah":55,"juz":24,"manzil":6,"page":464,"ruku":401,"hizbQuarter":186,"sajda":false,"surah":{"number":39,"name":"سُورَةُ الزُّمَرِ","englishName":"Az-Zumar","englishNameTranslation":"The Groups","revelationType":"Meccan"}},{"number":4114,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4114.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4114.mp3"],"text":"أَن تَقُولَ نَفْسٌۭ يَٰحَسْرَتَىٰ عَلَىٰ مَا فَرَّطتُ فِى جَنۢبِ ٱللَّهِ وَإِن كُنتُ لَمِ