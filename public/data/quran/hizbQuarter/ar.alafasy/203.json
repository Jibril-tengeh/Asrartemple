{"code":200,"status":"OK","data":{"number":203,"ayahs":[{"number":4555,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4555.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4555.mp3"],"text":"۞ أَفَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَيَنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ مِن قَبْلِهِمْ ۚ دَمَّرَ ٱللَّهُ عَلَيْهِمْ ۖ وَلِلْكَٰفِرِينَ أَمْثَٰلُهَا","numberInSurah":10,"juz":26,"manzil":6,"page":507,"ruku":442,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4556,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4556.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4556.mp3"],"text":"ذَٰلِكَ بِأَنَّ ٱللَّهَ مَوْلَى ٱلَّذِينَ ءَامَنُوا۟ وَأَنَّ ٱلْكَٰفِرِينَ لَا مَوْلَىٰ لَهُمْ","numberInSurah":11,"juz":26,"manzil":6,"page":507,"ruku":442,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4557,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4557.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4557.mp3"],"text":"إِنَّ ٱللَّهَ يُدْخِلُ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۖ وَٱلَّذِينَ كَفَرُوا۟ يَتَمَتَّعُونَ وَيَأْكُلُونَ كَمَا تَأْكُلُ ٱلْأَنْعَٰمُ وَٱلنَّارُ مَثْوًۭى لَّهُمْ","numberInSurah":12,"juz":26,"manzil":6,"page":508,"ruku":443,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4558,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4558.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4558.mp3"],"text":"وَكَأَيِّن مِّن قَرْيَةٍ هِىَ أَشَدُّ قُوَّةًۭ مِّن قَرْيَتِكَ ٱلَّتِىٓ أَخْرَجَتْكَ أَهْلَكْنَٰهُمْ فَلَا نَاصِرَ لَهُمْ","numberInSurah":13,"juz":26,"manzil":6,"page":508,"ruku":443,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4559,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4559.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4559.mp3"],"text":"أَفَمَن كَانَ عَلَىٰ بَيِّنَةٍۢ مِّن رَّبِّهِۦ كَمَن زُيِّنَ لَهُۥ سُوٓءُ عَمَلِهِۦ وَٱتَّبَعُوٓا۟ أَهْوَآءَهُم","numberInSurah":14,"juz":26,"manzil":6,"page":508,"ruku":443,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4560,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4560.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4560.mp3"],"text":"مَّثَلُ ٱلْجَنَّةِ ٱلَّتِى وُعِدَ ٱلْمُتَّقُونَ ۖ فِيهَآ أَنْهَٰرٌۭ مِّن مَّآءٍ غَيْرِ ءَاسِنٍۢ وَأَنْهَٰرٌۭ مِّن لَّبَنٍۢ لَّمْ يَتَغَيَّرْ طَعْمُهُۥ وَأَنْهَٰرٌۭ مِّنْ خَمْرٍۢ لَّذَّةٍۢ لِّلشَّٰرِبِينَ وَأَنْهَٰرٌۭ مِّنْ عَسَلٍۢ مُّصَفًّۭى ۖ وَلَهُمْ فِيهَا مِن كُلِّ ٱلثَّمَرَٰتِ وَمَغْفِرَةٌۭ مِّن رَّبِّهِمْ ۖ كَمَنْ هُوَ خَٰلِدٌۭ فِى ٱلنَّارِ وَسُقُوا۟ مَآءً حَمِيمًۭا فَقَطَّعَ أَمْعَآءَهُمْ","numberInSurah":15,"juz":26,"manzil":6,"page":508,"ruku":443,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4561,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4561.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4561.mp3"],"text":"وَمِنْهُم مَّن يَسْتَمِعُ إِلَيْكَ حَتَّىٰٓ إِذَا خَرَجُوا۟ مِنْ عِندِكَ قَالُوا۟ لِلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ مَاذَا قَالَ ءَانِفًا ۚ أُو۟لَٰٓئِكَ ٱلَّذِينَ طَبَعَ ٱللَّهُ عَلَىٰ قُلُوبِهِمْ وَٱتَّبَعُوٓا۟ أَهْوَآءَهُمْ","numberInSurah":16,"juz":26,"manzil":6,"page":508,"ruku":443,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4562,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4562.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4562.mp3"],"text":"وَٱلَّذِينَ ٱهْتَدَوْا۟ زَادَهُمْ هُدًۭى وَءَاتَىٰهُمْ تَقْوَىٰهُمْ","numberInSurah":17,"juz":26,"manzil":6,"page":508,"ruku":443,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4563,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4563.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4563.mp3"],"text":"فَهَلْ يَنظُرُونَ إِلَّا ٱلسَّاعَةَ أَن تَأْتِيَهُم بَغْتَةًۭ ۖ فَقَدْ جَآءَ أَشْرَاطُهَا ۚ فَأَنَّىٰ لَهُمْ إِذَا جَآءَتْهُمْ ذِكْرَىٰهُمْ","numberInSurah":18,"juz":26,"manzil":6,"page":508,"ruku":443,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4564,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4564.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4564.mp3"],"text":"فَٱعْلَمْ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا ٱللَّهُ وَٱسْتَغْفِرْ لِذَنۢبِكَ وَلِلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ ۗ وَٱللَّهُ يَعْلَمُ مُتَقَلَّبَكُمْ وَمَثْوَىٰكُمْ","numberInSurah":19,"juz":26,"manzil":6,"page":508,"ruku":443,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4565,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4565.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4565.mp3"],"text":"وَيَقُولُ ٱلَّذِينَ ءَامَنُوا۟ لَوْلَا نُزِّلَتْ سُورَةٌۭ ۖ فَإِذَآ أُنزِلَتْ سُورَةٌۭ مُّحْكَمَةٌۭ وَذُكِرَ فِيهَا ٱلْقِتَالُ ۙ رَأَيْتَ ٱلَّذِينَ فِى قُلُوبِهِم مَّرَضٌۭ يَنظُرُونَ إِلَيْكَ نَظَرَ ٱلْمَغْشِىِّ عَلَيْهِ مِنَ ٱلْمَوْتِ ۖ فَأَوْلَىٰ لَهُمْ","numberInSurah":20,"juz":26,"manzil":6,"page":509,"ruku":444,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4566,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4566.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4566.mp3"],"text":"طَاعَةٌۭ وَقَوْلٌۭ مَّعْرُوفٌۭ ۚ فَإِذَا عَزَمَ ٱلْأَمْرُ فَلَوْ صَدَقُوا۟ ٱللَّهَ لَكَانَ خَيْرًۭا لَّهُمْ","numberInSurah":21,"juz":26,"manzil":6,"page":509,"ruku":444,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4567,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4567.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4567.mp3"],"text":"فَهَلْ عَسَيْتُمْ إِن تَوَلَّيْتُمْ أَن تُفْسِدُوا۟ فِى ٱلْأَرْضِ وَتُقَطِّعُوٓا۟ أَرْحَامَكُمْ","numberInSurah":22,"juz":26,"manzil":6,"page":509,"ruku":444,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4568,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4568.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4568.mp3"],"text":"أُو۟لَٰٓئِكَ ٱلَّذِينَ لَعَنَهُمُ ٱللَّهُ فَأَصَمَّهُمْ وَأَعْمَىٰٓ أَبْصَٰرَهُمْ","numberInSurah":23,"juz":26,"manzil":6,"page":509,"ruku":444,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4569,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4569.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4569.mp3"],"text":"أَفَلَا يَتَدَبَّرُونَ ٱلْقُرْءَانَ أَمْ عَلَىٰ قُلُوبٍ أَقْفَالُهَآ","numberInSurah":24,"juz":26,"manzil":6,"page":509,"ruku":444,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4570,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4570.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4570.mp3"],"text":"إِنَّ ٱلَّذِينَ ٱرْتَدُّوا۟ عَلَىٰٓ أَدْبَٰرِهِم مِّنۢ بَعْدِ مَا تَبَيَّنَ لَهُمُ ٱلْهُدَى ۙ ٱلشَّيْطَٰنُ سَوَّلَ لَهُمْ وَأَمْلَىٰ لَهُمْ","numberInSurah":25,"juz":26,"manzil":6,"page":509,"ruku":444,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4571,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4571.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4571.mp3"],"text":"ذَٰلِكَ بِأَنَّهُمْ قَالُوا۟ لِلَّذِينَ كَرِهُوا۟ مَا نَزَّلَ ٱللَّهُ سَنُطِيعُكُمْ فِى بَعْضِ ٱلْأَمْرِ ۖ وَٱللَّهُ يَعْلَمُ إِسْرَارَهُمْ","numberInSurah":26,"juz":26,"manzil":6,"page":509,"ruku":444,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4572,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4572.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4572.mp3"],"text":"فَكَيْفَ إِذَا تَوَفَّتْهُمُ ٱلْمَلَٰٓئِكَةُ يَضْرِبُونَ وُجُوهَهُمْ وَأَدْبَٰرَهُمْ","numberInSurah":27,"juz":26,"manzil":6,"page":509,"ruku":444,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4573,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4573.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4573.mp3"],"text":"ذَٰلِكَ بِأَنَّهُمُ ٱتَّبَعُوا۟ مَآ أَسْخَطَ ٱللَّهَ وَكَرِهُوا۟ رِضْوَٰنَهُۥ فَأَحْبَطَ أَعْمَٰلَهُمْ","numberInSurah":28,"juz":26,"manzil":6,"page":509,"ruku":444,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4574,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4574.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4574.mp3"],"text":"أَمْ حَسِبَ ٱلَّذِينَ فِى قُلُوبِهِم مَّرَضٌ أَن لَّن يُخْرِجَ ٱللَّهُ أَضْغَٰنَهُمْ","numberInSurah":29,"juz":26,"manzil":6,"page":509,"ruku":445,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4575,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4575.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4575.mp3"],"text":"وَلَوْ نَشَآءُ لَأَرَيْنَٰكَهُمْ فَلَعَرَفْتَهُم بِسِيمَٰهُمْ ۚ وَلَتَعْرِفَنَّهُمْ فِى لَحْنِ ٱلْقَوْلِ ۚ وَٱللَّهُ يَعْلَمُ أَعْمَٰلَكُمْ","numberInSurah":30,"juz":26,"manzil":6,"page":510,"ruku":445,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4576,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4576.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4576.mp3"],"text":"وَلَنَبْلُوَنَّكُمْ حَتَّىٰ نَعْلَمَ ٱلْمُجَٰهِدِينَ مِنكُمْ وَٱلصَّٰبِرِينَ وَنَبْلُوَا۟ أَخْبَارَكُمْ","numberInSurah":31,"juz":26,"manzil":6,"page":510,"ruku":445,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},{"number":4577,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4577.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4577.mp3"],"text":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ وَصَدُّوا۟ عَن سَبِيلِ ٱللَّهِ وَشَآقُّوا۟ ٱلرَّسُولَ مِنۢ بَعْدِ مَا تَبَيَّنَ لَهُمُ ٱلْهُدَىٰ لَن يَضُرُّوا۟ ٱللَّهَ شَيْـًۭٔا وَسَيُحْبِطُ أَعْمَٰلَهُمْ","numberInSurah":32,"juz":26,"manzil":6,"page":510,"ruku":445,"hizbQuarter":203,"sajda":false,"surah":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}}],"surahs":{"47":{"number":47,"name":"سُورَةُ مُحَمَّدٍ","englishName":"Muhammad","englishNameTranslation":"Muhammad","revelationType":"Medinan"}},"edition":{}}}