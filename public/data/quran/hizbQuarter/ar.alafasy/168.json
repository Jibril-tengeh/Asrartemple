{"code":200,"status":"OK","data":{"number":168,"ayahs":[{"number":3551,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3551.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3551.mp3"],"text":"۞ قَدْ يَعْلَمُ ٱللَّهُ ٱلْمُعَوِّقِينَ مِنكُمْ وَٱلْقَآئِلِينَ لِإِخْوَٰنِهِمْ هَلُمَّ إِلَيْنَا ۖ وَلَا يَأْتُونَ ٱلْبَأْسَ إِلَّا قَلِيلًا","numberInSurah":18,"juz":21,"manzil":5,"page":420,"ruku":362,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3552,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3552.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3552.mp3"],"text":"أَشِحَّةً عَلَيْكُمْ ۖ فَإِذَا جَآءَ ٱلْخَوْفُ رَأَيْتَهُمْ يَنظُرُونَ إِلَيْكَ تَدُورُ أَعْيُنُهُمْ كَٱلَّذِى يُغْشَىٰ عَلَيْهِ مِنَ ٱلْمَوْتِ ۖ فَإِذَا ذَهَبَ ٱلْخَوْفُ سَلَقُوكُم بِأَلْسِنَةٍ حِدَادٍ أَشِحَّةً عَلَى ٱلْخَيْرِ ۚ أُو۟لَٰٓئِكَ لَمْ يُؤْمِنُوا۟ فَأَحْبَطَ ٱللَّهُ أَعْمَٰلَهُمْ ۚ وَكَانَ ذَٰلِكَ عَلَى ٱللَّهِ يَسِيرًۭا","numberInSurah":19,"juz":21,"manzil":5,"page":420,"ruku":362,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3553,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3553.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3553.mp3"],"text":"يَحْسَبُونَ ٱلْأَحْزَابَ لَمْ يَذْهَبُوا۟ ۖ وَإِن يَأْتِ ٱلْأَحْزَابُ يَوَدُّوا۟ لَوْ أَنَّهُم بَادُونَ فِى ٱلْأَعْرَابِ يَسْـَٔلُونَ عَنْ أَنۢبَآئِكُمْ ۖ وَلَوْ كَانُوا۟ فِيكُم مَّا قَٰتَلُوٓا۟ إِلَّا قَلِيلًۭا","numberInSurah":20,"juz":21,"manzil":5,"page":420,"ruku":362,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3554,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3554.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3554.mp3"],"text":"لَّقَدْ كَانَ لَكُمْ فِى رَسُولِ ٱللَّهِ أُسْوَةٌ حَسَنَةٌۭ لِّمَن كَانَ يَرْجُوا۟ ٱللَّهَ وَٱلْيَوْمَ ٱلْءَاخِرَ وَذَكَرَ ٱللَّهَ كَثِيرًۭا","numberInSurah":21,"juz":21,"manzil":5,"page":420,"ruku":363,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3555,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3555.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3555.mp3"],"text":"وَلَمَّا رَءَا ٱلْمُؤْمِنُونَ ٱلْأَحْزَابَ قَالُوا۟ هَٰذَا مَا وَعَدَنَا ٱللَّهُ وَرَسُولُهُۥ وَصَدَقَ ٱللَّهُ وَرَسُولُهُۥ ۚ وَمَا زَادَهُمْ إِلَّآ إِيمَٰنًۭا وَتَسْلِيمًۭا","numberInSurah":22,"juz":21,"manzil":5,"page":420,"ruku":363,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3556,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3556.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3556.mp3"],"text":"مِّنَ ٱلْمُؤْمِنِينَ رِجَالٌۭ صَدَقُوا۟ مَا عَٰهَدُوا۟ ٱللَّهَ عَلَيْهِ ۖ فَمِنْهُم مَّن قَضَىٰ نَحْبَهُۥ وَمِنْهُم مَّن يَنتَظِرُ ۖ وَمَا بَدَّلُوا۟ تَبْدِيلًۭا","numberInSurah":23,"juz":21,"manzil":5,"page":421,"ruku":363,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3557,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3557.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3557.mp3"],"text":"لِّيَجْزِىَ ٱللَّهُ ٱلصَّٰدِقِينَ بِصِدْقِهِمْ وَيُعَذِّبَ ٱلْمُنَٰفِقِينَ إِن شَآءَ أَوْ يَتُوبَ عَلَيْهِمْ ۚ إِنَّ ٱللَّهَ كَانَ غَفُورًۭا رَّحِيمًۭا","numberInSurah":24,"juz":21,"manzil":5,"page":421,"ruku":363,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3558,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3558.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3558.mp3"],"text":"وَرَدَّ ٱللَّهُ ٱلَّذِينَ كَفَرُوا۟ بِغَيْظِهِمْ لَمْ يَنَالُوا۟ خَيْرًۭا ۚ وَكَفَى ٱللَّهُ ٱلْمُؤْمِنِينَ ٱلْقِتَالَ ۚ وَكَانَ ٱللَّهُ قَوِيًّا عَزِيزًۭا","numberInSurah":25,"juz":21,"manzil":5,"page":421,"ruku":363,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3559,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3559.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3559.mp3"],"text":"وَأَنزَلَ ٱلَّذِينَ ظَٰهَرُوهُم مِّنْ أَهْلِ ٱلْكِتَٰبِ مِن صَيَاصِيهِمْ وَقَذَفَ فِى قُلُوبِهِمُ ٱلرُّعْبَ فَرِيقًۭا تَقْتُلُونَ وَتَأْسِرُونَ فَرِيقًۭا","numberInSurah":26,"juz":21,"manzil":5,"page":421,"ruku":363,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3560,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3560.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3560.mp3"],"text":"وَأَوْرَثَكُمْ أَرْضَهُمْ وَدِيَٰرَهُمْ وَأَمْوَٰلَهُمْ وَأَرْضًۭا لَّمْ تَطَـُٔوهَا ۚ وَكَانَ ٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرًۭا","numberInSurah":27,"juz":21,"manzil":5,"page":421,"ruku":363,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3561,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3561.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3561.mp3"],"text":"يَٰٓأَيُّهَا ٱلنَّبِىُّ قُل لِّأَزْوَٰجِكَ إِن كُنتُنَّ تُرِدْنَ ٱلْحَيَوٰةَ ٱلدُّنْيَا وَزِينَتَهَا فَتَعَالَيْنَ أُمَتِّعْكُنَّ وَأُسَرِّحْكُنَّ سَرَاحًۭا جَمِيلًۭا","numberInSurah":28,"juz":21,"manzil":5,"page":421,"ruku":364,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3562,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3562.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3562.mp3"],"text":"وَإِن كُنتُنَّ تُرِدْنَ ٱللَّهَ وَرَسُولَهُۥ وَٱلدَّارَ ٱلْءَاخِرَةَ فَإِنَّ ٱللَّهَ أَعَدَّ لِلْمُحْسِنَٰتِ مِنكُنَّ أَجْرًا عَظِيمًۭا","numberInSurah":29,"juz":21,"manzil":5,"page":421,"ruku":364,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},{"number":3563,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3563.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3563.mp3"],"text":"يَٰنِسَآءَ ٱلنَّبِىِّ مَن يَأْتِ مِنكُنَّ بِفَٰحِشَةٍۢ مُّبَيِّنَةٍۢ يُضَٰعَفْ لَهَا ٱلْعَذَابُ ضِعْفَيْنِ ۚ وَكَانَ ذَٰلِكَ عَلَى ٱللَّهِ يَسِيرًۭا","numberInSurah":30,"juz":21,"manzil":5,"page":421,"ruku":364,"hizbQuarter":168,"sajda":false,"surah":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}}],"surahs":{"33":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"}},"edition":{}}}