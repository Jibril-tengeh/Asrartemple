{"code":200,"status":"OK","data":{"number":178,"ayahs":[{"number":3765,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3765.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3765.mp3"],"text":"۞ أَلَمْ أَعْهَدْ إِلَيْكُمْ يَٰبَنِىٓ ءَادَمَ أَن لَّا تَعْبُدُوا۟ ٱلشَّيْطَٰنَ ۖ إِنَّهُۥ لَكُمْ عَدُوٌّۭ مُّبِينٌۭ","numberInSurah":60,"juz":23,"manzil":5,"page":444,"ruku":384,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3766,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3766.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3766.mp3"],"text":"وَأَنِ ٱعْبُدُونِى ۚ هَٰذَا صِرَٰطٌۭ مُّسْتَقِيمٌۭ","numberInSurah":61,"juz":23,"manzil":5,"page":444,"ruku":384,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3767,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3767.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3767.mp3"],"text":"وَلَقَدْ أَضَلَّ مِنكُمْ جِبِلًّۭا كَثِيرًا ۖ أَفَلَمْ تَكُونُوا۟ تَعْقِلُونَ","numberInSurah":62,"juz":23,"manzil":5,"page":444,"ruku":384,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3768,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3768.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3768.mp3"],"text":"هَٰذِهِۦ جَهَنَّمُ ٱلَّتِى كُنتُمْ تُوعَدُونَ","numberInSurah":63,"juz":23,"manzil":5,"page":444,"ruku":384,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3769,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3769.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3769.mp3"],"text":"ٱصْلَوْهَا ٱلْيَوْمَ بِمَا كُنتُمْ تَكْفُرُونَ","numberInSurah":64,"juz":23,"manzil":5,"page":444,"ruku":384,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3770,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3770.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3770.mp3"],"text":"ٱلْيَوْمَ نَخْتِمُ عَلَىٰٓ أَفْوَٰهِهِمْ وَتُكَلِّمُنَآ أَيْدِيهِمْ وَتَشْهَدُ أَرْجُلُهُم بِمَا كَانُوا۟ يَكْسِبُونَ","numberInSurah":65,"juz":23,"manzil":5,"page":444,"ruku":384,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3771,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3771.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3771.mp3"],"text":"وَلَوْ نَشَآءُ لَطَمَسْنَا عَلَىٰٓ أَعْيُنِهِمْ فَٱسْتَبَقُوا۟ ٱلصِّرَٰطَ فَأَنَّىٰ يُبْصِرُونَ","numberInSurah":66,"juz":23,"manzil":5,"page":444,"ruku":384,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3772,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3772.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3772.mp3"],"text":"وَلَوْ نَشَآءُ لَمَسَخْنَٰهُمْ عَلَىٰ مَكَانَتِهِمْ فَمَا ٱسْتَطَٰعُوا۟ مُضِيًّۭا وَلَا يَرْجِعُونَ","numberInSurah":67,"juz":23,"manzil":5,"page":444,"ruku":384,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3773,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3773.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3773.mp3"],"text":"وَمَن نُّعَمِّرْهُ نُنَكِّسْهُ فِى ٱلْخَلْقِ ۖ أَفَلَا يَعْقِلُونَ","numberInSurah":68,"juz":23,"manzil":5,"page":444,"ruku":385,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3774,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3774.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3774.mp3"],"text":"وَمَا عَلَّمْنَٰهُ ٱلشِّعْرَ وَمَا يَنۢبَغِى لَهُۥٓ ۚ إِنْ هُوَ إِلَّا ذِكْرٌۭ وَقُرْءَانٌۭ مُّبِينٌۭ","numberInSurah":69,"juz":23,"manzil":5,"page":444,"ruku":385,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3775,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3775.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3775.mp3"],"text":"لِّيُنذِرَ مَن كَانَ حَيًّۭا وَيَحِقَّ ٱلْقَوْلُ عَلَى ٱلْكَٰفِرِينَ","numberInSurah":70,"juz":23,"manzil":5,"page":444,"ruku":385,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3776,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3776.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3776.mp3"],"text":"أَوَلَمْ يَرَوْا۟ أَنَّا خَلَقْنَا لَهُم مِّمَّا عَمِلَتْ أَيْدِينَآ أَنْعَٰمًۭا فَهُمْ لَهَا مَٰلِكُونَ","numberInSurah":71,"juz":23,"manzil":5,"page":445,"ruku":385,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3777,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3777.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3777.mp3"],"text":"وَذَلَّلْنَٰهَا لَهُمْ فَمِنْهَا رَكُوبُهُمْ وَمِنْهَا يَأْكُلُونَ","numberInSurah":72,"juz":23,"manzil":5,"page":445,"ruku":385,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3778,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3778.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3778.mp3"],"text":"وَلَهُمْ فِيهَا مَنَٰفِعُ وَمَشَارِبُ ۖ أَفَلَا يَشْكُرُونَ","numberInSurah":73,"juz":23,"manzil":5,"page":445,"ruku":385,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3779,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3779.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3779.mp3"],"text":"وَٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ ءَالِهَةًۭ لَّعَلَّهُمْ يُنصَرُونَ","numberInSurah":74,"juz":23,"manzil":5,"page":445,"ruku":385,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3780,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3780.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3780.mp3"],"text":"لَا يَسْتَطِيعُونَ نَصْرَهُمْ وَهُمْ لَهُمْ جُندٌۭ مُّحْضَرُونَ","numberInSurah":75,"juz":23,"manzil":5,"page":445,"ruku":385,"hizbQuarter":178,"sajda":false,"surah":{"number":36,"name":"سُورَةُ يسٓ","englishName":"Yaseen","englishNameTranslation":"Yaseen","revelationType":"Meccan"}},{"number":3781,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3781.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3781.mp3"],"text":"فَلَا يَحْزُنكَ قَوْلُهُمْ ۘ إِنَّا نَعْلَمُ مَا يُسِرُّونَ وَمَا يُعْلِ