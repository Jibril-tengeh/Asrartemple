{"code":200,"status":"OK","data":{"number":195,"ayahs":[{"number":4299,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4299.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4299.mp3"],"text":"۞ وَلَوْ بَسَطَ ٱللَّهُ ٱلرِّزْقَ لِعِبَادِهِۦ لَبَغَوْا۟ فِى ٱلْأَرْضِ وَلَٰكِن يُنَزِّلُ بِقَدَرٍۢ مَّا يَشَآءُ ۚ إِنَّهُۥ بِعِبَادِهِۦ خَبِيرٌۢ بَصِيرٌۭ","numberInSurah":27,"juz":25,"manzil":6,"page":486,"ruku":421,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4300,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4300.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4300.mp3"],"text":"وَهُوَ ٱلَّذِى يُنَزِّلُ ٱلْغَيْثَ مِنۢ بَعْدِ مَا قَنَطُوا۟ وَيَنشُرُ رَحْمَتَهُۥ ۚ وَهُوَ ٱلْوَلِىُّ ٱلْحَمِيدُ","numberInSurah":28,"juz":25,"manzil":6,"page":486,"ruku":421,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4301,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4301.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4301.mp3"],"text":"وَمِنْ ءَايَٰتِهِۦ خَلْقُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَثَّ فِيهِمَا مِن دَآبَّةٍۢ ۚ وَهُوَ عَلَىٰ جَمْعِهِمْ إِذَا يَشَآءُ قَدِيرٌۭ","numberInSurah":29,"juz":25,"manzil":6,"page":486,"ruku":421,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4302,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4302.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4302.mp3"],"text":"وَمَآ أَصَٰبَكُم مِّن مُّصِيبَةٍۢ فَبِمَا كَسَبَتْ أَيْدِيكُمْ وَيَعْفُوا۟ عَن كَثِيرٍۢ","numberInSurah":30,"juz":25,"manzil":6,"page":486,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4303,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4303.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4303.mp3"],"text":"وَمَآ أَنتُم بِمُعْجِزِينَ فِى ٱلْأَرْضِ ۖ وَمَا لَكُم مِّن دُونِ ٱللَّهِ مِن وَلِىٍّۢ وَلَا نَصِيرٍۢ","numberInSurah":31,"juz":25,"manzil":6,"page":486,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4304,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4304.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4304.mp3"],"text":"وَمِنْ ءَايَٰتِهِ ٱلْجَوَارِ فِى ٱلْبَحْرِ كَٱلْأَعْلَٰمِ","numberInSurah":32,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4305,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4305.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4305.mp3"],"text":"إِن يَشَأْ يُسْكِنِ ٱلرِّيحَ فَيَظْلَلْنَ رَوَاكِدَ عَلَىٰ ظَهْرِهِۦٓ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّكُلِّ صَبَّارٍۢ شَكُورٍ","numberInSurah":33,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4306,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4306.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4306.mp3"],"text":"أَوْ يُوبِقْهُنَّ بِمَا كَسَبُوا۟ وَيَعْفُ عَن كَثِيرٍۢ","numberInSurah":34,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4307,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4307.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4307.mp3"],"text":"وَيَعْلَمَ ٱلَّذِينَ يُجَٰدِلُونَ فِىٓ ءَايَٰتِنَا مَا لَهُم مِّن مَّحِيصٍۢ","numberInSurah":35,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4308,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4308.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4308.mp3"],"text":"فَمَآ أُوتِيتُم مِّن شَىْءٍۢ فَمَتَٰعُ ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَمَا عِندَ ٱللَّهِ خَيْرٌۭ وَأَبْقَىٰ لِلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ","numberInSurah":36,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4309,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4309.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4309.mp3"],"text":"وَٱلَّذِينَ يَجْتَنِبُونَ كَبَٰٓئِرَ ٱلْإِثْمِ وَٱلْفَوَٰحِشَ وَإِذَا مَا غَضِبُوا۟ هُمْ يَغْفِرُونَ","numberInSurah":37,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4310,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4310.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4310.mp3"],"text":"وَٱلَّذِينَ ٱسْتَجَابُوا۟ لِرَبِّهِمْ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَأَمْرُهُمْ شُورَىٰ بَيْنَهُمْ وَمِمَّا رَزَقْنَٰهُمْ يُنفِقُونَ","numberInSurah":38,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4311,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4311.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4311.mp3"],"text":"وَٱلَّذِينَ إِذَآ أَصَابَهُمُ ٱلْبَغْىُ هُمْ يَنتَصِرُونَ","numberInSurah":39,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4312,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4312.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4312.mp3"],"text":"وَجَزَٰٓؤُا۟ سَيِّئَةٍۢ سَيِّئَةٌۭ مِّثْلُهَا ۖ فَمَنْ عَفَا وَأَصْلَحَ فَأَجْرُهُۥ عَلَى ٱللَّهِ ۚ إِنَّهُۥ لَا يُحِبُّ ٱلظَّٰلِمِينَ","numberInSurah":40,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4313,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4313.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4313.mp3"],"text":"وَلَمَنِ ٱنتَصَرَ بَعْدَ ظُلْمِهِۦ فَأُو۟لَٰٓئِكَ مَا عَلَيْهِم مِّن سَبِيلٍ","numberInSurah":41,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4314,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4314.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4314.mp3"],"text":"إِنَّمَا ٱلسَّبِيلُ عَلَى ٱلَّذِينَ يَظْلِمُونَ ٱلنَّاسَ وَيَبْغُونَ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ ۚ أُو۟لَٰٓئِكَ لَهُمْ عَذَابٌ أَلِيمٌۭ","numberInSurah":42,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4315,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4315.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4315.mp3"],"text":"وَلَمَن صَبَرَ وَغَفَرَ إِنَّ ذَٰلِكَ لَمِنْ عَزْمِ ٱلْأُمُورِ","numberInSurah":43,"juz":25,"manzil":6,"page":487,"ruku":422,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4316,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4316.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4316.mp3"],"text":"وَمَن يُضْلِلِ ٱللَّهُ فَمَا لَهُۥ مِن وَلِىٍّۢ مِّنۢ بَعْدِهِۦ ۗ وَتَرَى ٱلظَّٰلِمِينَ لَمَّا رَأَوُا۟ ٱلْعَذَابَ يَقُولُونَ هَلْ إِلَىٰ مَرَدٍّۢ مِّن سَبِيلٍۢ","numberInSurah":44,"juz":25,"manzil":6,"page":487,"ruku":423,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4317,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4317.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4317.mp3"],"text":"وَتَرَىٰهُمْ يُعْرَضُونَ عَلَيْهَا خَٰشِعِينَ مِنَ ٱلذُّلِّ يَنظُرُونَ مِن طَرْفٍ خَفِىٍّۢ ۗ وَقَالَ ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ ٱلْخَٰسِرِينَ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُمْ وَأَهْلِيهِمْ يَوْمَ ٱلْقِيَٰمَةِ ۗ أَلَآ إِنَّ ٱلظَّٰلِمِينَ فِى عَذَابٍۢ مُّقِيمٍۢ","numberInSurah":45,"juz":25,"manzil":6,"page":488,"ruku":423,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4318,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4318.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4318.mp3"],"text":"وَمَا كَانَ لَهُم مِّنْ أَوْلِيَآءَ يَنصُرُونَهُم مِّن دُونِ ٱللَّهِ ۗ وَمَن يُضْلِلِ ٱللَّهُ فَمَا لَهُۥ مِن سَبِيلٍ","numberInSurah":46,"juz":25,"manzil":6,"page":488,"ruku":423,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4319,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4319.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4319.mp3"],"text":"ٱسْتَجِيبُوا۟ لِرَبِّكُم مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌۭ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِ ۚ مَا لَكُم مِّن مَّلْجَإٍۢ يَوْمَئِذٍۢ وَمَا لَكُم مِّن نَّكِيرٍۢ","numberInSurah":47,"juz":25,"manzil":6,"page":488,"ruku":423,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4320,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4320.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4320.mp3"],"text":"فَإِنْ أَعْرَضُوا۟ فَمَآ أَرْسَلْنَٰكَ عَلَيْهِمْ حَفِيظًا ۖ إِنْ عَلَيْكَ إِلَّا ٱلْبَلَٰغُ ۗ وَإِنَّآ إِذَآ أَذَقْنَا ٱلْإِنسَٰنَ مِنَّا رَحْمَةًۭ فَرِحَ بِهَا ۖ وَإِن تُصِبْهُمْ سَيِّئَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ فَإِنَّ ٱلْإِنسَٰنَ كَفُورٌۭ","numberInSurah":48,"juz":25,"manzil":6,"page":488,"ruku":423,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4321,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4321.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4321.mp3"],"text":"لِّلَّهِ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ يَخْلُقُ مَا يَشَآءُ ۚ يَهَبُ لِمَن يَشَآءُ إِنَٰثًۭا وَيَهَبُ لِمَن يَشَآءُ ٱلذُّكُورَ","numberInSurah":49,"juz":25,"manzil":6,"page":488,"ruku":423,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},{"number":4322,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4322.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4322.mp3"],"text":"أَوْ يُزَوِّجُهُمْ ذُكْرَانًۭا وَإِنَٰثًۭا ۖ وَيَجْعَلُ مَن يَشَآءُ عَقِيمًا ۚ إِنَّهُۥ عَلِيمٌۭ قَدِيرٌۭ","numberInSurah":50,"juz":25,"manzil":6,"page":488,"ruku":423,"hizbQuarter":195,"sajda":false,"surah":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}}],"surahs":{"42":{"number":42,"name":"سُورَةُ الشُّورَىٰ","englishName":"Ash-Shura","englishNameTranslation":"Consultation","revelationType":"Meccan"}},"edition":{}}}