{"code":200,"status":"OK","data":{"number":190,"ayahs":[{"number":4199,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4199.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4199.mp3"],"text":"۞ قُلْ إِنِّى نُهِيتُ أَنْ أَعْبُدَ ٱلَّذِينَ تَدْعُونَ مِن دُونِ ٱللَّهِ لَمَّا جَآءَنِىَ ٱلْبَيِّنَٰتُ مِن رَّبِّى وَأُمِرْتُ أَنْ أُسْلِمَ لِرَبِّ ٱلْعَٰلَمِينَ","numberInSurah":66,"juz":24,"manzil":6,"page":474,"ruku":410,"hizbQuarter":190,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4200,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4200.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4200.mp3"],"text":"هُوَ ٱلَّذِى خَلَقَكُم مِّن تُرَابٍۢ ثُمَّ مِن نُّطْفَةٍۢ ثُمَّ مِنْ عَلَقَةٍۢ ثُمَّ يُخْرِجُكُمْ طِفْلًۭا ثُمَّ لِتَبْلُغُوٓا۟ أَشُدَّكُمْ ثُمَّ لِتَكُونُوا۟ شُيُوخًۭا ۚ وَمِنكُم مَّن يُتَوَفَّىٰ مِن قَبْلُ ۖ وَلِتَبْلُغُوٓا۟ أَجَلًۭا مُّسَمًّۭى وَلَعَلَّكُمْ تَعْقِلُونَ","numberInSurah":67,"juz":24,"manzil":6,"page":475,"ruku":410,"hizbQuarter":190,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4201,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4201.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4201.mp3"],"text":"هُوَ ٱلَّذِى يُحْىِۦ وَيُمِيتُ ۖ فَإِذَا قَضَىٰٓ أَمْرًۭا فَإِنَّمَا يَقُولُ لَهُۥ كُن فَيَكُونُ","numberInSurah":68,"juz":24,"manzil":6,"page":475,"ruku":410,"hizbQuarter":190,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4202,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4202.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4202.mp3"],