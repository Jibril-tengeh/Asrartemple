giver","revelationType":"Meccan"}},{"number":4214,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4214.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4214.mp3"],"text":"وَيُرِيكُمْ ءَايَٰتِهِۦ فَأَىَّ ءَايَٰتِ ٱللَّهِ تُنكِرُونَ","numberInSurah":81,"juz":24,"manzil":6,"page":476,"ruku":412,"hizbQuarter":190,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4215,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4215.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4215.mp3"],"text":"أَفَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَيَنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ مِن قَبْلِهِمْ ۚ كَانُوٓا۟ أَكْثَرَ مِنْهُمْ وَأَشَدَّ قُوَّةًۭ وَءَاثَارًۭا فِى ٱلْأَرْضِ فَمَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يَكْسِبُونَ","numberInSurah":82,"juz":24,"manzil":6,"page":476,"ruku":412,"hizbQuarter":190,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4216,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4216.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4216.mp3"],"text":"فَلَمَّا جَآءَتْهُمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ فَرِحُوا۟ بِمَا عِندَهُم مِّنَ ٱلْعِلْمِ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","numberInSurah":83,"juz":24,"manzil":6,"page":476,"ruku":412,"hizbQuarter":190,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4217,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4217.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4217.mp3"],"text":"فَلَمَّا رَأَوْا۟ بَأْسَنَا قَالُوٓا۟ ءَامَنَّا بِٱللَّهِ وَحْدَهُۥ وَكَفَرْنَا بِمَا كُنَّا بِهِۦ مُشْرِكِينَ","numberInSurah":