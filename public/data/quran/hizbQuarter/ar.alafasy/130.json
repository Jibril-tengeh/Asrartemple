{"code":200,"status":"OK","data":{"number":130,"ayahs":[{"number":2512,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2512.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2512.mp3"],"text":"۞ وَمَن يَقُلْ مِنْهُمْ إِنِّىٓ إِلَٰهٌۭ مِّن دُونِهِۦ فَذَٰلِكَ نَجْزِيهِ جَهَنَّمَ ۚ كَذَٰلِكَ نَجْزِى ٱلظَّٰلِمِينَ","numberInSurah":29,"juz":17,"manzil":4,"page":324,"ruku":279,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2513,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2513.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2513.mp3"],"text":"أَوَلَمْ يَرَ ٱلَّذِينَ كَفَرُوٓا۟ أَنَّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ كَانَتَا رَتْقًۭا فَفَتَقْنَٰهُمَا ۖ وَجَعَلْنَا مِنَ ٱلْمَآءِ كُلَّ شَىْءٍ حَىٍّ ۖ أَفَلَا يُؤْمِنُونَ","numberInSurah":30,"juz":17,"manzil":4,"page":324,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2514,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2514.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2514.mp3"],"text":"وَجَعَلْنَا فِى ٱلْأَرْضِ رَوَٰسِىَ أَن تَمِيدَ بِهِمْ وَجَعَلْنَا فِيهَا فِجَاجًۭا سُبُلًۭا لَّعَلَّهُمْ يَهْتَدُونَ","numberInSurah":31,"juz":17,"manzil":4,"page":324,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2515,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2515.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2515.mp3"],"text":"وَجَعَلْنَا ٱلسَّمَآءَ سَقْفًۭا مَّحْفُوظًۭا ۖ وَهُمْ عَنْ ءَايَٰتِهَا مُعْرِضُونَ","numberInSurah":32,"juz":17,"manzil":4,"page":324,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2516,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2516.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2516.mp3"],"text":"وَهُوَ ٱلَّذِى خَلَقَ ٱلَّيْلَ وَٱلنَّهَارَ وَٱلشَّمْسَ وَٱلْقَمَرَ ۖ كُلٌّۭ فِى فَلَكٍۢ يَسْبَحُونَ","numberInSurah":33,"juz":17,"manzil":4,"page":324,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2517,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2517.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2517.mp3"],"text":"وَمَا جَعَلْنَا لِبَشَرٍۢ مِّن قَبْلِكَ ٱلْخُلْدَ ۖ أَفَإِي۟ن مِّتَّ فَهُمُ ٱلْخَٰلِدُونَ","numberInSurah":34,"juz":17,"manzil":4,"page":324,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2518,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2518.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2518.mp3"],"text":"كُلُّ نَفْسٍۢ ذَآئِقَةُ ٱلْمَوْتِ ۗ وَنَبْلُوكُم بِٱلشَّرِّ وَٱلْخَيْرِ فِتْنَةًۭ ۖ وَإِلَيْنَا تُرْجَعُونَ","numberInSurah":35,"juz":17,"manzil":4,"page":324,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2519,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2519.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2519.mp3"],"text":"وَإِذَا رَءَاكَ ٱلَّذِينَ كَفَرُوٓا۟ إِن يَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَٰذَا ٱلَّذِى يَذْكُرُ ءَالِهَتَكُمْ وَهُم بِذِكْرِ ٱلرَّحْمَٰنِ هُمْ كَٰفِرُونَ","numberInSurah":36,"juz":17,"manzil":4,"page":325,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2520,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2520.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2520.mp3"],"text":"خُلِقَ ٱلْإِنسَٰنُ مِنْ عَجَلٍۢ ۚ سَأُو۟رِيكُمْ ءَايَٰتِى فَلَا تَسْتَعْجِلُونِ","numberInSurah":37,"juz":17,"manzil":4,"page":325,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2521,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2521.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2521.mp3"],"text":"وَيَقُولُونَ مَتَىٰ هَٰذَا ٱلْوَعْدُ إِن كُنتُمْ صَٰدِقِينَ","numberInSurah":38,"juz":17,"manzil":4,"page":325,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2522,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2522.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2522.mp3"],"text":"لَوْ يَعْلَمُ ٱلَّذِينَ كَفَرُوا۟ حِينَ لَا يَكُفُّونَ عَن وُجُوهِهِمُ ٱلنَّارَ وَلَا عَن ظُهُورِهِمْ وَلَا هُمْ يُنصَرُونَ","numberInSurah":39,"juz":17,"manzil":4,"page":325,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2523,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2523.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2523.mp3"],"text":"بَلْ تَأْتِيهِم بَغْتَةًۭ فَتَبْهَتُهُمْ فَلَا يَسْتَطِيعُونَ رَدَّهَا وَلَا هُمْ يُنظَرُونَ","numberInSurah":40,"juz":17,"manzil":4,"page":325,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2524,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2524.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2524.mp3"],"text":"وَلَقَدِ ٱسْتُهْزِئَ بِرُسُلٍۢ مِّن قَبْلِكَ فَحَاقَ بِٱلَّذِينَ سَخِرُوا۟ مِنْهُم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","numberInSurah":41,"juz":17,"manzil":4,"page":325,"ruku":280,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2525,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2525.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2525.mp3"],"text":"قُلْ مَن يَكْلَؤُكُم بِٱلَّيْلِ وَٱلنَّهَارِ مِنَ ٱلرَّحْمَٰنِ ۗ بَلْ هُمْ عَن ذِكْرِ رَبِّهِم مُّعْرِضُونَ","numberInSurah":42,"juz":17,"manzil":4,"page":325,"ruku":281,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2526,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2526.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2526.mp3"],"text":"أَمْ لَهُمْ ءَالِهَةٌۭ تَمْنَعُهُم مِّن دُونِنَا ۚ لَا يَسْتَطِيعُونَ نَصْرَ أَنفُسِهِمْ وَلَا هُم مِّنَّا يُصْحَبُونَ","numberInSurah":43,"juz":17,"manzil":4,"page":325,"ruku":281,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2527,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2527.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2527.mp3"],"text":"بَلْ مَتَّعْنَا هَٰٓؤُلَآءِ وَءَابَآءَهُمْ حَتَّىٰ طَالَ عَلَيْهِمُ ٱلْعُمُرُ ۗ أَفَلَا يَرَوْنَ أَنَّا نَأْتِى ٱلْأَرْضَ نَنقُصُهَا مِنْ أَطْرَافِهَآ ۚ أَفَهُمُ ٱلْغَٰلِبُونَ","numberInSurah":44,"juz":17,"manzil":4,"page":325,"ruku":281,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2528,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2528.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2528.mp3"],"text":"قُلْ إِنَّمَآ أُنذِرُكُم بِٱلْوَحْىِ ۚ وَلَا يَسْمَعُ ٱلصُّمُّ ٱلدُّعَآءَ إِذَا مَا يُنذَرُونَ","numberInSurah":45,"juz":17,"manzil":4,"page":326,"ruku":281,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2529,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2529.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2529.mp3"],"text":"وَلَئِن مَّسَّتْهُمْ نَفْحَةٌۭ مِّنْ عَذَابِ رَبِّكَ لَيَقُولُنَّ يَٰوَيْلَنَآ إِنَّا كُنَّا ظَٰلِمِينَ","numberInSurah":46,"juz":17,"manzil":4,"page":326,"ruku":281,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2530,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2530.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2530.mp3"],"text":"وَنَضَعُ ٱلْمَوَٰزِينَ ٱلْقِسْطَ لِيَوْمِ ٱلْقِيَٰمَةِ فَلَا تُظْلَمُ نَفْسٌۭ شَيْـًۭٔا ۖ وَإِن كَانَ مِثْقَالَ حَبَّةٍۢ مِّنْ خَرْدَلٍ أَتَيْنَا بِهَا ۗ وَكَفَىٰ بِنَا حَٰسِبِينَ","numberInSurah":47,"juz":17,"manzil":4,"page":326,"ruku":281,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2531,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2531.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2531.mp3"],"text":"وَلَقَدْ ءَاتَيْنَا مُوسَىٰ وَهَٰرُونَ ٱلْفُرْقَانَ وَضِيَآءًۭ وَذِكْرًۭا لِّلْمُتَّقِينَ","numberInSurah":48,"juz":17,"manzil":4,"page":326,"ruku":281,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2532,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2532.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2532.mp3"],"text":"ٱلَّذِينَ يَخْشَوْنَ رَبَّهُم بِٱلْغَيْبِ وَهُم مِّنَ ٱلسَّاعَةِ مُشْفِقُونَ","numberInSurah":49,"juz":17,"manzil":4,"page":326,"ruku":281,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2533,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2533.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2533.mp3"],"text":"وَهَٰذَا ذِكْرٌۭ مُّبَارَكٌ أَنزَلْنَٰهُ ۚ أَفَأَنتُمْ لَهُۥ مُنكِرُونَ","numberInSurah":50,"juz":17,"manzil":4,"page":326,"ruku":281,"hizbQuarter":130,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}}],"surahs":{"21":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},"edition":{}}}