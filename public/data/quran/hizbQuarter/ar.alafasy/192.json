{"code":200,"status":"OK","data":{"number":192,"ayahs":[{"number":4243,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4243.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4243.mp3"],"text":"۞ وَقَيَّضْنَا لَهُمْ قُرَنَآءَ فَزَيَّنُوا۟ لَهُم مَّا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَحَقَّ عَلَيْهِمُ ٱلْقَوْلُ فِىٓ أُمَمٍۢ قَدْ خَلَتْ مِن قَبْلِهِم مِّنَ ٱلْجِنِّ وَٱلْإِنسِ ۖ إِنَّهُمْ كَانُوا۟ خَٰسِرِينَ","numberInSurah":25,"juz":24,"manzil":6,"page":479,"ruku":415,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4244,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4244.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4244.mp3"],"text":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لَا تَسْمَعُوا۟ لِهَٰذَا ٱلْقُرْءَانِ وَٱلْغَوْا۟ فِيهِ لَعَلَّكُمْ تَغْلِبُونَ","numberInSurah":26,"juz":24,"manzil":6,"page":479,"ruku":416,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4245,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4245.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4245.mp3"],"text":"فَلَنُذِيقَنَّ ٱلَّذِينَ كَفَرُوا۟ عَذَابًۭا شَدِيدًۭا وَلَنَجْزِيَنَّهُمْ أَسْوَأَ ٱلَّذِى كَانُوا۟ يَعْمَلُونَ","numberInSurah":27,"juz":24,"manzil":6,"page":479,"ruku":416,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4246,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4246.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4246.mp3"],"text":"ذَٰلِكَ جَزَآءُ أَعْدَآءِ ٱللَّهِ ٱلنَّارُ ۖ لَهُمْ فِيهَا دَارُ ٱلْخُلْدِ ۖ جَزَآءًۢ بِمَا كَانُوا۟ بِـَٔايَٰتِنَا يَجْحَدُونَ","numberInSurah":28,"juz":24,"manzil":6,"page":479,"ruku":416,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4247,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4247.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4247.mp3"],"text":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ رَبَّنَآ أَرِنَا ٱلَّذَيْنِ أَضَلَّانَا مِنَ ٱلْجِنِّ وَٱلْإِنسِ نَجْعَلْهُمَا تَحْتَ أَقْدَامِنَا لِيَكُونَا مِنَ ٱلْأَسْفَلِينَ","numberInSurah":29,"juz":24,"manzil":6,"page":479,"ruku":416,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4248,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4248.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4248.mp3"],"text":"إِنَّ ٱلَّذِينَ قَالُوا۟ رَبُّنَا ٱللَّهُ ثُمَّ ٱسْتَقَٰمُوا۟ تَتَنَزَّلُ عَلَيْهِمُ ٱلْمَلَٰٓئِكَةُ أَلَّا تَخَافُوا۟ وَلَا تَحْزَنُوا۟ وَأَبْشِرُوا۟ بِٱلْجَنَّةِ ٱلَّتِى كُنتُمْ تُوعَدُونَ","numberInSurah":30,"juz":24,"manzil":6,"page":480,"ruku":416,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4249,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4249.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4249.mp3"],"text":"نَحْنُ أَوْلِيَآؤُكُمْ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا وَفِى ٱلْءَاخِرَةِ ۖ وَلَكُمْ فِيهَا مَا تَشْتَهِىٓ أَنفُسُكُمْ وَلَكُمْ فِيهَا مَا تَدَّعُونَ","numberInSurah":31,"juz":24,"manzil":6,"page":480,"ruku":416,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4250,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4250.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4250.mp3"],"text":"نُزُلًۭا مِّنْ غَفُورٍۢ رَّحِيمٍۢ","numberInSurah":32,"juz":24,"manzil":6,"page":480,"ruku":416,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4251,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4251.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4251.mp3"],"text":"وَمَنْ أَحْسَنُ قَوْلًۭا مِّمَّن دَعَآ إِلَى ٱللَّهِ وَعَمِلَ صَٰلِحًۭا وَقَالَ إِنَّنِى مِنَ ٱلْمُسْلِمِينَ","numberInSurah":33,"juz":24,"manzil":6,"page":480,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4252,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4252.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4252.mp3"],"text":"وَلَا تَسْتَوِى ٱلْحَسَنَةُ وَلَا ٱلسَّيِّئَةُ ۚ ٱدْفَعْ بِٱلَّتِى هِىَ أَحْسَنُ فَإِذَا ٱلَّذِى بَيْنَكَ وَبَيْنَهُۥ عَدَٰوَةٌۭ كَأَنَّهُۥ وَلِىٌّ حَمِيمٌۭ","numberInSurah":34,"juz":24,"manzil":6,"page":480,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4253,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4253.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4253.mp3"],"text":"وَمَا يُلَقَّىٰهَآ إِلَّا ٱلَّذِينَ صَبَرُوا۟ وَمَا يُلَقَّىٰهَآ إِلَّا ذُو حَظٍّ عَظِيمٍۢ","numberInSurah":35,"juz":24,"manzil":6,"page":480,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4254,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4254.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4254.mp3"],"text":"وَإِمَّا يَنزَغَنَّكَ مِنَ ٱلشَّيْطَٰنِ نَزْغٌۭ فَٱسْتَعِذْ بِٱللَّهِ ۖ إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","numberInSurah":36,"juz":24,"manzil":6,"page":480,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4255,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4255.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4255.mp3"],"text":"وَمِنْ ءَايَٰتِهِ ٱلَّيْلُ وَٱلنَّهَارُ وَٱلشَّمْسُ وَٱلْقَمَرُ ۚ لَا تَسْجُدُوا۟ لِلشَّمْسِ وَلَا لِلْقَمَرِ وَٱسْجُدُوا۟ لِلَّهِ ٱلَّذِى خَلَقَهُنَّ إِن كُنتُمْ إِيَّاهُ تَعْبُدُونَ","numberInSurah":37,"juz":24,"manzil":6,"page":480,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4256,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4256.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4256.mp3"],"text":"فَإِنِ ٱسْتَكْبَرُوا۟ فَٱلَّذِينَ عِندَ رَبِّكَ يُسَبِّحُونَ لَهُۥ بِٱلَّيْلِ وَٱلنَّهَارِ وَهُمْ لَا يَسْـَٔمُونَ ۩","numberInSurah":38,"juz":24,"manzil":6,"page":480,"ruku":417,"hizbQuarter":192,"sajda":{"id":12,"recommended":false,"obligatory":true},"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4257,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4257.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4257.mp3"],"text":"وَمِنْ ءَايَٰتِهِۦٓ أَنَّكَ تَرَى ٱلْأَرْضَ خَٰشِعَةًۭ فَإِذَآ أَنزَلْنَا عَلَيْهَا ٱلْمَآءَ ٱهْتَزَّتْ وَرَبَتْ ۚ إِنَّ ٱلَّذِىٓ أَحْيَاهَا لَمُحْىِ ٱلْمَوْتَىٰٓ ۚ إِنَّهُۥ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","numberInSurah":39,"juz":24,"manzil":6,"page":481,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4258,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4258.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4258.mp3"],"text":"إِنَّ ٱلَّذِينَ يُلْحِدُونَ فِىٓ ءَايَٰتِنَا لَا يَخْفَوْنَ عَلَيْنَآ ۗ أَفَمَن يُلْقَىٰ فِى ٱلنَّارِ خَيْرٌ أَم مَّن يَأْتِىٓ ءَامِنًۭا يَوْمَ ٱلْقِيَٰمَةِ ۚ ٱعْمَلُوا۟ مَا شِئْتُمْ ۖ إِنَّهُۥ بِمَا تَعْمَلُونَ بَصِيرٌ","numberInSurah":40,"juz":24,"manzil":6,"page":481,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4259,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4259.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4259.mp3"],"text":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ بِٱلذِّكْرِ لَمَّا جَآءَهُمْ ۖ وَإِنَّهُۥ لَكِتَٰبٌ عَزِيزٌۭ","numberInSurah":41,"juz":24,"manzil":6,"page":481,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4260,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4260.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4260.mp3"],"text":"لَّا يَأْتِيهِ ٱلْبَٰطِلُ مِنۢ بَيْنِ يَدَيْهِ وَلَا مِنْ خَلْفِهِۦ ۖ تَنزِيلٌۭ مِّنْ حَكِيمٍ حَمِيدٍۢ","numberInSurah":42,"juz":24,"manzil":6,"page":481,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4261,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4261.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4261.mp3"],"text":"مَّا يُقَالُ لَكَ إِلَّا مَا قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ ۚ إِنَّ رَبَّكَ لَذُو مَغْفِرَةٍۢ وَذُو عِقَابٍ أَلِيمٍۢ","numberInSurah":43,"juz":24,"manzil":6,"page":481,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4262,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4262.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4262.mp3"],"text":"وَلَوْ جَعَلْنَٰهُ قُرْءَانًا أَعْجَمِيًّۭا لَّقَالُوا۟ لَوْلَا فُصِّلَتْ ءَايَٰتُهُۥٓ ۖ ءَا۬عْجَمِىٌّۭ وَعَرَبِىٌّۭ ۗ قُلْ هُوَ لِلَّذِينَ ءَامَنُوا۟ هُدًۭى وَشِفَآءٌۭ ۖ وَٱلَّذِينَ لَا يُؤْمِنُونَ فِىٓ ءَاذَانِهِمْ وَقْرٌۭ وَهُوَ عَلَيْهِمْ عَمًى ۚ أُو۟لَٰٓئِكَ يُنَادَوْنَ مِن مَّكَانٍۭ بَعِيدٍۢ","numberInSurah":44,"juz":24,"manzil":6,"page":481,"ruku":417,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4263,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4263.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4263.mp3"],"text":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ فَٱخْتُلِفَ فِيهِ ۗ وَلَوْلَا كَلِمَةٌۭ سَبَقَتْ مِن رَّبِّكَ لَقُضِىَ بَيْنَهُمْ ۚ وَإِنَّهُمْ لَفِى شَكٍّۢ مِّنْهُ مُرِيبٍۢ","numberInSurah":45,"juz":24,"manzil":6,"page":481,"ruku":418,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},{"number":4264,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4264.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4264.mp3"],"text":"مَّنْ عَمِلَ صَٰلِحًۭا فَلِنَفْسِهِۦ ۖ وَمَنْ أَسَآءَ فَعَلَيْهَا ۗ وَمَا رَبُّكَ بِظَلَّٰمٍۢ لِّلْعَبِيدِ","numberInSurah":46,"juz":24,"manzil":6,"page":481,"ruku":418,"hizbQuarter":192,"sajda":false,"surah":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}}],"surahs":{"41":{"number":41,"name":"سُورَةُ فُصِّلَتۡ","englishName":"Fussilat","englishNameTranslation":"Explained in detail","revelationType":"Meccan"}},"edition":{}}}