{"code":200,"status":"OK","data":{"number":165,"ayahs":[{"number":3491,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3491.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3491.mp3"],"text":"۞ وَمَن يُسْلِمْ وَجْهَهُۥٓ إِلَى ٱللَّهِ وَهُوَ مُحْسِنٌۭ فَقَدِ ٱسْتَمْسَكَ بِٱلْعُرْوَةِ ٱلْوُثْقَىٰ ۗ وَإِلَى ٱللَّهِ عَٰقِبَةُ ٱلْأُمُورِ","numberInSurah":22,"juz":21,"manzil":5,"page":413,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3492,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3492.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3492.mp3"],"text":"وَمَن كَفَرَ فَلَا يَحْزُنكَ كُفْرُهُۥٓ ۚ إِلَيْنَا مَرْجِعُهُمْ فَنُنَبِّئُهُم بِمَا عَمِلُوٓا۟ ۚ إِنَّ ٱللَّهَ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","numberInSurah":23,"juz":21,"manzil":5,"page":413,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3493,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3493.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3493.mp3"],"text":"نُمَتِّعُهُمْ قَلِيلًۭا ثُمَّ نَضْطَرُّهُمْ إِلَىٰ عَذَابٍ غَلِيظٍۢ","numberInSurah":24,"juz":21,"manzil":5,"page":413,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3494,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3494.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3494.mp3"],"text":"وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ لَيَقُولُنَّ ٱللَّهُ ۚ قُلِ ٱلْحَمْدُ لِلَّهِ ۚ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ","numberInSurah":25,"juz":21,"manzil":5,"page":413,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3495,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3495.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3495.mp3"],"text":"لِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ إِنَّ ٱللَّهَ هُوَ ٱلْغَنِىُّ ٱلْحَمِيدُ","numberInSurah":26,"juz":21,"manzil":5,"page":413,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3496,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3496.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3496.mp3"],"text":"وَلَوْ أَنَّمَا فِى ٱلْأَرْضِ مِن شَجَرَةٍ أَقْلَٰمٌۭ وَٱلْبَحْرُ يَمُدُّهُۥ مِنۢ بَعْدِهِۦ سَبْعَةُ أَبْحُرٍۢ مَّا نَفِدَتْ كَلِمَٰتُ ٱللَّهِ ۗ إِنَّ ٱللَّهَ عَزِيزٌ حَكِيمٌۭ","numberInSurah":27,"juz":21,"manzil":5,"page":413,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3497,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3497.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3497.mp3"],"text":"مَّا خَلْقُكُمْ وَلَا بَعْثُكُمْ إِلَّا كَنَفْسٍۢ وَٰحِدَةٍ ۗ إِنَّ ٱللَّهَ سَمِيعٌۢ بَصِيرٌ","numberInSurah":28,"juz":21,"manzil":5,"page":413,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3498,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3498.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3498.mp3"],"text":"أَلَمْ تَرَ أَنَّ ٱللَّهَ يُولِجُ ٱلَّيْلَ فِى ٱلنَّهَارِ وَيُولِجُ ٱلنَّهَارَ فِى ٱلَّيْلِ وَسَخَّرَ ٱلشَّمْسَ وَٱلْقَمَرَ كُلٌّۭ يَجْرِىٓ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى وَأَنَّ ٱللَّهَ بِمَا تَعْمَلُونَ خَبِيرٌۭ","numberInSurah":29,"juz":21,"manzil":5,"page":414,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3499,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3499.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3499.mp3"],"text":"ذَٰلِكَ بِأَنَّ ٱللَّهَ هُوَ ٱلْحَقُّ وَأَنَّ مَا يَدْعُونَ مِن دُونِهِ ٱلْبَٰطِلُ وَأَنَّ ٱللَّهَ هُوَ ٱلْعَلِىُّ ٱلْكَبِيرُ","numberInSurah":30,"juz":21,"manzil":5,"page":414,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3500,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3500.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3500.mp3"],"text":"أَلَمْ تَرَ أَنَّ ٱلْفُلْكَ تَجْرِى فِى ٱلْبَحْرِ بِنِعْمَتِ ٱللَّهِ لِيُرِيَكُم مِّنْ ءَايَٰتِهِۦٓ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّكُلِّ صَبَّارٍۢ شَكُورٍۢ","numberInSurah":31,"juz":21,"manzil":5,"page":414,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3501,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3501.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3501.mp3"],"text":"وَإِذَا غَشِيَهُم مَّوْجٌۭ كَٱلظُّلَلِ دَعَوُا۟ ٱللَّهَ مُخْلِصِينَ لَهُ ٱلدِّينَ فَلَمَّا نَجَّىٰهُمْ إِلَى ٱلْبَرِّ فَمِنْهُم مُّقْتَصِدٌۭ ۚ وَمَا يَجْحَدُ بِـَٔايَٰتِنَآ إِلَّا كُلُّ خَتَّارٍۢ كَفُورٍۢ","numberInSurah":32,"juz":21,"manzil":5,"page":414,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3502,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3502.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3502.mp3"],"text":"يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ وَٱخْشَوْا۟ يَوْمًۭا لَّا يَجْزِى وَالِدٌ عَن وَلَدِهِۦ وَلَا مَوْلُودٌ هُوَ جَازٍ عَن وَالِدِهِۦ شَيْـًٔا ۚ إِنَّ وَعْدَ ٱللَّهِ حَقٌّۭ ۖ فَلَا تَغُرَّنَّكُمُ ٱلْحَيَوٰةُ ٱلدُّنْيَا وَلَا يَغُرَّنَّكُم بِٱللَّهِ ٱلْغَرُورُ","numberInSurah":33,"juz":21,"manzil":5,"page":414,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3503,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3503.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3503.mp3"],"text":"إِنَّ ٱللَّهَ عِندَهُۥ عِلْمُ ٱلسَّاعَةِ وَيُنَزِّلُ ٱلْغَيْثَ وَيَعْلَمُ مَا فِى ٱلْأَرْحَامِ ۖ وَمَا تَدْرِى نَفْسٌۭ مَّاذَا تَكْسِبُ غَدًۭا ۖ وَمَا تَدْرِى نَفْسٌۢ بِأَىِّ أَرْضٍۢ تَمُوتُ ۚ إِنَّ ٱللَّهَ عَلِيمٌ خَبِيرٌۢ","numberInSurah":34,"juz":21,"manzil":5,"page":414,"ruku":357,"hizbQuarter":165,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3504,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3504.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3504.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓمٓ","numberInSurah":1,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3505,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3505.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3505.mp3"],"text":"تَنزِيلُ ٱلْكِتَٰبِ لَا رَيْبَ فِيهِ مِن رَّبِّ ٱلْعَٰلَمِينَ","numberInSurah":2,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3506,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3506.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3506.mp3"],"text":"أَمْ يَقُولُونَ ٱفْتَرَىٰهُ ۚ بَلْ هُوَ ٱلْحَقُّ مِن رَّبِّكَ لِتُنذِرَ قَوْمًۭا مَّآ أَتَىٰهُم مِّن نَّذِيرٍۢ مِّن قَبْلِكَ لَعَلَّهُمْ يَهْتَدُونَ","numberInSurah":3,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3507,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3507.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3507.mp3"],"text":"ٱللَّهُ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا فِى سِتَّةِ أَيَّامٍۢ ثُمَّ ٱسْتَوَىٰ عَلَى ٱلْعَرْشِ ۖ مَا لَكُم مِّن دُونِهِۦ مِن وَلِىٍّۢ وَلَا شَفِيعٍ ۚ أَفَلَا تَتَذَكَّرُونَ","numberInSurah":4,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3508,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3508.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3508.mp3"],"text":"يُدَبِّرُ ٱلْأَمْرَ مِنَ ٱلسَّمَآءِ إِلَى ٱلْأَرْضِ ثُمَّ يَعْرُجُ إِلَيْهِ فِى يَوْمٍۢ كَانَ مِقْدَارُهُۥٓ أَلْفَ سَنَةٍۢ مِّمَّا تَعُدُّونَ","numberInSurah":5,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3509,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3509.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3509.mp3"],"text":"ذَٰلِكَ عَٰلِمُ ٱلْغَيْبِ وَٱلشَّهَٰدَةِ ٱلْعَزِيزُ ٱلرَّحِيمُ","numberInSurah":6,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3510,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3510.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3510.mp3"],"text":"ٱلَّذِىٓ أَحْسَنَ كُلَّ شَىْءٍ خَلَقَهُۥ ۖ وَبَدَأَ خَلْقَ ٱلْإِنسَٰنِ مِن طِينٍۢ","numberInSurah":7,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3511,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3511.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3511.mp3"],"text":"ثُمَّ جَعَلَ نَسْلَهُۥ مِن سُلَٰلَةٍۢ مِّن مَّآءٍۢ مَّهِينٍۢ","numberInSurah":8,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3512,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3512.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3512.mp3"],"text":"ثُمَّ سَوَّىٰهُ وَنَفَخَ فِيهِ مِن رُّوحِهِۦ ۖ وَجَعَلَ لَكُمُ ٱلسَّمْعَ وَٱلْأَبْصَٰرَ وَٱلْأَفْـِٔدَةَ ۚ قَلِيلًۭا مَّا تَشْكُرُونَ","numberInSurah":9,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},{"number":3513,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3513.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3513.mp3"],"text":"وَقَالُوٓا۟ أَءِذَا ضَلَلْنَا فِى ٱلْأَرْضِ أَءِنَّا لَفِى خَلْقٍۢ جَدِيدٍۭ ۚ بَلْ هُم بِلِقَآءِ رَبِّهِمْ كَٰفِرُونَ","numberInSurah":10,"juz":21,"manzil":5,"page":415,"ruku":358,"hizbQuarter":165,"sajda":false,"surah":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}}],"surahs":{"31":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"},"32":{"number":32,"name":"سُورَةُ السَّجۡدَةِ","englishName":"As-Sajda","englishNameTranslation":"The Prostration","revelationType":"Meccan"}},"edition":{}}}