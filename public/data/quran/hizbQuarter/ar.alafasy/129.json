{"code":200,"status":"OK","data":{"number":129,"ayahs":[{"number":2484,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2484.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2484.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْتَرَبَ لِلنَّاسِ حِسَابُهُمْ وَهُمْ فِى غَفْلَةٍۢ مُّعْرِضُونَ","numberInSurah":1,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2485,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2485.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2485.mp3"],"text":"مَا يَأْتِيهِم مِّن ذِكْرٍۢ مِّن رَّبِّهِم مُّحْدَثٍ إِلَّا ٱسْتَمَعُوهُ وَهُمْ يَلْعَبُونَ","numberInSurah":2,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2486,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2486.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2486.mp3"],"text":"لَاهِيَةًۭ قُلُوبُهُمْ ۗ وَأَسَرُّوا۟ ٱلنَّجْوَى ٱلَّذِينَ ظَلَمُوا۟ هَلْ هَٰذَآ إِلَّا بَشَرٌۭ مِّثْلُكُمْ ۖ أَفَتَأْتُونَ ٱلسِّحْرَ وَأَنتُمْ تُبْصِرُونَ","numberInSurah":3,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2487,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2487.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2487.mp3"],"text":"قَالَ رَبِّى يَعْلَمُ ٱلْقَوْلَ فِى ٱلسَّمَآءِ وَٱلْأَرْضِ ۖ وَهُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","numberInSurah":4,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2488,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2488.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2488.mp3"],"text":"بَلْ قَالُوٓا۟ أَضْغَٰثُ أَحْلَٰمٍۭ بَلِ ٱفْتَرَىٰهُ بَلْ هُوَ شَاعِرٌۭ فَلْيَأْتِنَا بِـَٔايَةٍۢ كَمَآ أُرْسِلَ ٱلْأَوَّلُونَ","numberInSurah":5,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2489,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2489.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2489.mp3"],"text":"مَآ ءَامَنَتْ قَبْلَهُم مِّن قَرْيَةٍ أَهْلَكْنَٰهَآ ۖ أَفَهُمْ يُؤْمِنُونَ","numberInSurah":6,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2490,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2490.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2490.mp3"],"text":"وَمَآ أَرْسَلْنَا قَبْلَكَ إِلَّا رِجَالًۭا نُّوحِىٓ إِلَيْهِمْ ۖ فَسْـَٔلُوٓا۟ أَهْلَ ٱلذِّكْرِ إِن كُنتُمْ لَا تَعْلَمُونَ","numberInSurah":7,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2491,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2491.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2491.mp3"],"text":"وَمَا جَعَلْنَٰهُمْ جَسَدًۭا لَّا يَأْكُلُونَ ٱلطَّعَامَ وَمَا كَانُوا۟ خَٰلِدِينَ","numberInSurah":8,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2492,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2492.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2492.mp3"],"text":"ثُمَّ صَدَقْنَٰهُمُ ٱلْوَعْدَ فَأَنجَيْنَٰهُمْ وَمَن نَّشَآءُ وَأَهْلَكْنَا ٱلْمُسْرِفِينَ","numberInSurah":9,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2493,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2493.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2493.mp3"],"text":"لَقَدْ أَنزَلْنَآ إِلَيْكُمْ كِتَٰبًۭا فِيهِ ذِكْرُكُمْ ۖ أَفَلَا تَعْقِلُونَ","numberInSurah":10,"juz":17,"manzil":4,"page":322,"ruku":278,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2494,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2494.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2494.mp3"],"text":"وَكَمْ قَصَمْنَا مِن قَرْيَةٍۢ كَانَتْ ظَالِمَةًۭ وَأَنشَأْنَا بَعْدَهَا قَوْمًا ءَاخَرِينَ","numberInSurah":11,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2495,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2495.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2495.mp3"],"text":"فَلَمَّآ أَحَسُّوا۟ بَأْسَنَآ إِذَا هُم مِّنْهَا يَرْكُضُونَ","numberInSurah":12,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2496,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2496.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2496.mp3"],"text":"لَا تَرْكُضُوا۟ وَٱرْجِعُوٓا۟ إِلَىٰ مَآ أُتْرِفْتُمْ فِيهِ وَمَسَٰكِنِكُمْ لَعَلَّكُمْ تُسْـَٔلُونَ","numberInSurah":13,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2497,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2497.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2497.mp3"],"text":"قَالُوا۟ يَٰوَيْلَنَآ إِنَّا كُنَّا ظَٰلِمِينَ","numberInSurah":14,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2498,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2498.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2498.mp3"],"text":"فَمَا زَالَت تِّلْكَ دَعْوَىٰهُمْ حَتَّىٰ جَعَلْنَٰهُمْ حَصِيدًا خَٰمِدِينَ","numberInSurah":15,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2499,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2499.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2499.mp3"],"text":"وَمَا خَلَقْنَا ٱلسَّمَآءَ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا لَٰعِبِينَ","numberInSurah":16,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2500,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2500.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2500.mp3"],"text":"لَوْ أَرَدْنَآ أَن نَّتَّخِذَ لَهْوًۭا لَّٱتَّخَذْنَٰهُ مِن لَّدُنَّآ إِن كُنَّا فَٰعِلِينَ","numberInSurah":17,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2501,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2501.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2501.mp3"],"text":"بَلْ نَقْذِفُ بِٱلْحَقِّ عَلَى ٱلْبَٰطِلِ فَيَدْمَغُهُۥ فَإِذَا هُوَ زَاهِقٌۭ ۚ وَلَكُمُ ٱلْوَيْلُ مِمَّا تَصِفُونَ","numberInSurah":18,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2502,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2502.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2502.mp3"],"text":"وَلَهُۥ مَن فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَمَنْ عِندَهُۥ لَا يَسْتَكْبِرُونَ عَنْ عِبَادَتِهِۦ وَلَا يَسْتَحْسِرُونَ","numberInSurah":19,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2503,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2503.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2503.mp3"],"text":"يُسَبِّحُونَ ٱلَّيْلَ وَٱلنَّهَارَ لَا يَفْتُرُونَ","numberInSurah":20,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2504,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2504.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2504.mp3"],"text":"أَمِ ٱتَّخَذُوٓا۟ ءَالِهَةًۭ مِّنَ ٱلْأَرْضِ هُمْ يُنشِرُونَ","numberInSurah":21,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2505,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2505.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2505.mp3"],"text":"لَوْ كَانَ فِيهِمَآ ءَالِهَةٌ إِلَّا ٱللَّهُ لَفَسَدَتَا ۚ فَسُبْحَٰنَ ٱللَّهِ رَبِّ ٱلْعَرْشِ عَمَّا يَصِفُونَ","numberInSurah":22,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2506,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2506.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2506.mp3"],"text":"لَا يُسْـَٔلُ عَمَّا يَفْعَلُ وَهُمْ يُسْـَٔلُونَ","numberInSurah":23,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2507,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2507.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2507.mp3"],"text":"أَمِ ٱتَّخَذُوا۟ مِن دُونِهِۦٓ ءَالِهَةًۭ ۖ قُلْ هَاتُوا۟ بُرْهَٰنَكُمْ ۖ هَٰذَا ذِكْرُ مَن مَّعِىَ وَذِكْرُ مَن قَبْلِى ۗ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ ٱلْحَقَّ ۖ فَهُم مُّعْرِضُونَ","numberInSurah":24,"juz":17,"manzil":4,"page":323,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2508,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2508.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2508.mp3"],"text":"وَمَآ أَرْسَلْنَا مِن قَبْلِكَ مِن رَّسُولٍ إِلَّا نُوحِىٓ إِلَيْهِ أَنَّهُۥ لَآ إِلَٰهَ إِلَّآ أَنَا۠ فَٱعْبُدُونِ","numberInSurah":25,"juz":17,"manzil":4,"page":324,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2509,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2509.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2509.mp3"],"text":"وَقَالُوا۟ ٱتَّخَذَ ٱلرَّحْمَٰنُ وَلَدًۭا ۗ سُبْحَٰنَهُۥ ۚ بَلْ عِبَادٌۭ مُّكْرَمُونَ","numberInSurah":26,"juz":17,"manzil":4,"page":324,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2510,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2510.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2510.mp3"],"text":"لَا يَسْبِقُونَهُۥ بِٱلْقَوْلِ وَهُم بِأَمْرِهِۦ يَعْمَلُونَ","numberInSurah":27,"juz":17,"manzil":4,"page":324,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2511,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2511.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2511.mp3"],"text":"يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يَشْفَعُونَ إِلَّا لِمَنِ ٱرْتَضَىٰ وَهُم مِّنْ خَشْيَتِهِۦ مُشْفِقُونَ","numberInSurah":28,"juz":17,"manzil":4,"page":324,"ruku":279,"hizbQuarter":129,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}}],"surahs":{"21":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},"edition":{}}}