{"code":200,"status":"OK","data":{"number":156,"ayahs":[{"number":3281,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3281.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3281.mp3"],"text":"۞ فَلَمَّا قَضَىٰ مُوسَى ٱلْأَجَلَ وَسَارَ بِأَهْلِهِۦٓ ءَانَسَ مِن جَانِبِ ٱلطُّورِ نَارًۭا قَالَ لِأَهْلِهِ ٱمْكُثُوٓا۟ إِنِّىٓ ءَانَسْتُ نَارًۭا لَّعَلِّىٓ ءَاتِيكُم مِّنْهَا بِخَبَرٍ أَوْ جَذْوَةٍۢ مِّنَ ٱلنَّارِ لَعَلَّكُمْ تَصْطَلُونَ","numberInSurah":29,"juz":20,"manzil":5,"page":389,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3282,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3282.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3282.mp3"],"text":"فَلَمَّآ أَتَىٰهَا نُودِىَ مِن شَٰطِئِ ٱلْوَادِ ٱلْأَيْمَنِ فِى ٱلْبُقْعَةِ ٱلْمُبَٰرَكَةِ مِنَ ٱلشَّجَرَةِ أَن يَٰمُوسَىٰٓ إِنِّىٓ أَنَا ٱللَّهُ رَبُّ ٱلْعَٰلَمِينَ","numberInSurah":30,"juz":20,"manzil":5,"page":389,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3283,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3283.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3283.mp3"],"text":"وَأَنْ أَلْقِ عَصَاكَ ۖ فَلَمَّا رَءَاهَا تَهْتَزُّ كَأَنَّهَا جَآنٌّۭ وَلَّىٰ مُدْبِرًۭا وَلَمْ يُعَقِّبْ ۚ يَٰمُوسَىٰٓ أَقْبِلْ وَلَا تَخَفْ ۖ إِنَّكَ مِنَ ٱلْءَامِنِينَ","numberInSurah":31,"juz":20,"manzil":5,"page":389,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3284,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3284.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3284.mp3"],"text":"ٱسْلُكْ يَدَكَ فِى جَيْبِكَ تَخْرُجْ بَيْضَآءَ مِنْ غَيْرِ سُوٓءٍۢ وَٱضْمُمْ إِلَيْكَ جَنَاحَكَ مِنَ ٱلرَّهْبِ ۖ فَذَٰنِكَ بُرْهَٰنَانِ مِن رَّبِّكَ إِلَىٰ فِرْعَوْنَ وَمَلَإِي۟هِۦٓ ۚ إِنَّهُمْ كَانُوا۟ قَوْمًۭا فَٰسِقِينَ","numberInSurah":32,"juz":20,"manzil":5,"page":389,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3285,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3285.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3285.mp3"],"text":"قَالَ رَبِّ إِنِّى قَتَلْتُ مِنْهُمْ نَفْسًۭا فَأَخَافُ أَن يَقْتُلُونِ","numberInSurah":33,"juz":20,"manzil":5,"page":389,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3286,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3286.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3286.mp3"],"text":"وَأَخِى هَٰرُونُ هُوَ أَفْصَحُ مِنِّى لِسَانًۭا فَأَرْسِلْهُ مَعِىَ رِدْءًۭا يُصَدِّقُنِىٓ ۖ إِنِّىٓ أَخَافُ أَن يُكَذِّبُونِ","numberInSurah":34,"juz":20,"manzil":5,"page":389,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3287,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3287.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3287.mp3"],"text":"قَالَ سَنَشُدُّ عَضُدَكَ بِأَخِيكَ وَنَجْعَلُ لَكُمَا سُلْطَٰنًۭا فَلَا يَصِلُونَ إِلَيْكُمَا ۚ بِـَٔايَٰتِنَآ أَنتُمَا وَمَنِ ٱتَّبَعَكُمَا ٱلْغَٰلِبُونَ","numberInSurah":35,"juz":20,"manzil":5,"page":389,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3288,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3288.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3288.mp3"],"text":"فَلَمَّا جَآءَهُم مُّوسَىٰ بِـَٔايَٰتِنَا بَيِّنَٰتٍۢ قَالُوا۟ مَا هَٰذَآ إِلَّا سِحْرٌۭ مُّفْتَرًۭى وَمَا سَمِعْنَا بِهَٰذَا فِىٓ ءَابَآئِنَا ٱلْأَوَّلِينَ","numberInSurah":36,"juz":20,"manzil":5,"page":390,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3289,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3289.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3289.mp3"],"text":"وَقَالَ مُوسَىٰ رَبِّىٓ أَعْلَمُ بِمَن جَآءَ بِٱلْهُدَىٰ مِنْ عِندِهِۦ وَمَن تَكُونُ لَهُۥ عَٰقِبَةُ ٱلدَّارِ ۖ إِنَّهُۥ لَا يُفْلِحُ ٱلظَّٰلِمُونَ","numberInSurah":37,"juz":20,"manzil":5,"page":390,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3290,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3290.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3290.mp3"],"text":"وَقَالَ فِرْعَوْنُ يَٰٓأَيُّهَا ٱلْمَلَأُ مَا عَلِمْتُ لَكُم مِّنْ إِلَٰهٍ غَيْرِى فَأَوْقِدْ لِى يَٰهَٰمَٰنُ عَلَى ٱلطِّينِ فَٱجْعَل لِّى صَرْحًۭا لَّعَلِّىٓ أَطَّلِعُ إِلَىٰٓ إِلَٰهِ مُوسَىٰ وَإِنِّى لَأَظُنُّهُۥ مِنَ ٱلْكَٰذِبِينَ","numberInSurah":38,"juz":20,"manzil":5,"page":390,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3291,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3291.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3291.mp3"],"text":"وَٱسْتَكْبَرَ هُوَ وَجُنُودُهُۥ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ وَظَنُّوٓا۟ أَنَّهُمْ إِلَيْنَا لَا يُرْجَعُونَ","numberInSurah":39,"juz":20,"manzil":5,"page":390,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3292,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3292.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3292.mp3"],"text":"فَأَخَذْنَٰهُ وَجُنُودَهُۥ فَنَبَذْنَٰهُمْ فِى ٱلْيَمِّ ۖ فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلظَّٰلِمِينَ","numberInSurah":40,"juz":20,"manzil":5,"page":390,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3293,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3293.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3293.mp3"],"text":"وَجَعَلْنَٰهُمْ أَئِمَّةًۭ يَدْعُونَ إِلَى ٱلنَّارِ ۖ وَيَوْمَ ٱلْقِيَٰمَةِ لَا يُنصَرُونَ","numberInSurah":41,"juz":20,"manzil":5,"page":390,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3294,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3294.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3294.mp3"],"text":"وَأَتْبَعْنَٰهُمْ فِى هَٰذِهِ ٱلدُّنْيَا لَعْنَةًۭ ۖ وَيَوْمَ ٱلْقِيَٰمَةِ هُم مِّنَ ٱلْمَقْبُوحِينَ","numberInSurah":42,"juz":20,"manzil":5,"page":390,"ruku":337,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3295,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3295.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3295.mp3"],"text":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ مِنۢ بَعْدِ مَآ أَهْلَكْنَا ٱلْقُرُونَ ٱلْأُولَىٰ بَصَآئِرَ لِلنَّاسِ وَهُدًۭى وَرَحْمَةًۭ لَّعَلَّهُمْ يَتَذَكَّرُونَ","numberInSurah":43,"juz":20,"manzil":5,"page":390,"ruku":338,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3296,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3296.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3296.mp3"],"text":"وَمَا كُنتَ بِجَانِبِ ٱلْغَرْبِىِّ إِذْ قَضَيْنَآ إِلَىٰ مُوسَى ٱلْأَمْرَ وَمَا كُنتَ مِنَ ٱلشَّٰهِدِينَ","numberInSurah":44,"juz":20,"manzil":5,"page":391,"ruku":338,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3297,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3297.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3297.mp3"],"text":"وَلَٰكِنَّآ أَنشَأْنَا قُرُونًۭا فَتَطَاوَلَ عَلَيْهِمُ ٱلْعُمُرُ ۚ وَمَا كُنتَ ثَاوِيًۭا فِىٓ أَهْلِ مَدْيَنَ تَتْلُوا۟ عَلَيْهِمْ ءَايَٰتِنَا وَلَٰكِنَّا كُنَّا مُرْسِلِينَ","numberInSurah":45,"juz":20,"manzil":5,"page":391,"ruku":338,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3298,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3298.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3298.mp3"],"text":"وَمَا كُنتَ بِجَانِبِ ٱلطُّورِ إِذْ نَادَيْنَا وَلَٰكِن رَّحْمَةًۭ مِّن رَّبِّكَ لِتُنذِرَ قَوْمًۭا مَّآ أَتَىٰهُم مِّن نَّذِيرٍۢ مِّن قَبْلِكَ لَعَلَّهُمْ يَتَذَكَّرُونَ","numberInSurah":46,"juz":20,"manzil":5,"page":391,"ruku":338,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3299,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3299.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3299.mp3"],"text":"وَلَوْلَآ أَن تُصِيبَهُم مُّصِيبَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ فَيَقُولُوا۟ رَبَّنَا لَوْلَآ أَرْسَلْتَ إِلَيْنَا رَسُولًۭا فَنَتَّبِعَ ءَايَٰتِكَ وَنَكُونَ مِنَ ٱلْمُؤْمِنِينَ","numberInSurah":47,"juz":20,"manzil":5,"page":391,"ruku":338,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3300,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3300.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3300.mp3"],"text":"فَلَمَّا جَآءَهُمُ ٱلْحَقُّ مِنْ عِندِنَا قَالُوا۟ لَوْلَآ أُوتِىَ مِثْلَ مَآ أُوتِىَ مُوسَىٰٓ ۚ أَوَلَمْ يَكْفُرُوا۟ بِمَآ أُوتِىَ مُوسَىٰ مِن قَبْلُ ۖ قَالُوا۟ سِحْرَانِ تَظَٰهَرَا وَقَالُوٓا۟ إِنَّا بِكُلٍّۢ كَٰفِرُونَ","numberInSurah":48,"juz":20,"manzil":5,"page":391,"ruku":338,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3301,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3301.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3301.mp3"],"text":"قُلْ فَأْتُوا۟ بِكِتَٰبٍۢ مِّنْ عِندِ ٱللَّهِ هُوَ أَهْدَىٰ مِنْهُمَآ أَتَّبِعْهُ إِن كُنتُمْ صَٰدِقِينَ","numberInSurah":49,"juz":20,"manzil":5,"page":391,"ruku":338,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3302,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3302.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3302.mp3"],"text":"فَإِن لَّمْ يَسْتَجِيبُوا۟ لَكَ فَٱعْلَمْ أَنَّمَا يَتَّبِعُونَ أَهْوَآءَهُمْ ۚ وَمَنْ أَضَلُّ مِمَّنِ ٱتَّبَعَ هَوَىٰهُ بِغَيْرِ هُدًۭى مِّنَ ٱللَّهِ ۚ إِنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّٰلِمِينَ","numberInSurah":50,"juz":20,"manzil":5,"page":391,"ruku":338,"hizbQuarter":156,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}}],"surahs":{"28":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},"edition":{}}}