":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3444,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3444.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3444.mp3"],"text":"أَمْ أَنزَلْنَا عَلَيْهِمْ سُلْطَٰنًۭا فَهُوَ يَتَكَلَّمُ بِمَا كَانُوا۟ بِهِۦ يُشْرِكُونَ","numberInSurah":35,"juz":21,"manzil":5,"page":408,"ruku":352,"hizbQuarter":163,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3445,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3445.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3445.mp3"],"text":"وَإِذَآ أَذَقْنَا ٱلنَّاسَ رَحْمَةًۭ فَرِحُوا۟ بِهَا ۖ وَإِن تُصِبْهُمْ سَيِّئَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ إِذَا هُمْ يَقْنَطُونَ","numberInSurah":36,"juz":21,"manzil":5,"page":408,"ruku":352,"hizbQuarter":163,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3446,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3446.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3446.mp3"],"text":"أَوَلَمْ يَرَوْا۟ أَنَّ ٱللَّهَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يُؤْمِنُونَ","numberInSurah":37,"juz":21,"manzil":5,"page":408,"ruku":352,"hizbQuarter":163,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3447,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3447.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3447.mp3"],"text":"فَـَٔاتِ ذَا ٱلْقُرْبَىٰ حَقَّهُۥ وَٱلْمِسْكِينَ وَٱبْنَ ٱلسَّبِيلِ ۚ ذَٰلِكَ خَيْرٌۭ لِّلَّذِ