ajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3455,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3455.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3455.mp3"],"text":"وَمِنْ ءَايَٰتِهِۦٓ أَن يُرْسِلَ ٱلرِّيَاحَ مُبَشِّرَٰتٍۢ وَلِيُذِيقَكُم مِّن رَّحْمَتِهِۦ وَلِتَجْرِىَ ٱلْفُلْكُ بِأَمْرِهِۦ وَلِتَبْتَغُوا۟ مِن فَضْلِهِۦ وَلَعَلَّكُمْ تَشْكُرُونَ","numberInSurah":46,"juz":21,"manzil":5,"page":409,"ruku":353,"hizbQuarter":163,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3456,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3456.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3456.mp3"],"text":"وَلَقَدْ أَرْسَلْنَا مِن قَبْلِكَ رُسُلًا إِلَىٰ قَوْمِهِمْ فَجَآءُوهُم بِٱلْبَيِّنَٰتِ فَٱنتَقَمْنَا مِنَ ٱلَّذِينَ أَجْرَمُوا۟ ۖ وَكَانَ حَقًّا عَلَيْنَا نَصْرُ ٱلْمُؤْمِنِينَ","numberInSurah":47,"juz":21,"manzil":5,"page":409,"ruku":353,"hizbQuarter":163,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3457,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3457.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3457.mp3"],"text":"ٱللَّهُ ٱلَّذِى يُرْسِلُ ٱلرِّيَٰحَ فَتُثِيرُ سَحَابًۭا فَيَبْسُطُهُۥ فِى ٱلسَّمَآءِ كَيْفَ يَشَآءُ وَيَجْعَلُهُۥ كِسَفًۭا فَتَرَى ٱلْوَدْقَ يَخْرُجُ مِنْ خِلَٰلِهِۦ ۖ فَإِذَآ أَصَابَ بِهِۦ مَن يَشَآءُ مِنْ عِبَادِهِۦٓ إِذَا هُمْ يَسْتَبْشِرُونَ","numberInSurah":48,"juz":21,"manzil":5,"page":409,"ruku":353,"hizbQuarter":163,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"nu