{"code":200,"status":"OK","data":{"number":134,"ayahs":[{"number":2614,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2614.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2614.mp3"],"text":"۞ هَٰذَانِ خَصْمَانِ ٱخْتَصَمُوا۟ فِى رَبِّهِمْ ۖ فَٱلَّذِينَ كَفَرُوا۟ قُطِّعَتْ لَهُمْ ثِيَابٌۭ مِّن نَّارٍۢ يُصَبُّ مِن فَوْقِ رُءُوسِهِمُ ٱلْحَمِيمُ","numberInSurah":19,"juz":17,"manzil":4,"page":334,"ruku":286,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2615,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2615.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2615.mp3"],"text":"يُصْهَرُ بِهِۦ مَا فِى بُطُونِهِمْ وَٱلْجُلُودُ","numberInSurah":20,"juz":17,"manzil":4,"page":334,"ruku":286,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2616,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2616.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2616.mp3"],"text":"وَلَهُم مَّقَٰمِعُ مِنْ حَدِيدٍۢ","numberInSurah":21,"juz":17,"manzil":4,"page":334,"ruku":286,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2617,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2617.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2617.mp3"],"text":"كُلَّمَآ أَرَادُوٓا۟ أَن يَخْرُجُوا۟ مِنْهَا مِنْ غَمٍّ أُعِيدُوا۟ فِيهَا وَذُوقُوا۟ عَذَابَ ٱلْحَرِيقِ","numberInSurah":22,"juz":17,"manzil":4,"page":334,"ruku":286,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2618,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2618.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2618.mp3"],"text":"إِنَّ ٱللَّهَ يُدْخِلُ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ يُحَلَّوْنَ فِيهَا مِنْ أَسَاوِرَ مِن ذَهَبٍۢ وَلُؤْلُؤًۭا ۖ وَلِبَاسُهُمْ فِيهَا حَرِيرٌۭ","numberInSurah":23,"juz":17,"manzil":4,"page":334,"ruku":287,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2619,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2619.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2619.mp3"],"text":"وَهُدُوٓا۟ إِلَى ٱلطَّيِّبِ مِنَ ٱلْقَوْلِ وَهُدُوٓا۟ إِلَىٰ صِرَٰطِ ٱلْحَمِيدِ","numberInSurah":24,"juz":17,"manzil":4,"page":335,"ruku":287,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2620,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2620.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2620.mp3"],"text":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ وَٱلْمَسْجِدِ ٱلْحَرَامِ ٱلَّذِى جَعَلْنَٰهُ لِلنَّاسِ سَوَآءً ٱلْعَٰكِفُ فِيهِ وَٱلْبَادِ ۚ وَمَن يُرِدْ فِيهِ بِإِلْحَادٍۭ بِظُلْمٍۢ نُّذِقْهُ مِنْ عَذَابٍ أَلِيمٍۢ","numberInSurah":25,"juz":17,"manzil":4,"page":335,"ruku":287,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2621,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2621.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2621.mp3"],"text":"وَإِذْ بَوَّأْنَا لِإِبْرَٰهِيمَ مَكَانَ ٱلْبَيْتِ أَن لَّا تُشْرِكْ بِى شَيْـًۭٔا وَطَهِّرْ بَيْتِىَ لِلطَّآئِفِينَ وَٱلْقَآئِمِينَ وَٱلرُّكَّعِ ٱلسُّجُودِ","numberInSurah":26,"juz":17,"manzil":4,"page":335,"ruku":288,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2622,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2622.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2622.mp3"],"text":"وَأَذِّن فِى ٱلنَّاسِ بِٱلْحَجِّ يَأْتُوكَ رِجَالًۭا وَعَلَىٰ كُلِّ ضَامِرٍۢ يَأْتِينَ مِن كُلِّ فَجٍّ عَمِيقٍۢ","numberInSurah":27,"juz":17,"manzil":4,"page":335,"ruku":288,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2623,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2623.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2623.mp3"],"text":"لِّيَشْهَدُوا۟ مَنَٰفِعَ لَهُمْ وَيَذْكُرُوا۟ ٱسْمَ ٱللَّهِ فِىٓ أَيَّامٍۢ مَّعْلُومَٰتٍ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِيمَةِ ٱلْأَنْعَٰمِ ۖ فَكُلُوا۟ مِنْهَا وَأَطْعِمُوا۟ ٱلْبَآئِسَ ٱلْفَقِيرَ","numberInSurah":28,"juz":17,"manzil":4,"page":335,"ruku":288,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2624,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2624.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2624.mp3"],"text":"ثُمَّ لْيَقْضُوا۟ تَفَثَهُمْ وَلْيُوفُوا۟ نُذُورَهُمْ وَلْيَطَّوَّفُوا۟ بِٱلْبَيْتِ ٱلْعَتِيقِ","numberInSurah":29,"juz":17,"manzil":4,"page":335,"ruku":288,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2625,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2625.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2625.mp3"],"text":"ذَٰلِكَ وَمَن يُعَظِّمْ حُرُمَٰتِ ٱللَّهِ فَهُوَ خَيْرٌۭ لَّهُۥ عِندَ رَبِّهِۦ ۗ وَأُحِلَّتْ لَكُمُ ٱلْأَنْعَٰمُ إِلَّا مَا يُتْلَىٰ عَلَيْكُمْ ۖ فَٱجْتَنِبُوا۟ ٱلرِّجْسَ مِنَ ٱلْأَوْثَٰنِ وَٱجْتَنِبُوا۟ قَوْلَ ٱلزُّورِ","numberInSurah":30,"juz":17,"manzil":4,"page":335,"ruku":288,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2626,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2626.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2626.mp3"],"text":"حُنَفَآءَ لِلَّهِ غَيْرَ مُشْرِكِينَ بِهِۦ ۚ وَمَن يُشْرِكْ بِٱللَّهِ فَكَأَنَّمَا خَرَّ مِنَ ٱلسَّمَآءِ فَتَخْطَفُهُ ٱلطَّيْرُ أَوْ تَهْوِى بِهِ ٱلرِّيحُ فِى مَكَانٍۢ سَحِيقٍۢ","numberInSurah":31,"juz":17,"manzil":4,"page":336,"ruku":288,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2627,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2627.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2627.mp3"],"text":"ذَٰلِكَ وَمَن يُعَظِّمْ شَعَٰٓئِرَ ٱللَّهِ فَإِنَّهَا مِن تَقْوَى ٱلْقُلُوبِ","numberInSurah":32,"juz":17,"manzil":4,"page":336,"ruku":288,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2628,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2628.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2628.mp3"],"text":"لَكُمْ فِيهَا مَنَٰفِعُ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى ثُمَّ مَحِلُّهَآ إِلَى ٱلْبَيْتِ ٱلْعَتِيقِ","numberInSurah":33,"juz":17,"manzil":4,"page":336,"ruku":288,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2629,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2629.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2629.mp3"],"text":"وَلِكُلِّ أُمَّةٍۢ جَعَلْنَا مَنسَكًۭا لِّيَذْكُرُوا۟ ٱسْمَ ٱللَّهِ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِيمَةِ ٱلْأَنْعَٰمِ ۗ فَإِلَٰهُكُمْ إِلَٰهٌۭ وَٰحِدٌۭ فَلَهُۥٓ أَسْلِمُوا۟ ۗ وَبَشِّرِ ٱلْمُخْبِتِينَ","numberInSurah":34,"juz":17,"manzil":4,"page":336,"ruku":289,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2630,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2630.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2630.mp3"],"text":"ٱلَّذِينَ إِذَا ذُكِرَ ٱللَّهُ وَجِلَتْ قُلُوبُهُمْ وَٱلصَّٰبِرِينَ عَلَىٰ مَآ أَصَابَهُمْ وَٱلْمُقِيمِى ٱلصَّلَوٰةِ وَمِمَّا رَزَقْنَٰهُمْ يُنفِقُونَ","numberInSurah":35,"juz":17,"manzil":4,"page":336,"ruku":289,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2631,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2631.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2631.mp3"],"text":"وَٱلْبُدْنَ جَعَلْنَٰهَا لَكُم مِّن شَعَٰٓئِرِ ٱللَّهِ لَكُمْ فِيهَا خَيْرٌۭ ۖ فَٱذْكُرُوا۟ ٱسْمَ ٱللَّهِ عَلَيْهَا صَوَآفَّ ۖ فَإِذَا وَجَبَتْ جُنُوبُهَا فَكُلُوا۟ مِنْهَا وَأَطْعِمُوا۟ ٱلْقَانِعَ وَٱلْمُعْتَرَّ ۚ كَذَٰلِكَ سَخَّرْنَٰهَا لَكُمْ لَعَلَّكُمْ تَشْكُرُونَ","numberInSurah":36,"juz":17,"manzil":4,"page":336,"ruku":289,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},{"number":2632,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2632.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2632.mp3"],"text":"لَن يَنَالَ ٱللَّهَ لُحُومُهَا وَلَا دِمَآؤُهَا وَلَٰكِن يَنَالُهُ ٱلتَّقْوَىٰ مِنكُمْ ۚ كَذَٰلِكَ سَخَّرَهَا لَكُمْ لِتُكَبِّرُوا۟ ٱللَّهَ عَلَىٰ مَا هَدَىٰكُمْ ۗ وَبَشِّرِ ٱلْمُحْسِنِينَ","numberInSurah":37,"juz":17,"manzil":4,"page":336,"ruku":289,"hizbQuarter":134,"sajda":false,"surah":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}}],"surahs":{"22":{"number":22,"name":"سُورَةُ الحَجِّ","englishName":"Al-Hajj","englishNameTranslation":"The Pilgrimage","revelationType":"Medinan"}},"edition":{}}}