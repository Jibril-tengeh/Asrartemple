{"code":200,"status":"OK","data":{"number":173,"ayahs":[{"number":3630,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3630.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3630.mp3"],"text":"۞ قُلْ مَن يَرْزُقُكُم مِّنَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۖ قُلِ ٱللَّهُ ۖ وَإِنَّآ أَوْ إِيَّاكُمْ لَعَلَىٰ هُدًى أَوْ فِى ضَلَٰلٍۢ مُّبِينٍۢ","numberInSurah":24,"juz":22,"manzil":5,"page":431,"ruku":372,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3631,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3631.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3631.mp3"],"text":"قُل لَّا تُسْـَٔلُونَ عَمَّآ أَجْرَمْنَا وَلَا نُسْـَٔلُ عَمَّا تَعْمَلُونَ","numberInSurah":25,"juz":22,"manzil":5,"page":431,"ruku":372,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3632,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3632.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3632.mp3"],"text":"قُلْ يَجْمَعُ بَيْنَنَا رَبُّنَا ثُمَّ يَفْتَحُ بَيْنَنَا بِٱلْحَقِّ وَهُوَ ٱلْفَتَّاحُ ٱلْعَلِيمُ","numberInSurah":26,"juz":22,"manzil":5,"page":431,"ruku":372,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3633,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3633.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3633.mp3"],"text":"قُلْ أَرُونِىَ ٱلَّذِينَ أَلْحَقْتُم بِهِۦ شُرَكَآءَ ۖ كَلَّا ۚ بَلْ هُوَ ٱللَّهُ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":27,"juz":22,"manzil":5,"page":431,"ruku":372,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3634,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3634.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3634.mp3"],"text":"وَمَآ أَرْسَلْنَٰكَ إِلَّا كَآفَّةًۭ لِّلنَّاسِ بَشِيرًۭا وَنَذِيرًۭا وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","numberInSurah":28,"juz":22,"manzil":5,"page":431,"ruku":372,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3635,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3635.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3635.mp3"],"text":"وَيَقُولُونَ مَتَىٰ هَٰذَا ٱلْوَعْدُ إِن كُنتُمْ صَٰدِقِينَ","numberInSurah":29,"juz":22,"manzil":5,"page":431,"ruku":372,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3636,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3636.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3636.mp3"],"text":"قُل لَّكُم مِّيعَادُ يَوْمٍۢ لَّا تَسْتَـْٔخِرُونَ عَنْهُ سَاعَةًۭ وَلَا تَسْتَقْدِمُونَ","numberInSurah":30,"juz":22,"manzil":5,"page":431,"ruku":372,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3637,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3637.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3637.mp3"],"text":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لَن نُّؤْمِنَ بِهَٰذَا ٱلْقُرْءَانِ وَلَا بِٱلَّذِى بَيْنَ يَدَيْهِ ۗ وَلَوْ تَرَىٰٓ إِذِ ٱلظَّٰلِمُونَ مَوْقُوفُونَ عِندَ رَبِّهِمْ يَرْجِعُ بَعْضُهُمْ إِلَىٰ بَعْضٍ ٱلْقَوْلَ يَقُولُ ٱلَّذِينَ ٱسْتُضْعِفُوا۟ لِلَّذِينَ ٱسْتَكْبَرُوا۟ لَوْلَآ أَنتُمْ لَكُنَّا مُؤْمِنِينَ","numberInSurah":31,"juz":22,"manzil":5,"page":431,"ruku":373,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3638,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3638.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3638.mp3"],"text":"قَالَ ٱلَّذِينَ ٱسْتَكْبَرُوا۟ لِلَّذِينَ ٱسْتُضْعِفُوٓا۟ أَنَحْنُ صَدَدْنَٰكُمْ عَنِ ٱلْهُدَىٰ بَعْدَ إِذْ جَآءَكُم ۖ بَلْ كُنتُم مُّجْرِمِينَ","numberInSurah":32,"juz":22,"manzil":5,"page":432,"ruku":373,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3639,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3639.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3639.mp3"],"text":"وَقَالَ ٱلَّذِينَ ٱسْتُضْعِفُوا۟ لِلَّذِينَ ٱسْتَكْبَرُوا۟ بَلْ مَكْرُ ٱلَّيْلِ وَٱلنَّهَارِ إِذْ تَأْمُرُونَنَآ أَن نَّكْفُرَ بِٱللَّهِ وَنَجْعَلَ لَهُۥٓ أَندَادًۭا ۚ وَأَسَرُّوا۟ ٱلنَّدَامَةَ لَمَّا رَأَوُا۟ ٱلْعَذَابَ وَجَعَلْنَا ٱلْأَغْلَٰلَ فِىٓ أَعْنَاقِ ٱلَّذِينَ كَفَرُوا۟ ۚ هَلْ يُجْزَوْنَ إِلَّا مَا كَانُوا۟ يَعْمَلُونَ","numberInSurah":33,"juz":22,"manzil":5,"page":432,"ruku":373,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3640,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3640.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3640.mp3"],"text":"وَمَآ أَرْسَلْنَا فِى قَرْيَةٍۢ مِّن نَّذِيرٍ إِلَّا قَالَ مُتْرَفُوهَآ إِنَّا بِمَآ أُرْسِلْتُم بِهِۦ كَٰفِرُونَ","numberInSurah":34,"juz":22,"manzil":5,"page":432,"ruku":373,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3641,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3641.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3641.mp3"],"text":"وَقَالُوا۟ نَحْنُ أَكْثَرُ أَمْوَٰلًۭا وَأَوْلَٰدًۭا وَمَا نَحْنُ بِمُعَذَّبِينَ","numberInSurah":35,"juz":22,"manzil":5,"page":432,"ruku":373,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3642,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3642.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3642.mp3"],"text":"قُلْ إِنَّ رَبِّى يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","numberInSurah":36,"juz":22,"manzil":5,"page":432,"ruku":373,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3643,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3643.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3643.mp3"],"text":"وَمَآ أَمْوَٰلُكُمْ وَلَآ أَوْلَٰدُكُم بِٱلَّتِى تُقَرِّبُكُمْ عِندَنَا زُلْفَىٰٓ إِلَّا مَنْ ءَامَنَ وَعَمِلَ صَٰلِحًۭا فَأُو۟لَٰٓئِكَ لَهُمْ جَزَآءُ ٱلضِّعْفِ بِمَا عَمِلُوا۟ وَهُمْ فِى ٱلْغُرُفَٰتِ ءَامِنُونَ","numberInSurah":37,"juz":22,"manzil":5,"page":432,"ruku":374,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3644,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3644.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3644.mp3"],"text":"وَٱلَّذِينَ يَسْعَوْنَ فِىٓ ءَايَٰتِنَا مُعَٰجِزِينَ أُو۟لَٰٓئِكَ فِى ٱلْعَذَابِ مُحْضَرُونَ","numberInSurah":38,"juz":22,"manzil":5,"page":432,"ruku":374,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3645,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3645.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3645.mp3"],"text":"قُلْ إِنَّ رَبِّى يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ مِنْ عِبَادِهِۦ وَيَقْدِرُ لَهُۥ ۚ وَمَآ أَنفَقْتُم مِّن شَىْءٍۢ فَهُوَ يُخْلِفُهُۥ ۖ وَهُوَ خَيْرُ ٱلرَّٰزِقِينَ","numberInSurah":39,"juz":22,"manzil":5,"page":432,"ruku":374,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3646,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3646.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3646.mp3"],"text":"وَيَوْمَ يَحْشُرُهُمْ جَمِيعًۭا ثُمَّ يَقُولُ لِلْمَلَٰٓئِكَةِ أَهَٰٓؤُلَآءِ إِيَّاكُمْ كَانُوا۟ يَعْبُدُونَ","numberInSurah":40,"juz":22,"manzil":5,"page":433,"ruku":374,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3647,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3647.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3647.mp3"],"text":"قَالُوا۟ سُبْحَٰنَكَ أَنتَ وَلِيُّنَا مِن دُونِهِم ۖ بَلْ كَانُوا۟ يَعْبُدُونَ ٱلْجِنَّ ۖ أَكْثَرُهُم بِهِم مُّؤْمِنُونَ","numberInSurah":41,"juz":22,"manzil":5,"page":433,"ruku":374,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3648,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3648.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3648.mp3"],"text":"فَٱلْيَوْمَ لَا يَمْلِكُ بَعْضُكُمْ لِبَعْضٍۢ نَّفْعًۭا وَلَا ضَرًّۭا وَنَقُولُ لِلَّذِينَ ظَلَمُوا۟ ذُوقُوا۟ عَذَابَ ٱلنَّارِ ٱلَّتِى كُنتُم بِهَا تُكَذِّبُونَ","numberInSurah":42,"juz":22,"manzil":5,"page":433,"ruku":374,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3649,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3649.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3649.mp3"],"text":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍۢ قَالُوا۟ مَا هَٰذَآ إِلَّا رَجُلٌۭ يُرِيدُ أَن يَصُدَّكُمْ عَمَّا كَانَ يَعْبُدُ ءَابَآؤُكُمْ وَقَالُوا۟ مَا هَٰذَآ إِلَّآ إِفْكٌۭ مُّفْتَرًۭى ۚ وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لِلْحَقِّ لَمَّا جَآءَهُمْ إِنْ هَٰذَآ إِلَّا سِحْرٌۭ مُّبِينٌۭ","numberInSurah":43,"juz":22,"manzil":5,"page":433,"ruku":374,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3650,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3650.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3650.mp3"],"text":"وَمَآ ءَاتَيْنَٰهُم مِّن كُتُبٍۢ يَدْرُسُونَهَا ۖ وَمَآ أَرْسَلْنَآ إِلَيْهِمْ قَبْلَكَ مِن نَّذِيرٍۢ","numberInSurah":44,"juz":22,"manzil":5,"page":433,"ruku":374,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},{"number":3651,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3651.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3651.mp3"],"text":"وَكَذَّبَ ٱلَّذِينَ مِن قَبْلِهِمْ وَمَا بَلَغُوا۟ مِعْشَارَ مَآ ءَاتَيْنَٰهُمْ فَكَذَّبُوا۟ رُسُلِى ۖ فَكَيْفَ كَانَ نَكِيرِ","numberInSurah":45,"juz":22,"manzil":5,"page":433,"ruku":374,"hizbQuarter":173,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}}],"surahs":{"34":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},"edition":{}}}