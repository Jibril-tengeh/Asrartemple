{"code":200,"status":"OK","data":{"number":182,"ayahs":[{"number":3991,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3991.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3991.mp3"],"text":"۞ وَهَلْ أَتَىٰكَ نَبَؤُا۟ ٱلْخَصْمِ إِذْ تَسَوَّرُوا۟ ٱلْمِحْرَابَ","numberInSurah":21,"juz":23,"manzil":6,"page":454,"ruku":392,"hizbQuarter":182,"sajda":false,"surah":{"number":38,"name":"سُورَةُ صٓ","englishName":"Saad","englishNameTranslation":"The letter Saad","revelationType":"Meccan"}},{"number":3992,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3992.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3992.mp3"],"text":"إِذْ دَخَلُوا۟ عَلَىٰ دَاوُۥدَ فَفَزِعَ مِنْهُمْ ۖ قَالُوا۟ لَا تَخَفْ ۖ خَصْمَانِ بَغَىٰ بَعْضُنَا عَلَىٰ بَعْضٍۢ فَٱحْكُم بَيْنَنَا بِٱلْحَقِّ وَلَا تُشْطِطْ وَٱهْدِنَآ إِلَىٰ سَوَآءِ ٱلصِّرَٰطِ","numberInSurah":22,"juz":23,"manzil":6,"page":454,"ruku":392,"hizbQuarter":182,"sajda":false,"surah":{"number":38,"name":"سُورَةُ صٓ","englishName":"Saad","englishNameTranslation":"The letter Saad","revelationType":"Meccan"}},{"number":3993,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3993.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3993.mp3"],"text":"إِنَّ هَٰذَآ أَخِى لَهُۥ تِسْعٌۭ وَتِسْعُونَ نَعْجَةًۭ وَلِىَ نَعْجَةٌۭ وَٰحِدَةٌۭ فَقَالَ أَكْفِلْنِيهَا وَعَزَّنِى فِى ٱلْخِطَابِ","numberInSurah":23,"juz":23,"manzil":6,"page":454,"ruku":392,"hizbQuarter":182,"sajda":false,"surah":{"number":38,"name":"سُورَةُ صٓ","englishName":"Saad","englishNameTranslation":"The letter Saad","revelationType":"Meccan"}},{"number":3994,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3994.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3994.mp3"],"text":"قَالَ لَقَدْ ظَلَمَكَ بِسُؤَالِ نَعْجَتِكَ إِلَىٰ نِعَاجِهِۦ ۖ وَإِنَّ كَثِيرًۭا مِّنَ ٱلْخُلَطَآءِ لَيَبْغِى بَعْضُهُمْ عَلَىٰ بَعْضٍ إِل