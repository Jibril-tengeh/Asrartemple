sajda":false,"surah":{"number":38,"name":"سُورَةُ صٓ","englishName":"Saad","englishNameTranslation":"The letter Saad","revelationType":"Meccan"}},{"number":3998,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3998.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3998.mp3"],"text":"أَمْ نَجْعَلُ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ كَٱلْمُفْسِدِينَ فِى ٱلْأَرْضِ أَمْ نَجْعَلُ ٱلْمُتَّقِينَ كَٱلْفُجَّارِ","numberInSurah":28,"juz":23,"manzil":6,"page":455,"ruku":393,"hizbQuarter":182,"sajda":false,"surah":{"number":38,"name":"سُورَةُ صٓ","englishName":"Saad","englishNameTranslation":"The letter Saad","revelationType":"Meccan"}},{"number":3999,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3999.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3999.mp3"],"text":"كِتَٰبٌ أَنزَلْنَٰهُ إِلَيْكَ مُبَٰرَكٌۭ لِّيَدَّبَّرُوٓا۟ ءَايَٰتِهِۦ وَلِيَتَذَكَّرَ أُو۟لُوا۟ ٱلْأَلْبَٰبِ","numberInSurah":29,"juz":23,"manzil":6,"page":455,"ruku":393,"hizbQuarter":182,"sajda":false,"surah":{"number":38,"name":"سُورَةُ صٓ","englishName":"Saad","englishNameTranslation":"The letter Saad","revelationType":"Meccan"}},{"number":4000,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4000.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4000.mp3"],"text":"وَوَهَبْنَا لِدَاوُۥدَ سُلَيْمَٰنَ ۚ نِعْمَ ٱلْعَبْدُ ۖ إِنَّهُۥٓ أَوَّابٌ","numberInSurah":30,"juz":23,"manzil":6,"page":455,"ruku":393,"hizbQuarter":182,"sajda":false,"surah":{"number":38,"name":"سُورَةُ صٓ","englishName":"Saad","englishNameTranslation":"The letter Saad","revelationType":"Meccan"}},{"number":4001,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4001.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4001.mp3"],"text":"إِذْ عُرِضَ عَلَيْهِ بِٱلْعَشِىِّ ٱلصَّٰفِنَٰتُ ٱلْجِيَادُ","numberInSurah":31,"juz":23,"manzil":6,"page":455,"ruku":393,"hizbQuar