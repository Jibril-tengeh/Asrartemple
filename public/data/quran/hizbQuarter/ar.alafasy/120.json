{"code":200,"status":"OK","data":{"number":120,"ayahs":[{"number":2191,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2191.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2191.mp3"],"text":"۞ مَّآ أَشْهَدتُّهُمْ خَلْقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَلَا خَلْقَ أَنفُسِهِمْ وَمَا كُنتُ مُتَّخِذَ ٱلْمُضِلِّينَ عَضُدًۭا","numberInSurah":51,"juz":15,"manzil":4,"page":299,"ruku":258,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2192,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2192.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2192.mp3"],"text":"وَيَوْمَ يَقُولُ نَادُوا۟ شُرَكَآءِىَ ٱلَّذِينَ زَعَمْتُمْ فَدَعَوْهُمْ فَلَمْ يَسْتَجِيبُوا۟ لَهُمْ وَجَعَلْنَا بَيْنَهُم مَّوْبِقًۭا","numberInSurah":52,"juz":15,"manzil":4,"page":299,"ruku":258,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2193,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2193.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2193.mp3"],"text":"وَرَءَا ٱلْمُجْرِمُونَ ٱلنَّارَ فَظَنُّوٓا۟ أَنَّهُم مُّوَاقِعُوهَا وَلَمْ يَجِدُوا۟ عَنْهَا مَصْرِفًۭا","numberInSurah":53,"juz":15,"manzil":4,"page":299,"ruku":258,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2194,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2194.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2194.mp3"],"text":"وَلَقَدْ صَرَّفْنَا فِى هَٰذَا ٱلْقُرْءَانِ لِلنَّاسِ مِن كُلِّ مَثَلٍۢ ۚ وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍۢ جَدَلًۭا","numberInSurah":54,"juz":15,"manzil":4,"page":300,"ruku":259,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2195,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2195.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2195.mp3"],"text":"وَمَا مَنَعَ ٱلنَّاسَ أَن يُؤْمِنُوٓا۟ إِذْ جَآءَهُمُ ٱلْهُدَىٰ وَيَسْتَغْفِرُوا۟ رَبَّهُمْ إِلَّآ أَن تَأْتِيَهُمْ سُنَّةُ ٱلْأَوَّلِينَ أَوْ يَأْتِيَهُمُ ٱلْعَذَابُ قُبُلًۭا","numberInSurah":55,"juz":15,"manzil":4,"page":300,"ruku":259,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2196,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2196.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2196.mp3"],"text":"وَمَا نُرْسِلُ ٱلْمُرْسَلِينَ إِلَّا مُبَشِّرِينَ وَمُنذِرِينَ ۚ وَيُجَٰدِلُ ٱلَّذِينَ كَفَرُوا۟ بِٱلْبَٰطِلِ لِيُدْحِضُوا۟ بِهِ ٱلْحَقَّ ۖ وَٱتَّخَذُوٓا۟ ءَايَٰتِى وَمَآ أُنذِرُوا۟ هُزُوًۭا","numberInSurah":56,"juz":15,"manzil":4,"page":300,"ruku":259,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2197,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2197.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2197.mp3"],"text":"وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ ۚ إِنَّا جَعَلْنَا عَلَىٰ قُلُوبِهِمْ أَكِنَّةً أَن يَفْقَهُوهُ وَفِىٓ ءَاذَانِهِمْ وَقْرًۭا ۖ وَإِن تَدْعُهُمْ إِلَى ٱلْهُدَىٰ فَلَن يَهْتَدُوٓا۟ إِذًا أَبَدًۭا","numberInSurah":57,"juz":15,"manzil":4,"page":300,"ruku":259,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2198,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2198.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2198.mp3"],"text":"وَرَبُّكَ ٱلْغَفُورُ ذُو ٱلرَّحْمَةِ ۖ لَوْ يُؤَاخِذُهُم بِمَا كَسَبُوا۟ لَعَجَّلَ لَهُمُ ٱلْعَذَابَ ۚ بَل لَّهُم مَّوْعِدٌۭ لَّن يَجِدُوا۟ مِن دُونِهِۦ مَوْئِلًۭا","numberInSurah":58,"juz":15,"manzil":4,"page":300,"ruku":259,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2199,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2199.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2199.mp3"],"text":"وَتِلْكَ ٱلْقُرَىٰٓ أَهْلَكْنَٰهُمْ لَمَّا ظَلَمُوا۟ وَجَعَلْنَا لِمَهْلِكِهِم مَّوْعِدًۭا","numberInSurah":59,"juz":15,"manzil":4,"page":300,"ruku":259,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2200,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2200.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2200.mp3"],"text":"وَإِذْ قَالَ مُوسَىٰ لِفَتَىٰهُ لَآ أَبْرَحُ حَتَّىٰٓ أَبْلُغَ مَجْمَعَ ٱلْبَحْرَيْنِ أَوْ أَمْضِىَ حُقُبًۭا","numberInSurah":60,"juz":15,"manzil":4,"page":300,"ruku":260,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2201,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2201.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2201.mp3"],"text":"فَلَمَّا بَلَغَا مَجْمَعَ بَيْنِهِمَا نَسِيَا حُوتَهُمَا فَٱتَّخَذَ سَبِيلَهُۥ فِى ٱلْبَحْرِ سَرَبًۭا","numberInSurah":61,"juz":15,"manzil":4,"page":300,"ruku":260,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2202,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2202.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2202.mp3"],"text":"فَلَمَّا جَاوَزَا قَالَ لِفَتَىٰهُ ءَاتِنَا غَدَآءَنَا لَقَدْ لَقِينَا مِن سَفَرِنَا هَٰذَا نَصَبًۭا","numberInSurah":62,"juz":15,"manzil":4,"page":301,"ruku":260,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2203,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2203.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2203.mp3"],"text":"قَالَ أَرَءَيْتَ إِذْ أَوَيْنَآ إِلَى ٱلصَّخْرَةِ فَإِنِّى نَسِيتُ ٱلْحُوتَ وَمَآ أَنسَىٰنِيهُ إِلَّا ٱلشَّيْطَٰنُ أَنْ أَذْكُرَهُۥ ۚ وَٱتَّخَذَ سَبِيلَهُۥ فِى ٱلْبَحْرِ عَجَبًۭا","numberInSurah":63,"juz":15,"manzil":4,"page":301,"ruku":260,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2204,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2204.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2204.mp3"],"text":"قَالَ ذَٰلِكَ مَا كُنَّا نَبْغِ ۚ فَٱرْتَدَّا عَلَىٰٓ ءَاثَارِهِمَا قَصَصًۭا","numberInSurah":64,"juz":15,"manzil":4,"page":301,"ruku":260,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2205,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2205.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2205.mp3"],"text":"فَوَجَدَا عَبْدًۭا مِّنْ عِبَادِنَآ ءَاتَيْنَٰهُ رَحْمَةًۭ مِّنْ عِندِنَا وَعَلَّمْنَٰهُ مِن لَّدُنَّا عِلْمًۭا","numberInSurah":65,"juz":15,"manzil":4,"page":301,"ruku":260,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2206,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2206.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2206.mp3"],"text":"قَالَ لَهُۥ مُوسَىٰ هَلْ أَتَّبِعُكَ عَلَىٰٓ أَن تُعَلِّمَنِ مِمَّا عُلِّمْتَ رُشْدًۭا","numberInSurah":66,"juz":15,"manzil":4,"page":301,"ruku":260,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2207,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2207.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2207.mp3"],"text":"قَالَ إِنَّكَ لَن تَسْتَطِيعَ مَعِىَ صَبْرًۭا","numberInSurah":67,"juz":15,"manzil":4,"page":301,"ruku":260,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2208,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2208.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2208.mp3"],"text":"وَكَيْفَ تَصْبِرُ عَلَىٰ مَا لَمْ تُحِطْ بِهِۦ خُبْرًۭا","numberInSurah":68,"juz":15,"manzil":4,"page":301,"ruku":260,"hizbQuarter":120,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2209,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2209.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2209.mp3"],"text":"قَالَ سَتَجِدُنِىٓ إِن شَآءَ ٱللَّهُ صَابِرًۭا وَلَآ أَعْصِى لَكَ أَمْرًۭا","numberInSurah":69,"juz":15,"manzil":4,"page":301,"ruku"