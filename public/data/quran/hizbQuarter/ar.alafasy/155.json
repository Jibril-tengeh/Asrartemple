{"code":200,"status":"OK","data":{"number":155,"ayahs":[{"number":3264,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3264.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3264.mp3"],"text":"۞ وَحَرَّمْنَا عَلَيْهِ ٱلْمَرَاضِعَ مِن قَبْلُ فَقَالَتْ هَلْ أَدُلُّكُمْ عَلَىٰٓ أَهْلِ بَيْتٍۢ يَكْفُلُونَهُۥ لَكُمْ وَهُمْ لَهُۥ نَٰصِحُونَ","numberInSurah":12,"juz":20,"manzil":5,"page":386,"ruku":334,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3265,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3265.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3265.mp3"],"text":"فَرَدَدْنَٰهُ إِلَىٰٓ أُمِّهِۦ كَىْ تَقَرَّ عَيْنُهَا وَلَا تَحْزَنَ وَلِتَعْلَمَ أَنَّ وَعْدَ ٱللَّهِ حَقٌّۭ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","numberInSurah":13,"juz":20,"manzil":5,"page":386,"ruku":334,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3266,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3266.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3266.mp3"],"text":"وَلَمَّا بَلَغَ أَشُدَّهُۥ وَٱسْتَوَىٰٓ ءَاتَيْنَٰهُ حُكْمًۭا وَعِلْمًۭا ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","numberInSurah":14,"juz":20,"manzil":5,"page":387,"ruku":335,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3267,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3267.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3267.mp3"],"text":"وَدَخَلَ ٱلْمَدِينَةَ عَلَىٰ حِينِ غَفْلَةٍۢ مِّنْ أَهْلِهَا فَوَجَدَ فِيهَا رَجُلَيْنِ يَقْتَتِلَانِ هَٰذَا مِن شِيعَتِهِۦ وَهَٰذَا مِنْ عَدُوِّهِۦ ۖ فَٱسْتَغَٰثَهُ ٱلَّذِى مِن شِيعَتِهِۦ عَلَى ٱلَّذِى مِنْ عَدُوِّهِۦ فَوَكَزَهُۥ مُوسَىٰ فَقَضَىٰ عَلَيْهِ ۖ قَالَ هَٰذَا مِنْ عَمَلِ ٱلشَّيْطَٰنِ ۖ إِنَّهُۥ عَدُوٌّۭ مُّضِلٌّۭ مُّبِينٌۭ","numberInSurah":15,"juz":20,"manzil":5,"page":387,"ruku":335,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3268,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3268.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3268.mp3"],"text":"قَالَ رَبِّ إِنِّى ظَلَمْتُ نَفْسِى فَٱغْفِرْ لِى فَغَفَرَ لَهُۥٓ ۚ إِنَّهُۥ هُوَ ٱلْغَفُورُ ٱلرَّحِيمُ","numberInSurah":16,"juz":20,"manzil":5,"page":387,"ruku":335,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3269,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3269.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3269.mp3"],"text":"قَالَ رَبِّ بِمَآ أَنْعَمْتَ عَلَىَّ فَلَنْ أَكُونَ ظَهِيرًۭا لِّلْمُجْرِمِينَ","numberInSurah":17,"juz":20,"manzil":5,"page":387,"ruku":335,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3270,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3270.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3270.mp3"],"text":"فَأَصْبَحَ فِى ٱلْمَدِينَةِ خَآئِفًۭا يَتَرَقَّبُ فَإِذَا ٱلَّذِى ٱسْتَنصَرَهُۥ بِٱلْأَمْسِ يَسْتَصْرِخُهُۥ ۚ قَالَ لَهُۥ مُوسَىٰٓ إِنَّكَ لَغَوِىٌّۭ مُّبِينٌۭ","numberInSurah":18,"juz":20,"manzil":5,"page":387,"ruku":335,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3271,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3271.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3271.mp3"],"text":"فَلَمَّآ أَنْ أَرَادَ أَن يَبْطِشَ بِٱلَّذِى هُوَ عَدُوٌّۭ لَّهُمَا قَالَ يَٰمُوسَىٰٓ أَتُرِيدُ أَن تَقْتُلَنِى كَمَا قَتَلْتَ نَفْسًۢا بِٱلْأَمْسِ ۖ إِن تُرِيدُ إِلَّآ أَن تَكُونَ جَبَّارًۭا فِى ٱلْأَرْضِ وَمَا تُرِيدُ أَن تَكُونَ مِنَ ٱلْمُصْلِحِينَ","numberInSurah":19,"juz":20,"manzil":5,"page":387,"ruku":335,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3272,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3272.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3272.mp3"],"text":"وَجَآءَ رَجُلٌۭ مِّنْ أَقْصَا ٱلْمَدِينَةِ يَسْعَىٰ قَالَ يَٰمُوسَىٰٓ إِنَّ ٱلْمَلَأَ يَأْتَمِرُونَ بِكَ لِيَقْتُلُوكَ فَٱخْرُجْ إِنِّى لَكَ مِنَ ٱلنَّٰصِحِينَ","numberInSurah":20,"juz":20,"manzil":5,"page":387,"ruku":335,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3273,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3273.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3273.mp3"],"text":"فَخَرَجَ مِنْهَا خَآئِفًۭا يَتَرَقَّبُ ۖ قَالَ رَبِّ نَجِّنِى مِنَ ٱلْقَوْمِ ٱلظَّٰلِمِينَ","numberInSurah":21,"juz":20,"manzil":5,"page":387,"ruku":335,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3274,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3274.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3274.mp3"],"text":"وَلَمَّا تَوَجَّهَ تِلْقَآءَ مَدْيَنَ قَالَ عَسَىٰ رَبِّىٓ أَن يَهْدِيَنِى سَوَآءَ ٱلسَّبِيلِ","numberInSurah":22,"juz":20,"manzil":5,"page":388,"ruku":336,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3275,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3275.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3275.mp3"],"text":"وَلَمَّا وَرَدَ مَآءَ مَدْيَنَ وَجَدَ عَلَيْهِ أُمَّةًۭ مِّنَ ٱلنَّاسِ يَسْقُونَ وَوَجَدَ مِن دُونِهِمُ ٱمْرَأَتَيْنِ تَذُودَانِ ۖ قَالَ مَا خَطْبُكُمَا ۖ قَالَتَا لَا نَسْقِى حَتَّىٰ يُصْدِرَ ٱلرِّعَآءُ ۖ وَأَبُونَا شَيْخٌۭ كَبِيرٌۭ","numberInSurah":23,"juz":20,"manzil":5,"page":388,"ruku":336,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3276,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3276.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3276.mp3"],"text":"فَسَقَىٰ لَهُمَا ثُمَّ تَوَلَّىٰٓ إِلَى ٱلظِّلِّ فَقَالَ رَبِّ إِنِّى لِمَآ أَنزَلْتَ إِلَىَّ مِنْ خَيْرٍۢ فَقِيرٌۭ","numberInSurah":24,"juz":20,"manzil":5,"page":388,"ruku":336,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3277,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3277.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3277.mp3"],"text":"فَجَآءَتْهُ إِحْدَىٰهُمَا تَمْشِى عَلَى ٱسْتِحْيَآءٍۢ قَالَتْ إِنَّ أَبِى يَدْعُوكَ لِيَجْزِيَكَ أَجْرَ مَا سَقَيْتَ لَنَا ۚ فَلَمَّا جَآءَهُۥ وَقَصَّ عَلَيْهِ ٱلْقَصَصَ قَالَ لَا تَخَفْ ۖ نَجَوْتَ مِنَ ٱلْقَوْمِ ٱلظَّٰلِمِينَ","numberInSurah":25,"juz":20,"manzil":5,"page":388,"ruku":336,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3278,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3278.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3278.mp3"],"text":"قَالَتْ إِحْدَىٰهُمَا يَٰٓأَبَتِ ٱسْتَـْٔجِرْهُ ۖ إِنَّ خَيْرَ مَنِ ٱسْتَـْٔجَرْتَ ٱلْقَوِىُّ ٱلْأَمِينُ","numberInSurah":26,"juz":20,"manzil":5,"page":388,"ruku":336,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3279,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3279.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3279.mp3"],"text":"قَالَ إِنِّىٓ أُرِيدُ أَنْ أُنكِحَكَ إِحْدَى ٱبْنَتَىَّ هَٰتَيْنِ عَلَىٰٓ أَن تَأْجُرَنِى ثَمَٰنِىَ حِجَجٍۢ ۖ فَإِنْ أَتْمَمْتَ عَشْرًۭا فَمِنْ عِندِكَ ۖ وَمَآ أُرِيدُ أَنْ أَشُقَّ عَلَيْكَ ۚ سَتَجِدُنِىٓ إِن شَآءَ ٱللَّهُ مِنَ ٱلصَّٰلِحِينَ","numberInSurah":27,"juz":20,"manzil":5,"page":388,"ruku":336,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},{"number":3280,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3280.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3280.mp3"],"text":"قَالَ ذَٰلِكَ بَيْنِى وَبَيْنَكَ ۖ أَيَّمَا ٱلْأَجَلَيْنِ قَضَيْتُ فَلَا عُدْوَٰنَ عَلَىَّ ۖ وَٱللَّهُ عَلَىٰ مَا نَقُولُ وَكِيلٌۭ","numberInSurah":28,"juz":20,"manzil":5,"page":388,"ruku":336,"hizbQuarter":155,"sajda":false,"surah":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}}],"surahs":{"28":{"number":28,"name":"سُورَةُ القَصَصِ","englishName":"Al-Qasas","englishNameTranslation":"The Stories","revelationType":"Meccan"}},"editio