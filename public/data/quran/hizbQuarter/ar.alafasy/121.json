an/audio/128/ar.alafasy/2234.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2234.mp3"],"text":"قَالُوا۟ يَٰذَا ٱلْقَرْنَيْنِ إِنَّ يَأْجُوجَ وَمَأْجُوجَ مُفْسِدُونَ فِى ٱلْأَرْضِ فَهَلْ نَجْعَلُ لَكَ خَرْجًا عَلَىٰٓ أَن تَجْعَلَ بَيْنَنَا وَبَيْنَهُمْ سَدًّۭا","numberInSurah":94,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2235,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2235.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2235.mp3"],"text":"قَالَ مَا مَكَّنِّى فِيهِ رَبِّى خَيْرٌۭ فَأَعِينُونِى بِقُوَّةٍ أَجْعَلْ بَيْنَكُمْ وَبَيْنَهُمْ رَدْمًا","numberInSurah":95,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2236,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2236.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2236.mp3"],"text":"ءَاتُونِى زُبَرَ ٱلْحَدِيدِ ۖ حَتَّىٰٓ إِذَا سَاوَىٰ بَيْنَ ٱلصَّدَفَيْنِ قَالَ ٱنفُخُوا۟ ۖ حَتَّىٰٓ إِذَا جَعَلَهُۥ نَارًۭا قَالَ ءَاتُونِىٓ أُفْرِغْ عَلَيْهِ قِطْرًۭا","numberInSurah":96,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2237,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2237.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2237.mp3"],"text":"فَمَا ٱسْطَٰعُوٓا۟ أَن يَظْهَرُوهُ وَمَا ٱسْتَطَٰعُوا۟ لَهُۥ نَقْبًۭا","numberInSurah":97,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2238,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2238.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2238.mp3"],"text":"قَالَ هَٰذَا رَحْمَةٌۭ مِّن رَّبِّى ۖ فَإِذَا جَآءَ وَعْدُ رَبِّى جَعَلَهُۥ دَكَّآءَ ۖ وَكَانَ وَعْدُ رَبِّى حَقًّۭا","numberInSurah":98,"juz":16,"manzil":4,"page":304,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}}],"surahs":{"18":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},"edition":{}}}