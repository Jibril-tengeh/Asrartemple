{"code":200,"status":"OK","data":{"number":121,"ayahs":[{"number":2215,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2215.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2215.mp3"],"text":"۞ قَالَ أَلَمْ أَقُل لَّكَ إِنَّكَ لَن تَسْتَطِيعَ مَعِىَ صَبْرًۭا","numberInSurah":75,"juz":16,"manzil":4,"page":302,"ruku":261,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2216,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2216.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2216.mp3"],"text":"قَالَ إِن سَأَلْتُكَ عَن شَىْءٍۭ بَعْدَهَا فَلَا تُصَٰحِبْنِى ۖ قَدْ بَلَغْتَ مِن لَّدُنِّى عُذْرًۭا","numberInSurah":76,"juz":16,"manzil":4,"page":302,"ruku":261,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2217,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2217.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2217.mp3"],"text":"فَٱنطَلَقَا حَتَّىٰٓ إِذَآ أَتَيَآ أَهْلَ قَرْيَةٍ ٱسْتَطْعَمَآ أَهْلَهَا فَأَبَوْا۟ أَن يُضَيِّفُوهُمَا فَوَجَدَا فِيهَا جِدَارًۭا يُرِيدُ أَن يَنقَضَّ فَأَقَامَهُۥ ۖ قَالَ لَوْ شِئْتَ لَتَّخَذْتَ عَلَيْهِ أَجْرًۭا","numberInSurah":77,"juz":16,"manzil":4,"page":302,"ruku":261,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2218,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2218.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2218.mp3"],"text":"قَالَ هَٰذَا فِرَاقُ بَيْنِى وَبَيْنِكَ ۚ سَأُنَبِّئُكَ بِتَأْوِيلِ مَا لَمْ تَسْتَطِع عَّلَيْهِ صَبْرًا","numberInSurah":78,"juz":16,"manzil":4,"page":302,"ruku":261,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2219,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2219.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2219.mp3"],"text":"أَمَّا ٱلسَّفِينَةُ فَكَانَتْ لِمَسَٰكِينَ يَعْمَلُونَ فِى ٱلْبَحْرِ فَأَرَدتُّ أَنْ أَعِيبَهَا وَكَانَ وَرَآءَهُم مَّلِكٌۭ يَأْخُذُ كُلَّ سَفِينَةٍ غَصْبًۭا","numberInSurah":79,"juz":16,"manzil":4,"page":302,"ruku":261,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2220,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2220.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2220.mp3"],"text":"وَأَمَّا ٱلْغُلَٰمُ فَكَانَ أَبَوَاهُ مُؤْمِنَيْنِ فَخَشِينَآ أَن يُرْهِقَهُمَا طُغْيَٰنًۭا وَكُفْرًۭا","numberInSurah":80,"juz":16,"manzil":4,"page":302,"ruku":261,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2221,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2221.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2221.mp3"],"text":"فَأَرَدْنَآ أَن يُبْدِلَهُمَا رَبُّهُمَا خَيْرًۭا مِّنْهُ زَكَوٰةًۭ وَأَقْرَبَ رُحْمًۭا","numberInSurah":81,"juz":16,"manzil":4,"page":302,"ruku":261,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2222,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2222.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2222.mp3"],"text":"وَأَمَّا ٱلْجِدَارُ فَكَانَ لِغُلَٰمَيْنِ يَتِيمَيْنِ فِى ٱلْمَدِينَةِ وَكَانَ تَحْتَهُۥ كَنزٌۭ لَّهُمَا وَكَانَ أَبُوهُمَا صَٰلِحًۭا فَأَرَادَ رَبُّكَ أَن يَبْلُغَآ أَشُدَّهُمَا وَيَسْتَخْرِجَا كَنزَهُمَا رَحْمَةًۭ مِّن رَّبِّكَ ۚ وَمَا فَعَلْتُهُۥ عَنْ أَمْرِى ۚ ذَٰلِكَ تَأْوِيلُ مَا لَمْ تَسْطِع عَّلَيْهِ صَبْرًۭا","numberInSurah":82,"juz":16,"manzil":4,"page":302,"ruku":261,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2223,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2223.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2223.mp3"],"text":"وَيَسْـَٔلُونَكَ عَن ذِى ٱلْقَرْنَيْنِ ۖ قُلْ سَأَتْلُوا۟ عَلَيْكُم مِّنْهُ ذِكْرًا","numberInSurah":83,"juz":16,"manzil":4,"page":302,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2224,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2224.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2224.mp3"],"text":"إِنَّا مَكَّنَّا لَهُۥ فِى ٱلْأَرْضِ وَءَاتَيْنَٰهُ مِن كُلِّ شَىْءٍۢ سَبَبًۭا","numberInSurah":84,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2225,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2225.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2225.mp3"],"text":"فَأَتْبَعَ سَبَبًا","numberInSurah":85,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2226,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2226.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2226.mp3"],"text":"حَتَّىٰٓ إِذَا بَلَغَ مَغْرِبَ ٱلشَّمْسِ وَجَدَهَا تَغْرُبُ فِى عَيْنٍ حَمِئَةٍۢ وَوَجَدَ عِندَهَا قَوْمًۭا ۗ قُلْنَا يَٰذَا ٱلْقَرْنَيْنِ إِمَّآ أَن تُعَذِّبَ وَإِمَّآ أَن تَتَّخِذَ فِيهِمْ حُسْنًۭا","numberInSurah":86,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2227,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2227.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2227.mp3"],"text":"قَالَ أَمَّا مَن ظَلَمَ فَسَوْفَ نُعَذِّبُهُۥ ثُمَّ يُرَدُّ إِلَىٰ رَبِّهِۦ فَيُعَذِّبُهُۥ عَذَابًۭا نُّكْرًۭا","numberInSurah":87,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2228,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2228.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2228.mp3"],"text":"وَأَمَّا مَنْ ءَامَنَ وَعَمِلَ صَٰلِحًۭا فَلَهُۥ جَزَآءً ٱلْحُسْنَىٰ ۖ وَسَنَقُولُ لَهُۥ مِنْ أَمْرِنَا يُسْرًۭا","numberInSurah":88,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}},{"number":2229,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2229.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2229.mp3"],"text":"ثُمَّ أَتْبَعَ سَبَبًا","numberInSurah":89,"juz":16,"manzil":4,"page":303,"ruku":262,"hizbQuarter":121,"sajda":false,"surah":{"number":18,"name":"سُورَةُ الكَهۡفِ","englishName":"Al-Kahf","englishNameTranslation":"The Cave","revelationType":"Meccan"}