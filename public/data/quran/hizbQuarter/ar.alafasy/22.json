{"code":200,"status":"OK","data":{"number":22,"ayahs":[{"number":326,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/326.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/326.mp3"],"text":"۞ إِنَّ ٱللَّهَ ٱصْطَفَىٰٓ ءَادَمَ وَنُوحًۭا وَءَالَ إِبْرَٰهِيمَ وَءَالَ عِمْرَٰنَ عَلَى ٱلْعَٰلَمِينَ","numberInSurah":33,"juz":3,"manzil":1,"page":54,"ruku":45,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":327,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/327.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/327.mp3"],"text":"ذُرِّيَّةًۢ بَعْضُهَا مِنۢ بَعْضٍۢ ۗ وَٱللَّهُ سَمِيعٌ عَلِيمٌ","numberInSurah":34,"juz":3,"manzil":1,"page":54,"ruku":45,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":328,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/328.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/328.mp3"],"text":"إِذْ قَالَتِ ٱمْرَأَتُ عِمْرَٰنَ رَبِّ إِنِّى نَذَرْتُ لَكَ مَا فِى بَطْنِى مُحَرَّرًۭا فَتَقَبَّلْ مِنِّىٓ ۖ إِنَّكَ أَنتَ ٱلسَّمِيعُ ٱلْعَلِيمُ","numberInSurah":35,"juz":3,"manzil":1,"page":54,"ruku":45,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":329,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/329.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/329.mp3"],"text":"فَلَمَّا وَضَعَتْهَا قَالَتْ رَبِّ إِنِّى وَضَعْتُهَآ أُنثَىٰ وَٱللَّهُ أَعْلَمُ بِمَا وَضَعَتْ وَلَيْسَ ٱلذَّكَرُ كَٱلْأُنثَىٰ ۖ وَإِنِّى سَمَّيْتُهَا مَرْيَمَ وَإِنِّىٓ أُعِيذُهَا بِكَ وَذُرِّيَّتَهَا مِنَ ٱلشَّيْطَٰنِ ٱلرَّجِيمِ","numberInSurah":36,"juz":3,"manzil":1,"page":54,"ruku":45,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":330,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/330.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/330.mp3"],"text":"فَتَقَبَّلَهَا رَبُّهَا بِقَبُولٍ حَسَنٍۢ وَأَنۢبَتَهَا نَبَاتًا حَسَنًۭا وَكَفَّلَهَا زَكَرِيَّا ۖ كُلَّمَا دَخَلَ عَلَيْهَا زَكَرِيَّا ٱلْمِحْرَابَ وَجَدَ عِندَهَا رِزْقًۭا ۖ قَالَ يَٰمَرْيَمُ أَنَّىٰ لَكِ هَٰذَا ۖ قَالَتْ هُوَ مِنْ عِندِ ٱللَّهِ ۖ إِنَّ ٱللَّهَ يَرْزُقُ مَن يَشَآءُ بِغَيْرِ حِسَابٍ","numberInSurah":37,"juz":3,"manzil":1,"page":54,"ruku":45,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":331,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/331.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/331.mp3"],"text":"هُنَالِكَ دَعَا زَكَرِيَّا رَبَّهُۥ ۖ قَالَ رَبِّ هَبْ لِى مِن لَّدُنكَ ذُرِّيَّةًۭ طَيِّبَةً ۖ إِنَّكَ سَمِيعُ ٱلدُّعَآءِ","numberInSurah":38,"juz":3,"manzil":1,"page":55,"ruku":45,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":332,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/332.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/332.mp3"],"text":"فَنَادَتْهُ ٱلْمَلَٰٓئِكَةُ وَهُوَ قَآئِمٌۭ يُصَلِّى فِى ٱلْمِحْرَابِ أَنَّ ٱللَّهَ يُبَشِّرُكَ بِيَحْيَىٰ مُصَدِّقًۢا بِكَلِمَةٍۢ مِّنَ ٱللَّهِ وَسَيِّدًۭا وَحَصُورًۭا وَنَبِيًّۭا مِّنَ ٱلصَّٰلِحِينَ","numberInSurah":39,"juz":3,"manzil":1,"page":55,"ruku":45,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":333,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/333.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/333.mp3"],"text":"قَالَ رَبِّ أَنَّىٰ يَكُونُ لِى غُلَٰمٌۭ وَقَدْ بَلَغَنِىَ ٱلْكِبَرُ وَٱمْرَأَتِى عَاقِرٌۭ ۖ قَالَ كَذَٰلِكَ ٱللَّهُ يَفْعَلُ مَا يَشَآءُ","numberInSurah":40,"juz":3,"manzil":1,"page":55,"ruku":45,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":334,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/334.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/334.mp3"],"text":"قَالَ رَبِّ ٱجْعَل لِّىٓ ءَايَةًۭ ۖ قَالَ ءَايَتُكَ أَلَّا تُكَلِّمَ ٱلنَّاسَ ثَلَٰثَةَ أَيَّامٍ إِلَّا رَمْزًۭا ۗ وَٱذْكُر رَّبَّكَ كَثِيرًۭا وَسَبِّحْ بِٱلْعَشِىِّ وَٱلْإِبْكَٰرِ","numberInSurah":41,"juz":3,"manzil":1,"page":55,"ruku":45,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":335,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/335.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/335.mp3"],"text":"وَإِذْ قَالَتِ ٱلْمَلَٰٓئِكَةُ يَٰمَرْيَمُ إِنَّ ٱللَّهَ ٱصْطَفَىٰكِ وَطَهَّرَكِ وَٱصْطَفَىٰكِ عَلَىٰ نِسَآءِ ٱلْعَٰلَمِينَ","numberInSurah":42,"juz":3,"manzil":1,"page":55,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":336,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/336.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/336.mp3"],"text":"يَٰمَرْيَمُ ٱقْنُتِى لِرَبِّكِ وَٱسْجُدِى وَٱرْكَعِى مَعَ ٱلرَّٰكِعِينَ","numberInSurah":43,"juz":3,"manzil":1,"page":55,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":337,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/337.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/337.mp3"],"text":"ذَٰلِكَ مِنْ أَنۢبَآءِ ٱلْغَيْبِ نُوحِيهِ إِلَيْكَ ۚ وَمَا كُنتَ لَدَيْهِمْ إِذْ يُلْقُونَ أَقْلَٰمَهُمْ أَيُّهُمْ يَكْفُلُ مَرْيَمَ وَمَا كُنتَ لَدَيْهِمْ إِذْ يَخْتَصِمُونَ","numberInSurah":44,"juz":3,"manzil":1,"page":55,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":338,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/338.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/338.mp3"],"text":"إِذْ قَالَتِ ٱلْمَلَٰٓئِكَةُ يَٰمَرْيَمُ إِنَّ ٱللَّهَ يُبَشِّرُكِ بِكَلِمَةٍۢ مِّنْهُ ٱسْمُهُ ٱلْمَسِيحُ عِيسَى ٱبْنُ مَرْيَمَ وَجِيهًۭا فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ وَمِنَ ٱلْمُقَرَّبِينَ","numberInSurah":45,"juz":3,"manzil":1,"page":55,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":339,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/339.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/339.mp3"],"text":"وَيُكَلِّمُ ٱلنَّاسَ فِى ٱلْمَهْدِ وَكَهْلًۭا وَمِنَ ٱلصَّٰلِحِينَ","numberInSurah":46,"juz":3,"manzil":1,"page":56,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":340,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/340.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/340.mp3"],"text":"قَالَتْ رَبِّ أَنَّىٰ يَكُونُ لِى وَلَدٌۭ وَلَمْ يَمْسَسْنِى بَشَرٌۭ ۖ قَالَ كَذَٰلِكِ ٱللَّهُ يَخْلُقُ مَا يَشَآءُ ۚ إِذَا قَضَىٰٓ أَمْرًۭا فَإِنَّمَا يَقُولُ لَهُۥ كُن فَيَكُونُ","numberInSurah":47,"juz":3,"manzil":1,"page":56,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":341,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/341.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/341.mp3"],"text":"وَيُعَلِّمُهُ ٱلْكِتَٰبَ وَٱلْحِكْمَةَ وَٱلتَّوْرَىٰةَ وَٱلْإِنجِيلَ","numberInSurah":48,"juz":3,"manzil":1,"page":56,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":342,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/342.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/342.mp3"],"text":"وَرَسُولًا إِلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ أَنِّى قَدْ جِئْتُكُم بِـَٔايَةٍۢ مِّن رَّبِّكُمْ ۖ أَنِّىٓ أَخْلُقُ لَكُم مِّنَ ٱلطِّينِ كَهَيْـَٔةِ ٱلطَّيْرِ فَأَنفُخُ فِيهِ فَيَكُونُ طَيْرًۢا بِإِذْنِ ٱللَّهِ ۖ وَأُبْرِئُ ٱلْأَكْمَهَ وَٱلْأَبْرَصَ وَأُحْىِ ٱلْمَوْتَىٰ بِإِذْنِ ٱللَّهِ ۖ وَأُنَبِّئُكُم بِمَا تَأْكُلُونَ وَمَا تَدَّخِرُونَ فِى بُيُوتِكُمْ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لَّكُمْ إِن كُنتُم مُّؤْمِنِينَ","numberInSurah":49,"juz":3,"manzil":1,"page":56,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":343,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/343.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/343.mp3"],"text":"وَمُصَدِّقًۭا لِّمَا بَيْنَ يَدَىَّ مِنَ ٱلتَّوْرَىٰةِ وَلِأُحِلَّ لَكُم بَعْضَ ٱلَّذِى حُرِّمَ عَلَيْكُمْ ۚ وَجِئْتُكُم بِـَٔايَةٍۢ مِّن رَّبِّكُمْ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ","numberInSurah":50,"juz":3,"manzil":1,"page":56,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":344,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/344.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/344.mp3"],"text":"إِنَّ ٱللَّهَ رَبِّى وَرَبُّكُمْ فَٱعْبُدُوهُ ۗ هَٰذَا صِرَٰطٌۭ مُّسْتَقِيمٌۭ","numberInSurah":51,"juz":3,"manzil":1,"page":56,"ruku":46,"hizbQuarter":22,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}}],"surahs":{"3":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},"edition":{}}}