{"code":200,"status":"OK","data":{"number":164,"ayahs":[{"number":3463,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3463.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3463.mp3"],"text":"۞ ٱللَّهُ ٱلَّذِى خَلَقَكُم مِّن ضَعْفٍۢ ثُمَّ جَعَلَ مِنۢ بَعْدِ ضَعْفٍۢ قُوَّةًۭ ثُمَّ جَعَلَ مِنۢ بَعْدِ قُوَّةٍۢ ضَعْفًۭا وَشَيْبَةًۭ ۚ يَخْلُقُ مَا يَشَآءُ ۖ وَهُوَ ٱلْعَلِيمُ ٱلْقَدِيرُ","numberInSurah":54,"juz":21,"manzil":5,"page":410,"ruku":354,"hizbQuarter":164,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3464,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3464.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3464.mp3"],"text":"وَيَوْمَ تَقُومُ ٱلسَّاعَةُ يُقْسِمُ ٱلْمُجْرِمُونَ مَا لَبِثُوا۟ غَيْرَ سَاعَةٍۢ ۚ كَذَٰلِكَ كَانُوا۟ يُؤْفَكُونَ","numberInSurah":55,"juz":21,"manzil":5,"page":410,"ruku":354,"hizbQuarter":164,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3465,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3465.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3465.mp3"],"text":"وَقَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ وَٱلْإِيمَٰنَ لَقَدْ لَبِثْتُمْ فِى كِتَٰبِ ٱللَّهِ إِلَىٰ يَوْمِ ٱلْبَعْثِ ۖ فَهَٰذَا يَوْمُ ٱلْبَعْثِ وَلَٰكِنَّكُمْ كُنتُمْ لَا تَعْلَمُونَ","numberInSurah":56,"juz":21,"manzil":5,"page":410,"ruku":354,"hizbQuarter":164,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3466,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3466.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3466.mp3"],"text":"فَيَوْمَئِذٍۢ لَّا يَنفَعُ ٱلَّذِينَ ظَ