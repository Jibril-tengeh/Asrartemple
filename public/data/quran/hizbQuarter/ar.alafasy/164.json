":355,"hizbQuarter":164,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3475,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3475.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3475.mp3"],"text":"وَمِنَ ٱلنَّاسِ مَن يَشْتَرِى لَهْوَ ٱلْحَدِيثِ لِيُضِلَّ عَن سَبِيلِ ٱللَّهِ بِغَيْرِ عِلْمٍۢ وَيَتَّخِذَهَا هُزُوًا ۚ أُو۟لَٰٓئِكَ لَهُمْ عَذَابٌۭ مُّهِينٌۭ","numberInSurah":6,"juz":21,"manzil":5,"page":411,"ruku":355,"hizbQuarter":164,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3476,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3476.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3476.mp3"],"text":"وَإِذَا تُتْلَىٰ عَلَيْهِ ءَايَٰتُنَا وَلَّىٰ مُسْتَكْبِرًۭا كَأَن لَّمْ يَسْمَعْهَا كَأَنَّ فِىٓ أُذُنَيْهِ وَقْرًۭا ۖ فَبَشِّرْهُ بِعَذَابٍ أَلِيمٍ","numberInSurah":7,"juz":21,"manzil":5,"page":411,"ruku":355,"hizbQuarter":164,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3477,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3477.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3477.mp3"],"text":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ جَنَّٰتُ ٱلنَّعِيمِ","numberInSurah":8,"juz":21,"manzil":5,"page":411,"ruku":355,"hizbQuarter":164,"sajda":false,"surah":{"number":31,"name":"سُورَةُ لُقۡمَانَ","englishName":"Luqman","englishNameTranslation":"Luqman","revelationType":"Meccan"}},{"number":3478,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3478.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3478.mp3"],"text":"خَٰلِدِينَ فِيهَا ۖ وَعْدَ ٱللَّهِ حَق