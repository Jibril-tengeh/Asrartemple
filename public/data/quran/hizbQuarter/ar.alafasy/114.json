{"code":200,"status":"OK","data":{"number":114,"ayahs":[{"number":2052,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2052.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2052.mp3"],"text":"۞ وَقَضَىٰ رَبُّكَ أَلَّا تَعْبُدُوٓا۟ إِلَّآ إِيَّاهُ وَبِٱلْوَٰلِدَيْنِ إِحْسَٰنًا ۚ إِمَّا يَبْلُغَنَّ عِندَكَ ٱلْكِبَرَ أَحَدُهُمَآ أَوْ كِلَاهُمَا فَلَا تَقُل لَّهُمَآ أُفٍّۢ وَلَا تَنْهَرْهُمَا وَقُل لَّهُمَا قَوْلًۭا كَرِيمًۭا","numberInSurah":23,"juz":15,"manzil":4,"page":284,"ruku":242,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2053,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2053.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2053.mp3"],"text":"وَٱخْفِضْ لَهُمَا جَنَاحَ ٱلذُّلِّ مِنَ ٱلرَّحْمَةِ وَقُل رَّبِّ ٱرْحَمْهُمَا كَمَا رَبَّيَانِى صَغِيرًۭا","numberInSurah":24,"juz":15,"manzil":4,"page":284,"ruku":242,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2054,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2054.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2054.mp3"],"text":"رَّبُّكُمْ أَعْلَمُ بِمَا فِى نُفُوسِكُمْ ۚ إِن تَكُونُوا۟ صَٰلِحِينَ فَإِنَّهُۥ كَانَ لِلْأَوَّٰبِينَ غَفُورًۭا","numberInSurah":25,"juz":15,"manzil":4,"page":284,"ruku":242,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2055,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2055.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2055.mp3"],"text":"وَءَاتِ ذَا ٱلْقُرْبَىٰ حَقَّهُۥ وَٱلْمِسْكِينَ وَٱبْنَ ٱلسَّبِيلِ وَلَا تُبَذِّرْ تَبْذِيرًا","numberInSurah":26,"juz":15,"manzil":4,"page":284,"ruku":242,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2056,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2056.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2056.mp3"],"text":"إِنَّ ٱلْمُبَذِّرِينَ كَانُوٓا۟ إِخْوَٰنَ ٱلشَّيَٰطِينِ ۖ وَكَانَ ٱلشَّيْطَٰنُ لِرَبِّهِۦ كَفُورًۭا","numberInSurah":27,"juz":15,"manzil":4,"page":284,"ruku":242,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2057,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2057.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2057.mp3"],"text":"وَإِمَّا تُعْرِضَنَّ عَنْهُمُ ٱبْتِغَآءَ رَحْمَةٍۢ مِّن رَّبِّكَ تَرْجُوهَا فَقُل لَّهُمْ قَوْلًۭا مَّيْسُورًۭا","numberInSurah":28,"juz":15,"manzil":4,"page":285,"ruku":242,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2058,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2058.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2058.mp3"],"text":"وَلَا تَجْعَلْ يَدَكَ مَغْلُولَةً إِلَىٰ عُنُقِكَ وَلَا تَبْسُطْهَا كُلَّ ٱلْبَسْطِ فَتَقْعُدَ مَلُومًۭا مَّحْسُورًا","numberInSurah":29,"juz":15,"manzil":4,"page":285,"ruku":242,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2059,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2059.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2059.mp3"],"text":"إِنَّ رَبَّكَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ إِنَّهُۥ كَانَ بِعِبَادِهِۦ خَبِيرًۢا بَصِيرًۭا","numberInSurah":30,"juz":15,"manzil":4,"page":285,"ruku":242,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2060,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2060.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2060.mp3"],"text":"وَلَا تَقْتُلُوٓا۟ أَوْلَٰدَكُمْ خَشْيَةَ إِمْلَٰقٍۢ ۖ نَّحْنُ نَرْزُقُهُمْ وَإِيَّاكُمْ ۚ إِنَّ قَتْلَهُمْ كَانَ خِطْـًۭٔا كَبِيرًۭا","numberInSurah":31,"juz":15,"manzil":4,"page":285,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2061,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2061.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2061.mp3"],"text":"وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ ۖ إِنَّهُۥ كَانَ فَٰحِشَةًۭ وَسَآءَ سَبِيلًۭا","numberInSurah":32,"juz":15,"manzil":4,"page":285,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2062,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2062.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2062.mp3"],"text":"وَلَا تَقْتُلُوا۟ ٱلنَّفْسَ ٱلَّتِى حَرَّمَ ٱللَّهُ إِلَّا بِٱلْحَقِّ ۗ وَمَن قُتِلَ مَظْلُومًۭا فَقَدْ جَعَلْنَا لِوَلِيِّهِۦ سُلْطَٰنًۭا فَلَا يُسْرِف فِّى ٱلْقَتْلِ ۖ إِنَّهُۥ كَانَ مَنصُورًۭا","numberInSurah":33,"juz":15,"manzil":4,"page":285,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2063,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2063.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2063.mp3"],"text":"وَلَا تَقْرَبُوا۟ مَالَ ٱلْيَتِيمِ إِلَّا بِٱلَّتِى هِىَ أَحْسَنُ حَتَّىٰ يَبْلُغَ أَشُدَّهُۥ ۚ وَأَوْفُوا۟ بِٱلْعَهْدِ ۖ إِنَّ ٱلْعَهْدَ كَانَ مَسْـُٔولًۭا","numberInSurah":34,"juz":15,"manzil":4,"page":285,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2064,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2064.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2064.mp3"],"text":"وَأَوْفُوا۟ ٱلْكَيْلَ إِذَا كِلْتُمْ وَزِنُوا۟ بِٱلْقِسْطَاسِ ٱلْمُسْتَقِيمِ ۚ ذَٰلِكَ خَيْرٌۭ وَأَحْسَنُ تَأْوِيلًۭا","numberInSurah":35,"juz":15,"manzil":4,"page":285,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2065,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2065.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2065.mp3"],"text":"وَلَا تَقْفُ مَا لَيْسَ لَكَ بِهِۦ عِلْمٌ ۚ إِنَّ ٱلسَّمْعَ وَٱلْبَصَرَ وَٱلْفُؤَادَ كُلُّ أُو۟لَٰٓئِكَ كَانَ عَنْهُ مَسْـُٔولًۭا","numberInSurah":36,"juz":15,"manzil":4,"page":285,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2066,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2066.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2066.mp3"],"text":"وَلَا تَمْشِ فِى ٱلْأَرْضِ مَرَحًا ۖ إِنَّكَ لَن تَخْرِقَ ٱلْأَرْضَ وَلَن تَبْلُغَ ٱلْجِبَالَ طُولًۭا","numberInSurah":37,"juz":15,"manzil":4,"page":285,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2067,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2067.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2067.mp3"],"text":"كُلُّ ذَٰلِكَ كَانَ سَيِّئُهُۥ عِندَ رَبِّكَ مَكْرُوهًۭا","numberInSurah":38,"juz":15,"manzil":4,"page":285,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2068,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2068.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2068.mp3"],"text":"ذَٰلِكَ مِمَّآ أَوْحَىٰٓ إِلَيْكَ رَبُّكَ مِنَ ٱلْحِكْمَةِ ۗ وَلَا تَجْعَلْ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتُلْقَىٰ فِى جَهَنَّمَ مَلُومًۭا مَّدْحُورًا","numberInSurah":39,"juz":15,"manzil":4,"page":286,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2069,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2069.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2069.mp3"],"text":"أَفَأَصْفَىٰكُمْ رَبُّكُم بِٱلْبَنِينَ وَٱتَّخَذَ مِنَ ٱلْمَلَٰٓئِكَةِ إِنَٰثًا ۚ إِنَّكُمْ لَتَقُولُونَ قَوْلًا عَظِيمًۭا","numberInSurah":40,"juz":15,"manzil":4,"page":286,"ruku":243,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2070,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2070.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2070.mp3"],"text":"وَلَقَدْ صَرَّفْنَا فِى هَٰذَا ٱلْقُرْءَانِ لِيَذَّكَّرُوا۟ وَمَا يَزِيدُهُمْ إِلَّا نُفُورًۭا","numberInSurah":41,"juz":15,"manzil":4,"page":286,"ruku":244,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2071,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2071.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2071.mp3"],"text":"قُل لَّوْ كَانَ مَعَهُۥٓ ءَالِهَةٌۭ كَمَا يَقُولُونَ إِذًۭا لَّٱبْتَغَوْا۟ إِلَىٰ ذِى ٱلْعَرْشِ سَبِيلًۭا","numberInSurah":42,"juz":15,"manzil":4,"page":286,"ruku":244,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2072,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2072.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2072.mp3"],"text":"سُبْحَٰنَهُۥ وَتَعَٰلَىٰ عَمَّا يَقُولُونَ عُلُوًّۭا كَبِيرًۭا","numberInSurah":43,"juz":15,"manzil":4,"page":286,"ruku":244,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2073,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2073.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2073.mp3"],"text":"تُسَبِّحُ لَهُ ٱلسَّمَٰوَٰتُ ٱلسَّبْعُ وَٱلْأَرْضُ وَمَن فِيهِنَّ ۚ وَإِن مِّن شَىْءٍ إِلَّا يُسَبِّحُ بِحَمْدِهِۦ وَلَٰكِن لَّا تَفْقَهُونَ تَسْبِيحَهُمْ ۗ إِنَّهُۥ كَانَ حَلِيمًا غَفُورًۭا","numberInSurah":44,"juz":15,"manzil":4,"page":286,"ruku":244,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2074,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2074.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2074.mp3"],"text":"وَإِذَا قَرَأْتَ ٱلْقُرْءَانَ جَعَلْنَا بَيْنَكَ وَبَيْنَ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ حِجَابًۭا مَّسْتُورًۭا","numberInSurah":45,"juz":15,"manzil":4,"page":286,"ruku":244,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2075,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2075.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2075.mp3"],"text":"وَجَعَلْنَا عَلَىٰ قُلُوبِهِمْ أَكِنَّةً أَن يَفْقَهُوهُ وَفِىٓ ءَاذَانِهِمْ وَقْرًۭا ۚ وَإِذَا ذَكَرْتَ رَبَّكَ فِى ٱلْقُرْءَانِ وَحْدَهُۥ وَلَّوْا۟ عَلَىٰٓ أَدْبَٰرِهِمْ نُفُورًۭا","numberInSurah":46,"juz":15,"manzil":4,"page":286,"ruku":244,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2076,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2076.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2076.mp3"],"text":"نَّحْنُ أَعْلَمُ بِمَا يَسْتَمِعُونَ بِهِۦٓ إِذْ يَسْتَمِعُونَ إِلَيْكَ وَإِذْ هُمْ نَجْوَىٰٓ إِذْ يَقُولُ ٱلظَّٰلِمُونَ إِن تَتَّبِعُونَ إِلَّا رَجُلًۭا مَّسْحُورًا","numberInSurah":47,"juz":15,"manzil":4,"page":286,"ruku":244,"hizbQuarter":114,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2077,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2077.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2077.mp3"],"text":"ٱنظُرْ كَيْفَ ضَرَبُوا۟ لَك