{"code":200,"status":"OK","data":{"number":131,"ayahs":[{"number":2534,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2534.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2534.mp3"],"text":"۞ وَلَقَدْ ءَاتَيْنَآ إِبْرَٰهِيمَ رُشْدَهُۥ مِن قَبْلُ وَكُنَّا بِهِۦ عَٰلِمِينَ","numberInSurah":51,"juz":17,"manzil":4,"page":326,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2535,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2535.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2535.mp3"],"text":"إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَا هَٰذِهِ ٱلتَّمَاثِيلُ ٱلَّتِىٓ أَنتُمْ لَهَا عَٰكِفُونَ","numberInSurah":52,"juz":17,"manzil":4,"page":326,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2536,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2536.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2536.mp3"],"text":"قَالُوا۟ وَجَدْنَآ ءَابَآءَنَا لَهَا عَٰبِدِينَ","numberInSurah":53,"juz":17,"manzil":4,"page":326,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2537,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2537.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2537.mp3"],"text":"قَالَ لَقَدْ كُنتُمْ أَنتُمْ وَءَابَآؤُكُمْ فِى ضَلَٰلٍۢ مُّبِينٍۢ","numberInSurah":54,"juz":17,"manzil":4,"page":326,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2538,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2538.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2538.mp3"],"text":"قَالُوٓا۟ أَجِئْتَنَا بِٱلْحَقِّ أَمْ أَنتَ مِنَ ٱللَّٰعِبِينَ","numberInSurah":55,"juz":17,"manzil":4,"page":326,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2539,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2539.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2539.mp3"],"text":"قَالَ بَل رَّبُّكُمْ رَبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ٱلَّذِى فَطَرَهُنَّ وَأَنَا۠ عَلَىٰ ذَٰلِكُم مِّنَ ٱلشَّٰهِدِينَ","numberInSurah":56,"juz":17,"manzil":4,"page":326,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2540,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2540.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2540.mp3"],"text":"وَتَٱللَّهِ لَأَكِيدَنَّ أَصْنَٰمَكُم بَعْدَ أَن تُوَلُّوا۟ مُدْبِرِينَ","numberInSurah":57,"juz":17,"manzil":4,"page":326,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2541,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2541.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2541.mp3"],"text":"فَجَعَلَهُمْ جُذَٰذًا إِلَّا كَبِيرًۭا لَّهُمْ لَعَلَّهُمْ إِلَيْهِ يَرْجِعُونَ","numberInSurah":58,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2542,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2542.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2542.mp3"],"text":"قَالُوا۟ مَن فَعَلَ هَٰذَا بِـَٔالِهَتِنَآ إِنَّهُۥ لَمِنَ ٱلظَّٰلِمِينَ","numberInSurah":59,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2543,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2543.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2543.mp3"],"text":"قَالُوا۟ سَمِعْنَا فَتًۭى يَذْكُرُهُمْ يُقَالُ لَهُۥٓ إِبْرَٰهِيمُ","numberInSurah":60,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2544,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2544.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2544.mp3"],"text":"قَالُوا۟ فَأْتُوا۟ بِهِۦ عَلَىٰٓ أَعْيُنِ ٱلنَّاسِ لَعَلَّهُمْ يَشْهَدُونَ","numberInSurah":61,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2545,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2545.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2545.mp3"],"text":"قَالُوٓا۟ ءَأَنتَ فَعَلْتَ هَٰذَا بِـَٔالِهَتِنَا يَٰٓإِبْرَٰهِيمُ","numberInSurah":62,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2546,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2546.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2546.mp3"],"text":"قَالَ بَلْ فَعَلَهُۥ كَبِيرُهُمْ هَٰذَا فَسْـَٔلُوهُمْ إِن كَانُوا۟ يَنطِقُونَ","numberInSurah":63,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2547,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2547.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2547.mp3"],"text":"فَرَجَعُوٓا۟ إِلَىٰٓ أَنفُسِهِمْ فَقَالُوٓا۟ إِنَّكُمْ أَنتُمُ ٱلظَّٰلِمُونَ","numberInSurah":64,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2548,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2548.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2548.mp3"],"text":"ثُمَّ نُكِسُوا۟ عَلَىٰ رُءُوسِهِمْ لَقَدْ عَلِمْتَ مَا هَٰٓؤُلَآءِ يَنطِقُونَ","numberInSurah":65,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2549,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2549.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2549.mp3"],"text":"قَالَ أَفَتَعْبُدُونَ مِن دُونِ ٱللَّهِ مَا لَا يَنفَعُكُمْ شَيْـًۭٔا وَلَا يَضُرُّكُمْ","numberInSurah":66,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2550,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2550.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2550.mp3"],"text":"أُفٍّۢ لَّكُمْ وَلِمَا تَعْبُدُونَ مِن دُونِ ٱللَّهِ ۖ أَفَلَا تَعْقِلُونَ","numberInSurah":67,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2551,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2551.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2551.mp3"],"text":"قَالُوا۟ حَرِّقُوهُ وَٱنصُرُوٓا۟ ءَالِهَتَكُمْ إِن كُنتُمْ فَٰعِلِينَ","numberInSurah":68,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2552,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2552.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2552.mp3"],"text":"قُلْنَا يَٰنَارُ كُونِى بَرْدًۭا وَسَلَٰمًا عَلَىٰٓ إِبْرَٰهِيمَ","numberInSurah":69,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2553,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2553.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2553.mp3"],"text":"وَأَرَادُوا۟ بِهِۦ كَيْدًۭا فَجَعَلْنَٰهُمُ ٱلْأَخْسَرِينَ","numberInSurah":70,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2554,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2554.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2554.mp3"],"text":"وَنَجَّيْنَٰهُ وَلُوطًا إِلَى ٱلْأَرْضِ ٱلَّتِى بَٰرَكْنَا فِيهَا لِلْعَٰلَمِينَ","numberInSurah":71,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2555,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2555.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2555.mp3"],"text":"وَوَهَبْنَا لَهُۥٓ إِسْحَٰقَ وَيَعْقُوبَ نَافِلَةًۭ ۖ وَكُلًّۭا جَعَلْنَا صَٰلِحِينَ","numberInSurah":72,"juz":17,"manzil":4,"page":327,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2556,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2556.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2556.mp3"],"text":"وَجَعَلْنَٰهُمْ أَئِمَّةًۭ يَهْدُونَ بِأَمْرِنَا وَأَوْحَيْنَآ إِلَيْهِمْ فِعْلَ ٱلْخَيْرَٰتِ وَإِقَامَ ٱلصَّلَوٰةِ وَإِيتَآءَ ٱلزَّكَوٰةِ ۖ وَكَانُوا۟ لَنَا عَٰبِدِينَ","numberInSurah":73,"juz":17,"manzil":4,"page":328,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2557,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2557.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2557.mp3"],"text":"وَلُوطًا ءَاتَيْنَٰهُ حُكْمًۭا وَعِلْمًۭا وَنَجَّيْنَٰهُ مِنَ ٱلْقَرْيَةِ ٱلَّتِى كَانَت تَّعْمَلُ ٱلْخَبَٰٓئِثَ ۗ إِنَّهُمْ كَانُوا۟ قَوْمَ سَوْءٍۢ فَٰسِقِينَ","numberInSurah":74,"juz":17,"manzil":4,"page":328,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2558,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2558.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2558.mp3"],"text":"وَأَدْخَلْنَٰهُ فِى رَحْمَتِنَآ ۖ إِنَّهُۥ مِنَ ٱلصَّٰلِحِينَ","numberInSurah":75,"juz":17,"manzil":4,"page":328,"ruku":282,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2559,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2559.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2559.mp3"],"text":"وَنُوحًا إِذْ نَادَىٰ مِن قَبْلُ فَٱسْتَجَبْنَا لَهُۥ فَنَجَّيْنَٰهُ وَأَهْلَهُۥ مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ","numberInSurah":76,"juz":17,"manzil":4,"page":328,"ruku":283,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2560,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2560.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2560.mp3"],"text":"وَنَصَرْنَٰهُ مِنَ ٱلْقَوْمِ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَآ ۚ إِنَّهُمْ كَانُوا۟ قَوْمَ سَوْءٍۢ فَأَغْرَقْنَٰهُمْ أَجْمَعِينَ","numberInSurah":77,"juz":17,"manzil":4,"page":328,"ruku":283,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2561,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2561.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2561.mp3"],"text":"وَدَاوُۥدَ وَسُلَيْمَٰنَ إِذْ يَحْكُمَانِ فِى ٱلْحَرْثِ إِذْ نَفَشَتْ فِيهِ غَنَمُ ٱلْقَوْمِ وَكُنَّا لِحُكْمِهِمْ شَٰهِدِينَ","numberInSurah":78,"juz":17,"manzil":4,"page":328,"ruku":283,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2562,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2562.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2562.mp3"],"text":"فَفَهَّمْنَٰهَا سُلَيْمَٰنَ ۚ وَكُلًّا ءَاتَيْنَا حُكْمًۭا وَعِلْمًۭا ۚ وَسَخَّرْنَا مَعَ دَاوُۥدَ ٱلْجِبَالَ يُسَبِّحْنَ وَٱلطَّيْرَ ۚ وَكُنَّا فَٰعِلِينَ","numberInSurah":79,"juz":17,"manzil":4,"page":328,"ruku":283,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2563,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2563.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2563.mp3"],"text":"وَعَلَّمْنَٰهُ صَنْعَةَ لَبُوسٍۢ لَّكُمْ لِتُحْصِنَكُم مِّنۢ بَأْسِكُمْ ۖ فَهَلْ أَنتُمْ شَٰكِرُونَ","numberInSurah":80,"juz":17,"manzil":4,"page":328,"ruku":283,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2564,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2564.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2564.mp3"],"text":"وَلِسُلَيْمَٰنَ ٱلرِّيحَ عَاصِفَةًۭ تَجْرِى بِأَمْرِهِۦٓ إِلَى ٱلْأَرْضِ ٱلَّتِى بَٰرَكْنَا فِيهَا ۚ وَكُنَّا بِكُلِّ شَىْءٍ عَٰلِمِينَ","numberInSurah":81,"juz":17,"manzil":4,"page":328,"ruku":283,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},{"number":2565,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2565.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2565.mp3"],"text":"وَمِنَ ٱلشَّيَٰطِينِ مَن يَغُوصُونَ لَهُۥ وَيَعْمَلُونَ عَمَلًۭا دُونَ ذَٰلِكَ ۖ وَكُنَّا لَهُمْ حَٰفِظِينَ","numberInSurah":82,"juz":17,"manzil":4,"page":329,"ruku":283,"hizbQuarter":131,"sajda":false,"surah":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}}],"surahs":{"21":{"number":21,"name":"سُورَةُ الأَنبِيَاءِ","englishName":"Al-Anbiyaa","englishNameTranslation":"The Prophets","revelationType":"Meccan"}},"edition":{}}}