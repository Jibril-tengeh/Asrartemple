{"code":200,"status":"OK","data":{"number":161,"ayahs":[{"number":3386,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3386.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3386.mp3"],"text":"۞ وَلَا تُجَٰدِلُوٓا۟ أَهْلَ ٱلْكِتَٰبِ إِلَّا بِٱلَّتِى هِىَ أَحْسَنُ إِلَّا ٱلَّذِينَ ظَلَمُوا۟ مِنْهُمْ ۖ وَقُولُوٓا۟ ءَامَنَّا بِٱلَّذِىٓ أُنزِلَ إِلَيْنَا وَأُنزِلَ إِلَيْكُمْ وَإِلَٰهُنَا وَإِلَٰهُكُمْ وَٰحِدٌۭ وَنَحْنُ لَهُۥ مُسْلِمُونَ","numberInSurah":46,"juz":21,"manzil":5,"page":402,"ruku":346,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3387,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3387.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3387.mp3"],"text":"وَكَذَٰلِكَ أَنزَلْنَآ إِلَيْكَ ٱلْكِتَٰبَ ۚ فَٱلَّذِينَ ءَاتَيْنَٰهُمُ ٱلْكِتَٰبَ يُؤْمِنُونَ بِهِۦ ۖ وَمِنْ هَٰٓؤُلَآءِ مَن يُؤْمِنُ بِهِۦ ۚ وَمَا يَجْحَدُ بِـَٔايَٰتِنَآ إِلَّا ٱلْكَٰفِرُونَ","numberInSurah":47,"juz":21,"manzil":5,"page":402,"ruku":346,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3388,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3388.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3388.mp3"],"text":"وَمَا كُنتَ تَتْلُوا۟ مِن قَبْلِهِۦ مِن كِتَٰبٍۢ وَلَا تَخُطُّهُۥ بِيَمِينِكَ ۖ إِذًۭا لَّٱرْتَابَ ٱلْمُبْطِلُونَ","numberInSurah":48,"juz":21,"manzil":5,"page":402,"ruku":346,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3389,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3389.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3389.mp3"],"text":"بَلْ هُوَ ءَايَٰتٌۢ بَيِّنَٰتٌۭ فِى صُدُورِ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ ۚ وَمَا يَجْحَدُ بِـَٔايَٰتِنَآ إِلَّا ٱلظَّٰلِمُونَ","numberInSurah":49,"juz":21,"manzil":5,"page":402,"ruku":346,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3390,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3390.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3390.mp3"],"text":"وَقَالُوا۟ لَوْلَآ أُنزِلَ عَلَيْهِ ءَايَٰتٌۭ مِّن رَّبِّهِۦ ۖ قُلْ إِنَّمَا ٱلْءَايَٰتُ عِندَ ٱللَّهِ وَإِنَّمَآ أَنَا۠ نَذِيرٌۭ مُّبِينٌ","numberInSurah":50,"juz":21,"manzil":5,"page":402,"ruku":346,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3391,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3391.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3391.mp3"],"text":"أَوَلَمْ يَكْفِهِمْ أَنَّآ أَنزَلْنَا عَلَيْكَ ٱلْكِتَٰبَ يُتْلَىٰ عَلَيْهِمْ ۚ إِنَّ فِى ذَٰلِكَ لَرَحْمَةًۭ وَذِكْرَىٰ لِقَوْمٍۢ يُؤْمِنُونَ","numberInSurah":51,"juz":21,"manzil":5,"page":402,"ruku":346,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3392,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3392.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3392.mp3"],"text":"قُلْ كَفَىٰ بِٱللَّهِ بَيْنِى وَبَيْنَكُمْ شَهِيدًۭا ۖ يَعْلَمُ مَا فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۗ وَٱلَّذِينَ ءَامَنُوا۟ بِٱلْبَٰطِلِ وَكَفَرُوا۟ بِٱللَّهِ أُو۟لَٰٓئِكَ هُمُ ٱلْخَٰسِرُونَ","numberInSurah":52,"juz":21,"manzil":5,"page":402,"ruku":347,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3393,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3393.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3393.mp3"],"text":"وَيَسْتَعْجِلُونَكَ بِٱلْعَذَابِ ۚ وَلَوْلَآ أَجَلٌۭ مُّسَمًّۭى لَّجَآءَهُمُ ٱلْعَذَابُ وَلَيَأْتِيَنَّهُم بَغْتَةًۭ وَهُمْ لَا يَشْعُرُونَ","numberInSurah":53,"juz":21,"manzil":5,"page":403,"ruku":347,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3394,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3394.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3394.mp3"],"text":"يَسْتَعْجِلُونَكَ بِٱلْعَذَابِ وَإِنَّ جَهَنَّمَ لَمُحِيطَةٌۢ بِٱلْكَٰفِرِينَ","numberInSurah":54,"juz":21,"manzil":5,"page":403,"ruku":347,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3395,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3395.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3395.mp3"],"text":"يَوْمَ يَغْشَىٰهُمُ ٱلْعَذَابُ مِن فَوْقِهِمْ وَمِن تَحْتِ أَرْجُلِهِمْ وَيَقُولُ ذُوقُوا۟ مَا كُنتُمْ تَعْمَلُونَ","numberInSurah":55,"juz":21,"manzil":5,"page":403,"ruku":347,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3396,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3396.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3396.mp3"],"text":"يَٰعِبَادِىَ ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ أَرْضِى وَٰسِعَةٌۭ فَإِيَّٰىَ فَٱعْبُدُونِ","numberInSurah":56,"juz":21,"manzil":5,"page":403,"ruku":347,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3397,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3397.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3397.mp3"],"text":"كُلُّ نَفْسٍۢ ذَآئِقَةُ ٱلْمَوْتِ ۖ ثُمَّ إِلَيْنَا تُرْجَعُونَ","numberInSurah":57,"juz":21,"manzil":5,"page":403,"ruku":347,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3398,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3398.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3398.mp3"],"text":"وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَنُبَوِّئَنَّهُم مِّنَ ٱلْجَنَّةِ غُرَفًۭا تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَا ۚ نِعْمَ أَجْرُ ٱلْعَٰمِلِينَ","numberInSurah":58,"juz":21,"manzil":5,"page":403,"ruku":347,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3399,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3399.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3399.mp3"],"text":"ٱلَّذِينَ صَبَرُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ","numberInSurah":59,"juz":21,"manzil":5,"page":403,"ruku":347,"hizbQuarter":161,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3400,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3400.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3400.mp3"],"text":"وَكَأَيِّن م