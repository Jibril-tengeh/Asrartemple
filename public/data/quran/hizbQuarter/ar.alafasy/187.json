.alafasy/4141.mp3"],"text":"رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۚ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":8,"juz":24,"manzil":6,"page":468,"ruku":404,"hizbQuarter":187,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4142,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4142.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4142.mp3"],"text":"وَقِهِمُ ٱلسَّيِّـَٔاتِ ۚ وَمَن تَقِ ٱلسَّيِّـَٔاتِ يَوْمَئِذٍۢ فَقَدْ رَحِمْتَهُۥ ۚ وَذَٰلِكَ هُوَ ٱلْفَوْزُ ٱلْعَظِيمُ","numberInSurah":9,"juz":24,"manzil":6,"page":468,"ruku":404,"hizbQuarter":187,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4143,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4143.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4143.mp3"],"text":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ يُنَادَوْنَ لَمَقْتُ ٱللَّهِ أَكْبَرُ مِن مَّقْتِكُمْ أَنفُسَكُمْ إِذْ تُدْعَوْنَ إِلَى ٱلْإِيمَٰنِ فَتَكْفُرُونَ","numberInSurah":10,"juz":24,"manzil":6,"page":468,"ruku":405,"hizbQuarter":187,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTranslation":"The Forgiver","revelationType":"Meccan"}},{"number":4144,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4144.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4144.mp3"],"text":"قَالُوا۟ رَبَّنَآ أَمَتَّنَا ٱثْنَتَيْنِ وَأَحْيَيْتَنَا ٱثْنَتَيْنِ فَٱعْتَرَفْنَا بِذُنُوبِنَا فَهَلْ إِلَىٰ خُرُوجٍۢ مِّن سَبِيلٍۢ","numberInSurah":11,"juz":24,"manzil":6,"page":468,"ruku":405,"hizbQuarter":187,"sajda":false,"surah":{"number":40,"name":"سُورَةُ غَافِرٍ","englishName":"Ghafir","englishNameTr