{"code":200,"status":"OK","data":{"number":160,"ayahs":[{"number":3366,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3366.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3366.mp3"],"text":"۞ فَـَٔامَنَ لَهُۥ لُوطٌۭ ۘ وَقَالَ إِنِّى مُهَاجِرٌ إِلَىٰ رَبِّىٓ ۖ إِنَّهُۥ هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":26,"juz":20,"manzil":5,"page":399,"ruku":344,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3367,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3367.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3367.mp3"],"text":"وَوَهَبْنَا لَهُۥٓ إِسْحَٰقَ وَيَعْقُوبَ وَجَعَلْنَا فِى ذُرِّيَّتِهِ ٱلنُّبُوَّةَ وَٱلْكِتَٰبَ وَءَاتَيْنَٰهُ أَجْرَهُۥ فِى ٱلدُّنْيَا ۖ وَإِنَّهُۥ فِى ٱلْءَاخِرَةِ لَمِنَ ٱلصَّٰلِحِينَ","numberInSurah":27,"juz":20,"manzil":5,"page":399,"ruku":344,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3368,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3368.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3368.mp3"],"text":"وَلُوطًا إِذْ قَالَ لِقَوْمِهِۦٓ إِنَّكُمْ لَتَأْتُونَ ٱلْفَٰحِشَةَ مَا سَبَقَكُم بِهَا مِنْ أَحَدٍۢ مِّنَ ٱلْعَٰلَمِينَ","numberInSurah":28,"juz":20,"manzil":5,"page":399,"ruku":344,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3369,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3369.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3369.mp3"],"text":"أَئِنَّكُمْ لَتَأْتُونَ ٱلرِّجَالَ وَتَقْطَعُونَ ٱلسَّبِيلَ وَتَأْتُونَ فِى نَادِيكُمُ ٱلْمُنكَرَ ۖ فَمَا كَانَ جَوَابَ قَوْمِهِۦٓ إِلَّآ أَن قَالُوا۟ ٱئْتِنَا بِعَذَابِ ٱللَّهِ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ","numberInSurah":29,"juz":20,"manzil":5,"page":399,"ruku":344,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3370,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3370.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3370.mp3"],"text":"قَالَ رَبِّ ٱنصُرْنِى عَلَى ٱلْقَوْمِ ٱلْمُفْسِدِينَ","numberInSurah":30,"juz":20,"manzil":5,"page":399,"ruku":344,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3371,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3371.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3371.mp3"],"text":"وَلَمَّا جَآءَتْ رُسُلُنَآ إِبْرَٰهِيمَ بِٱلْبُشْرَىٰ قَالُوٓا۟ إِنَّا مُهْلِكُوٓا۟ أَهْلِ هَٰذِهِ ٱلْقَرْيَةِ ۖ إِنَّ أَهْلَهَا كَانُوا۟ ظَٰلِمِينَ","numberInSurah":31,"juz":20,"manzil":5,"page":400,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3372,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3372.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3372.mp3"],"text":"قَالَ إِنَّ فِيهَا لُوطًۭا ۚ قَالُوا۟ نَحْنُ أَعْلَمُ بِمَن فِيهَا ۖ لَنُنَجِّيَنَّهُۥ وَأَهْلَهُۥٓ إِلَّا ٱمْرَأَتَهُۥ كَانَتْ مِنَ ٱلْغَٰبِرِينَ","numberInSurah":32,"juz":20,"manzil":5,"page":400,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3373,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3373.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3373.mp3"],"text":"وَلَمَّآ أَن جَآءَتْ رُسُلُنَا لُوطًۭا سِىٓءَ بِهِمْ وَضَاقَ بِهِمْ ذَرْعًۭا وَقَالُوا۟ لَا تَخَفْ وَلَا تَحْزَنْ ۖ إِنَّا مُنَجُّوكَ وَأَهْلَكَ إِلَّا ٱمْرَأَتَكَ كَانَتْ مِنَ ٱلْغَٰبِرِينَ","numberInSurah":33,"juz":20,"manzil":5,"page":400,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3374,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3374.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3374.mp3"],"text":"إِنَّا مُنزِلُونَ عَلَىٰٓ أَهْلِ هَٰذِهِ ٱلْقَرْيَةِ رِجْزًۭا مِّنَ ٱلسَّمَآءِ بِمَا كَانُوا۟ يَفْسُقُونَ","numberInSurah":34,"juz":20,"manzil":5,"page":400,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3375,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3375.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3375.mp3"],"text":"وَلَقَد تَّرَكْنَا مِنْهَآ ءَايَةًۢ بَيِّنَةًۭ لِّقَوْمٍۢ يَعْقِلُونَ","numberInSurah":35,"juz":20,"manzil":5,"page":400,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3376,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3376.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3376.mp3"],"text":"وَإِلَىٰ مَدْيَنَ أَخَاهُمْ شُعَيْبًۭا فَقَالَ يَٰقَوْمِ ٱعْبُدُوا۟ ٱللَّهَ وَٱرْجُوا۟ ٱلْيَوْمَ ٱلْءَاخِرَ وَلَا تَعْثَوْا۟ فِى ٱلْأَرْضِ مُفْسِدِينَ","numberInSurah":36,"juz":20,"manzil":5,"page":400,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3377,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3377.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3377.mp3"],"text":"فَكَذَّبُوهُ فَأَخَذَتْهُمُ ٱلرَّجْفَةُ فَأَصْبَحُوا۟ فِى دَارِهِمْ جَٰثِمِينَ","numberInSurah":37,"juz":20,"manzil":5,"page":400,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3378,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3378.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3378.mp3"],"text":"وَعَادًۭا وَثَمُودَا۟ وَقَد تَّبَيَّنَ لَكُم مِّن مَّسَٰكِنِهِمْ ۖ وَزَيَّنَ لَهُمُ ٱلشَّيْطَٰنُ أَعْمَٰلَهُمْ فَصَدَّهُمْ عَنِ ٱلسَّبِيلِ وَكَانُوا۟ مُسْتَبْصِرِينَ","numberInSurah":38,"juz":20,"manzil":5,"page":400,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3379,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3379.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3379.mp3"],"text":"وَقَٰرُونَ وَفِرْعَوْنَ وَهَٰمَٰنَ ۖ وَلَقَدْ جَآءَهُم مُّوسَىٰ بِٱلْبَيِّنَٰتِ فَٱسْتَكْبَرُوا۟ فِى ٱلْأَرْضِ وَمَا كَانُوا۟ سَٰبِقِينَ","numberInSurah":39,"juz":20,"manzil":5,"page":401,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3380,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3380.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3380.mp3"],"text":"فَكُلًّا أَخَذْنَا بِذَنۢبِهِۦ ۖ فَمِنْهُم مَّنْ أَرْسَلْنَا عَلَيْهِ حَاصِبًۭا وَمِنْهُم مَّنْ أَخَذَتْهُ ٱلصَّيْحَةُ وَمِنْهُم مَّنْ خَسَفْنَا بِهِ ٱلْأَرْضَ وَمِنْهُم مَّنْ أَغْرَقْنَا ۚ وَمَا كَانَ ٱللَّهُ لِيَظْلِمَهُمْ وَلَٰكِن كَانُوٓا۟ أَنفُسَهُمْ يَظْلِمُونَ","numberInSurah":40,"juz":20,"manzil":5,"page":401,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3381,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3381.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3381.mp3"],"text":"مَثَلُ ٱلَّذِينَ ٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ أَوْلِيَآءَ كَمَثَلِ ٱلْعَنكَبُوتِ ٱتَّخَذَتْ بَيْتًۭا ۖ وَإِنَّ أَوْهَنَ ٱلْبُيُوتِ لَبَيْتُ ٱلْعَنكَبُوتِ ۖ لَوْ كَانُوا۟ يَعْلَمُونَ","numberInSurah":41,"juz":20,"manzil":5,"page":401,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3382,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3382.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3382.mp3"],"text":"إِنَّ ٱللَّهَ يَعْلَمُ مَا يَدْعُونَ مِن دُونِهِۦ مِن شَىْءٍۢ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":42,"juz":20,"manzil":5,"page":401,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3383,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3383.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3383.mp3"],"text":"وَتِلْكَ ٱلْأَمْثَٰلُ نَضْرِبُهَا لِلنَّاسِ ۖ وَمَا يَعْقِلُهَآ إِلَّا ٱلْعَٰلِمُونَ","numberInSurah":43,"juz":20,"manzil":5,"page":401,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3384,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3384.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3384.mp3"],"text":"خَلَقَ ٱللَّهُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّلْمُؤْمِنِينَ","numberInSurah":44,"juz":20,"manzil":5,"page":401,"ruku":345,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},{"number":3385,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3385.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3385.mp3"],"text":"ٱتْلُ مَآ أُوحِىَ إِلَيْكَ مِنَ ٱلْكِتَٰبِ وَأَقِمِ ٱلصَّلَوٰةَ ۖ إِنَّ ٱلصَّلَوٰةَ تَنْهَىٰ عَنِ ٱلْفَحْشَآءِ وَٱلْمُنكَرِ ۗ وَلَذِكْرُ ٱللَّهِ أَكْبَرُ ۗ وَٱللَّهُ يَعْلَمُ مَا تَصْنَعُونَ","numberInSurah":45,"juz":20,"manzil":5,"page":401,"ruku":346,"hizbQuarter":160,"sajda":false,"surah":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}}],"surahs":{"29":{"number":29,"name":"سُورَةُ العَنكَبُوتِ","englishName":"Al-Ankaboot","englishNameTranslation":"The Spider","revelationType":"Meccan"}},"edition":{}}}