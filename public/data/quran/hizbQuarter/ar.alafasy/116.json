{"code":200,"status":"OK","data":{"number":116,"ayahs":[{"number":2099,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2099.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2099.mp3"],"text":"۞ وَلَقَدْ كَرَّمْنَا بَنِىٓ ءَادَمَ وَحَمَلْنَٰهُمْ فِى ٱلْبَرِّ وَٱلْبَحْرِ وَرَزَقْنَٰهُم مِّنَ ٱلطَّيِّبَٰتِ وَفَضَّلْنَٰهُمْ عَلَىٰ كَثِيرٍۢ مِّمَّنْ خَلَقْنَا تَفْضِيلًۭا","numberInSurah":70,"juz":15,"manzil":4,"page":289,"ruku":246,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2100,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2100.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2100.mp3"],"text":"يَوْمَ نَدْعُوا۟ كُلَّ أُنَاسٍۭ بِإِمَٰمِهِمْ ۖ فَمَنْ أُوتِىَ كِتَٰبَهُۥ بِيَمِينِهِۦ فَأُو۟لَٰٓئِكَ يَقْرَءُونَ كِتَٰبَهُمْ وَلَا يُظْلَمُونَ فَتِيلًۭا","numberInSurah":71,"juz":15,"manzil":4,"page":289,"ruku":247,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2101,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2101.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2101.mp3"],"text":"وَمَن كَانَ فِى هَٰذِهِۦٓ أَعْمَىٰ فَهُوَ فِى ٱلْءَاخِرَةِ أَعْمَىٰ وَأَضَلُّ سَبِيلًۭا","numberInSurah":72,"juz":15,"manzil":4,"page":289,"ruku":247,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2102,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2102.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2102.mp3"],"text":"وَإِن كَادُوا۟ لَيَفْتِنُونَكَ عَنِ ٱلَّذِىٓ أَوْحَيْنَآ إِلَيْكَ لِتَفْتَرِىَ عَلَيْنَا غَيْرَهُۥ ۖ وَإِذًۭا لَّٱتَّخَذُوكَ خَلِيلًۭا","numberInSurah":73,"juz":15,"manzil":4,"page":289,"ruku":247,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2103,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2103.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2103.mp3"],"text":"وَلَوْلَآ أَن ثَبَّتْنَٰكَ لَقَدْ كِدتَّ تَرْكَنُ إِلَيْهِمْ شَيْـًۭٔا قَلِيلًا","numberInSurah":74,"juz":15,"manzil":4,"page":289,"ruku":247,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2104,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2104.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2104.mp3"],"text":"إِذًۭا لَّأَذَقْنَٰكَ ضِعْفَ ٱلْحَيَوٰةِ وَضِعْفَ ٱلْمَمَاتِ ثُمَّ لَا تَجِدُ لَكَ عَلَيْنَا نَصِيرًۭا","numberInSurah":75,"juz":15,"manzil":4,"page":289,"ruku":247,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2105,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2105.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2105.mp3"],"text":"وَإِن كَادُوا۟ لَيَسْتَفِزُّونَكَ مِنَ ٱلْأَرْضِ لِيُخْرِجُوكَ مِنْهَا ۖ وَإِذًۭا لَّا يَلْبَثُونَ خِلَٰفَكَ إِلَّا قَلِيلًۭا","numberInSurah":76,"juz":15,"manzil":4,"page":290,"ruku":247,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2106,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2106.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2106.mp3"],"text":"سُنَّةَ مَن قَدْ أَرْسَلْنَا قَبْلَكَ مِن رُّسُلِنَا ۖ وَلَا تَجِدُ لِسُنَّتِنَا تَحْوِيلًا","numberInSurah":77,"juz":15,"manzil":4,"page":290,"ruku":247,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2107,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2107.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2107.mp3"],"text":"أَقِمِ ٱلصَّلَوٰةَ لِدُلُوكِ ٱلشَّمْسِ إِلَىٰ غَسَقِ ٱلَّيْلِ وَقُرْءَانَ ٱلْفَجْرِ ۖ إِنَّ قُرْءَانَ ٱلْفَجْرِ كَانَ مَشْهُودًۭا","numberInSurah":78,"juz":15,"manzil":4,"page":290,"ruku":248,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2108,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2108.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2108.mp3"],"text":"وَمِنَ ٱلَّيْلِ فَتَهَجَّدْ بِهِۦ نَافِلَةًۭ لَّكَ عَسَىٰٓ أَن يَبْعَثَكَ رَبُّكَ مَقَامًۭا مَّحْمُودًۭا","numberInSurah":79,"juz":15,"manzil":4,"page":290,"ruku":248,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2109,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2109.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2109.mp3"],"text":"وَقُل رَّبِّ أَدْخِلْنِى مُدْخَلَ صِدْقٍۢ وَأَخْرِجْنِى مُخْرَجَ صِدْقٍۢ وَٱجْعَل لِّى مِن لَّدُنكَ سُلْطَٰنًۭا نَّصِيرًۭا","numberInSurah":80,"juz":15,"manzil":4,"page":290,"ruku":248,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2110,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2110.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2110.mp3"],"text":"وَقُلْ جَآءَ ٱلْحَقُّ وَزَهَقَ ٱلْبَٰطِلُ ۚ إِنَّ ٱلْبَٰطِلَ كَانَ زَهُوقًۭا","numberInSurah":81,"juz":15,"manzil":4,"page":290,"ruku":248,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2111,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2111.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2111.mp3"],"text":"وَنُنَزِّلُ مِنَ ٱلْقُرْءَانِ مَا هُوَ شِفَآءٌۭ وَرَحْمَةٌۭ لِّلْمُؤْمِنِينَ ۙ وَلَا يَزِيدُ ٱلظَّٰلِمِينَ إِلَّا خَسَارًۭا","numberInSurah":82,"juz":15,"manzil":4,"page":290,"ruku":248,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2112,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2112.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2112.mp3"],"text":"وَإِذَآ أَنْعَمْنَا عَلَى ٱلْإِنسَٰنِ أَعْرَضَ وَنَـَٔا بِجَانِبِهِۦ ۖ وَإِذَا مَسَّهُ ٱلشَّرُّ كَانَ يَـُٔوسًۭا","numberInSurah":83,"juz":15,"manzil":4,"page":290,"ruku":248,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2113,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2113.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2113.mp3"],"text":"قُلْ كُلٌّۭ يَعْمَلُ عَلَىٰ شَاكِلَتِهِۦ فَرَبُّكُمْ أَعْلَمُ بِمَنْ هُوَ أَهْدَىٰ سَبِيلًۭا","numberInSurah":84,"juz":15,"manzil":4,"page":290,"ruku":248,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2114,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2114.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2114.mp3"],"text":"وَيَسْـَٔلُونَكَ عَنِ ٱلرُّوحِ ۖ قُلِ ٱلرُّوحُ مِنْ أَمْرِ رَبِّى وَمَآ أُوتِيتُم مِّنَ ٱلْعِلْمِ إِلَّا قَلِيلًۭا","numberInSurah":85,"juz":15,"manzil":4,"page":290,"ruku":249,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2115,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2115.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2115.mp3"],"text":"وَلَئِن شِئْنَا لَنَذْهَبَنَّ بِٱلَّذِىٓ أَوْحَيْنَآ إِلَيْكَ ثُمَّ لَا تَجِدُ لَكَ بِهِۦ عَلَيْنَا وَكِيلًا","numberInSurah":86,"juz":15,"manzil":4,"page":290,"ruku":249,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2116,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2116.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2116.mp3"],"text":"إِلَّا رَحْمَةًۭ مِّن رَّبِّكَ ۚ إِنَّ فَضْلَهُۥ كَانَ عَلَيْكَ كَبِيرًۭا","numberInSurah":87,"juz":15,"manzil":4,"page":291,"ruku":249,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2117,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2117.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2117.mp3"],"text":"قُل لَّئِنِ ٱجْتَمَعَتِ ٱلْإِنسُ وَٱلْجِنُّ عَلَىٰٓ أَن يَأْتُوا۟ بِمِثْلِ هَٰذَا ٱلْقُرْءَانِ لَا يَأْتُونَ بِمِثْلِهِۦ وَل