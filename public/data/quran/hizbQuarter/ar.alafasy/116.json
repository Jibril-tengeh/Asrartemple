.alafasy/2121.mp3"],"text":"أَوْ تُسْقِطَ ٱلسَّمَآءَ كَمَا زَعَمْتَ عَلَيْنَا كِسَفًا أَوْ تَأْتِىَ بِٱللَّهِ وَٱلْمَلَٰٓئِكَةِ قَبِيلًا","numberInSurah":92,"juz":15,"manzil":4,"page":291,"ruku":249,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2122,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2122.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2122.mp3"],"text":"أَوْ يَكُونَ لَكَ بَيْتٌۭ مِّن زُخْرُفٍ أَوْ تَرْقَىٰ فِى ٱلسَّمَآءِ وَلَن نُّؤْمِنَ لِرُقِيِّكَ حَتَّىٰ تُنَزِّلَ عَلَيْنَا كِتَٰبًۭا نَّقْرَؤُهُۥ ۗ قُلْ سُبْحَانَ رَبِّى هَلْ كُنتُ إِلَّا بَشَرًۭا رَّسُولًۭا","numberInSurah":93,"juz":15,"manzil":4,"page":291,"ruku":249,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2123,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2123.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2123.mp3"],"text":"وَمَا مَنَعَ ٱلنَّاسَ أَن يُؤْمِنُوٓا۟ إِذْ جَآءَهُمُ ٱلْهُدَىٰٓ إِلَّآ أَن قَالُوٓا۟ أَبَعَثَ ٱللَّهُ بَشَرًۭا رَّسُولًۭا","numberInSurah":94,"juz":15,"manzil":4,"page":291,"ruku":250,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2124,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2124.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2124.mp3"],"text":"قُل لَّوْ كَانَ فِى ٱلْأَرْضِ مَلَٰٓئِكَةٌۭ يَمْشُونَ مُطْمَئِنِّينَ لَنَزَّلْنَا عَلَيْهِم مِّنَ ٱلسَّمَآءِ مَلَكًۭا رَّسُولًۭا","numberInSurah":95,"juz":15,"manzil":4,"page":291,"ruku":250,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2125,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2125.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2125.mp3"],"text":"قُلْ كَفَىٰ بِٱللَّهِ شَهِيدًۢا بَيْنِى وَبَيْنَكُمْ ۚ إِنَّهُۥ كَانَ بِعِبَادِهِۦ خَبِيرًۢا بَصِيرًۭا","numberInSurah":96,"juz":15,"manzil":4,"page":291,"ruku":250,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2126,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2126.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2126.mp3"],"text":"وَمَن يَهْدِ ٱللَّهُ فَهُوَ ٱلْمُهْتَدِ ۖ وَمَن يُضْلِلْ فَلَن تَجِدَ لَهُمْ أَوْلِيَآءَ مِن دُونِهِۦ ۖ وَنَحْشُرُهُمْ يَوْمَ ٱلْقِيَٰمَةِ عَلَىٰ وُجُوهِهِمْ عُمْيًۭا وَبُكْمًۭا وَصُمًّۭا ۖ مَّأْوَىٰهُمْ جَهَنَّمُ ۖ كُلَّمَا خَبَتْ زِدْنَٰهُمْ سَعِيرًۭا","numberInSurah":97,"juz":15,"manzil":4,"page":292,"ruku":250,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2127,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2127.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2127.mp3"],"text":"ذَٰلِكَ جَزَآؤُهُم بِأَنَّهُمْ كَفَرُوا۟ بِـَٔايَٰتِنَا وَقَالُوٓا۟ أَءِذَا كُنَّا عِظَٰمًۭا وَرُفَٰتًا أَءِنَّا لَمَبْعُوثُونَ خَلْقًۭا جَدِيدًا","numberInSurah":98,"juz":15,"manzil":4,"page":292,"ruku":250,"hizbQuarter":116,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}}],"surahs":{"17":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"Th