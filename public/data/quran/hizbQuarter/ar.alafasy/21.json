{"code":200,"status":"OK","data":{"number":21,"ayahs":[{"number":308,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/308.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/308.mp3"],"text":"۞ قُلْ أَؤُنَبِّئُكُم بِخَيْرٍۢ مِّن ذَٰلِكُمْ ۚ لِلَّذِينَ ٱتَّقَوْا۟ عِندَ رَبِّهِمْ جَنَّٰتٌۭ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَا وَأَزْوَٰجٌۭ مُّطَهَّرَةٌۭ وَرِضْوَٰنٌۭ مِّنَ ٱللَّهِ ۗ وَٱللَّهُ بَصِيرٌۢ بِٱلْعِبَادِ","numberInSurah":15,"juz":3,"manzil":1,"page":51,"ruku":43,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":309,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/309.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/309.mp3"],"text":"ٱلَّذِينَ يَقُولُونَ رَبَّنَآ إِنَّنَآ ءَامَنَّا فَٱغْفِرْ لَنَا ذُنُوبَنَا وَقِنَا عَذَابَ ٱلنَّارِ","numberInSurah":16,"juz":3,"manzil":1,"page":52,"ruku":43,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":310,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/310.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/310.mp3"],"text":"ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ","numberInSurah":17,"juz":3,"manzil":1,"page":52,"ruku":43,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":311,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/311.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/311.mp3"],"text":"شَهِدَ ٱللَّهُ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا هُوَ وَٱلْمَلَٰٓئِكَةُ وَأُو۟لُوا۟ ٱلْعِلْمِ قَآئِمًۢا بِٱلْقِسْطِ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":18,"juz":3,"manzil":1,"page":52,"ruku":43,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":312,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/312.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/312.mp3"],"text":"إِنَّ ٱلدِّينَ عِندَ ٱللَّهِ ٱلْإِسْلَٰمُ ۗ وَمَا ٱخْتَلَفَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَهُمُ ٱلْعِلْمُ بَغْيًۢا بَيْنَهُمْ ۗ وَمَن يَكْفُرْ بِـَٔايَٰتِ ٱللَّهِ فَإِنَّ ٱللَّهَ سَرِيعُ ٱلْحِسَابِ","numberInSurah":19,"juz":3,"manzil":1,"page":52,"ruku":43,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":313,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/313.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/313.mp3"],"text":"فَإِنْ حَآجُّوكَ فَقُلْ أَسْلَمْتُ وَجْهِىَ لِلَّهِ وَمَنِ ٱتَّبَعَنِ ۗ وَقُل لِّلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ وَٱلْأُمِّيِّۦنَ ءَأَسْلَمْتُمْ ۚ فَإِنْ أَسْلَمُوا۟ فَقَدِ ٱهْتَدَوا۟ ۖ وَّإِن تَوَلَّوْا۟ فَإِنَّمَا عَلَيْكَ ٱلْبَلَٰغُ ۗ وَٱللَّهُ بَصِيرٌۢ بِٱلْعِبَادِ","numberInSurah":20,"juz":3,"manzil":1,"page":52,"ruku":43,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":314,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/314.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/314.mp3"],"text":"إِنَّ ٱلَّذِينَ يَكْفُرُونَ بِـَٔايَٰتِ ٱللَّهِ وَيَقْتُلُونَ ٱلنَّبِيِّۦنَ بِغَيْرِ حَقٍّۢ وَيَقْتُلُونَ ٱلَّذِينَ يَأْمُرُونَ بِٱلْقِسْطِ مِنَ ٱلنَّاسِ فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ","numberInSurah":21,"juz":3,"manzil":1,"page":52,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":315,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/315.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/315.mp3"],"text":"أُو۟لَٰٓئِكَ ٱلَّذِينَ حَبِطَتْ أَعْمَٰلُهُمْ فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ وَمَا لَهُم مِّن نَّٰصِرِينَ","numberInSurah":22,"juz":3,"manzil":1,"page":52,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":316,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/316.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/316.mp3"],"text":"أَلَمْ تَرَ إِلَى ٱلَّذِينَ أُوتُوا۟ نَصِيبًۭا مِّنَ ٱلْكِتَٰبِ يُدْعَوْنَ إِلَىٰ كِتَٰبِ ٱللَّهِ لِيَحْكُمَ بَيْنَهُمْ ثُمَّ يَتَوَلَّىٰ فَرِيقٌۭ مِّنْهُمْ وَهُم مُّعْرِضُونَ","numberInSurah":23,"juz":3,"manzil":1,"page":53,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":317,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/317.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/317.mp3"],"text":"ذَٰلِكَ بِأَنَّهُمْ قَالُوا۟ لَن تَمَسَّنَا ٱلنَّارُ إِلَّآ أَيَّامًۭا مَّعْدُودَٰتٍۢ ۖ وَغَرَّهُمْ فِى دِينِهِم مَّا كَانُوا۟ يَفْتَرُونَ","numberInSurah":24,"juz":3,"manzil":1,"page":53,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":318,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/318.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/318.mp3"],"text":"فَكَيْفَ إِذَا جَمَعْنَٰهُمْ لِيَوْمٍۢ لَّا رَيْبَ فِيهِ وَوُفِّيَتْ كُلُّ نَفْسٍۢ مَّا كَسَبَتْ وَهُمْ لَا يُظْلَمُونَ","numberInSurah":25,"juz":3,"manzil":1,"page":53,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":319,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/319.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/319.mp3"],"text":"قُلِ ٱللَّهُمَّ مَٰلِكَ ٱلْمُلْكِ تُؤْتِى ٱلْمُلْكَ مَن تَشَآءُ وَتَنزِعُ ٱلْمُلْكَ مِمَّن تَشَآءُ وَتُعِزُّ مَن تَشَآءُ وَتُذِلُّ مَن تَشَآءُ ۖ بِيَدِكَ ٱلْخَيْرُ ۖ إِنَّكَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","numberInSurah":26,"juz":3,"manzil":1,"page":53,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":320,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/320.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/320.mp3"],"text":"تُولِجُ ٱلَّيْلَ فِى ٱلنَّهَارِ وَتُولِجُ ٱلنَّهَارَ فِى ٱلَّيْلِ ۖ وَتُخْرِجُ ٱلْحَىَّ مِنَ ٱلْمَيِّتِ وَتُخْرِجُ ٱلْمَيِّتَ مِنَ ٱلْحَىِّ ۖ وَتَرْزُقُ مَن تَشَآءُ بِغَيْرِ حِسَابٍۢ","numberInSurah":27,"juz":3,"manzil":1,"page":53,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":321,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/321.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/321.mp3"],"text":"لَّا يَتَّخِذِ ٱلْمُؤْمِنُونَ ٱلْكَٰفِرِينَ أَوْلِيَآءَ مِن دُونِ ٱلْمُؤْمِنِينَ ۖ وَمَن يَفْعَلْ ذَٰلِكَ فَلَيْسَ مِنَ ٱللَّهِ فِى شَىْءٍ إِلَّآ أَن تَتَّقُوا۟ مِنْهُمْ تُقَىٰةًۭ ۗ وَيُحَذِّرُكُمُ ٱللَّهُ نَفْسَهُۥ ۗ وَإِلَى ٱللَّهِ ٱلْمَصِيرُ","numberInSurah":28,"juz":3,"manzil":1,"page":53,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":322,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/322.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/322.mp3"],"text":"قُلْ إِن تُخْفُوا۟ مَا فِى صُدُورِكُمْ أَوْ تُبْدُوهُ يَعْلَمْهُ ٱللَّهُ ۗ وَيَعْلَمُ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۗ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","numberInSurah":29,"juz":3,"manzil":1,"page":53,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":323,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/323.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/323.mp3"],"text":"يَوْمَ تَجِدُ كُلُّ نَفْسٍۢ مَّا عَمِلَتْ مِنْ خَيْرٍۢ مُّحْضَرًۭا وَمَا عَمِلَتْ مِن سُوٓءٍۢ تَوَدُّ لَوْ أَنَّ بَيْنَهَا وَبَيْنَهُۥٓ أَمَدًۢا بَعِيدًۭا ۗ وَيُحَذِّرُكُمُ ٱللَّهُ نَفْسَهُۥ ۗ وَٱللَّهُ رَءُوفٌۢ بِٱلْعِبَادِ","numberInSurah":30,"juz":3,"manzil":1,"page":54,"ruku":44,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":324,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/324.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/324.mp3"],"text":"قُلْ إِن كُنتُمْ تُحِبُّونَ ٱللَّهَ فَٱتَّبِعُونِى يُحْبِبْكُمُ ٱللَّهُ وَيَغْفِرْ لَكُمْ ذُنُوبَكُمْ ۗ وَٱللَّهُ غَفُورٌۭ رَّحِيمٌۭ","numberInSurah":31,"juz":3,"manzil":1,"page":54,"ruku":45,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},{"number":325,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/325.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/325.mp3"],"text":"قُلْ أَطِيعُوا۟ ٱللَّهَ وَٱلرَّسُولَ ۖ فَإِن تَوَلَّوْا۟ فَإِنَّ ٱللَّهَ لَا يُحِبُّ ٱلْكَٰفِرِينَ","numberInSurah":32,"juz":3,"manzil":1,"page":54,"ruku":45,"hizbQuarter":21,"sajda":false,"surah":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}}],"surahs":{"3":{"number":3,"name":"سُورَةُ آلِ عِمۡرَانَ","englishName":"Aal-i-Imraan","englishNameTranslation":"The Family of Imraan","revelationType":"Medinan"}},"edition":{}}}