{"code":200,"status":"OK","data":{"number":124,"ayahs":[{"number":2309,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2309.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2309.mp3"],"text":"۞ فَخَلَفَ مِنۢ بَعْدِهِمْ خَلْفٌ أَضَاعُوا۟ ٱلصَّلَوٰةَ وَٱتَّبَعُوا۟ ٱلشَّهَوَٰتِ ۖ فَسَوْفَ يَلْقَوْنَ غَيًّا","numberInSurah":59,"juz":16,"manzil":4,"page":309,"ruku":267,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2310,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2310.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2310.mp3"],"text":"إِلَّا مَن تَابَ وَءَامَنَ وَعَمِلَ صَٰلِحًۭا فَأُو۟لَٰٓئِكَ يَدْخُلُونَ ٱلْجَنَّةَ وَلَا يُظْلَمُونَ شَيْـًۭٔا","numberInSurah":60,"juz":16,"manzil":4,"page":309,"ruku":267,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2311,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2311.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2311.mp3"],"text":"جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدَ ٱلرَّحْمَٰنُ عِبَادَهُۥ بِٱلْغَيْبِ ۚ إِنَّهُۥ كَانَ وَعْدُهُۥ مَأْتِيًّۭا","numberInSurah":61,"juz":16,"manzil":4,"page":309,"ruku":267,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2312,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2312.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2312.mp3"],"text":"لَّا يَسْمَعُونَ فِيهَا لَغْوًا إِلَّا سَلَٰمًۭا ۖ وَلَهُمْ رِزْقُهُمْ فِيهَا بُكْرَةًۭ وَعَشِيًّۭا","numberInSurah":62,"juz":16,"manzil":4,"page":309,"ruku":267,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2313,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2313.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2313.mp3"],"text":"تِلْكَ ٱلْجَنَّةُ ٱلَّتِى نُورِثُ مِنْ عِبَادِنَا مَن كَانَ تَقِيًّۭا","numberInSurah":63,"juz":16,"manzil":4,"page":309,"ruku":267,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2314,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2314.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2314.mp3"],"text":"وَمَا نَتَنَزَّلُ إِلَّا بِأَمْرِ رَبِّكَ ۖ لَهُۥ مَا بَيْنَ أَيْدِينَا وَمَا خَلْفَنَا وَمَا بَيْنَ ذَٰلِكَ ۚ وَمَا كَانَ رَبُّكَ نَسِيًّۭا","numberInSurah":64,"juz":16,"manzil":4,"page":309,"ruku":267,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2315,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2315.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2315.mp3"],"text":"رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا فَٱعْبُدْهُ وَٱصْطَبِرْ لِعِبَٰدَتِهِۦ ۚ هَلْ تَعْلَمُ لَهُۥ سَمِيًّۭا","numberInSurah":65,"juz":16,"manzil":4,"page":310,"ruku":267,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2316,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2316.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2316.mp3"],"text":"وَيَقُولُ ٱلْإِنسَٰنُ أَءِذَا مَا مِتُّ لَسَوْفَ أُخْرَجُ حَيًّا","numberInSurah":66,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2317,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2317.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2317.mp3"],"text":"أَوَلَا يَذْكُرُ ٱلْإِنسَٰنُ أَنَّا خَلَقْنَٰهُ مِن قَبْلُ وَلَمْ يَكُ شَيْـًۭٔا","numberInSurah":67,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2318,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2318.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2318.mp3"],"text":"فَوَرَبِّكَ لَنَحْشُرَنَّهُمْ وَٱلشَّيَٰطِينَ ثُمَّ لَنُحْضِرَنَّهُمْ حَوْلَ جَهَنَّمَ جِثِيًّۭا","numberInSurah":68,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2319,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2319.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2319.mp3"],"text":"ثُمَّ لَنَنزِعَنَّ مِن كُلِّ شِيعَةٍ أَيُّهُمْ أَشَدُّ عَلَى ٱلرَّحْمَٰنِ عِتِيًّۭا","numberInSurah":69,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2320,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2320.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2320.mp3"],"text":"ثُمَّ لَنَحْنُ أَعْلَمُ بِٱلَّذِينَ هُمْ أَوْلَىٰ بِهَا صِلِيًّۭا","numberInSurah":70,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2321,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2321.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2321.mp3"],"text":"وَإِن مِّنكُمْ إِلَّا وَارِدُهَا ۚ كَانَ عَلَىٰ رَبِّكَ حَتْمًۭا مَّقْضِيًّۭا","numberInSurah":71,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2322,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2322.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2322.mp3"],"text":"ثُمَّ نُنَجِّى ٱلَّذِينَ ٱتَّقَوا۟ وَّنَذَرُ ٱلظَّٰلِمِينَ فِيهَا جِثِيًّۭا","numberInSurah":72,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2323,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2323.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2323.mp3"],"text":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍۢ قَالَ ٱلَّذِينَ كَفَرُوا۟ لِلَّذِينَ ءَامَنُوٓا۟ أَىُّ ٱلْفَرِيقَيْنِ خَيْرٌۭ مَّقَامًۭا وَأَحْسَنُ نَدِيًّۭا","numberInSurah":73,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2324,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2324.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2324.mp3"],"text":"وَكَمْ أَهْلَكْنَا قَبْلَهُم مِّن قَرْنٍ هُمْ أَحْسَنُ أَثَٰثًۭا وَرِءْيًۭا","numberInSurah":74,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2325,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2325.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2325.mp3"],"text":"قُلْ مَن كَانَ فِى ٱلضَّلَٰلَةِ فَلْيَمْدُدْ لَهُ ٱلرَّحْمَٰنُ مَدًّا ۚ حَتَّىٰٓ إِذَا رَأَوْا۟ مَا يُوعَدُونَ إِمَّا ٱلْعَذَابَ وَإِمَّا ٱلسَّاعَةَ فَسَيَعْلَمُونَ مَنْ هُوَ شَرٌّۭ مَّكَانًۭا وَأَضْعَفُ جُندًۭا","numberInSurah":75,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2326,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2326.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2326.mp3"],"text":"وَيَزِيدُ ٱللَّهُ ٱلَّذِينَ ٱهْتَدَوْا۟ هُدًۭى ۗ وَٱلْبَٰقِيَٰتُ ٱلصَّٰلِحَٰتُ خَيْرٌ عِندَ رَبِّكَ ثَوَابًۭا وَخَيْرٌۭ مَّرَدًّا","numberInSurah":76,"juz":16,"manzil":4,"page":310,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2327,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2327.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2327.mp3"],"text":"أَفَرَءَيْتَ ٱلَّذِى كَفَرَ بِـَٔايَٰتِنَا وَقَالَ لَأُوتَيَنَّ مَالًۭا وَوَلَدًا","numberInSurah":77,"juz":16,"manzil":4,"page":311,"ruku":268,"hizbQuarter":124,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2328,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2328.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2328.mp3"],"text":"أَطَّلَعَ ٱلْغَيْبَ أَمِ ٱتَّخَذَ عِندَ ٱلرَّحْمَٰنِ عَهْدًۭا","numberInSurah":78,"juz":16,"man