{"code":200,"status":"OK","data":{"number":102,"ayahs":[{"number":1742,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1742.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1742.mp3"],"text":"۞ مَّثَلُ ٱلْجَنَّةِ ٱلَّتِى وُعِدَ ٱلْمُتَّقُونَ ۖ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۖ أُكُلُهَا دَآئِمٌۭ وَظِلُّهَا ۚ تِلْكَ عُقْبَى ٱلَّذِينَ ٱتَّقَوا۟ ۖ وَّعُقْبَى ٱلْكَٰفِرِينَ ٱلنَّارُ","numberInSurah":35,"juz":13,"manzil":3,"page":254,"ruku":209,"hizbQuarter":102,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1743,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1743.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1743.mp3"],"text":"وَٱلَّذِينَ ءَاتَيْنَٰهُمُ ٱلْكِتَٰبَ يَفْرَحُونَ بِمَآ أُنزِلَ إِلَيْكَ ۖ وَمِنَ ٱلْأَحْزَابِ مَن يُنكِرُ بَعْضَهُۥ ۚ قُلْ إِنَّمَآ أُمِرْتُ أَنْ أَعْبُدَ ٱللَّهَ وَلَآ أُشْرِكَ بِهِۦٓ ۚ إِلَيْهِ أَدْعُوا۟ وَإِلَيْهِ مَـَٔابِ","numberInSurah":36,"juz":13,"manzil":3,"page":254,"ruku":209,"hizbQuarter":102,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1744,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1744.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1744.mp3"],"text":"وَكَذَٰلِكَ أَنزَلْنَٰهُ حُكْمًا عَرَبِيًّۭا ۚ وَلَئِنِ ٱتَّبَعْتَ أَهْوَآءَهُم بَعْدَمَا جَآءَكَ مِنَ ٱلْعِلْمِ مَا لَكَ مِنَ ٱللَّهِ مِن وَلِىٍّۢ وَلَا وَاقٍۢ","numberInSurah":37,"juz":13,"manzil":3,"page":254,"ruku":209,"hizbQuarter":102,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1745,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1745.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1745.mp3"],"text":"وَلَقَدْ أَرْسَلْنَا رُسُلًۭا مِّن قَبْلِكَ وَجَعَلْنَا لَهُمْ أَزْوَٰجًۭا وَذُرِّيَّةًۭ ۚ وَمَا كَانَ لِرَسُولٍ أَن يَأْتِىَ بِـَٔايَةٍ إِلَّا بِإِذْنِ ٱللَّهِ ۗ لِكُلِّ أَجَلٍۢ كِتَابٌۭ","numberInSurah":38,"juz":13,"manzil":3,"page":254,"ruku":210,"hizbQuarter":102,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1746,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1746.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1746.mp3"],"text":"يَمْحُوا۟ ٱللَّهُ مَا يَشَآءُ وَيُثْبِتُ ۖ وَعِندَهُۥٓ أُمُّ ٱلْكِتَٰبِ","numberInSurah":39,"juz":13,"manzil":3,"page":254,"ruku":210,"hizbQuarter":102,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1747,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1747.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1747.mp3"],"text":"وَإِن مَّا نُرِيَنَّكَ بَعْضَ ٱلَّذِى نَعِدُهُمْ أَوْ نَتَوَفَّيَنَّكَ فَإِنَّمَا عَلَيْكَ ٱلْبَلَٰغُ وَعَلَيْنَا ٱلْحِسَابُ","numberInSurah":40,"juz":13,"manzil":3,"page":254,"ruku":210,"hizbQuarter":102,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1748,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1748.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1748.mp3"],"text":"أَوَلَمْ يَرَوْا۟ أَنَّا نَأْتِى ٱلْأَرْضَ نَنقُصُهَا مِنْ أَطْرَافِهَا ۚ وَٱللَّهُ يَحْكُمُ لَا مُعَقِّبَ لِحُكْمِهِۦ ۚ وَهُوَ سَرِيعُ ٱلْحِسَابِ","numberInSurah":41,"juz":13,"manzil":3,"page":254,"ruku":210,"hizbQuarter":102,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1749,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1749.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1749.mp3"],"text":"وَقَدْ مَكَرَ ٱلَّذِينَ مِن قَبْلِهِمْ فَلِلَّهِ ٱلْمَكْرُ جَمِيعًۭا ۖ يَعْلَمُ مَا تَكْسِبُ كُلُّ نَفْسٍۢ ۗ وَسَيَعْلَمُ ٱلْكُفَّٰرُ لِمَنْ عُقْبَى ٱلدَّارِ","numberInSurah":42,"juz":13,"manzil":3,"page":254,"ruku":210,"hizbQuarter":102,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1750,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1750.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1750.mp3"],"text":"وَيَقُولُ ٱلَّذِينَ كَفَرُوا۟ لَسْتَ مُرْسَلًۭا ۚ قُلْ كَفَىٰ بِٱللَّهِ شَهِيدًۢا بَيْنِى وَبَيْنَكُمْ وَمَنْ عِندَهُۥ عِلْمُ ٱلْكِتَٰبِ","numberInSurah":43,"juz":13,"manzil":3,"page":255,"ruku":210,"hizbQuarter":102,"sajda":false,"surah":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"}},{"number":1751,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1751.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1751.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓر ۚ كِتَٰبٌ أَنزَلْنَٰهُ إِلَيْكَ لِتُخْرِجَ ٱلنَّاسَ مِنَ ٱلظُّلُمَٰتِ إِلَى ٱلنُّورِ بِإِذْنِ رَبِّهِمْ إِلَىٰ صِرَٰطِ ٱلْعَزِيزِ ٱلْحَمِيدِ","numberInSurah":1,"juz":13,"manzil":3,"page":255,"ruku":211,"hizbQuarter":102,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1752,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1752.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1752.mp3"],"text":"ٱللَّهِ ٱلَّذِى لَهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۗ وَوَيْلٌۭ لِّلْكَٰفِرِينَ مِنْ عَذَابٍۢ شَدِيدٍ","numberInSurah":2,"juz":13,"manzil":3,"page":255,"ruku":211,"hizbQuarter":102,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1753,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1753.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1753.mp3"],"text":"ٱلَّذِينَ يَسْتَحِبُّونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا عَلَى ٱلْءَاخِرَةِ وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ وَيَبْغُونَهَا عِوَجًا ۚ أُو۟لَٰٓئِكَ فِى ضَلَٰلٍۭ بَعِيدٍۢ","numberInSurah":3,"juz":13,"manzil":3,"page":255,"ruku":211,"hizbQuarter":102,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1754,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1754.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1754.mp3"],"text":"وَمَآ أَرْسَلْنَا مِن رَّسُولٍ إِلَّا بِلِسَانِ قَوْمِهِۦ لِيُبَيِّنَ لَهُمْ ۖ فَيُضِلُّ ٱللَّهُ مَن يَشَآءُ وَيَهْدِى مَن يَشَآءُ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","numberInSurah":4,"juz":13,"manzil":3,"page":255,"ruku":211,"hizbQuarter":102,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1755,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1755.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1755.mp3"],"text":"وَلَقَدْ أَرْسَلْنَا مُوسَىٰ بِـَٔايَٰتِنَآ أَنْ أَخْرِجْ قَوْمَكَ مِنَ ٱلظُّلُمَٰتِ إِلَى ٱلنُّورِ وَذَكِّرْهُم بِأَيَّىٰمِ ٱللَّهِ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّكُلِّ صَبَّارٍۢ شَكُورٍۢ","numberInSurah":5,"juz":13,"manzil":3,"page":255,"ruku":211,"hizbQuarter":102,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1756,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1756.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1756.mp3"],"text":"وَإِذْ قَالَ مُوسَىٰ لِقَوْمِهِ ٱذْكُرُوا۟ نِعْمَةَ ٱللَّهِ عَلَيْكُمْ إِذْ أَنجَىٰكُم مِّنْ ءَالِ فِرْعَوْنَ يَسُومُونَكُمْ سُوٓءَ ٱلْعَذَابِ وَيُذَبِّحُونَ أَبْنَآءَكُمْ وَيَسْتَحْيُونَ نِسَآءَكُمْ ۚ وَفِى ذَٰلِكُم بَلَآءٌۭ مِّن رَّبِّكُمْ عَظِيمٌۭ","numberInSurah":6,"juz":13,"manzil":3,"page":256,"ruku":211,"hizbQuarter":102,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1757,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1757.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1757.mp3"],"text":"وَإِذْ تَأَذَّنَ رَبُّكُمْ لَئِن شَكَرْتُمْ لَأَزِيدَنَّكُمْ ۖ وَلَئِن كَفَرْتُمْ إِنَّ عَذَابِى لَشَدِيدٌۭ","numberInSurah":7,"juz":13,"manzil":3,"page":256,"ruku":212,"hizbQuarter":102,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1758,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1758.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1758.mp3"],"text":"وَقَالَ مُوسَىٰٓ إِن تَكْفُرُوٓا۟ أَنتُمْ وَمَن فِى ٱلْأَرْضِ جَمِيعًۭا فَإِنَّ ٱللَّهَ لَغَنِىٌّ حَمِيدٌ","numberInSurah":8,"juz":13,"manzil":3,"page":256,"ruku":212,"hizbQuarter":102,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1759,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1759.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1759.mp3"],"text":"أَلَمْ يَأْتِكُمْ نَبَؤُا۟ ٱلَّذِينَ مِن قَبْلِكُمْ قَوْمِ نُوحٍۢ وَعَادٍۢ وَثَمُودَ ۛ وَٱلَّذِينَ مِنۢ بَعْدِهِمْ ۛ لَا يَعْلَمُهُمْ إِلَّا ٱللَّهُ ۚ جَآءَتْهُمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ فَرَدُّوٓا۟ أَيْدِيَهُمْ فِىٓ أَفْوَٰهِهِمْ وَقَالُوٓا۟ إِنَّا كَفَرْنَا بِمَآ أُرْسِلْتُم بِهِۦ وَإِنَّا لَفِى شَكٍّۢ مِّمَّا تَدْعُونَنَآ إِلَيْهِ مُرِيبٍۢ","numberInSurah":9,"juz":13,"manzil":3,"page":256,"ruku":212,"hizbQuarter":102,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}}],"surahs":{"13":{"number":13,"name":"سُورَةُ الرَّعۡدِ","englishName":"Ar-Ra'd","englishNameTranslation":"The Thunder","revelationType":"Medinan"},"14":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},"edition":{}}}