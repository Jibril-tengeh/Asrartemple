{"code":200,"status":"OK","data":{"number":146,"ayahs":[{"number":2908,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2908.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2908.mp3"],"text":"۞ وَهُوَ ٱلَّذِى مَرَجَ ٱلْبَحْرَيْنِ هَٰذَا عَذْبٌۭ فُرَاتٌۭ وَهَٰذَا مِلْحٌ أُجَاجٌۭ وَجَعَلَ بَيْنَهُمَا بَرْزَخًۭا وَحِجْرًۭا مَّحْجُورًۭا","numberInSurah":53,"juz":19,"manzil":4,"page":364,"ruku":314,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2909,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2909.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2909.mp3"],"text":"وَهُوَ ٱلَّذِى خَلَقَ مِنَ ٱلْمَآءِ بَشَرًۭا فَجَعَلَهُۥ نَسَبًۭا وَصِهْرًۭا ۗ وَكَانَ رَبُّكَ قَدِيرًۭا","numberInSurah":54,"juz":19,"manzil":4,"page":364,"ruku":314,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2910,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2910.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2910.mp3"],"text":"وَيَعْبُدُونَ مِن دُونِ ٱللَّهِ مَا لَا يَنفَعُهُمْ وَلَا يَضُرُّهُمْ ۗ وَكَانَ ٱلْكَافِرُ عَلَىٰ رَبِّهِۦ ظَهِيرًۭا","numberInSurah":55,"juz":19,"manzil":4,"page":364,"ruku":314,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2911,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2911.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2911.mp3"],"text":"وَمَآ أَرْسَلْنَٰكَ إِلَّا مُبَشِّرًۭا وَنَذِيرًۭا","numberInSurah":56,"juz":19,"manzil":4,"page":365,"ruku":314,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2912,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2912.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2912.mp3"],"text":"قُلْ مَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ إِلَّا مَن شَآءَ أَن يَتَّخِذَ إِلَىٰ رَبِّهِۦ سَبِيلًۭا","numberInSurah":57,"juz":19,"manzil":4,"page":365,"ruku":314,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2913,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2913.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2913.mp3"],"text":"وَتَوَكَّلْ عَلَى ٱلْحَىِّ ٱلَّذِى لَا يَمُوتُ وَسَبِّحْ بِحَمْدِهِۦ ۚ وَكَفَىٰ بِهِۦ بِذُنُوبِ عِبَادِهِۦ خَبِيرًا","numberInSurah":58,"juz":19,"manzil":4,"page":365,"ruku":314,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2914,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2914.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2914.mp3"],"text":"ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا فِى سِتَّةِ أَيَّامٍۢ ثُمَّ ٱسْتَوَىٰ عَلَى ٱلْعَرْشِ ۚ ٱلرَّحْمَٰنُ فَسْـَٔلْ بِهِۦ خَبِيرًۭا","numberInSurah":59,"juz":19,"manzil":4,"page":365,"ruku":314,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2915,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2915.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2915.mp3"],"text":"وَإِذَا قِيلَ لَهُمُ ٱسْجُدُوا۟ لِلرَّحْمَٰنِ قَالُوا۟ وَمَا ٱلرَّحْمَٰنُ أَنَسْجُدُ لِمَا تَأْمُرُنَا وَزَادَهُمْ نُفُورًۭا ۩","numberInSurah":60,"juz":19,"manzil":4,"page":365,"ruku":314,"hizbQuarter":146,"sajda":{"id":8,"recommended":true,"obligatory":false},"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2916,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2916.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2916.mp3"],"text":"تَبَارَكَ ٱلَّذِى جَعَلَ فِى ٱلسَّمَآءِ بُرُوجًۭا وَجَعَلَ فِيهَا سِرَٰجًۭا وَقَمَرًۭا مُّنِيرًۭا","numberInSurah":61,"juz":19,"manzil":4,"page":365,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2917,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2917.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2917.mp3"],"text":"وَهُوَ ٱلَّذِى جَعَلَ ٱلَّيْلَ وَٱلنَّهَارَ خِلْفَةًۭ لِّمَنْ أَرَادَ أَن يَذَّكَّرَ أَوْ أَرَادَ شُكُورًۭا","numberInSurah":62,"juz":19,"manzil":4,"page":365,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2918,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2918.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2918.mp3"],"text":"وَعِبَادُ ٱلرَّحْمَٰنِ ٱلَّذِينَ يَمْشُونَ عَلَى ٱلْأَرْضِ هَوْنًۭا وَإِذَا خَاطَبَهُمُ ٱلْجَٰهِلُونَ قَالُوا۟ سَلَٰمًۭا","numberInSurah":63,"juz":19,"manzil":4,"page":365,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2919,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2919.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2919.mp3"],"text":"وَٱلَّذِينَ يَبِيتُونَ لِرَبِّهِمْ سُجَّدًۭا وَقِيَٰمًۭا","numberInSurah":64,"juz":19,"manzil":4,"page":365,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2920,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2920.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2920.mp3"],"text":"وَٱلَّذِينَ يَقُولُونَ رَبَّنَا ٱصْرِفْ عَنَّا عَذَابَ جَهَنَّمَ ۖ إِنَّ عَذَابَهَا كَانَ غَرَامًا","numberInSurah":65,"juz":19,"manzil":4,"page":365,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2921,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2921.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2921.mp3"],"text":"إِنَّهَا سَآءَتْ مُسْتَقَرًّۭا وَمُقَامًۭا","numberInSurah":66,"juz":19,"manzil":4,"page":365,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2922,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2922.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2922.mp3"],"text":"وَٱلَّذِينَ إِذَآ أَنفَقُوا۟ لَمْ يُسْرِفُوا۟ وَلَمْ يَقْتُرُوا۟ وَكَانَ بَيْنَ ذَٰلِكَ قَوَامًۭا","numberInSurah":67,"juz":19,"manzil":4,"page":365,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2923,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2923.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2923.mp3"],"text":"وَٱلَّذِينَ لَا يَدْعُونَ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ وَلَا يَقْتُلُونَ ٱلنَّفْسَ ٱلَّتِى حَرَّمَ ٱللَّهُ إِلَّا بِٱلْحَقِّ وَلَا يَزْنُونَ ۚ وَمَن يَفْعَلْ ذَٰلِكَ يَلْقَ أَثَامًۭا","numberInSurah":68,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2924,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2924.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2924.mp3"],"text":"يُضَٰعَفْ لَهُ ٱلْعَذَابُ يَوْمَ ٱلْقِيَٰمَةِ وَيَخْلُدْ فِيهِۦ مُهَانًا","numberInSurah":69,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2925,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2925.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2925.mp3"],"text":"إِلَّا مَن تَابَ وَءَامَنَ وَعَمِلَ عَمَلًۭا صَٰلِحًۭا فَأُو۟لَٰٓئِكَ يُبَدِّلُ ٱللَّهُ سَيِّـَٔاتِهِمْ حَسَنَٰتٍۢ ۗ وَكَانَ ٱللَّهُ غَفُورًۭا رَّحِيمًۭا","numberInSurah":70,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2926,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2926.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2926.mp3"],"text":"وَمَن تَابَ وَعَمِلَ صَٰلِحًۭا فَإِنَّهُۥ يَتُوبُ إِلَى ٱللَّهِ مَتَابًۭا","numberInSurah":71,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2927,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2927.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2927.mp3"],"text":"وَٱلَّذِينَ لَا يَشْهَدُونَ ٱلزُّورَ وَإِذَا مَرُّوا۟ بِٱللَّغْوِ مَرُّوا۟ كِرَامًۭا","numberInSurah":72,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2928,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2928.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2928.mp3"],"text":"وَٱلَّذِينَ إِذَا ذُكِّرُوا۟ بِـَٔايَٰتِ رَبِّهِمْ لَمْ يَخِرُّوا۟ عَلَيْهَا صُمًّۭا وَعُمْيَانًۭا","numberInSurah":73,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2929,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2929.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2929.mp3"],"text":"وَٱلَّذِينَ يَقُولُونَ رَبَّنَا هَبْ لَنَا مِنْ أَزْوَٰجِنَا وَذُرِّيَّٰتِنَا قُرَّةَ أَعْيُنٍۢ وَٱجْعَلْنَا لِلْمُتَّقِينَ إِمَامًا","numberInSurah":74,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2930,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2930.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2930.mp3"],"text":"أُو۟لَٰٓئِكَ يُجْزَوْنَ ٱلْغُرْفَةَ بِمَا صَبَرُوا۟ وَيُلَقَّوْنَ فِيهَا تَحِيَّةًۭ وَسَلَٰمًا","numberInSurah":75,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2931,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2931.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2931.mp3"],"text":"خَٰلِدِينَ فِيهَا ۚ حَسُنَتْ مُسْتَقَرًّۭا وَمُقَامًۭا","numberInSurah":76,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2932,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2932.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2932.mp3"],"text":"قُلْ مَا يَعْبَؤُا۟ بِكُمْ رَبِّى لَوْلَا دُعَآؤُكُمْ ۖ فَقَدْ كَذَّبْتُمْ فَسَوْفَ يَكُونُ لِزَامًۢا","numberInSurah":77,"juz":19,"manzil":4,"page":366,"ruku":315,"hizbQuarter":146,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}}],"surahs":{"25":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},"edition":{}}}