{"code":200,"status":"OK","data":{"number":115,"ayahs":[{"number":2079,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2079.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2079.mp3"],"text":"۞ قُلْ كُونُوا۟ حِجَارَةً أَوْ حَدِيدًا","numberInSurah":50,"juz":15,"manzil":4,"page":287,"ruku":244,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2080,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2080.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2080.mp3"],"text":"أَوْ خَلْقًۭا مِّمَّا يَكْبُرُ فِى صُدُورِكُمْ ۚ فَسَيَقُولُونَ مَن يُعِيدُنَا ۖ قُلِ ٱلَّذِى فَطَرَكُمْ أَوَّلَ مَرَّةٍۢ ۚ فَسَيُنْغِضُونَ إِلَيْكَ رُءُوسَهُمْ وَيَقُولُونَ مَتَىٰ هُوَ ۖ قُلْ عَسَىٰٓ أَن يَكُونَ قَرِيبًۭا","numberInSurah":51,"juz":15,"manzil":4,"page":287,"ruku":244,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2081,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2081.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2081.mp3"],"text":"يَوْمَ يَدْعُوكُمْ فَتَسْتَجِيبُونَ بِحَمْدِهِۦ وَتَظُنُّونَ إِن لَّبِثْتُمْ إِلَّا قَلِيلًۭا","numberInSurah":52,"juz":15,"manzil":4,"page":287,"ruku":244,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2082,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2082.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2082.mp3"],"text":"وَقُل لِّعِبَادِى يَقُولُوا۟ ٱلَّتِى هِىَ أَحْسَنُ ۚ إِنَّ ٱلشَّيْطَٰنَ يَنزَغُ بَيْنَهُمْ ۚ إِنَّ ٱلشَّيْطَٰنَ كَانَ لِلْإِنسَٰنِ عَدُوًّۭا مُّبِينًۭا","numberInSurah":53,"juz":15,"manzil":4,"page":287,"ruku":245,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2083,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2083.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2083.mp3"],"text":"رَّبُّكُمْ أَعْلَمُ بِكُمْ ۖ إِن يَشَأْ يَرْحَمْكُمْ أَوْ إِن يَشَأْ يُعَذِّبْكُمْ ۚ وَمَآ أَرْسَلْنَٰكَ عَلَيْهِمْ وَكِيلًۭا","numberInSurah":54,"juz":15,"manzil":4,"page":287,"ruku":245,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2084,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2084.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2084.mp3"],"text":"وَرَبُّكَ أَعْلَمُ بِمَن فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۗ وَلَقَدْ فَضَّلْنَا بَعْضَ ٱلنَّبِيِّۦنَ عَلَىٰ بَعْضٍۢ ۖ وَءَاتَيْنَا دَاوُۥدَ زَبُورًۭا","numberInSurah":55,"juz":15,"manzil":4,"page":287,"ruku":245,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2085,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2085.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2085.mp3"],"text":"قُلِ ٱدْعُوا۟ ٱلَّذِينَ زَعَمْتُم مِّن دُونِهِۦ فَلَا يَمْلِكُونَ كَشْفَ ٱلضُّرِّ عَنكُمْ وَلَا تَحْوِيلًا","numberInSurah":56,"juz":15,"manzil":4,"page":287,"ruku":245,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2086,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2086.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2086.mp3"],"text":"أُو۟لَٰٓئِكَ ٱلَّذِينَ يَدْعُونَ يَبْتَغُونَ إِلَىٰ رَبِّهِمُ ٱلْوَسِيلَةَ أَيُّهُمْ أَقْرَبُ وَيَرْجُونَ رَحْمَتَهُۥ وَيَخَافُونَ عَذَابَهُۥٓ ۚ إِنَّ عَذَابَ رَبِّكَ كَانَ مَحْذُورًۭا","numberInSurah":57,"juz":15,"manzil":4,"page":287,"ruku":245,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2087,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2087.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2087.mp3"],"text":"وَإِن مِّن قَرْيَةٍ إِلَّا نَحْنُ مُهْلِكُوهَا قَبْلَ يَوْمِ ٱلْقِيَٰمَةِ أَوْ مُعَذِّبُوهَا عَذَابًۭا شَدِيدًۭا ۚ كَانَ ذَٰلِكَ فِى ٱلْكِتَٰبِ مَسْطُورًۭا","numberInSurah":58,"juz":15,"manzil":4,"page":287,"ruku":245,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2088,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2088.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2088.mp3"],"text":"وَمَا مَنَعَنَآ أَن نُّرْسِلَ بِٱلْءَايَٰتِ إِلَّآ أَن كَذَّبَ بِهَا ٱلْأَوَّلُونَ ۚ وَءَاتَيْنَا ثَمُودَ ٱلنَّاقَةَ مُبْصِرَةًۭ فَظَلَمُوا۟ بِهَا ۚ وَمَا نُرْسِلُ بِٱلْءَايَٰتِ إِلَّا تَخْوِيفًۭا","numberInSurah":59,"juz":15,"manzil":4,"page":288,"ruku":245,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2089,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2089.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2089.mp3"],"text":"وَإِذْ قُلْنَا لَكَ إِنَّ رَبَّكَ أَحَاطَ بِٱلنَّاسِ ۚ وَمَا جَعَلْنَا ٱلرُّءْيَا ٱلَّتِىٓ أَرَيْنَٰكَ إِلَّا فِتْنَةًۭ لِّلنَّاسِ وَٱلشَّجَرَةَ ٱلْمَلْعُونَةَ فِى ٱلْقُرْءَانِ ۚ وَنُخَوِّفُهُمْ فَمَا يَزِيدُهُمْ إِلَّا طُغْيَٰنًۭا كَبِيرًۭا","numberInSurah":60,"juz":15,"manzil":4,"page":288,"ruku":245,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2090,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2090.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2090.mp3"],"text":"وَإِذْ قُلْنَا لِلْمَلَٰٓئِكَةِ ٱسْجُدُوا۟ لِءَادَمَ فَسَجَدُوٓا۟ إِلَّآ إِبْلِيسَ قَالَ ءَأَسْجُدُ لِمَنْ خَلَقْتَ طِينًۭا","numberInSurah":61,"juz":15,"manzil":4,"page":288,"ruku":246,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2091,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2091.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2091.mp3"],"text":"قَالَ أَرَءَيْتَكَ هَٰذَا ٱلَّذِى كَرَّمْتَ عَلَىَّ لَئِنْ أَخَّرْتَنِ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ لَأَحْتَنِكَنَّ ذُرِّيَّتَهُۥٓ إِلَّا قَلِيلًۭا","numberInSurah":62,"juz":15,"manzil":4,"page":288,"ruku":246,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2092,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2092.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2092.mp3"],"text":"قَالَ ٱذْهَبْ فَمَن تَبِعَكَ مِنْهُمْ فَإِنَّ جَهَنَّمَ جَزَآؤُكُمْ جَزَآءًۭ مَّوْفُورًۭا","numberInSurah":63,"juz":15,"manzil":4,"page":288,"ruku":246,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2093,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2093.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2093.mp3"],"text":"وَٱسْتَفْزِزْ مَنِ ٱسْتَطَعْتَ مِنْهُم بِصَوْتِكَ وَأَجْلِبْ عَلَيْهِم بِخَيْلِكَ وَرَجِلِكَ وَشَارِكْهُمْ فِى ٱلْأَمْوَٰلِ وَٱلْأَوْلَٰدِ وَعِدْهُمْ ۚ وَمَا يَعِدُهُمُ ٱلشَّيْطَٰنُ إِلَّا غُرُورًا","numberInSurah":64,"juz":15,"manzil":4,"page":288,"ruku":246,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2094,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2094.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2094.mp3"],"text":"إِنَّ عِبَادِى لَيْسَ لَكَ عَلَيْهِمْ سُلْطَٰنٌۭ ۚ وَكَفَىٰ بِرَبِّكَ وَكِيلًۭا","numberInSurah":65,"juz":15,"manzil":4,"page":288,"ruku":246,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2095,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2095.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2095.mp3"],"text":"رَّبُّكُمُ ٱلَّذِى يُزْجِى لَكُمُ ٱلْفُلْكَ فِى ٱلْبَحْرِ لِتَبْتَغُوا۟ مِن فَضْلِهِۦٓ ۚ إِنَّهُۥ كَانَ بِكُمْ رَحِيمًۭا","numberInSurah":66,"juz":15,"manzil":4,"page":288,"ruku":246,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2096,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2096.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2096.mp3"],"text":"وَإِذَا مَسَّكُمُ ٱلضُّرُّ فِى ٱلْبَحْرِ ضَلَّ مَن تَدْعُونَ إِلَّآ إِيَّاهُ ۖ فَلَمَّا نَجَّىٰكُمْ إِلَى ٱلْبَرِّ أَعْرَضْتُمْ ۚ وَكَانَ ٱلْإِنسَٰنُ كَفُورًا","numberInSurah":67,"juz":15,"manzil":4,"page":289,"ruku":246,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2097,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2097.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2097.mp3"],"text":"أَفَأَمِنتُمْ أَن يَخْسِفَ بِكُمْ جَانِبَ ٱلْبَرِّ أَوْ يُرْسِلَ عَلَيْكُمْ حَاصِبًۭا ثُمَّ لَا تَجِدُوا۟ لَكُمْ وَكِيلًا","numberInSurah":68,"juz":15,"manzil":4,"page":289,"ruku":246,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},{"number":2098,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2098.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2098.mp3"],"text":"أَمْ أَمِنتُمْ أَن يُعِيدَكُمْ فِيهِ تَارَةً أُخْرَىٰ فَيُرْسِلَ عَلَيْكُمْ قَاصِفًۭا مِّنَ ٱلرِّيحِ فَيُغْرِقَكُم بِمَا كَفَرْتُمْ ۙ ثُمَّ لَا تَجِدُوا۟ لَكُمْ عَلَيْنَا بِهِۦ تَبِيعًۭا","numberInSurah":69,"juz":15,"manzil":4,"page":289,"ruku":246,"hizbQuarter":115,"sajda":false,"surah":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}}],"surahs":{"17":{"number":17,"name":"سُورَةُ الإِسۡرَاءِ","englishName":"Al-Israa","englishNameTranslation":"The Night Journey","revelationType":"Meccan"}},"edition":{}}}