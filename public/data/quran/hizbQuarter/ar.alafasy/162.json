َأُو۟لَٰٓئِكَ فِى ٱلْعَذَابِ مُحْضَرُونَ","numberInSurah":16,"juz":21,"manzil":5,"page":406,"ruku":350,"hizbQuarter":162,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3426,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3426.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3426.mp3"],"text":"فَسُبْحَٰنَ ٱللَّهِ حِينَ تُمْسُونَ وَحِينَ تُصْبِحُونَ","numberInSurah":17,"juz":21,"manzil":5,"page":406,"ruku":350,"hizbQuarter":162,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3427,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3427.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3427.mp3"],"text":"وَلَهُ ٱلْحَمْدُ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَعَشِيًّۭا وَحِينَ تُظْهِرُونَ","numberInSurah":18,"juz":21,"manzil":5,"page":406,"ruku":350,"hizbQuarter":162,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3428,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3428.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3428.mp3"],"text":"يُخْرِجُ ٱلْحَىَّ مِنَ ٱلْمَيِّتِ وَيُخْرِجُ ٱلْمَيِّتَ مِنَ ٱلْحَىِّ وَيُحْىِ ٱلْأَرْضَ بَعْدَ مَوْتِهَا ۚ وَكَذَٰلِكَ تُخْرَجُونَ","numberInSurah":19,"juz":21,"manzil":5,"page":406,"ruku":350,"hizbQuarter":162,"sajda":false,"surah":{"number":30,"name":"سُورَةُ الرُّومِ","englishName":"Ar-Room","englishNameTranslation":"The Romans","revelationType":"Meccan"}},{"number":3429,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3429.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3429.mp3"],"text":"وَمِنْ ءَايَٰتِهِۦٓ أَنْ خَلَقَكُم مِّن تُرَ