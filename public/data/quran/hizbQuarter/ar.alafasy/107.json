{"code":200,"status":"OK","data":{"number":107,"ayahs":[{"number":1902,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1902.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1902.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَتَىٰٓ أَمْرُ ٱللَّهِ فَلَا تَسْتَعْجِلُوهُ ۚ سُبْحَٰنَهُۥ وَتَعَٰلَىٰ عَمَّا يُشْرِكُونَ","numberInSurah":1,"juz":14,"manzil":3,"page":267,"ruku":224,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1903,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1903.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1903.mp3"],"text":"يُنَزِّلُ ٱلْمَلَٰٓئِكَةَ بِٱلرُّوحِ مِنْ أَمْرِهِۦ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦٓ أَنْ أَنذِرُوٓا۟ أَنَّهُۥ لَآ إِلَٰهَ إِلَّآ أَنَا۠ فَٱتَّقُونِ","numberInSurah":2,"juz":14,"manzil":3,"page":267,"ruku":224,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1904,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1904.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1904.mp3"],"text":"خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ ۚ تَعَٰلَىٰ عَمَّا يُشْرِكُونَ","numberInSurah":3,"juz":14,"manzil":3,"page":267,"ruku":224,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1905,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1905.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1905.mp3"],"text":"خَلَقَ ٱلْإِنسَٰنَ مِن نُّطْفَةٍۢ فَإِذَا هُوَ خَصِيمٌۭ مُّبِينٌۭ","numberInSurah":4,"juz":14,"manzil":3,"page":267,"ruku":224,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1906,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1906.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1906.mp3"],"text":"وَٱلْأَنْعَٰمَ خَلَقَهَا ۗ لَكُمْ فِيهَا دِفْءٌۭ وَمَنَٰفِعُ وَمِنْهَا تَأْكُلُونَ","numberInSurah":5,"juz":14,"manzil":3,"page":267,"ruku":224,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1907,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1907.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1907.mp3"],"text":"وَلَكُمْ فِيهَا جَمَالٌ حِينَ تُرِيحُونَ وَحِينَ تَسْرَحُونَ","numberInSurah":6,"juz":14,"manzil":3,"page":267,"ruku":224,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1908,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1908.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1908.mp3"],"text":"وَتَحْمِلُ أَثْقَالَكُمْ إِلَىٰ بَلَدٍۢ لَّمْ تَكُونُوا۟ بَٰلِغِيهِ إِلَّا بِشِقِّ ٱلْأَنفُسِ ۚ إِنَّ رَبَّكُمْ لَرَءُوفٌۭ رَّحِيمٌۭ","numberInSurah":7,"juz":14,"manzil":3,"page":268,"ruku":224,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1909,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1909.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1909.mp3"],"text":"وَٱلْخَيْلَ وَٱلْبِغَالَ وَٱلْحَمِيرَ لِتَرْكَبُوهَا وَزِينَةًۭ ۚ وَيَخْلُقُ مَا لَا تَعْلَمُونَ","numberInSurah":8,"juz":14,"manzil":3,"page":268,"ruku":224,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1910,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1910.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1910.mp3"],"text":"وَعَلَى ٱللَّهِ قَصْدُ ٱلسَّبِيلِ وَمِنْهَا جَآئِرٌۭ ۚ وَلَوْ شَآءَ لَهَدَىٰكُمْ أَجْمَعِينَ","numberInSurah":9,"juz":14,"manzil":3,"page":268,"ruku":224,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1911,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1911.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1911.mp3"],"text":"هُوَ ٱلَّذِىٓ أَنزَلَ مِنَ ٱلسَّمَآءِ مَآءًۭ ۖ لَّكُم مِّنْهُ شَرَابٌۭ وَمِنْهُ شَجَرٌۭ فِيهِ تُسِيمُونَ","numberInSurah":10,"juz":14,"manzil":3,"page":268,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1912,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1912.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1912.mp3"],"text":"يُنۢبِتُ لَكُم بِهِ ٱلزَّرْعَ وَٱلزَّيْتُونَ وَٱلنَّخِيلَ وَٱلْأَعْنَٰبَ وَمِن كُلِّ ٱلثَّمَرَٰتِ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّقَوْمٍۢ يَتَفَكَّرُونَ","numberInSurah":11,"juz":14,"manzil":3,"page":268,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1913,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1913.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1913.mp3"],"text":"وَسَخَّرَ لَكُمُ ٱلَّيْلَ وَٱلنَّهَارَ وَٱلشَّمْسَ وَٱلْقَمَرَ ۖ وَٱلنُّجُومُ مُسَخَّرَٰتٌۢ بِأَمْرِهِۦٓ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يَعْقِلُونَ","numberInSurah":12,"juz":14,"manzil":3,"page":268,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1914,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1914.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1914.mp3"],"text":"وَمَا ذَرَأَ لَكُمْ فِى ٱلْأَرْضِ مُخْتَلِفًا أَلْوَٰنُهُۥٓ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّقَوْمٍۢ يَذَّكَّرُونَ","numberInSurah":13,"juz":14,"manzil":3,"page":268,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1915,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1915.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1915.mp3"],"text":"وَهُوَ ٱلَّذِى سَخَّرَ ٱلْبَحْرَ لِتَأْكُلُوا۟ مِنْهُ لَحْمًۭا طَرِيًّۭا وَتَسْتَخْرِجُوا۟ مِنْهُ حِلْيَةًۭ تَلْبَسُونَهَا وَتَرَى ٱلْفُلْكَ مَوَاخِرَ فِيهِ وَلِتَبْتَغُوا۟ مِن فَضْلِهِۦ وَلَعَلَّكُمْ تَشْكُرُونَ","numberInSurah":14,"juz":14,"manzil":3,"page":268,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1916,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1916.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1916.mp3"],"text":"وَأَلْقَىٰ فِى ٱلْأَرْضِ رَوَٰسِىَ أَن تَمِيدَ بِكُمْ وَأَنْهَٰرًۭا وَسُبُلًۭا لَّعَلَّكُمْ تَهْتَدُونَ","numberInSurah":15,"juz":14,"manzil":3,"page":269,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1917,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1917.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1917.mp3"],"text":"وَعَلَٰمَٰتٍۢ ۚ وَبِٱلنَّجْمِ هُمْ يَهْتَدُونَ","numberInSurah":16,"juz":14,"manzil":3,"page":269,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1918,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1918.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1918.mp3"],"text":"أَفَمَن يَخْلُقُ كَمَن لَّا يَخْلُقُ ۗ أَفَلَا تَذَكَّرُونَ","numberInSurah":17,"juz":14,"manzil":3,"page":269,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1919,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1919.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1919.mp3"],"text":"وَإِن تَعُدُّوا۟ نِعْمَةَ ٱللَّهِ لَا تُحْصُوهَآ ۗ إِنَّ ٱللَّهَ لَغَفُورٌۭ رَّحِيمٌۭ","numberInSurah":18,"juz":14,"manzil":3,"page":269,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1920,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1920.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1920.mp3"],"text":"وَٱللَّهُ يَعْلَمُ مَا تُسِرُّونَ وَمَا تُعْلِنُونَ","numberInSurah":19,"juz":14,"manzil":3,"page":269,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1921,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1921.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1921.mp3"],"text":"وَٱلَّذِينَ يَدْعُونَ مِن دُونِ ٱللَّهِ لَا يَخْلُقُونَ شَيْـًۭٔا وَهُمْ يُخْلَقُونَ","numberInSurah":20,"juz":14,"manzil":3,"page":269,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1922,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1922.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1922.mp3"],"text":"أَمْوَٰتٌ غَيْرُ أَحْيَآءٍۢ ۖ وَمَا يَشْعُرُونَ أَيَّانَ يُبْعَثُونَ","numberInSurah":21,"juz":14,"manzil":3,"page":269,"ruku":225,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1923,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1923.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1923.mp3"],"text":"إِلَٰهُكُمْ إِلَٰهٌۭ وَٰحِدٌۭ ۚ فَٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ قُلُوبُهُم مُّنكِرَةٌۭ وَهُم مُّسْتَكْبِرُونَ","numberInSurah":22,"juz":14,"manzil":3,"page":269,"ruku":226,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1924,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1924.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1924.mp3"],"text":"لَا جَرَمَ أَنَّ ٱللَّهَ يَعْلَمُ مَا يُسِرُّونَ وَمَا يُعْلِنُونَ ۚ إِنَّهُۥ لَا يُحِبُّ ٱلْمُسْتَكْبِرِينَ","numberInSurah":23,"juz":14,"manzil":3,"page":269,"ruku":226,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1925,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1925.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1925.mp3"],"text":"وَإِذَا قِيلَ لَهُم مَّاذَآ أَنزَلَ رَبُّكُمْ ۙ قَالُوٓا۟ أَسَٰطِيرُ ٱلْأَوَّلِينَ","numberInSurah":24,"juz":14,"manzil":3,"page":269,"ruku":226,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1926,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1926.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1926.mp3"],"text":"لِيَحْمِلُوٓا۟ أَوْزَارَهُمْ كَامِلَةًۭ يَوْمَ ٱلْقِيَٰمَةِ ۙ وَمِنْ أَوْزَارِ ٱلَّذِينَ يُضِلُّونَهُم بِغَيْرِ عِلْمٍ ۗ أَلَا سَآءَ مَا يَزِرُونَ","numberInSurah":25,"juz":14,"manzil":3,"page":269,"ruku":226,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1927,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1927.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1927.mp3"],"text":"قَدْ مَكَرَ ٱلَّذِينَ مِن قَبْلِهِمْ فَأَتَى ٱللَّهُ بُنْيَٰنَهُم مِّنَ ٱلْقَوَاعِدِ فَخَرَّ عَلَيْهِمُ ٱلسَّقْفُ مِن فَوْقِهِمْ وَأَتَىٰهُمُ ٱلْعَذَابُ مِنْ حَيْثُ لَا يَشْعُرُونَ","numberInSurah":26,"juz":14,"manzil":3,"page":269,"ruku":227,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1928,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1928.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1928.mp3"],"text":"ثُمَّ يَوْمَ ٱلْقِيَٰمَةِ يُخْزِيهِمْ وَيَقُولُ أَيْنَ شُرَكَآءِىَ ٱلَّذِينَ كُنتُمْ تُشَٰٓقُّونَ فِيهِمْ ۚ قَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ إِنَّ ٱلْخِزْىَ ٱلْيَوْمَ وَٱلسُّوٓءَ عَلَى ٱلْكَٰفِرِينَ","numberInSurah":27,"juz":14,"manzil":3,"page":270,"ruku":227,"hizbQuarter":107,"sajda":false,"surah":{"number":16,"