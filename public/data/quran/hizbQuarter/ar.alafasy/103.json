{"code":200,"status":"OK","data":{"number":103,"ayahs":[{"number":1760,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1760.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1760.mp3"],"text":"۞ قَالَتْ رُسُلُهُمْ أَفِى ٱللَّهِ شَكٌّۭ فَاطِرِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۖ يَدْعُوكُمْ لِيَغْفِرَ لَكُم مِّن ذُنُوبِكُمْ وَيُؤَخِّرَكُمْ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى ۚ قَالُوٓا۟ إِنْ أَنتُمْ إِلَّا بَشَرٌۭ مِّثْلُنَا تُرِيدُونَ أَن تَصُدُّونَا عَمَّا كَانَ يَعْبُدُ ءَابَآؤُنَا فَأْتُونَا بِسُلْطَٰنٍۢ مُّبِينٍۢ","numberInSurah":10,"juz":13,"manzil":3,"page":256,"ruku":212,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1761,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1761.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1761.mp3"],"text":"قَالَتْ لَهُمْ رُسُلُهُمْ إِن نَّحْنُ إِلَّا بَشَرٌۭ مِّثْلُكُمْ وَلَٰكِنَّ ٱللَّهَ يَمُنُّ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦ ۖ وَمَا كَانَ لَنَآ أَن نَّأْتِيَكُم بِسُلْطَٰنٍ إِلَّا بِإِذْنِ ٱللَّهِ ۚ وَعَلَى ٱللَّهِ فَلْيَتَوَكَّلِ ٱلْمُؤْمِنُونَ","numberInSurah":11,"juz":13,"manzil":3,"page":257,"ruku":212,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1762,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1762.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1762.mp3"],"text":"وَمَا لَنَآ أَلَّا نَتَوَكَّلَ عَلَى ٱللَّهِ وَقَدْ هَدَىٰنَا سُبُلَنَا ۚ وَلَنَصْبِرَنَّ عَلَىٰ مَآ ءَاذَيْتُمُونَا ۚ وَعَلَى ٱللَّهِ فَلْيَتَوَكَّلِ ٱلْمُتَوَكِّلُونَ","numberInSurah":12,"juz":13,"manzil":3,"page":257,"ruku":212,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1763,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1763.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1763.mp3"],"text":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لِرُسُلِهِمْ لَنُخْرِجَنَّكُم مِّنْ أَرْضِنَآ أَوْ لَتَعُودُنَّ فِى مِلَّتِنَا ۖ فَأَوْحَىٰٓ إِلَيْهِمْ رَبُّهُمْ لَنُهْلِكَنَّ ٱلظَّٰلِمِينَ","numberInSurah":13,"juz":13,"manzil":3,"page":257,"ruku":213,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1764,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1764.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1764.mp3"],"text":"وَلَنُسْكِنَنَّكُمُ ٱلْأَرْضَ مِنۢ بَعْدِهِمْ ۚ ذَٰلِكَ لِمَنْ خَافَ مَقَامِى وَخَافَ وَعِيدِ","numberInSurah":14,"juz":13,"manzil":3,"page":257,"ruku":213,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1765,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1765.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1765.mp3"],"text":"وَٱسْتَفْتَحُوا۟ وَخَابَ كُلُّ جَبَّارٍ عَنِيدٍۢ","numberInSurah":15,"juz":13,"manzil":3,"page":257,"ruku":213,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1766,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1766.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1766.mp3"],"text":"مِّن وَرَآئِهِۦ جَهَنَّمُ وَيُسْقَىٰ مِن مَّآءٍۢ صَدِيدٍۢ","numberInSurah":16,"juz":13,"manzil":3,"page":257,"ruku":213,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1767,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1767.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1767.mp3"],"text":"يَتَجَرَّعُهُۥ وَلَا يَكَادُ يُسِيغُهُۥ وَيَأْتِيهِ ٱلْمَوْتُ مِن كُلِّ مَكَانٍۢ وَمَا هُوَ بِمَيِّتٍۢ ۖ وَمِن وَرَآئِهِۦ عَذَابٌ غَلِيظٌۭ","numberInSurah":17,"juz":13,"manzil":3,"page":257,"ruku":213,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1768,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1768.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1768.mp3"],"text":"مَّثَلُ ٱلَّذِينَ كَفَرُوا۟ بِرَبِّهِمْ ۖ أَعْمَٰلُهُمْ كَرَمَادٍ ٱشْتَدَّتْ بِهِ ٱلرِّيحُ فِى يَوْمٍ عَاصِفٍۢ ۖ لَّا يَقْدِرُونَ مِمَّا كَسَبُوا۟ عَلَىٰ شَىْءٍۢ ۚ ذَٰلِكَ هُوَ ٱلضَّلَٰلُ ٱلْبَعِيدُ","numberInSurah":18,"juz":13,"manzil":3,"page":257,"ruku":213,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1769,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1769.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1769.mp3"],"text":"أَلَمْ تَرَ أَنَّ ٱللَّهَ خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ ۚ إِن يَشَأْ يُذْهِبْكُمْ وَيَأْتِ بِخَلْقٍۢ جَدِيدٍۢ","numberInSurah":19,"juz":13,"manzil":3,"page":258,"ruku":213,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1770,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1770.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1770.mp3"],"text":"وَمَا ذَٰلِكَ عَلَى ٱللَّهِ بِعَزِيزٍۢ","numberInSurah":20,"juz":13,"manzil":3,"page":258,"ruku":213,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1771,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1771.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1771.mp3"],"text":"وَبَرَزُوا۟ لِلَّهِ جَمِيعًۭا فَقَالَ ٱلضُّعَفَٰٓؤُا۟ لِلَّذِينَ ٱسْتَكْبَرُوٓا۟ إِنَّا كُنَّا لَكُمْ تَبَعًۭا فَهَلْ أَنتُم مُّغْنُونَ عَنَّا مِنْ عَذَابِ ٱللَّهِ مِن شَىْءٍۢ ۚ قَالُوا۟ لَوْ هَدَىٰنَا ٱللَّهُ لَهَدَيْنَٰكُمْ ۖ سَوَآءٌ عَلَيْنَآ أَجَزِعْنَآ أَمْ صَبَرْنَا مَا لَنَا مِن مَّحِيصٍۢ","numberInSurah":21,"juz":13,"manzil":3,"page":258,"ruku":213,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1772,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1772.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1772.mp3"],"text":"وَقَالَ ٱلشَّيْطَٰنُ لَمَّا قُضِىَ ٱلْأَمْرُ إِنَّ ٱللَّهَ وَعَدَكُمْ وَعْدَ ٱلْحَقِّ وَوَعَدتُّكُمْ فَأَخْلَفْتُكُمْ ۖ وَمَا كَانَ لِىَ عَلَيْكُم مِّن سُلْطَٰنٍ إِلَّآ أَن دَعَوْتُكُمْ فَٱسْتَجَبْتُمْ لِى ۖ فَلَا تَلُومُونِى وَلُومُوٓا۟ أَنفُسَكُم ۖ مَّآ أَنَا۠ بِمُصْرِخِكُمْ وَمَآ أَنتُم بِمُصْرِخِىَّ ۖ إِنِّى كَفَرْتُ بِمَآ أَشْرَكْتُمُونِ مِن قَبْلُ ۗ إِنَّ ٱلظَّٰلِمِينَ لَهُمْ عَذَابٌ أَلِيمٌۭ","numberInSurah":22,"juz":13,"manzil":3,"page":258,"ruku":214,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1773,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1773.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1773.mp3"],"text":"وَأُدْخِلَ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَا بِإِذْنِ رَبِّهِمْ ۖ تَحِيَّتُهُمْ فِيهَا سَلَٰمٌ","numberInSurah":23,"juz":13,"manzil":3,"page":258,"ruku":214,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1774,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1774.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1774.mp3"],"text":"أَلَمْ تَرَ كَيْفَ ضَرَبَ ٱللَّهُ مَثَلًۭا كَلِمَةًۭ طَيِّبَةًۭ كَشَجَرَةٍۢ طَيِّبَةٍ أَصْلُهَا ثَابِتٌۭ وَفَرْعُهَا فِى ٱلسَّمَآءِ","numberInSurah":24,"juz":13,"manzil":3,"page":258,"ruku":214,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1775,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1775.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1775.mp3"],"text":"تُؤْتِىٓ أُكُلَهَا كُلَّ حِينٍۭ بِإِذْنِ رَبِّهَا ۗ وَيَضْرِبُ ٱللَّهُ ٱلْأَمْثَالَ لِلنَّاسِ لَعَلَّهُمْ يَتَذَكَّرُونَ","numberInSurah":25,"juz":13,"manzil":3,"page":259,"ruku":214,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1776,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1776.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1776.mp3"],"text":"وَمَثَلُ كَلِمَةٍ خَبِيثَةٍۢ كَشَجَرَةٍ خَبِيثَةٍ ٱجْتُثَّتْ مِن فَوْقِ ٱلْأَرْضِ مَا لَهَا مِن قَرَارٍۢ","numberInSurah":26,"juz":13,"manzil":3,"page":259,"ruku":214,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},{"number":1777,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1777.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1777.mp3"],"text":"يُثَبِّتُ ٱللَّهُ ٱلَّذِينَ ءَامَنُوا۟ بِٱلْقَوْلِ ٱلثَّابِتِ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا وَفِى ٱلْءَاخِرَةِ ۖ وَيُضِلُّ ٱللَّهُ ٱلظَّٰلِمِينَ ۚ وَيَفْعَلُ ٱللَّهُ مَا يَشَآءُ","numberInSurah":27,"juz":13,"manzil":3,"page":259,"ruku":214,"hizbQuarter":103,"sajda":false,"surah":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}}],"surahs":{"14":{"number":14,"name":"سُورَةُ إِبۡرَاهِيمَ","englishName":"Ibrahim","englishNameTranslation":"Abraham","revelationType":"Meccan"}},"edition":{}}}