{"code":200,"status":"OK","data":{"number":145,"ayahs":[{"number":2876,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2876.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2876.mp3"],"text":"۞ وَقَالَ ٱلَّذِينَ لَا يَرْجُونَ لِقَآءَنَا لَوْلَآ أُنزِلَ عَلَيْنَا ٱلْمَلَٰٓئِكَةُ أَوْ نَرَىٰ رَبَّنَا ۗ لَقَدِ ٱسْتَكْبَرُوا۟ فِىٓ أَنفُسِهِمْ وَعَتَوْ عُتُوًّۭا كَبِيرًۭا","numberInSurah":21,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2877,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2877.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2877.mp3"],"text":"يَوْمَ يَرَوْنَ ٱلْمَلَٰٓئِكَةَ لَا بُشْرَىٰ يَوْمَئِذٍۢ لِّلْمُجْرِمِينَ وَيَقُولُونَ حِجْرًۭا مَّحْجُورًۭا","numberInSurah":22,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2878,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2878.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2878.mp3"],"text":"وَقَدِمْنَآ إِلَىٰ مَا عَمِلُوا۟ مِنْ عَمَلٍۢ فَجَعَلْنَٰهُ هَبَآءًۭ مَّنثُورًا","numberInSurah":23,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2879,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2879.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2879.mp3"],"text":"أَصْحَٰبُ ٱلْجَنَّةِ يَوْمَئِذٍ خَيْرٌۭ مُّسْتَقَرًّۭا وَأَحْسَنُ مَقِيلًۭا","numberInSurah":24,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2880,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2880.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2880.mp3"],"text":"وَيَوْمَ تَشَقَّقُ ٱلسَّمَآءُ بِٱلْغَمَٰمِ وَنُزِّلَ ٱلْمَلَٰٓئِكَةُ تَنزِيلًا","numberInSurah":25,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2881,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2881.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2881.mp3"],"text":"ٱلْمُلْكُ يَوْمَئِذٍ ٱلْحَقُّ لِلرَّحْمَٰنِ ۚ وَكَانَ يَوْمًا عَلَى ٱلْكَٰفِرِينَ عَسِيرًۭا","numberInSurah":26,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2882,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2882.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2882.mp3"],"text":"وَيَوْمَ يَعَضُّ ٱلظَّالِمُ عَلَىٰ يَدَيْهِ يَقُولُ يَٰلَيْتَنِى ٱتَّخَذْتُ مَعَ ٱلرَّسُولِ سَبِيلًۭا","numberInSurah":27,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2883,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2883.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2883.mp3"],"text":"يَٰوَيْلَتَىٰ لَيْتَنِى لَمْ أَتَّخِذْ فُلَانًا خَلِيلًۭا","numberInSurah":28,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2884,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2884.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2884.mp3"],"text":"لَّقَدْ أَضَلَّنِى عَنِ ٱلذِّكْرِ بَعْدَ إِذْ جَآءَنِى ۗ وَكَانَ ٱلشَّيْطَٰنُ لِلْإِنسَٰنِ خَذُولًۭا","numberInSurah":29,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2885,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2885.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2885.mp3"],"text":"وَقَالَ ٱلرَّسُولُ يَٰرَبِّ إِنَّ قَوْمِى ٱتَّخَذُوا۟ هَٰذَا ٱلْقُرْءَانَ مَهْجُورًۭا","numberInSurah":30,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2886,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2886.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2886.mp3"],"text":"وَكَذَٰلِكَ جَعَلْنَا لِكُلِّ نَبِىٍّ عَدُوًّۭا مِّنَ ٱلْمُجْرِمِينَ ۗ وَكَفَىٰ بِرَبِّكَ هَادِيًۭا وَنَصِيرًۭا","numberInSurah":31,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2887,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2887.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2887.mp3"],"text":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لَوْلَا نُزِّلَ عَلَيْهِ ٱلْقُرْءَانُ جُمْلَةًۭ وَٰحِدَةًۭ ۚ كَذَٰلِكَ لِنُثَبِّتَ بِهِۦ فُؤَادَكَ ۖ وَرَتَّلْنَٰهُ تَرْتِيلًۭا","numberInSurah":32,"juz":19,"manzil":4,"page":362,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2888,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2888.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2888.mp3"],"text":"وَلَا يَأْتُونَكَ بِمَثَلٍ إِلَّا جِئْنَٰكَ بِٱلْحَقِّ وَأَحْسَنَ تَفْسِيرًا","numberInSurah":33,"juz":19,"manzil":4,"page":363,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2889,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2889.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2889.mp3"],"text":"ٱلَّذِينَ يُحْشَرُونَ عَلَىٰ وُجُوهِهِمْ إِلَىٰ جَهَنَّمَ أُو۟لَٰٓئِكَ شَرٌّۭ مَّكَانًۭا وَأَضَلُّ سَبِيلًۭا","numberInSurah":34,"juz":19,"manzil":4,"page":363,"ruku":312,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2890,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2890.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2890.mp3"],"text":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ وَجَعَلْنَا مَعَهُۥٓ أَخَاهُ هَٰرُونَ وَزِيرًۭا","numberInSurah":35,"juz":19,"manzil":4,"page":363,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2891,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2891.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2891.mp3"],"text":"فَقُلْنَا ٱذْهَبَآ إِلَى ٱلْقَوْمِ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَا فَدَمَّرْنَٰهُمْ تَدْمِيرًۭا","numberInSurah":36,"juz":19,"manzil":4,"page":363,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2892,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2892.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2892.mp3"],"text":"وَقَوْمَ نُوحٍۢ لَّمَّا كَذَّبُوا۟ ٱلرُّسُلَ أَغْرَقْنَٰهُمْ وَجَعَلْنَٰهُمْ لِلنَّاسِ ءَايَةًۭ ۖ وَأَعْتَدْنَا لِلظَّٰلِمِينَ عَذَابًا أَلِيمًۭا","numberInSurah":37,"juz":19,"manzil":4,"page":363,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2893,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2893.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2893.mp3"],"text":"وَعَادًۭا وَثَمُودَا۟ وَأَصْحَٰبَ ٱلرَّسِّ وَقُرُونًۢا بَيْنَ ذَٰلِكَ كَثِيرًۭا","numberInSurah":38,"juz":19,"manzil":4,"page":363,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2894,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2894.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2894.mp3"],"text":"وَكُلًّۭا ضَرَبْنَا لَهُ ٱلْأَمْثَٰلَ ۖ وَكُلًّۭا تَبَّرْنَا تَتْبِيرًۭا","numberInSurah":39,"juz":19,"manzil":4,"page":363,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2895,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2895.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2895.mp3"],"text":"وَلَقَدْ أَتَوْا۟ عَلَى ٱلْقَرْيَةِ ٱلَّتِىٓ أُمْطِرَتْ مَطَرَ ٱلسَّوْءِ ۚ أَفَلَمْ يَكُونُوا۟ يَرَوْنَهَا ۚ بَلْ كَانُوا۟ لَا يَرْجُونَ نُشُورًۭا","numberInSurah":40,"juz":19,"manzil":4,"page":363,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2896,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2896.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2896.mp3"],"text":"وَإِذَا رَأَوْكَ إِن يَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَٰذَا ٱلَّذِى بَعَثَ ٱللَّهُ رَسُولًا","numberInSurah":41,"juz":19,"manzil":4,"page":363,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2897,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2897.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2897.mp3"],"text":"إِن كَادَ لَيُضِلُّنَا عَنْ ءَالِهَتِنَا لَوْلَآ أَن صَبَرْنَا عَلَيْهَا ۚ وَسَوْفَ يَعْلَمُونَ حِينَ يَرَوْنَ ٱلْعَذَابَ مَنْ أَضَلُّ سَبِيلًا","numberInSurah":42,"juz":19,"manzil":4,"page":363,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2898,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2898.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2898.mp3"],"text":"أَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ أَفَأَنتَ تَكُونُ عَلَيْهِ وَكِيلًا","numberInSurah":43,"juz":19,"manzil":4,"page":363,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2899,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2899.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2899.mp3"],"text":"أَمْ تَحْسَبُ أَنَّ أَكْثَرَهُمْ يَسْمَعُونَ أَوْ يَعْقِلُونَ ۚ إِنْ هُمْ إِلَّا كَٱلْأَنْعَٰمِ ۖ بَلْ هُمْ أَضَلُّ سَبِيلًا","numberInSurah":44,"juz":19,"manzil":4,"page":364,"ruku":313,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2900,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2900.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2900.mp3"],"text":"أَلَمْ تَرَ إِلَىٰ رَبِّكَ كَيْفَ مَدَّ ٱلظِّلَّ وَلَوْ شَآءَ لَجَعَلَهُۥ سَاكِنًۭا ثُمَّ جَعَلْنَا ٱلشَّمْسَ عَلَيْهِ دَلِيلًۭا","numberInSurah":45,"juz":19,"manzil":4,"page":364,"ruku":314,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2901,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2901.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2901.mp3"],"text":"ثُمَّ قَبَضْنَٰهُ إِلَيْنَا قَبْضًۭا يَسِيرًۭا","numberInSurah":46,"juz":19,"manzil":4,"page":364,"ruku":314,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2902,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2902.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2902.mp3"],"text":"وَهُوَ ٱلَّذِى جَعَلَ لَكُمُ ٱلَّيْلَ لِبَاسًۭا وَٱلنَّوْمَ سُبَاتًۭا وَجَعَلَ ٱلنَّهَارَ نُشُورًۭا","numberInSurah":47,"juz":19,"manzil":4,"page":364,"ruku":314,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2903,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2903.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2903.mp3"],"text":"وَهُوَ ٱلَّذِىٓ أَرْسَلَ ٱلرِّيَٰحَ بُشْرًۢا بَيْنَ يَدَىْ رَحْمَتِهِۦ ۚ وَأَنزَلْنَا مِنَ ٱلسَّمَآءِ مَآءًۭ طَهُورًۭا","numberInSurah":48,"juz":19,"manzil":4,"page":364,"ruku":314,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2904,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2904.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2904.mp3"],"text":"لِّنُحْۦِىَ بِهِۦ بَلْدَةًۭ مَّيْتًۭا وَنُسْقِيَهُۥ مِمَّا خَلَقْنَآ أَنْعَٰمًۭا وَأَنَاسِىَّ كَثِيرًۭا","numberInSurah":49,"juz":19,"manzil":4,"page":364,"ruku":314,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2905,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2905.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2905.mp3"],"text":"وَلَقَدْ صَرَّفْنَٰهُ بَيْنَهُمْ لِيَذَّكَّرُوا۟ فَأَبَىٰٓ أَكْثَرُ ٱلنَّاسِ إِلَّا كُفُورًۭا","numberInSurah":50,"juz":19,"manzil":4,"page":364,"ruku":314,"hizbQuarter":145,"sajda":false,"surah":{"number":25,"name":"سُورَةُ الفُرۡقَانِ","englishName":"Al-Furqaan","englishNameTranslation":"The Criterion","revelationType":"Meccan"}},{"number":2906,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2906.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2906.mp3"],"text":"وَلَوْ شِئْنَا لَبَعَثْنَا فِى كُلِّ قَ