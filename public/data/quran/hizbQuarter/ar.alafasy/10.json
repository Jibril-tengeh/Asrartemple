{"code":200,"status":"OK","data":{"number":10,"ayahs":[{"number":165,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/165.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/165.mp3"],"text":"۞ إِنَّ ٱلصَّفَا وَٱلْمَرْوَةَ مِن شَعَآئِرِ ٱللَّهِ ۖ فَمَنْ حَجَّ ٱلْبَيْتَ أَوِ ٱعْتَمَرَ فَلَا جُنَاحَ عَلَيْهِ أَن يَطَّوَّفَ بِهِمَا ۚ وَمَن تَطَوَّعَ خَيْرًۭا فَإِنَّ ٱللَّهَ شَاكِرٌ عَلِيمٌ","numberInSurah":158,"juz":2,"manzil":1,"page":24,"ruku":20,"hizbQuarter":10,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":166,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/166.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/166.mp3"],"text":"إِنَّ ٱلَّذِينَ يَكْتُمُونَ مَآ أَنزَلْنَا مِنَ ٱلْبَيِّنَٰتِ وَٱلْهُدَىٰ مِنۢ بَعْدِ مَا بَيَّنَّٰهُ لِلنَّاسِ فِى ٱلْكِتَٰبِ ۙ أُو۟لَٰٓئِكَ يَلْعَنُهُمُ ٱللَّهُ وَيَلْعَنُهُمُ ٱللَّٰعِنُونَ","numberInSurah":159,"juz":2,"manzil":1,"page":24,"ruku":20,"hizbQuarter":10,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":167,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/167.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/167.mp3"],"text":"إِلَّا ٱلَّذِينَ تَابُوا۟ وَأَصْلَحُوا۟ وَبَيَّنُوا۟ فَأُو۟لَٰٓئِكَ أَتُوبُ عَلَيْهِمْ ۚ وَأَنَا ٱلتَّوَّابُ ٱلرَّحِيمُ","numberInSurah":160,"juz":2,"manzil":1,"page":24,"ruku":20,"hizbQuarter":10,"sajda":false,"surah":{"number":2,"name":"سُورَةُ البَقَرَةِ","englishName":"Al-Baqara","englishNameTranslation":"The Cow","revelationType":"Medinan"}},{"number":168,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/168.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/168.mp3"],"text":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ وَمَاتُو