{"code":200,"status":"OK","data":{"number":211,"ayahs":[{"number":4810,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4810.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4810.mp3"],"text":"۞ وَكَم مِّن مَّلَكٍۢ فِى ٱلسَّمَٰوَٰتِ لَا تُغْنِى شَفَٰعَتُهُمْ شَيْـًٔا إِلَّا مِنۢ بَعْدِ أَن يَأْذَنَ ٱللَّهُ لِمَن يَشَآءُ وَيَرْضَىٰٓ","numberInSurah":26,"juz":27,"manzil":7,"page":526,"ruku":461,"hizbQuarter":211,"sajda":false,"surah":{"number":53,"name":"سُورَةُ النَّجۡمِ","englishName":"An-Najm","englishNameTranslation":"The Star","revelationType":"Meccan"}},{"number":4811,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4811.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4811.mp3"],"text":"إِنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ لَيُسَمُّونَ ٱلْمَلَٰٓئِكَةَ تَسْمِيَةَ ٱلْأُنثَىٰ","numberInSurah":27,"juz":27,"manzil":7,"page":527,"ruku":461,"hizbQuarter":211,"sajda":false,"surah":{"number":53,"name":"سُورَةُ النَّجۡمِ","englishName":"An-Najm","englishNameTranslation":"The Star","revelationType":"Meccan"}},{"number":4812,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4812.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4812.mp3"],"text":"وَمَا لَهُم بِهِۦ مِنْ عِلْمٍ ۖ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ ۖ وَإِنَّ ٱلظَّنَّ لَا يُغْنِى مِنَ ٱلْحَقِّ شَيْـًۭٔا","numberInSurah":28,"juz":27,"manzil":7,"page":527,"ruku":461,"hizbQuarter":211,"sajda":false,"surah":{"number":53,"name":"سُورَةُ النَّجۡمِ","englishName":"An-Najm","englishNameTranslation":"The Star","revelationType":"Meccan"}},{"number":4813,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4813.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4813.mp3"],"text":"فَأَعْرِضْ عَن مَّن تَوَلَّىٰ عَن ذِكْرِنَا وَلَمْ يُرِدْ إِلَّا ٱلْحَيَوٰةَ ٱلدُّنْيَا","numberInSurah":29,"juz":27,"manzil":7,"page":527,"ruku":461,"hizbQuarter":211,"s