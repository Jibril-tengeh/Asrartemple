o/128/ar.alafasy/3615.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3615.mp3"],"text":"أَفَلَمْ يَرَوْا۟ إِلَىٰ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُم مِّنَ ٱلسَّمَآءِ وَٱلْأَرْضِ ۚ إِن نَّشَأْ نَخْسِفْ بِهِمُ ٱلْأَرْضَ أَوْ نُسْقِطْ عَلَيْهِمْ كِسَفًۭا مِّنَ ٱلسَّمَآءِ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّكُلِّ عَبْدٍۢ مُّنِيبٍۢ","numberInSurah":9,"juz":22,"manzil":5,"page":429,"ruku":370,"hizbQuarter":171,"sajda":false,"surah":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}}],"surahs":{"33":{"number":33,"name":"سُورَةُ الأَحۡزَابِ","englishName":"Al-Ahzaab","englishNameTranslation":"The Clans","revelationType":"Medinan"},"34":{"number":34,"name":"سُورَةُ سَبَإٍ","englishName":"Saba","englishNameTranslation":"Sheba","revelationType":"Meccan"}},"edition":{}}}