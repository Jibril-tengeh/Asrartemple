.alafasy/1811.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1811.mp3"],"text":"إِنَّا نَحْنُ نَزَّلْنَا ٱلذِّكْرَ وَإِنَّا لَهُۥ لَحَٰفِظُونَ","numberInSurah":9,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1812,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1812.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1812.mp3"],"text":"وَلَقَدْ أَرْسَلْنَا مِن قَبْلِكَ فِى شِيَعِ ٱلْأَوَّلِينَ","numberInSurah":10,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1813,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1813.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1813.mp3"],"text":"وَمَا يَأْتِيهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","numberInSurah":11,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1814,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1814.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1814.mp3"],"text":"كَذَٰلِكَ نَسْلُكُهُۥ فِى قُلُوبِ ٱلْمُجْرِمِينَ","numberInSurah":12,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1815,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1815.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1815.mp3"],"text":"لَا يُؤْمِنُونَ بِهِۦ ۖ وَقَدْ خَلَتْ سُنَّةُ ٱلْأَوَّلِينَ","numberInSurah":13,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1816,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1816.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1816.mp3"],"text":"وَلَوْ فَتَحْنَا عَلَيْهِم بَابًۭا مِّنَ ٱلسَّمَآءِ فَظَلُّوا۟ فِيهِ يَعْرُجُونَ","numberInSurah":14,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1817,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1817.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1817.mp3"],"text":"لَقَالُوٓا۟ إِنَّمَا سُكِّرَتْ أَبْصَٰرُنَا بَلْ نَحْنُ قَوْمٌۭ مَّسْحُورُونَ","numberInSurah":15,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1818,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1818.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1818.mp3"],"text":"وَلَقَدْ جَعَلْنَا فِى ٱلسَّمَآءِ بُرُوجًۭا وَزَيَّنَّٰهَا لِلنَّٰظِرِينَ","numberInSurah":16,"juz":14,"manzil":3,"page":263,"ruku":219,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1819,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1819.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1819.mp3"],"text":"وَحَفِظْنَٰهَا مِن كُلِّ شَيْطَٰنٍۢ رَّجِيمٍ","numberInSurah":17,"juz":14,"manzil":3,"page":263,"ruku":219,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1820,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1820.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1820.mp3"],"text":"إِلَّا مَنِ ٱسْتَرَقَ ٱلسَّمْعَ فَأَتْبَعَهُۥ شِهَابٌۭ مُّبِينٌۭ","numberInSurah":18,"juz":14,"manzil":3,"page":263,"ruku":219,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1821,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1821.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1821.mp3"],"text":"وَٱلْأَرْضَ مَدَدْنَٰهَا وَأَلْقَيْنَا فِيهَا رَوَٰسِىَ وَأَنۢبَتْنَا فِيهَا مِن كُلِّ شَىْءٍۢ مَّوْزُونٍۢ","numberInSurah":19,"juz":14,"manzil":3,"page":263,"ruku":219,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1822,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1822.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1822.mp3"],"text":"وَجَعَلْنَا لَكُمْ فِيهَا مَعَٰيِشَ وَمَن لَّسْتُمْ لَهُۥ بِرَٰزِقِينَ","numberInSurah":20,"juz":14,"manzil":3,"page":263,"ruku":219,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1823,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1823.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1823.mp3"],"text":"وَإِن مِّن شَىْءٍ إِلَّا عِندَنَا خَزَآئِنُهُۥ وَمَا نُنَزِّلُهُۥٓ إِلَّا بِقَدَرٍۢ مَّعْلُومٍۢ","numberInSurah":21,"juz":14,"manzil":3,"page":263