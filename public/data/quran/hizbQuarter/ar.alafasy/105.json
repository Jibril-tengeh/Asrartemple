{"code":200,"status":"OK","data":{"number":105,"ayahs":[{"number":1803,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1803.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1803.mp3"],"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓر ۚ تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ وَقُرْءَانٍۢ مُّبِينٍۢ","numberInSurah":1,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1804,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1804.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1804.mp3"],"text":"رُّبَمَا يَوَدُّ ٱلَّذِينَ كَفَرُوا۟ لَوْ كَانُوا۟ مُسْلِمِينَ","numberInSurah":2,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1805,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1805.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1805.mp3"],"text":"ذَرْهُمْ يَأْكُلُوا۟ وَيَتَمَتَّعُوا۟ وَيُلْهِهِمُ ٱلْأَمَلُ ۖ فَسَوْفَ يَعْلَمُونَ","numberInSurah":3,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"}},{"number":1806,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1806.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1806.mp3"],"text":"وَمَآ أَهْلَكْنَا مِن قَرْيَةٍ إِلَّا وَلَهَا كِتَابٌۭ مَّعْلُومٌۭ","numberInSurah":4,"juz":14,"manzil":3,"page":262,"ruku":218,"hizbQuarter":105,"sajda":false,"surah":{"number":15,"name":"سُورَةُ الحِجۡرِ","englishName":"Al-Hijr","englishNameTranslation":"The Rock","revelationType":"Meccan"