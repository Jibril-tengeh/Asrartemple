{"code":200,"status":"OK","data":{"number":110,"ayahs":[{"number":1976,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1976.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1976.mp3"],"text":"۞ ضَرَبَ ٱللَّهُ مَثَلًا عَبْدًۭا مَّمْلُوكًۭا لَّا يَقْدِرُ عَلَىٰ شَىْءٍۢ وَمَن رَّزَقْنَٰهُ مِنَّا رِزْقًا حَسَنًۭا فَهُوَ يُنفِقُ مِنْهُ سِرًّۭا وَجَهْرًا ۖ هَلْ يَسْتَوُۥنَ ۚ ٱلْحَمْدُ لِلَّهِ ۚ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ","numberInSurah":75,"juz":14,"manzil":3,"page":275,"ruku":233,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1977,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1977.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1977.mp3"],"text":"وَضَرَبَ ٱللَّهُ مَثَلًۭا رَّجُلَيْنِ أَحَدُهُمَآ أَبْكَمُ لَا يَقْدِرُ عَلَىٰ شَىْءٍۢ وَهُوَ كَلٌّ عَلَىٰ مَوْلَىٰهُ أَيْنَمَا يُوَجِّههُّ لَا يَأْتِ بِخَيْرٍ ۖ هَلْ يَسْتَوِى هُوَ وَمَن يَأْمُرُ بِٱلْعَدْلِ ۙ وَهُوَ عَلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","numberInSurah":76,"juz":14,"manzil":3,"page":275,"ruku":233,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1978,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1978.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1978.mp3"],"text":"وَلِلَّهِ غَيْبُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَمَآ أَمْرُ ٱلسَّاعَةِ إِلَّا كَلَمْحِ ٱلْبَصَرِ أَوْ هُوَ أَقْرَبُ ۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","numberInSurah":77,"juz":14,"manzil":3,"page":275,"ruku":234,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1979,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1979.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1979.mp3"],"text":"وَٱللَّهُ أَخْرَجَكُم مِّنۢ بُطُونِ أُمَّهَٰتِكُمْ لَا تَعْلَمُونَ شَيْـًۭٔا وَجَعَلَ لَكُمُ ٱلسَّمْعَ وَٱلْأَبْصَٰرَ وَٱلْأَفْـِٔدَةَ ۙ لَعَلَّكُمْ تَشْكُرُونَ","numberInSurah":78,"juz":14,"manzil":3,"page":275,"ruku":234,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1980,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1980.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1980.mp3"],"text":"أَلَمْ يَرَوْا۟ إِلَى ٱلطَّيْرِ مُسَخَّرَٰتٍۢ فِى جَوِّ ٱلسَّمَآءِ مَا يُمْسِكُهُنَّ إِلَّا ٱللَّهُ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يُؤْمِنُونَ","numberInSurah":79,"juz":14,"manzil":3,"page":275,"ruku":234,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1981,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1981.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1981.mp3"],"text":"وَٱللَّهُ جَعَلَ لَكُم مِّنۢ بُيُوتِكُمْ سَكَنًۭا وَجَعَلَ لَكُم مِّن جُلُودِ ٱلْأَنْعَٰمِ بُيُوتًۭا تَسْتَخِفُّونَهَا يَوْمَ ظَعْنِكُمْ وَيَوْمَ إِقَامَتِكُمْ ۙ وَمِنْ أَصْوَافِهَا وَأَوْبَارِهَا وَأَشْعَارِهَآ أَثَٰثًۭا وَمَتَٰعًا إِلَىٰ حِينٍۢ","numberInSurah":80,"juz":14,"manzil":3,"page":276,"ruku":234,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1982,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1982.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1982.mp3"],"text":"وَٱللَّهُ جَعَلَ لَكُم مِّمَّا خَلَقَ ظِلَٰلًۭا وَجَعَلَ لَكُم مِّنَ ٱلْجِبَالِ أَكْنَٰنًۭا وَجَعَلَ لَكُمْ سَرَٰبِيلَ تَقِيكُمُ ٱلْحَرَّ وَسَرَٰبِيلَ تَقِيكُم بَأْسَكُمْ ۚ كَذَٰلِكَ يُتِمُّ نِعْمَتَهُۥ عَلَيْكُمْ لَعَلَّكُمْ تُسْلِمُونَ","numberInSurah":81,"juz":14,"manzil":3,"page":276,"ruku":234,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1983,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1983.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1983.mp3"],"text":"فَإِن تَوَلَّوْا۟ فَإِنَّمَا عَلَيْكَ ٱلْبَلَٰغُ ٱلْمُبِينُ","numberInSurah":82,"juz":14,"manzil":3,"page":276,"ruku":234,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1984,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1984.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1984.mp3"],"text":"يَعْرِفُونَ نِعْمَتَ ٱللَّهِ ثُمَّ يُنكِرُونَهَا وَأَكْثَرُهُمُ ٱلْكَٰفِرُونَ","numberInSurah":83,"juz":14,"manzil":3,"page":276,"ruku":234,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1985,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1985.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1985.mp3"],"text":"وَيَوْمَ نَبْعَثُ مِن كُلِّ أُمَّةٍۢ شَهِيدًۭا ثُمَّ لَا يُؤْذَنُ لِلَّذِينَ كَفَرُوا۟ وَلَا هُمْ يُسْتَعْتَبُونَ","numberInSurah":84,"juz":14,"manzil":3,"page":276,"ruku":235,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1986,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1986.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1986.mp3"],"text":"وَإِذَا رَءَا ٱلَّذِينَ ظَلَمُوا۟ ٱلْعَذَابَ فَلَا يُخَفَّفُ عَنْهُمْ وَلَا هُمْ يُنظَرُونَ","numberInSurah":85,"juz":14,"manzil":3,"page":276,"ruku":235,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1987,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1987.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1987.mp3"],"text":"وَإِذَا رَءَا ٱلَّذِينَ أَشْرَكُوا۟ شُرَكَآءَهُمْ قَالُوا۟ رَبَّنَا هَٰٓؤُلَآءِ شُرَكَآؤُنَا ٱلَّذِينَ كُنَّا نَدْعُوا۟ مِن دُونِكَ ۖ فَأَلْقَوْا۟ إِلَيْهِمُ ٱلْقَوْلَ إِنَّكُمْ لَكَٰذِبُونَ","numberInSurah":86,"juz":14,"manzil":3,"page":276,"ruku":235,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1988,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1988.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1988.mp3"],"text":"وَأَلْقَوْا۟ إِلَى ٱللَّهِ يَوْمَئِذٍ ٱلسَّلَمَ ۖ وَضَلَّ عَنْهُم مَّا كَانُوا۟ يَفْتَرُونَ","numberInSurah":87,"juz":14,"manzil":3,"page":276,"ruku":235,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1989,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1989.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1989.mp3"],"text":"ٱلَّذِينَ كَفَرُوا۟ وَصَدُّوا۟ عَن سَبِيلِ ٱللَّهِ زِدْنَٰهُمْ عَذَابًۭا فَوْقَ ٱلْعَذَابِ بِمَا كَانُوا۟ يُفْسِدُونَ","numberInSurah":88,"juz":14,"manzil":3,"page":277,"ruku":235,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},{"number":1990,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1990.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/1990.mp3"],"text":"وَيَوْمَ نَبْعَثُ فِى كُلِّ أُمَّةٍۢ شَهِيدًا عَلَيْهِم مِّنْ أَنفُسِهِمْ ۖ وَجِئْنَا بِكَ شَهِيدًا عَلَىٰ هَٰٓؤُلَآءِ ۚ وَنَزَّلْنَا عَلَيْكَ ٱلْكِتَٰبَ تِبْيَٰنًۭا لِّكُلِّ شَىْءٍۢ وَهُدًۭى وَرَحْمَةًۭ وَبُشْرَىٰ لِلْمُسْلِمِينَ","numberInSurah":89,"juz":14,"manzil":3,"page":277,"ruku":235,"hizbQuarter":110,"sajda":false,"surah":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}}],"surahs":{"16":{"number":16,"name":"سُورَةُ النَّحۡلِ","englishName":"An-Nahl","englishNameTranslation":"The Bee","revelationType":"Meccan"}},"edition":{}}}