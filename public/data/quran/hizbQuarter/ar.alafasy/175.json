ةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3683,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3683.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3683.mp3"],"text":"إِنْ أَنتَ إِلَّا نَذِيرٌ","numberInSurah":23,"juz":22,"manzil":5,"page":437,"ruku":378,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3684,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3684.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3684.mp3"],"text":"إِنَّآ أَرْسَلْنَٰكَ بِٱلْحَقِّ بَشِيرًۭا وَنَذِيرًۭا ۚ وَإِن مِّنْ أُمَّةٍ إِلَّا خَلَا فِيهَا نَذِيرٌۭ","numberInSurah":24,"juz":22,"manzil":5,"page":437,"ruku":378,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3685,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3685.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3685.mp3"],"text":"وَإِن يُكَذِّبُوكَ فَقَدْ كَذَّبَ ٱلَّذِينَ مِن قَبْلِهِمْ جَآءَتْهُمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ وَبِٱلزُّبُرِ وَبِٱلْكِتَٰبِ ٱلْمُنِيرِ","numberInSurah":25,"juz":22,"manzil":5,"page":437,"ruku":378,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3686,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3686.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3686.mp3"],"text":"ثُمَّ أَخَذْتُ ٱلَّذِينَ كَفَرُوا۟ ۖ فَكَيْفَ كَانَ نَكِيرِ","numberInSurah":26,"juz":22,"manzil":5,"page":437,"ruku":378,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3687,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3687.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3687.mp3"],"text":"أَلَمْ تَرَ أَنَّ ٱللَّهَ أَنزَلَ مِنَ ٱلسَّمَآءِ مَآءًۭ فَأَخْرَجْنَا بِهِۦ ثَمَرَٰتٍۢ مُّخْتَلِفًا أَلْوَٰنُهَا ۚ وَمِنَ ٱلْجِبَالِ جُدَدٌۢ بِيضٌۭ وَحُمْرٌۭ مُّخْتَلِفٌ أَلْوَٰنُهَا وَغَرَابِيبُ سُودٌۭ","numberInSurah":27,"juz":22,"manzil":5,"page":437,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3688,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3688.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3688.mp3"],"text":"وَمِنَ ٱلنَّاسِ وَٱلدَّوَآبِّ وَٱلْأَنْعَٰمِ مُخْتَلِفٌ أَلْوَٰنُهُۥ كَذَٰلِكَ ۗ إِنَّمَا يَخْشَى ٱللَّهَ مِنْ عِبَادِهِ ٱلْعُلَمَٰٓؤُا۟ ۗ إِنَّ ٱللَّهَ عَزِيزٌ غَفُورٌ","numberInSurah":28,"juz":22,"manzil":5,"page":437,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3689,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3689.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3689.mp3"],"text":"إِنَّ ٱلَّذِينَ يَتْلُونَ كِتَٰبَ ٱللَّهِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَأَنفَقُوا۟ مِمَّا رَزَقْنَٰهُمْ سِرًّۭا وَعَلَانِيَةًۭ يَرْجُونَ تِجَٰرَةًۭ لَّن تَبُورَ","numberInSurah":29,"juz":22,"manzil":5,"page":437,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3690,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3690.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3690.mp3"],"text":"لِيُوَفِّيَهُمْ أُجُورَهُمْ وَيَزِيدَهُم مِّن فَضْلِهِۦٓ ۚ إِنَّهُۥ غَفُورٌۭ شَكُورٌۭ","numberInSurah":30,"juz":22,"manzil":5,"page":437,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3691,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3691.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3691.mp3"],"text":"وَٱلَّذِىٓ أَوْحَيْنَآ إِلَيْكَ مِنَ ٱلْكِتَٰبِ هُوَ ٱلْحَقُّ مُصَدِّقًۭا لِّمَا بَيْنَ يَدَيْهِ ۗ إِنَّ ٱللَّهَ بِعِبَادِهِۦ لَخَبِيرٌۢ بَصِيرٌۭ","numberInSurah":31,"juz":22,"manzil":5,"page":438,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3692,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3692.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3692.mp3"],"text":"ثُمَّ أَوْرَثْنَا ٱلْكِتَٰبَ ٱلَّذِينَ ٱصْطَفَيْنَا مِنْ عِبَادِنَا ۖ فَمِنْهُمْ ظَالِمٌۭ لِّنَفْسِهِۦ وَمِنْهُم مُّقْتَصِدٌۭ وَمِنْهُمْ سَابِقٌۢ بِٱلْخَيْرَٰتِ بِإِذْنِ ٱللَّهِ ۚ ذَٰلِكَ هُوَ ٱلْفَضْلُ ٱلْكَبِيرُ","numberInSurah":32,"juz":22,"manzil":5,"page":438,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3693,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3693.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3693.mp3"],"text":"جَنَّٰتُ عَدْنٍۢ يَدْخُلُونَهَا يُحَلَّوْنَ فِيهَا مِنْ أَسَاوِرَ مِن ذَهَبٍۢ وَلُؤْلُؤًۭا ۖ وَلِبَاسُهُمْ فِيهَا حَرِيرٌۭ","numberInSurah":33,"juz":22,"manzil":5,"page":438,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3694,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3694.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3694.mp3"],"text":"وَقَالُوا۟ ٱلْحَمْدُ لِلَّهِ ٱلَّذِىٓ أَذْهَبَ عَنَّا ٱلْحَزَنَ ۖ إِنَّ رَبَّنَا لَغَفُورٌۭ شَكُورٌ","numberInSurah":34,"juz":22,"manzil":5,"page":438,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3695,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3695.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3695.mp3"],"text":"ٱلَّذِىٓ أَحَلَّنَا دَارَ ٱلْمُقَامَةِ مِن فَضْلِهِۦ لَا يَمَسُّنَا فِيهَا نَصَبٌۭ وَلَا يَمَسُّنَا فِيهَا لُغُوبٌۭ","numberInSurah":35,"juz":22,"manzil":5,"page":438,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3696,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3696.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3696.mp3"],"text":"وَٱلَّذِينَ كَفَرُوا۟ لَهُمْ نَارُ جَهَنَّمَ لَا يُقْضَىٰ عَلَيْهِمْ فَيَمُوتُوا۟ وَلَا يُخَفَّفُ عَنْهُم مِّنْ عَذَابِهَا ۚ كَذَٰلِكَ نَجْزِى كُلَّ كَفُورٍۢ","numberInSurah":36,"juz":22,"manzil":5,"page":438,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3697,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3697.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3697.mp3"],"text":"وَهُمْ يَصْطَرِخُونَ فِيهَا رَبَّنَآ أَخْرِجْنَا نَعْمَلْ صَٰلِحًا غَيْرَ ٱلَّذِى كُنَّا نَعْمَلُ ۚ أَوَلَمْ نُعَمِّرْكُم مَّا يَتَذَكَّرُ فِيهِ مَن تَذَكَّرَ وَجَآءَكُمُ ٱلنَّذِيرُ ۖ فَذُوقُوا۟ فَمَا لِلظَّٰلِمِينَ مِن نَّصِيرٍ","numberInSurah":37,"juz":22,"manzil":5,"page":438,"ruku":379,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3698,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3698.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3698.mp3"],"text":"إِنَّ ٱللَّهَ عَٰلِمُ غَيْبِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ إِنَّهُۥ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","numberInSurah":38,"juz":22,"manzil":5,"page":438,"ruku":380,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3699,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3699.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3699.mp3"],"text":"هُوَ ٱلَّذِى جَعَلَكُمْ خَلَٰٓئِفَ فِى ٱلْأَرْضِ ۚ فَمَن كَفَرَ فَعَلَيْهِ كُفْرُهُۥ ۖ وَلَا يَزِيدُ ٱلْكَٰفِرِينَ كُفْرُهُمْ عِندَ رَبِّهِمْ إِلَّا مَقْتًۭا ۖ وَلَا يَزِيدُ ٱلْكَٰفِرِينَ كُفْرُهُمْ إِلَّا خَسَارًۭا","numberInSurah":39,"juz":22,"manzil":5,"page":439,"ruku":380,"hizbQuarter":175,"sajda":false,"surah":{"number":35,"name":"سُورَةُ فَاطِرٍ","englishName":"Faatir","englishNameTranslation":"The Originator","revelationType":"Meccan"}},{"number":3700,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3700.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/3700.mp3"],"text":"قُلْ أَرَءَيْتُمْ شُرَكَآءَكُمُ ٱلَّذِينَ تَدْعُونَ مِن دُونِ ٱللَّهِ أَرُونِى مَاذَا خَلَقُوا۟ مِنَ ٱلْأَرْضِ أَمْ لَهُمْ شِرْكٌۭ فِى ٱلسَّمَٰوَٰتِ أَمْ ءَاتَيْنَٰهُمْ كِتَٰبًۭا فَهُمْ عَلَىٰ بَيِّنَتٍۢ مِّنْهُ ۚ بَلْ إِن يَعِدُ ٱلظَّٰلِمُونَ بَعْضُهُم بَعْضًا إِلَّا غُرُورًا","numberInSurah":40,"juz":22,"manzil":5,"page":4