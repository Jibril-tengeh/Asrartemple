{"code":200,"status":"OK","data":{"number":197,"ayahs":[{"number":4349,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4349.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4349.mp3"],"text":"۞ قَٰلَ أَوَلَوْ جِئْتُكُم بِأَهْدَىٰ مِمَّا وَجَدتُّمْ عَلَيْهِ ءَابَآءَكُمْ ۖ قَالُوٓا۟ إِنَّا بِمَآ أُرْسِلْتُم بِهِۦ كَٰفِرُونَ","numberInSurah":24,"juz":25,"manzil":6,"page":491,"ruku":425,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4350,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4350.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4350.mp3"],"text":"فَٱنتَقَمْنَا مِنْهُمْ ۖ فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُكَذِّبِينَ","numberInSurah":25,"juz":25,"manzil":6,"page":491,"ruku":425,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4351,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4351.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4351.mp3"],"text":"وَإِذْ قَالَ إِبْرَٰهِيمُ لِأَبِيهِ وَقَوْمِهِۦٓ إِنَّنِى بَرَآءٌۭ مِّمَّا تَعْبُدُونَ","numberInSurah":26,"juz":25,"manzil":6,"page":491,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4352,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4352.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4352.mp3"],"text":"إِلَّا ٱلَّذِى فَطَرَنِى فَإِنَّهُۥ سَيَهْدِينِ","numberInSurah":27,"juz":25,"manzil":6,"page":491,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4353,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4353.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4353.mp3"],"text":"وَجَعَلَهَا كَلِمَةًۢ بَاقِيَةًۭ فِى عَقِبِهِۦ لَعَلَّهُمْ يَرْجِعُونَ","numberInSurah":28,"juz":25,"manzil":6,"page":491,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4354,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4354.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4354.mp3"],"text":"بَلْ مَتَّعْتُ هَٰٓؤُلَآءِ وَءَابَآءَهُمْ حَتَّىٰ جَآءَهُمُ ٱلْحَقُّ وَرَسُولٌۭ مُّبِينٌۭ","numberInSurah":29,"juz":25,"manzil":6,"page":491,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4355,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4355.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4355.mp3"],"text":"وَلَمَّا جَآءَهُمُ ٱلْحَقُّ قَالُوا۟ هَٰذَا سِحْرٌۭ وَإِنَّا بِهِۦ كَٰفِرُونَ","numberInSurah":30,"juz":25,"manzil":6,"page":491,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4356,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4356.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4356.mp3"],"text":"وَقَالُوا۟ لَوْلَا نُزِّلَ هَٰذَا ٱلْقُرْءَانُ عَلَىٰ رَجُلٍۢ مِّنَ ٱلْقَرْيَتَيْنِ عَظِيمٍ","numberInSurah":31,"juz":25,"manzil":6,"page":491,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4357,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4357.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4357.mp3"],"text":"أَهُمْ يَقْسِمُونَ رَحْمَتَ رَبِّكَ ۚ نَحْنُ قَسَمْنَا بَيْنَهُم مَّعِيشَتَهُمْ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا ۚ وَرَفَعْنَا بَعْضَهُمْ فَوْقَ بَعْضٍۢ دَرَجَٰتٍۢ لِّيَتَّخِذَ بَعْضُهُم بَعْضًۭا سُخْرِيًّۭا ۗ وَرَحْمَتُ رَبِّكَ خَيْرٌۭ مِّمَّا يَجْمَعُونَ","numberInSurah":32,"juz":25,"manzil":6,"page":491,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4358,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4358.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4358.mp3"],"text":"وَلَوْلَآ أَن يَكُونَ ٱلنَّاسُ أُمَّةًۭ وَٰحِدَةًۭ لَّجَعَلْنَا لِمَن يَكْفُرُ بِٱلرَّحْمَٰنِ لِبُيُوتِهِمْ سُقُفًۭا مِّن فِضَّةٍۢ وَمَعَارِجَ عَلَيْهَا يَظْهَرُونَ","numberInSurah":33,"juz":25,"manzil":6,"page":491,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4359,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4359.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4359.mp3"],"text":"وَلِبُيُوتِهِمْ أَبْوَٰبًۭا وَسُرُرًا عَلَيْهَا يَتَّكِـُٔونَ","numberInSurah":34,"juz":25,"manzil":6,"page":492,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4360,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4360.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4360.mp3"],"text":"وَزُخْرُفًۭا ۚ وَإِن كُلُّ ذَٰلِكَ لَمَّا مَتَٰعُ ٱلْحَيَوٰةِ ٱلدُّنْيَا ۚ وَٱلْءَاخِرَةُ عِندَ رَبِّكَ لِلْمُتَّقِينَ","numberInSurah":35,"juz":25,"manzil":6,"page":492,"ruku":426,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4361,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4361.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4361.mp3"],"text":"وَمَن يَعْشُ عَن ذِكْرِ ٱلرَّحْمَٰنِ نُقَيِّضْ لَهُۥ شَيْطَٰنًۭا فَهُوَ لَهُۥ قَرِينٌۭ","numberInSurah":36,"juz":25,"manzil":6,"page":492,"ruku":427,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4362,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4362.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4362.mp3"],"text":"وَإِنَّهُمْ لَيَصُدُّونَهُمْ عَنِ ٱلسَّبِيلِ وَيَحْسَبُونَ أَنَّهُم مُّهْتَدُونَ","numberInSurah":37,"juz":25,"manzil":6,"page":492,"ruku":427,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4363,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4363.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4363.mp3"],"text":"حَتَّىٰٓ إِذَا جَآءَنَا قَالَ يَٰلَيْتَ بَيْنِى وَبَيْنَكَ بُعْدَ ٱلْمَشْرِقَيْنِ فَبِئْسَ ٱلْقَرِينُ","numberInSurah":38,"juz":25,"manzil":6,"page":492,"ruku":427,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4364,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4364.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4364.mp3"],"text":"وَلَن يَنفَعَكُمُ ٱلْيَوْمَ إِذ ظَّلَمْتُمْ أَنَّكُمْ فِى ٱلْعَذَابِ مُشْتَرِكُونَ","numberInSurah":39,"juz":25,"manzil":6,"page":492,"ruku":427,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4365,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4365.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4365.mp3"],"text":"أَفَأَنتَ تُسْمِعُ ٱلصُّمَّ أَوْ تَهْدِى ٱلْعُمْىَ وَمَن كَانَ فِى ضَلَٰلٍۢ مُّبِينٍۢ","numberInSurah":40,"juz":25,"manzil":6,"page":492,"ruku":427,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4366,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4366.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4366.mp3"],"text":"فَإِمَّا نَذْهَبَنَّ بِكَ فَإِنَّا مِنْهُم مُّنتَقِمُونَ","numberInSurah":41,"juz":25,"manzil":6,"page":492,"ruku":427,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4367,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4367.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/4367.mp3"],"text":"أَوْ نُرِيَنَّكَ ٱلَّذِى وَعَدْنَٰهُمْ فَإِنَّا عَلَيْهِم مُّقْتَدِرُونَ","numberInSurah":42,"juz":25,"manzil":6,"page":492,"ruku":427,"hizbQuarter":197,"sajda":false,"surah":{"number":43,"name":"سُورَةُ الزُّخۡرُفِ","englishName":"Az-Zukhruf","englishNameTranslation":"Ornaments of gold","revelationType":"Meccan"}},{"number":4368,"audio":