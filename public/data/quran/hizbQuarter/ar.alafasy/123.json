{"code":200,"status":"OK","data":{"number":123,"ayahs":[{"number":2272,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2272.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2272.mp3"],"text":"۞ فَحَمَلَتْهُ فَٱنتَبَذَتْ بِهِۦ مَكَانًۭا قَصِيًّۭا","numberInSurah":22,"juz":16,"manzil":4,"page":306,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2273,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2273.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2273.mp3"],"text":"فَأَجَآءَهَا ٱلْمَخَاضُ إِلَىٰ جِذْعِ ٱلنَّخْلَةِ قَالَتْ يَٰلَيْتَنِى مِتُّ قَبْلَ هَٰذَا وَكُنتُ نَسْيًۭا مَّنسِيًّۭا","numberInSurah":23,"juz":16,"manzil":4,"page":306,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2274,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2274.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2274.mp3"],"text":"فَنَادَىٰهَا مِن تَحْتِهَآ أَلَّا تَحْزَنِى قَدْ جَعَلَ رَبُّكِ تَحْتَكِ سَرِيًّۭا","numberInSurah":24,"juz":16,"manzil":4,"page":306,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2275,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2275.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2275.mp3"],"text":"وَهُزِّىٓ إِلَيْكِ بِجِذْعِ ٱلنَّخْلَةِ تُسَٰقِطْ عَلَيْكِ رُطَبًۭا جَنِيًّۭا","numberInSurah":25,"juz":16,"manzil":4,"page":306,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2276,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2276.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2276.mp3"],"text":"فَكُلِى وَٱشْرَبِى وَقَرِّى عَيْنًۭا ۖ فَإِمَّا تَرَيِنَّ مِنَ ٱلْبَشَرِ أَحَدًۭا فَقُولِىٓ إِنِّى نَذَرْتُ لِلرَّحْمَٰنِ صَوْمًۭا فَلَنْ أُكَلِّمَ ٱلْيَوْمَ إِنسِيًّۭا","numberInSurah":26,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2277,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2277.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2277.mp3"],"text":"فَأَتَتْ بِهِۦ قَوْمَهَا تَحْمِلُهُۥ ۖ قَالُوا۟ يَٰمَرْيَمُ لَقَدْ جِئْتِ شَيْـًۭٔا فَرِيًّۭا","numberInSurah":27,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2278,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2278.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2278.mp3"],"text":"يَٰٓأُخْتَ هَٰرُونَ مَا كَانَ أَبُوكِ ٱمْرَأَ سَوْءٍۢ وَمَا كَانَتْ أُمُّكِ بَغِيًّۭا","numberInSurah":28,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2279,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2279.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2279.mp3"],"text":"فَأَشَارَتْ إِلَيْهِ ۖ قَالُوا۟ كَيْفَ نُكَلِّمُ مَن كَانَ فِى ٱلْمَهْدِ صَبِيًّۭا","numberInSurah":29,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2280,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2280.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2280.mp3"],"text":"قَالَ إِنِّى عَبْدُ ٱللَّهِ ءَاتَىٰنِىَ ٱلْكِتَٰبَ وَجَعَلَنِى نَبِيًّۭا","numberInSurah":30,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2281,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2281.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2281.mp3"],"text":"وَجَعَلَنِى مُبَارَكًا أَيْنَ مَا كُنتُ وَأَوْصَٰنِى بِٱلصَّلَوٰةِ وَٱلزَّكَوٰةِ مَا دُمْتُ حَيًّۭا","numberInSurah":31,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2282,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2282.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2282.mp3"],"text":"وَبَرًّۢا بِوَٰلِدَتِى وَلَمْ يَجْعَلْنِى جَبَّارًۭا شَقِيًّۭا","numberInSurah":32,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2283,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2283.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2283.mp3"],"text":"وَٱلسَّلَٰمُ عَلَىَّ يَوْمَ وُلِدتُّ وَيَوْمَ أَمُوتُ وَيَوْمَ أُبْعَثُ حَيًّۭا","numberInSurah":33,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2284,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2284.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2284.mp3"],"text":"ذَٰلِكَ عِيسَى ٱبْنُ مَرْيَمَ ۚ قَوْلَ ٱلْحَقِّ ٱلَّذِى فِيهِ يَمْتَرُونَ","numberInSurah":34,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2285,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2285.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2285.mp3"],"text":"مَا كَانَ لِلَّهِ أَن يَتَّخِذَ مِن وَلَدٍۢ ۖ سُبْحَٰنَهُۥٓ ۚ إِذَا قَضَىٰٓ أَمْرًۭا فَإِنَّمَا يَقُولُ لَهُۥ كُن فَيَكُونُ","numberInSurah":35,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2286,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2286.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2286.mp3"],"text":"وَإِنَّ ٱللَّهَ رَبِّى وَرَبُّكُمْ فَٱعْبُدُوهُ ۚ هَٰذَا صِرَٰطٌۭ مُّسْتَقِيمٌۭ","numberInSurah":36,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"}},{"number":2287,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2287.mp3","audioSecondary":["https://cdn.islamic.network/quran/audio/64/ar.alafasy/2287.mp3"],"text":"فَٱخْتَلَفَ ٱلْأَحْزَابُ مِنۢ بَيْنِهِمْ ۖ فَوَيْلٌۭ لِّلَّذِينَ كَفَرُوا۟ مِن مَّشْهَدِ يَوْمٍ عَظِيمٍ","numberInSurah":37,"juz":16,"manzil":4,"page":307,"ruku":265,"hizbQuarter":123,"sajda":false,"surah":{"number":19,"name":"سُورَةُ مَرۡيَمَ","englishName":"Maryam","englishNameTranslation":"Mary","revelationType":"Meccan"