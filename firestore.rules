rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'vX1d1eD0qf' || // Fallback if we know the UID, but we don't.
        request.auth.token.email == 'sbireino@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == 'sbireino@gmail.com';
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    match /lexique_terms/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ruqyah_audios/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /community_posts/{document=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.authorId || isAdmin());
    }
    
    match /notifications/{document=**} {
      allow read: if true; // changed to true so everyone can read notifications
      allow write: if isAdmin();
    }
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /articles/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
